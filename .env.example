# =============================================================================
# Calc Hammer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# This .env.example is safe to commit as a reference.
# =============================================================================

# -----------------------------------------------------------------------------
# Rails Core
# -----------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
RAILS_MASTER_KEY=                         # From config/master.key
SECRET_KEY_BASE=                          # Run: bin/rails secret

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------
DOMAIN=https://calchammer.com             # Used in sitemap, canonical URLs, OG tags

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://calchammer:PASSWORD@localhost:5432/calchammer_production

# -----------------------------------------------------------------------------
# Web Server (Puma)
# -----------------------------------------------------------------------------
PORT=3000
WEB_CONCURRENCY=2
PIDFILE=tmp/pids/server.pid

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_TOKEN=calchammer-admin-2026         # Token for /admin/ratings?token=THIS

# -----------------------------------------------------------------------------
# Google AdSense
# -----------------------------------------------------------------------------
ADSENSE_ENABLED=false                     # Set to "true" after AdSense approval
ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX    # Your AdSense publisher ID
AD_PROVIDER=adsense                       # "adsense" or "gam"

# Ad unit slot IDs — create in AdSense dashboard after approval
AD_SLOT_LEADERBOARD=
AD_SLOT_IN_RESULTS=
AD_SLOT_IN_CONTENT=
AD_SLOT_SIDEBAR=
AD_SLOT_ANCHOR=
AD_SLOT_MULTIPLEX=
AD_SLOT_AFTER_INTRO=

# -----------------------------------------------------------------------------
# Google Analytics (optional)
# -----------------------------------------------------------------------------
GA_MEASUREMENT_ID=                        # G-XXXXXXXXXX from GA4

# -----------------------------------------------------------------------------
# Google Search Console (optional)
# -----------------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=                 # For meta verification tag

# -----------------------------------------------------------------------------
# SMTP / Email (optional)
# -----------------------------------------------------------------------------
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=calchammer.com

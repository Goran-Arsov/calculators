<%# SEO meta tags — German %>
<% set_meta_tags(
  title: t("finance.calculators.mortgage.title"),
  description: t("finance.calculators.mortgage.description"),
  canonical: locale_canonical_url,
  og: {
    title: "#{t('finance.calculators.mortgage.title')} | CalcWise",
    description: t("finance.calculators.mortgage.description"),
    url: locale_canonical_url,
    type: "website",
    site_name: "CalcWise"
  }
) %>

<%= breadcrumb_schema([
  { name: "Startseite", url: root_url },
  { name: t("finance.category_name"), url: category_url("finance") },
  { name: t("finance.calculators.mortgage.breadcrumb"), url: locale_canonical_url }
]) %>

<%= faq_schema([
  { question: t("finance.calculators.mortgage.faq.q1"), answer: t("finance.calculators.mortgage.faq.a1") },
  { question: t("finance.calculators.mortgage.faq.q2"), answer: t("finance.calculators.mortgage.faq.a2") },
  { question: t("finance.calculators.mortgage.faq.q3"), answer: t("finance.calculators.mortgage.faq.a3") },
  { question: t("finance.calculators.mortgage.faq.q4"), answer: t("finance.calculators.mortgage.faq.a4") },
  { question: t("finance.calculators.mortgage.faq.q5"), answer: t("finance.calculators.mortgage.faq.a5") }
]) %>

<%= calculator_schema_with_ratings(
  name: t("finance.calculators.mortgage.breadcrumb"),
  description: t("finance.calculators.mortgage.description"),
  url: locale_canonical_url,
  category: "FinanceApplication",
  calculator_slug: "mortgage"
) %>

<%= render "shared/breadcrumbs", items: [
  { name: "Startseite", url: root_path },
  { name: t("finance.category_name"), url: category_path("finance") },
  { name: t("finance.calculators.mortgage.breadcrumb") }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("finance.calculators.mortgage.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("finance.calculators.mortgage.intro") %></p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="mortgage-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="mortgage-home-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("finance.calculators.mortgage.labels.home_price") %></label>
            <input id="mortgage-home-price" type="number" inputmode="decimal" data-mortgage-calculator-target="principal" data-action="input->mortgage-calculator#calculate" class="w-full" placeholder="300000" step="1000" min="0">
          </div>
          <div>
            <label for="mortgage-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("finance.calculators.mortgage.labels.annual_interest_rate") %></label>
            <input id="mortgage-annual-interest-rate" type="number" inputmode="decimal" data-mortgage-calculator-target="rate" data-action="input->mortgage-calculator#calculate" class="w-full" placeholder="6.5" step="0.01" min="0">
          </div>
          <div>
            <label for="mortgage-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("finance.calculators.mortgage.labels.loan_term") %></label>
            <input id="mortgage-loan-term" type="number" inputmode="decimal" data-mortgage-calculator-target="years" data-action="input->mortgage-calculator#calculate" class="w-full" placeholder="30" step="1" min="1" max="50">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5"><%= t("finance.calculators.mortgage.labels.results") %></h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("finance.calculators.mortgage.labels.monthly_payment") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-mortgage-calculator-target="monthlyPayment">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("finance.calculators.mortgage.labels.total_paid") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-mortgage-calculator-target="totalPaid">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("finance.calculators.mortgage.labels.total_interest") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-mortgage-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("finance.calculators.mortgage.labels.number_of_payments") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-mortgage-calculator-target="numPayments">0</span>
            </div>
          </div>
          <button data-action="click->mortgage-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium"><%= t("finance.calculators.mortgage.labels.copy_results") %></button>
        </div>
      </div>
    </div>

    <%= render "shared/calculator_rating", slug: "mortgage" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>

    <article class="prose dark:prose-invert max-w-none">
      <h2><%= t("finance.calculators.mortgage.article.how_to_use") %></h2>
      <p><%= t("finance.calculators.mortgage.article.how_to_use_p1") %></p>
      <p><%= t("finance.calculators.mortgage.article.how_to_use_p2") %></p>

      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <h2><%= t("finance.calculators.mortgage.article.formula_title") %></h2>
      <p><%= t("finance.calculators.mortgage.article.formula_p1") %></p>

      <h2><%= t("finance.calculators.mortgage.faq.q1") %></h2>
      <p><%= t("finance.calculators.mortgage.faq.a1") %></p>

      <h2><%= t("finance.calculators.mortgage.faq.q2") %></h2>
      <p><%= t("finance.calculators.mortgage.faq.a2") %></p>

      <h2><%= t("finance.calculators.mortgage.faq.q3") %></h2>
      <p><%= t("finance.calculators.mortgage.faq.a3") %></p>

    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>

    <%= render "shared/related_calculators", related: [
      { name: "Kreditrechner", description: t("finance.calculators.loan.description"), path: finance_loan_path, icon_path: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" },
      { name: "Zinseszinsrechner", description: t("finance.calculators.compound_interest.description"), path: finance_compound_interest_path, icon_path: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" },
      { name: "Investitionsrechner", description: t("finance.calculators.investment.description"), path: finance_investment_path, icon_path: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" }
    ] %>

    <%= render "shared/calculator_disclaimer", category: "finance" %>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

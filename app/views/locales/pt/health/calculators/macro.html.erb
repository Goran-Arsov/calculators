<% k = "health.calculators.macro" %>
<% locale_calculator_seo("health", "macro", "HealthApplication", "macro") %>
<%= breadcrumb_schema(locale_breadcrumb_items("health", "macro")) %>
<%= faq_schema(locale_faq_data("health", "macro")) %>
<%= calculator_schema_with_ratings(name: t("#{k}.breadcrumb"), description: t("#{k}.description"), url: locale_canonical_url, category: "HealthApplication", calculator_slug: "macro") %>
<%= render "shared/breadcrumbs", items: locale_breadcrumb_nav_items("health", "macro") %>
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("#{k}.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("#{k}.intro") %></p>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>
    <div data-controller="macro-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="macro-daily-calories" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.daily_calories") %></label>
            <input id="macro-daily-calories" type="number" inputmode="decimal" data-macro-calculator-target="calories" data-action="input->macro-calculator#calculate" class="w-full" placeholder="2000" step="1" min="0">
          </div>
          <div>
            <label for="macro-goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.goal") %></label>
            <select id="macro-goal" data-macro-calculator-target="goal" data-action="change->macro-calculator#calculate" class="w-full">
              <option value="maintain"><%= t("#{k}.labels.maintain") %></option>
              <option value="cut"><%= t("#{k}.labels.cut") %></option>
              <option value="bulk"><%= t("#{k}.labels.bulk") %></option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5"><%= t("#{k}.labels.results") %></h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.protein") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="protein">&mdash; g</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.carbs") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="carbs">&mdash; g</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.fat") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="fat">&mdash; g</span></div>
          </div>
          <button data-action="click->macro-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium"><%= t("#{k}.labels.copy_results") %></button>
        </div>
      </div>
    </div>
    <%= render "shared/calculator_rating", slug: "macro" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>
    <article class="prose dark:prose-invert max-w-none">
      <% (1..5).each do |i| %><h3><%= t("#{k}.faq.q#{i}") %></h3><p><%= t("#{k}.faq.a#{i}") %></p><% end %>
      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>
    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>
    <%= render "shared/calculator_disclaimer", category: "health" %>
  </div>
  <div class="hidden lg:block"><div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div></div>
</div>

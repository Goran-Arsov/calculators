<% k = "health.calculators.bmi" %>
<% locale_calculator_seo("health", "bmi", "HealthApplication", "bmi") %>
<%= breadcrumb_schema(locale_breadcrumb_items("health", "bmi")) %>
<%= faq_schema(locale_faq_data("health", "bmi")) %>
<%= calculator_schema_with_ratings(name: t("#{k}.breadcrumb"), description: t("#{k}.description"), url: locale_canonical_url, category: "HealthApplication", calculator_slug: "bmi") %>
<%= render "shared/breadcrumbs", items: locale_breadcrumb_nav_items("health", "bmi") %>
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("#{k}.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("#{k}.intro") %></p>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>
    <div data-controller="bmi-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div><label for="bmi-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.unit_system") %></label><select id="bmi-unit-system" data-bmi-calculator-target="unitSystem" data-action="change->bmi-calculator#updateLabels" class="w-full"><option value="metric"><%= t("#{k}.labels.metric") %></option><option value="imperial"><%= t("#{k}.labels.imperial") %></option></select></div>
          <div><label for="bmi-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bmi-calculator-target="weightLabel"><%= t("#{k}.labels.weight") %></label><input id="bmi-weight" type="number" inputmode="decimal" data-bmi-calculator-target="weight" data-action="input->bmi-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0"></div>
          <div><label for="bmi-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bmi-calculator-target="heightLabel"><%= t("#{k}.labels.height") %></label><input id="bmi-height" type="number" inputmode="decimal" data-bmi-calculator-target="height" data-action="input->bmi-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0"></div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5"><%= t("#{k}.labels.results") %></h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.your_bmi") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="bmi">&mdash;</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.category") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="category">&mdash;</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.healthy_weight_min") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="healthyMin">&mdash;</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.healthy_weight_max") %></span><span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="healthyMax">&mdash;</span></div>
          </div>
          <button data-action="click->bmi-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium"><%= t("#{k}.labels.copy_results") %></button>
        </div>
      </div>
    </div>
    <%= render "shared/calculator_rating", slug: "bmi" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>
    <article class="prose dark:prose-invert max-w-none">
      <% (1..5).each do |i| %><h3><%= t("#{k}.faq.q#{i}") %></h3><p><%= t("#{k}.faq.a#{i}") %></p><% end %>
      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>
    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>
    <%= render "shared/calculator_disclaimer", category: "health" %>
  </div>
  <div class="hidden lg:block"><div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div></div>
</div>

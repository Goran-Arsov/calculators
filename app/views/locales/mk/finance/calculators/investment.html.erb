<% k = "finance.calculators.investment" %>
<% locale_calculator_seo("finance", "investment", "FinanceApplication", "investment") %>
<%= breadcrumb_schema(locale_breadcrumb_items("finance", "investment")) %>
<%= faq_schema(locale_faq_data("finance", "investment")) %>
<%= calculator_schema_with_ratings(name: t("#{k}.breadcrumb"), description: t("#{k}.description"), url: locale_canonical_url, category: "FinanceApplication", calculator_slug: "investment") %>
<%= render "shared/breadcrumbs", items: locale_breadcrumb_nav_items("finance", "investment") %>
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("#{k}.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("#{k}.intro") %></p>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>
    <div data-controller="investment-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div><label for="investment-initial-investment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.initial_investment") %></label><input id="investment-initial-investment" type="number" inputmode="decimal" data-investment-calculator-target="initial" data-action="input->investment-calculator#calculate" class="w-full" placeholder="10000" step="500" min="0"></div>
          <div><label for="investment-monthly-contribution" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.monthly_contribution") %></label><input id="investment-monthly-contribution" type="number" inputmode="decimal" data-investment-calculator-target="monthly" data-action="input->investment-calculator#calculate" class="w-full" placeholder="500" step="50" min="0"></div>
          <div><label for="investment-expected-annual-return" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.expected_annual_return") %></label><input id="investment-expected-annual-return" type="number" inputmode="decimal" data-investment-calculator-target="rate" data-action="input->investment-calculator#calculate" class="w-full" placeholder="7" step="0.1" min="0"></div>
          <div><label for="investment-investment-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.investment_period") %></label><input id="investment-investment-period" type="number" inputmode="decimal" data-investment-calculator-target="years" data-action="input->investment-calculator#calculate" class="w-full" placeholder="20" step="1" min="1" max="100"></div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5"><%= t("#{k}.labels.results") %></h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.future_value") %></span><span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="futureValue">$0.00</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.total_contributions") %></span><span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="totalContributions">$0.00</span></div>
            <div class="flex justify-between items-center"><span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.investment_growth") %></span><span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="totalGrowth">$0.00</span></div>
          </div>
          <button data-action="click->investment-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium"><%= t("#{k}.labels.copy_results") %></button>
        </div>
      </div>
    </div>
    <%= render "shared/calculator_rating", slug: "investment" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>
    <article class="prose dark:prose-invert max-w-none">
      <% (1..5).each do |i| %><h3><%= t("#{k}.faq.q#{i}") %></h3><p><%= t("#{k}.faq.a#{i}") %></p><% end %>
      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>
    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>
    <%= render "shared/calculator_disclaimer", category: "finance" %>
  </div>
  <div class="hidden lg:block"><div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div></div>
</div>

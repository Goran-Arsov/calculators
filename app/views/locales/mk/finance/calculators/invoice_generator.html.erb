<% k = "finance.calculators.invoice_generator" %>
<% locale_calculator_seo("finance", "invoice_generator", "FinanceApplication", "invoice-generator") %>
<%= breadcrumb_schema(locale_breadcrumb_items("finance", "invoice_generator")) %>
<%= faq_schema(locale_faq_data("finance", "invoice_generator")) %>
<%= calculator_schema_with_ratings(name: t("#{k}.breadcrumb"), description: t("#{k}.description"), url: locale_canonical_url, category: "FinanceApplication", calculator_slug: "invoice-generator") %>
<%= render "shared/breadcrumbs", items: locale_breadcrumb_nav_items("finance", "invoice_generator") %>
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("#{k}.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("#{k}.intro") %></p>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="invoice-generator-calculator ad-engagement"
         data-invoice-generator-calculator-labels-value="<%= invoice_labels(key_prefix: k).to_json %>"
         class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">

      <%# Business Information %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <%= t("#{k}.labels.your_business") %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.business_name") %></label>
            <input type="text" data-invoice-generator-calculator-target="businessName" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="<%= t("#{k}.placeholders.business_name") %>">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.email") %></label>
            <input type="email" data-invoice-generator-calculator-target="businessEmail" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="billing@company.com">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.address") %></label>
            <input type="text" data-invoice-generator-calculator-target="businessAddress" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="<%= t("#{k}.placeholders.business_address") %>">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.phone") %></label>
            <input type="tel" data-invoice-generator-calculator-target="businessPhone" data-action="input->invoice-generator-calculator#updatePreview" class="w-full placeholder-gray-200" placeholder="+389 (0) 00 000 000">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.tax_id") %></label>
            <input type="text" data-invoice-generator-calculator-target="businessTaxId" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="MK1234567890">
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.iban") %></label>
            <input type="text" data-invoice-generator-calculator-target="businessIban" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="MK07 2501 2000 0058 984">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.swift") %></label>
            <input type="text" data-invoice-generator-calculator-target="businessSwift" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="COBADEFFXXX">
          </div>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-700 mb-8">

      <%# Client Information %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <%= t("#{k}.labels.client_details") %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.client_name") %></label>
            <input type="text" data-invoice-generator-calculator-target="clientName" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="<%= t("#{k}.placeholders.client_name") %>">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.client_email") %></label>
            <input type="email" data-invoice-generator-calculator-target="clientEmail" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="accounts@client.com">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.client_address") %></label>
            <input type="text" data-invoice-generator-calculator-target="clientAddress" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="<%= t("#{k}.placeholders.client_address") %>">
          </div>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-700 mb-8">

      <%# Invoice Details %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <%= t("#{k}.labels.invoice_details") %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.invoice_number") %></label>
            <input type="text" data-invoice-generator-calculator-target="invoiceNumber" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" placeholder="INV-001">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.invoice_date") %></label>
            <input type="date" data-invoice-generator-calculator-target="invoiceDate" data-action="input->invoice-generator-calculator#updatePreview" class="w-full">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.due_date_preset") %></label>
            <select data-invoice-generator-calculator-target="dueDatePreset" data-action="change->invoice-generator-calculator#applyDueDatePreset" class="w-full">
              <option value=""><%= t("#{k}.labels.custom") %></option>
              <option value="receipt"><%= t("#{k}.labels.due_on_receipt") %></option>
              <option value="15">Net 15</option>
              <option value="30" selected>Net 30</option>
              <option value="60">Net 60</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.due_date") %></label>
            <input type="date" data-invoice-generator-calculator-target="dueDate" data-action="input->invoice-generator-calculator#updatePreview" class="w-full">
          </div>
        </div>
      </div>

      <hr class="border-gray-200 dark:border-gray-700 mb-8">

      <%# Line Items %>
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
          <%= t("#{k}.labels.line_items") %>
        </h2>
        <div data-invoice-generator-calculator-target="lineItems"></div>
        <button type="button" data-action="click->invoice-generator-calculator#addLineItem" class="mt-3 inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          <%= t("#{k}.labels.add_line_item") %>
        </button>
      </div>

      <hr class="border-gray-200 dark:border-gray-700 mb-8">

      <%# Tax, Discount, Notes %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.tax_rate") %></label>
          <input type="number" inputmode="decimal" data-invoice-generator-calculator-target="taxRate" data-action="input->invoice-generator-calculator#recalculate" class="w-full" placeholder="0" min="0" max="100" step="0.01" value="0">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.discount") %></label>
          <input type="number" inputmode="decimal" data-invoice-generator-calculator-target="discountValue" data-action="input->invoice-generator-calculator#recalculate" class="w-full" placeholder="0" min="0" step="0.01" value="0">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.discount_type") %></label>
          <select data-invoice-generator-calculator-target="discountType" data-action="change->invoice-generator-calculator#recalculate" class="w-full">
            <option value="percent"><%= t("#{k}.labels.percentage") %></option>
            <option value="flat"><%= t("#{k}.labels.flat_amount") %></option>
          </select>
        </div>
      </div>

      <%# Totals %>
      <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6 mb-8">
        <div class="max-w-xs ml-auto space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.subtotal") %></span>
            <span class="font-semibold text-gray-700 dark:text-gray-300" data-invoice-generator-calculator-target="subtotalDisplay">$0.00</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.tax") %></span>
            <span class="font-semibold text-gray-700 dark:text-gray-300" data-invoice-generator-calculator-target="taxDisplay">$0.00</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.discount") %></span>
            <span class="font-semibold text-red-500" data-invoice-generator-calculator-target="discountDisplay">$0.00</span>
          </div>
          <hr class="border-gray-300 dark:border-gray-600">
          <div class="flex justify-between">
            <span class="text-base font-bold text-gray-900 dark:text-white"><%= t("#{k}.labels.total") %></span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-invoice-generator-calculator-target="totalDisplay">$0.00</span>
          </div>
        </div>
      </div>

      <%# Notes and Terms %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.notes") %></label>
          <textarea data-invoice-generator-calculator-target="notes" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" rows="3" placeholder="<%= t("#{k}.placeholders.notes") %>"></textarea>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.terms") %></label>
          <textarea data-invoice-generator-calculator-target="terms" data-action="input->invoice-generator-calculator#updatePreview" class="w-full" rows="3" placeholder="<%= t("#{k}.placeholders.terms") %>"></textarea>
        </div>
      </div>

      <%# Action Buttons %>
      <div class="flex flex-wrap gap-3">
        <button data-action="click->invoice-generator-calculator#downloadPdf" class="inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <%= t("#{k}.labels.download_pdf") %>
        </button>
        <button data-action="click->invoice-generator-calculator#printInvoice" class="inline-flex items-center gap-2 px-6 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          <%= t("#{k}.labels.print") %>
        </button>
      </div>

      <%# Live Preview — must stay inside the Stimulus controller scope. %>
      <div class="mt-8">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4"><%= t("#{k}.labels.invoice_preview") %></h2>
        <div data-invoice-generator-calculator-target="preview"></div>
      </div>
    </div>

    <%= render "shared/calculator_rating", slug: "invoice-generator" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>
    <article class="prose dark:prose-invert max-w-none">
      <% (1..5).each do |i| %><h3><%= t("#{k}.faq.q#{i}") %></h3><p><%= t("#{k}.faq.a#{i}") %></p><% end %>
      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>
    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>
    <%= render "shared/calculator_disclaimer", category: "finance" %>
  </div>
  <div class="hidden lg:block"><div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div></div>
</div>

<% k = "finance.calculators.compound_interest" %>
<% locale_calculator_seo("finance", "compound_interest", "FinanceApplication", "compound-interest") %>
<%= breadcrumb_schema(locale_breadcrumb_items("finance", "compound_interest")) %>
<%= faq_schema(locale_faq_data("finance", "compound_interest")) %>
<%= calculator_schema_with_ratings(name: t("#{k}.breadcrumb"), description: t("#{k}.description"), url: locale_canonical_url, category: "FinanceApplication", calculator_slug: "compound-interest") %>
<%= render "shared/breadcrumbs", items: locale_breadcrumb_nav_items("finance", "compound_interest") %>
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <%= hreflang_tags %>
  <div class="lg:col-span-2">
    <%= render "shared/language_switcher" %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight"><%= t("#{k}.h1") %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed"><%= t("#{k}.intro") %></p>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>
    <div data-controller="compound-interest-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="compound-interest-initial-principal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.initial_principal") %></label>
            <input id="compound-interest-initial-principal" type="number" inputmode="decimal" data-compound-interest-calculator-target="principal" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="10000" step="100" min="0">
          </div>
          <div>
            <label for="compound-interest-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.annual_interest_rate") %></label>
            <input id="compound-interest-annual-interest-rate" type="number" inputmode="decimal" data-compound-interest-calculator-target="rate" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="5" step="0.01" min="0">
          </div>
          <div>
            <label for="compound-interest-time-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.time_period") %></label>
            <input id="compound-interest-time-period" type="number" inputmode="decimal" data-compound-interest-calculator-target="years" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="10" step="1" min="1" max="100">
          </div>
          <div>
            <label for="compound-interest-compounding-frequency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><%= t("#{k}.labels.compounding_frequency") %></label>
            <select id="compound-interest-compounding-frequency" data-compound-interest-calculator-target="frequency" data-action="change->compound-interest-calculator#calculate" class="w-full">
              <option value="1"><%= t("#{k}.labels.annually") %></option>
              <option value="2"><%= t("#{k}.labels.semi_annually") %></option>
              <option value="4"><%= t("#{k}.labels.quarterly") %></option>
              <option value="12" selected><%= t("#{k}.labels.monthly") %></option>
              <option value="365"><%= t("#{k}.labels.daily") %></option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5"><%= t("#{k}.labels.results") %></h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.future_value") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="futureValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.total_interest_earned") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400"><%= t("#{k}.labels.initial_principal_display") %></span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="principalDisplay">$0.00</span>
            </div>
          </div>
          <button data-action="click->compound-interest-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium"><%= t("#{k}.labels.copy_results") %></button>
        </div>
      </div>
    </div>
    <%= render "shared/calculator_rating", slug: "compound-interest" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>
    <article class="prose dark:prose-invert max-w-none">
      <h2><%= t("#{k}.faq.q1") %></h2>
      <p><%= t("#{k}.faq.a1") %></p>
      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>
      <h2><%= t("#{k}.faq.q2") %></h2>
      <p><%= t("#{k}.faq.a2") %></p>
      <h2><%= t("#{k}.faq.q3") %></h2>
      <p><%= t("#{k}.faq.a3") %></p>
    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>
</article>
    <%= render "shared/calculator_disclaimer", category: "finance" %>
  </div>
  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

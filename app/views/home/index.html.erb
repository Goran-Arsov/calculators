<!-- Hero Section -->
<section class="text-center py-12 md:py-20">
  <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-4">
    Free Online Calculators
  </h1>
  <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8">
    Fast, accurate calculators for finance, math, and health. No sign-up required — just instant results.
  </p>
</section>

<!-- Popular Calculators -->
<section class="mb-16">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Popular Calculators</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <%= render "shared/calculator_card", calculator: { name: "Mortgage Calculator", description: "Calculate your monthly mortgage payment and total interest.", path: finance_mortgage_path, icon_path: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" } %>
    <%= render "shared/calculator_card", calculator: { name: "BMI Calculator", description: "Calculate your Body Mass Index and find your weight category.", path: health_bmi_path, icon_path: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" } %>
    <%= render "shared/calculator_card", calculator: { name: "Percentage Calculator", description: "Calculate percentages, percentage change, and more.", path: math_percentage_path, icon_path: "M7 20l4-16m2 16l4-16M6 9h14M4 15h14" } %>
    <%= render "shared/calculator_card", calculator: { name: "Compound Interest Calculator", description: "See how your money grows over time with compound interest.", path: finance_compound_interest_path, icon_path: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" } %>
    <%= render "shared/calculator_card", calculator: { name: "Loan Calculator", description: "Calculate monthly payments and total cost for any loan.", path: finance_loan_path, icon_path: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" } %>
    <%= render "shared/calculator_card", calculator: { name: "Calorie Calculator", description: "Estimate your daily calorie needs based on your profile.", path: health_calorie_path, icon_path: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" } %>
  </div>
</section>

<!-- Finance Category -->
<section class="mb-12">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Finance Calculators</h2>
    <%= link_to "View All →", category_path("finance"), class: "text-blue-600 dark:text-blue-400 font-medium hover:underline" %>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% CalculatorHelper::FINANCE_CALCULATORS.first(3).each do |calc| %>
      <%= render "shared/calculator_card", calculator: calc.merge(path: send(calc[:path])) %>
    <% end %>
  </div>
</section>


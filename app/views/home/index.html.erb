<%# Latest blog posts — drives traffic to content pages %>
<% latest_posts = BlogPost.published.recent.limit(3) %>
<% if latest_posts.any? %>
  <section class="mb-14">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="w-1.5 h-8 bg-gradient-to-b from-emerald-500 to-teal-600 rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Latest Articles</h2>
      </div>
      <%= link_to blog_path, class: "inline-flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
        View All
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% latest_posts.each do |post| %>
        <%= link_to blog_post_path(post.slug), class: "group bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" do %>
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300"><%= post.category&.capitalize %></span>
            <time class="text-xs text-gray-400 dark:text-gray-500"><%= post.published_at.strftime("%b %d") %></time>
          </div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug mb-2"><%= post.title %></h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2"><%= post.excerpt %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# Newsletter signup %>
<%= render "shared/newsletter_signup" %>

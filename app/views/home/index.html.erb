<%# WebSite schema — enables sitelinks search box in Google results %>
<%= website_schema(url: root_url, search_url: root_url) %>

<!-- Hero Section -->
<section class="relative text-center py-6 md:py-10 -mt-10 mb-8 rounded-b-3xl hero-gradient dark:hero-gradient-dark overflow-hidden">
  <!-- Decorative blobs -->
  <div class="absolute top-10 left-10 w-64 h-64 bg-blue-400/10 dark:bg-blue-400/5 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-10 right-10 w-72 h-72 bg-violet-400/10 dark:bg-violet-400/5 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>

  <div class="relative z-10 px-4">
    <%# Search bar %>
    <div class="max-w-xl mx-auto mb-8" data-controller="calculator-search" data-calculator-search-calculators-value="<%= all_calculators_json %>">
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <input type="text"
          data-calculator-search-target="input"
          data-action="input->calculator-search#search keydown->calculator-search#keydown"
          class="w-full pl-12 pr-12 py-3.5 bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm rounded-2xl border border-gray-200/80 dark:border-gray-700/80 shadow-lg shadow-black/5 text-gray-900 dark:text-white text-base focus:outline-none focus:ring-2 focus:ring-blue-500/40 focus:border-blue-400 dark:focus:border-blue-500 transition-all"
          placeholder="Search calculators..."
          autocomplete="off">
        <button data-action="click->calculator-search#submitSearch" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 dark:text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" aria-label="Search">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </button>
        <%# Dropdown %>
        <div data-calculator-search-target="dropdown" class="hidden absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-900 rounded-2xl border border-gray-200/80 dark:border-gray-800 shadow-xl shadow-black/10 overflow-hidden z-50">
          <div data-calculator-search-target="list" class="max-h-80 overflow-y-auto divide-y divide-gray-100 dark:divide-gray-800"></div>
        </div>
      </div>
    </div>

    <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-sm font-medium mb-6">
      <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>
      100% Free &middot; No Sign-up Required
    </div>
    <h1 class="text-4xl md:text-6xl font-extrabold mb-5 tracking-tight">
      <span class="gradient-text dark:gradient-text-dark">Free Online</span>
      <br class="hidden sm:block">
      <span class="text-gray-900 dark:text-white">Calculators</span>
    </h1>
    <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
      Fast, accurate calculators for finance, math, physics, and health. Instant results with no sign-up required.
    </p>
  </div>
</section>

<!-- Popular Calculators -->
<section class="mb-16 animate-fade-in-up">
  <div class="flex items-center gap-3 mb-8">
    <div class="w-1.5 h-8 bg-gradient-to-b from-blue-600 to-violet-600 rounded-full"></div>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Popular Calculators</h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <%= render "shared/calculator_card", calculator: { name: "Mortgage Calculator", description: "Calculate your monthly mortgage payment and total interest.", path: finance_mortgage_path, icon_path: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" } %>
    <%= render "shared/calculator_card", calculator: { name: "BMI Calculator", description: "Calculate your Body Mass Index and find your weight category.", path: health_bmi_path, icon_path: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" } %>
    <%= render "shared/calculator_card", calculator: { name: "Percentage Calculator", description: "Calculate percentages, percentage change, and more.", path: math_percentage_path, icon_path: "M7 20l4-16m2 16l4-16M6 9h14M4 15h14" } %>
    <%= render "shared/calculator_card", calculator: { name: "Compound Interest Calculator", description: "See how your money grows over time with compound interest.", path: finance_compound_interest_path, icon_path: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" } %>
    <%= render "shared/calculator_card", calculator: { name: "Loan Calculator", description: "Calculate monthly payments and total cost for any loan.", path: finance_loan_path, icon_path: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" } %>
    <%= render "shared/calculator_card", calculator: { name: "Calorie Calculator", description: "Estimate your daily calorie needs based on your profile.", path: health_calorie_path, icon_path: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" } %>
  </div>
</section>

<!-- Finance Category -->
<section class="mb-14">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-8 bg-gradient-to-b from-emerald-500 to-teal-600 rounded-full"></div>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Finance Calculators</h2>
    </div>
    <%= link_to category_path("finance"), class: "inline-flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
      View All
      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <% CalculatorHelper::FINANCE_CALCULATORS.first(3).each do |calc| %>
      <%= render "shared/calculator_card", calculator: calc.merge(path: send(calc[:path])) %>
    <% end %>
  </div>
</section>


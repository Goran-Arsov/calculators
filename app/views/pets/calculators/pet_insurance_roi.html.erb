<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Pets", url: category_url("pets") },
  { name: "Pet Insurance ROI Calculator", url: pets_pet_insurance_roi_url }
]) %>

<%= faq_schema([
  { question: "Is pet insurance worth the cost?", answer: "Pet insurance is generally worth it for owners who want financial protection against unexpected large vet bills. The average dog owner will face $2,000-$5,000 in emergency vet costs over their pet's lifetime, and a single surgery or hospitalization can cost $3,000-$10,000. If your monthly premium is reasonable relative to your pet's risk profile, insurance can provide significant savings and peace of mind. The ROI tends to be better for larger breeds, younger pets, and pets with higher health risks." },
  { question: "How much does pet insurance typically cost?", answer: "Average monthly premiums range from $30-$60 for dogs and $15-$35 for cats, depending on breed, age, location, coverage level, deductible, and reimbursement rate. Accident-only plans cost less ($10-$20/month) but cover fewer situations. Comprehensive plans that include illness, accidents, and sometimes wellness care cost more but provide broader protection. Premiums typically increase as your pet ages." },
  { question: "What is a good reimbursement rate for pet insurance?", answer: "Most pet insurance plans offer reimbursement rates of 70%, 80%, or 90%. An 80% reimbursement rate is the most popular choice, balancing premium cost with coverage. At 80%, the insurance company pays 80% of the eligible vet bill after you meet your deductible. Higher reimbursement rates mean higher premiums but lower out-of-pocket costs when you file a claim." },
  { question: "What is a pet insurance deductible?", answer: "A pet insurance deductible is the amount you pay out of pocket before insurance coverage kicks in. Annual deductibles (reset each year) typically range from $100 to $500. A higher deductible means lower monthly premiums but more out-of-pocket costs per incident. Most financial advisors recommend choosing a deductible you can comfortably afford in an emergency." },
  { question: "Does pet insurance cover pre-existing conditions?", answer: "No, pet insurance does not cover pre-existing conditions — health issues that existed before coverage began or during a waiting period. This is the main reason experts recommend getting pet insurance when your pet is young and healthy. Some conditions that are considered cured (no symptoms for 12-18 months) may eventually be covered, but this varies by provider. Hereditary and congenital conditions are covered by most plans if they have not yet manifested." }
]) %>

<%= calculator_schema_with_ratings(
  name: "Pet Insurance ROI Calculator",
  description: "Compare pet insurance premiums vs estimated veterinary costs over your pet's lifetime to determine if insurance is worth the investment.",
  url: pets_pet_insurance_roi_url,
  category: "FinanceApplication",
  calculator_slug: "pet-insurance-roi"
) %>


          </div>
          <div>
            <label for="fish-tank-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-fish-tank-calculator-target="widthLabel">Width (inches)</span></label>
            <input id="fish-tank-width" type="number" inputmode="decimal" data-fish-tank-calculator-target="width" data-action="input->fish-tank-calculator#calculate" class="w-full" placeholder="12" step="0.5" min="0">
          </div>
          <div>
            <label for="fish-tank-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-fish-tank-calculator-target="heightLabel">Height (inches)</span></label>
            <input id="fish-tank-height" type="number" inputmode="decimal" data-fish-tank-calculator-target="height" data-action="input->fish-tank-calculator#calculate" class="w-full" placeholder="16" step="0.5" min="0">

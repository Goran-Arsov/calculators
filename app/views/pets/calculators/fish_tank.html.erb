              <option value="imperial">Imperial (in, gal)</option>
              <option value="metric">Metric (cm, L)</option>
            </select>
          </div>
          <div>
            <label for="fish-tank-shape" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tank Shape</label>
            <select id="fish-tank-shape" data-fish-tank-calculator-target="tankShape" data-action="change->fish-tank-calculator#calculate" class="w-full" aria-label="Tank Shape">

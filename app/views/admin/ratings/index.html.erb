<div class="max-w-5xl mx-auto py-10 px-4">
  <div class="flex items-center justify-between mb-2">
    <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white">Ratings Dashboard</h1>
    <div class="flex gap-2">
      <%= link_to "+ New Note", new_admin_note_path, class: "px-4 py-2 text-sm font-medium bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-lg shadow-sm transition-colors" %>
      <%= link_to "My Photos", admin_photos_path, class: "px-4 py-2 text-sm font-medium bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white rounded-lg shadow-sm transition-colors" %>
      <%= link_to "My Notes", admin_notes_path, class: "px-4 py-2 text-sm font-medium bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white rounded-lg shadow-sm transition-colors" %>
      <%= button_to "Log Out", admin_logout_path, method: :delete, class: "px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400 border border-gray-300 dark:border-gray-700 rounded-lg hover:border-red-300 dark:hover:border-red-700 transition-colors" %>
    </div>
  </div>
  <p class="text-gray-500 dark:text-gray-400 mb-8">Filter and sort calculator ratings to find tools that need improvement.</p>

  <%# Summary stats %>
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <p class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= @total_ratings %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400">Total Ratings</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <p class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= @total_calculators %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400">Rated Calculators</p>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 text-center">
      <p class="text-3xl font-bold text-blue-600 dark:text-blue-400"><%= @overall_avg %></p>
      <p class="text-sm text-gray-500 dark:text-gray-400">Overall Average</p>
    </div>
  </div>

  <%# Filters %>
  <%= form_tag(admin_ratings_path, method: :get, class: "bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 mb-6") do %>
    <input type="hidden" name="token" value="<%= params[:token] %>">
    <div class="flex flex-wrap items-end gap-4">
      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Min Stars</label>
        <select name="min_stars" class="rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-800 text-sm">
          <option value="">Any</option>
          <% (0..4).each do |n| %>
            <option value="<%= n %>" <%= "selected" if @min_stars == n.to_f %>><%= n %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Max Stars</label>
        <select name="max_stars" class="rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-800 text-sm">
          <option value="">Any</option>
          <% (1..5).each do |n| %>
            <option value="<%= n %>" <%= "selected" if @max_stars == n.to_f %>><%= n %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Sort By</label>
        <select name="sort" class="rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-800 text-sm">
          <option value="avg_score" <%= "selected" if @sort == "avg_score" %>>Average Rating</option>
          <option value="total_count" <%= "selected" if @sort == "total_count" %>>Number of Ratings</option>
          <option value="latest_rating" <%= "selected" if @sort == "latest_rating" %>>Latest Rating</option>
          <option value="slug" <%= "selected" if @sort == "slug" %>>Name</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Direction</label>
        <select name="direction" class="rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-800 text-sm">
          <option value="asc" <%= "selected" if @direction == "asc" %>>Low to High</option>
          <option value="desc" <%= "selected" if @direction == "desc" %>>High to Low</option>
        </select>
      </div>
      <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-colors">Filter</button>
    </div>
  <% end %>

  <%# Quick filter buttons %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "Needs Work (0-2 stars)", admin_ratings_path(token: params[:token], max_stars: 2, sort: "avg_score", direction: "asc"),
        class: "px-3 py-1.5 text-xs font-medium rounded-lg bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors" %>
    <%= link_to "Average (2-3.5 stars)", admin_ratings_path(token: params[:token], min_stars: 2, max_stars: 3.5, sort: "avg_score", direction: "asc"),
        class: "px-3 py-1.5 text-xs font-medium rounded-lg bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400 hover:bg-yellow-100 dark:hover:bg-yellow-900/30 transition-colors" %>
    <%= link_to "Good (3.5-5 stars)", admin_ratings_path(token: params[:token], min_stars: 3.5, sort: "avg_score", direction: "desc"),
        class: "px-3 py-1.5 text-xs font-medium rounded-lg bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors" %>
    <%= link_to "Most Rated", admin_ratings_path(token: params[:token], sort: "total_count", direction: "desc"),
        class: "px-3 py-1.5 text-xs font-medium rounded-lg bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors" %>
    <%= link_to "All", admin_ratings_path(token: params[:token]),
        class: "px-3 py-1.5 text-xs font-medium rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" %>
  </div>

  <%# Ratings table %>
  <% if @ratings.any? %>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Calculator</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Avg Rating</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Stars</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase"># Ratings</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Latest</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <% @ratings.each do |r| %>
            <% avg = r.avg_score.to_f %>
            <% color = avg <= 2 ? "text-red-600 dark:text-red-400" : avg <= 3.5 ? "text-yellow-600 dark:text-yellow-400" : "text-green-600 dark:text-green-400" %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-4 py-3">
                <span class="text-sm font-medium text-gray-900 dark:text-white"><%= r.calculator_slug.tr("-", " ").titleize %></span>
                <span class="block text-xs text-gray-400 dark:text-gray-500 font-mono"><%= r.calculator_slug %></span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="text-lg font-bold <%= color %>"><%= avg.round(1) %></span>
              </td>
              <td class="px-4 py-3 text-center">
                <% 5.times do |i| %>
                  <svg class="inline w-4 h-4 <%= i < avg.round ? 'text-yellow-400' : 'text-gray-300 dark:text-gray-600' %>" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                <% end %>
              </td>
              <td class="px-4 py-3 text-center text-sm text-gray-600 dark:text-gray-400"><%= r.total_count %></td>
              <td class="px-4 py-3 text-center text-xs text-gray-400 dark:text-gray-500"><%= r.latest_rating.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-12 text-center">
      <p class="text-gray-500 dark:text-gray-400">No ratings found matching your filters.</p>
    </div>
  <% end %>
</div>

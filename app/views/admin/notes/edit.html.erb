<% content_for :title, "Edit Note" %>

<div class="max-w-2xl mx-auto py-10 px-4">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 text-center">Edit Note</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 text-center">Saved <%= time_ago_in_words(@note.created_at) %> ago · <%= number_to_human_size(@note.byte_size) %></p>

    <% if flash[:alert] %>
      <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: admin_note_path(@note), method: :patch, class: "space-y-4" do |f| %>
      <div>
        <label for="note_title" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Title <span class="font-normal text-gray-400">(optional)</span></label>
        <input type="text" name="note[title]" id="note_title" maxlength="200" value="<%= @note.title %>"
               class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g. shopping list">
      </div>
      <div>
        <label for="note_body" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Content</label>
        <textarea name="note[body]" id="note_body" rows="16" required autofocus
                  class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-mono text-sm"
                  placeholder="Type your note here..."><%= @body %></textarea>
      </div>
      <button type="submit" class="w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white rounded-xl shadow-sm font-medium transition-all duration-200">
        Save changes
      </button>
      <%= link_to "← Back to notes", admin_notes_path, class: "block text-center text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" %>
    <% end %>
  </div>
</div>

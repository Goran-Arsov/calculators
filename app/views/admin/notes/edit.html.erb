<% content_for :fullwidth, true %>

<%= form_with url: admin_note_path(@note), method: :patch, class: "flex flex-col flex-1 min-h-0 w-full bg-slate-50 dark:bg-slate-900" do |f| %>
  <div class="shrink-0 border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
    <div class="grid grid-cols-3 items-center gap-4 px-4 py-1.5">
      <div class="justify-self-start">
        <%= link_to "← Back to notes", admin_notes_path, class: "text-xs font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
      </div>
      <div class="justify-self-center">
        <%= f.submit "Save", class: "w-32 py-1 text-xs font-semibold text-white bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 rounded shadow-sm cursor-pointer transition-colors border-0" %>
      </div>
      <div class="justify-self-end">
        <%= link_to "Cancel", admin_note_path(@note), class: "px-2.5 py-1 text-xs font-medium text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 rounded hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" %>
      </div>
    </div>
  </div>

  <% if flash[:alert] %>
    <div class="shrink-0 px-4 py-2 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <input type="text" name="note[title]" id="note_title" maxlength="200" value="<%= @note.title %>"
         class="shrink-0 w-full pt-6 pb-2 text-3xl md:text-4xl font-bold bg-slate-50 dark:bg-slate-900 border-0 focus:ring-0 focus:outline-none text-gray-900 dark:text-white placeholder:text-gray-400 dark:placeholder:text-gray-600"
         placeholder="Untitled note">

  <hr class="shrink-0 border-gray-300 dark:border-gray-700">

  <textarea name="note[body]" id="note_body" required autofocus
            class="flex-1 min-h-0 w-full bg-slate-50 dark:bg-slate-900 border-0 focus:ring-0 focus:outline-none resize-none font-mono text-sm md:text-base text-gray-800 dark:text-gray-200 leading-relaxed placeholder:text-gray-400 dark:placeholder:text-gray-600 pt-4 pb-10"
            placeholder="Start writing..."><%= @body %></textarea>
<% end %>

<% content_for :title, "Upload Photo" %>

<div class="max-w-md mx-auto py-10 px-4">
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 text-center">Upload Photo</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 text-center">Converted to JPG, max 2000 px, quality 95.</p>

    <% if flash[:alert] %>
      <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 rounded-lg text-sm"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: admin_photos_path, method: :post, multipart: true, class: "space-y-4" do |f| %>
      <div>
        <label for="photo_file" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Image file</label>
        <input type="file" name="photo[file]" id="photo_file" required accept="image/*"
               class="w-full text-sm text-gray-700 dark:text-gray-300 file:mr-3 file:py-2.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/30 dark:file:text-blue-400">
      </div>
      <div>
        <label for="photo_tags" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tags <span class="font-normal text-gray-400">(optional, up to <%= Photo::MAX_TAGS %>, comma-separated)</span></label>
        <input type="text" name="photo[tags]" id="photo_tags"
               class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               placeholder="e.g. landscape, sunset, beach">
      </div>
      <button type="submit" class="w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white rounded-xl shadow-sm font-medium transition-all duration-200">
        Upload
      </button>
      <%= link_to "← Back to photos", admin_photos_path, class: "block text-center text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" %>
    <% end %>
  </div>
</div>

              <option value="imperial">Imperial (inches)</option>
              <option value="metric">Metric (cm)</option>
            </select>
          </div>
          <div>
            <label for="staircase-floor-to-floor-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-staircase-calculator-target="floorHeightLabel">Floor-to-Floor Height (inches)</span></label>
            <input id="staircase-floor-to-floor-height" type="number" inputmode="decimal" data-staircase-calculator-target="floorHeight" data-action="input->staircase-calculator#calculate" class="w-full" placeholder="108" step="0.25" min="0">
          </div>
          <div>
            <label for="staircase-preferred-run-per-step" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-staircase-calculator-target="runPrefLabel">Preferred Run per Step (inches, optional)</span></label>

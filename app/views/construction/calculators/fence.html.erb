          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Post Spacing (ft)</label>
            <input type="number" data-fence-calculator-target="spacing" data-action="input->fence-calculator#calculate" class="w-full" value="8" step="0.5" min="1">
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">

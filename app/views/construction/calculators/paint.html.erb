          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Doors</label>
            <input type="number" data-paint-calculator-target="doors" data-action="input->paint-calculator#calculate" class="w-full" value="1" step="1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Windows</label>
            <input type="number" data-paint-calculator-target="windows" data-action="input->paint-calculator#calculate" class="w-full" value="2" step="1" min="0">
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">

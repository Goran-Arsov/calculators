            <input type="number" data-paint-calculator-target="length" data-action="input->paint-calculator#calculate" class="w-full" placeholder="12" step="0.1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room Width (ft)</label>
            <input type="number" data-paint-calculator-target="width" data-action="input->paint-calculator#calculate" class="w-full" placeholder="10" step="0.1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room Height (ft)</label>
            <input type="number" data-paint-calculator-target="height" data-action="input->paint-calculator#calculate" class="w-full" placeholder="8" step="0.1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Coats</label>

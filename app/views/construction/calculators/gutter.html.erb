            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-gutter-calculator-target="eave2Label">Eave 2 (ft)</span></label>
              <input type="number" inputmode="decimal" data-gutter-calculator-target="eave2" data-action="input->gutter-calculator#calculate" class="w-full" value="40" step="any" min="0">
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-gutter-calculator-target="eave3Label">Eave 3 (ft)</span></label>
              <input type="number" inputmode="decimal" data-gutter-calculator-target="eave3" data-action="input->gutter-calculator#calculate" class="w-full" value="30" step="any" min="0">
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-gutter-calculator-target="eave4Label">Eave 4 (ft)</span></label>
              <input type="number" inputmode="decimal" data-gutter-calculator-target="eave4" data-action="input->gutter-calculator#calculate" class="w-full" value="30" step="any" min="0">

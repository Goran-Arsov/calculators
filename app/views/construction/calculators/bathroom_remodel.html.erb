<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Bathroom Remodel Cost Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">How much will your bathroom remodel cost? Enter bathroom size, tier, and any major additions to see a budget estimate with a component breakdown.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="bathroom-remodel-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Units</label>
            <select data-bathroom-remodel-calculator-target="unitSystem" data-action="change->bathroom-remodel-calculator#switchUnits" class="w-full">
              <option value="imperial">Imperial (sq ft)</option>
              <option value="metric">Metric (m²)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-bathroom-remodel-calculator-target="sizeLabel">Bathroom size (sq ft)</span></label>
            <input type="number" inputmode="decimal" data-bathroom-remodel-calculator-target="size" data-action="input->bathroom-remodel-calculator#calculate" class="w-full" value="40" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tier</label>
            <select data-bathroom-remodel-calculator-target="tier" data-action="change->bathroom-remodel-calculator#calculate" class="w-full">
              <option value="minor">Minor (cosmetic refresh) — $125/sq ft</option>
              <option value="midrange" selected>Midrange — $275/sq ft</option>
              <option value="major">Major (full gut) — $425/sq ft</option>
              <option value="luxury">Luxury — $650/sq ft</option>
            </select>
          </div>
          <label class="flex items-center gap-2 text-sm font-semibold text-gray-600 dark:text-gray-400">
            <input type="checkbox" data-bathroom-remodel-calculator-target="movePlumbing" data-action="change->bathroom-remodel-calculator#calculate" class="rounded"> Move plumbing (+$1,500)
          </label>
          <label class="flex items-center gap-2 text-sm font-semibold text-gray-600 dark:text-gray-400">
            <input type="checkbox" data-bathroom-remodel-calculator-target="addShower" data-action="change->bathroom-remodel-calculator#calculate" class="rounded"> Add walk-in shower (+$3,000)
          </label>
          <label class="flex items-center gap-2 text-sm font-semibold text-gray-600 dark:text-gray-400">
            <input type="checkbox" data-bathroom-remodel-calculator-target="walkInTub" data-action="change->bathroom-remodel-calculator#calculate" class="rounded"> Walk-in tub (+$5,000)
          </label>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-pink-50 to-rose-50 dark:from-pink-900/20 dark:to-rose-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Estimated Budget</h2>
          <div class="space-y-3">
            <div>
              <span class="text-gray-600 dark:text-gray-400 text-sm block">Total estimate</span>
              <span class="text-3xl font-extrabold text-rose-700 dark:text-rose-400" data-bathroom-remodel-calculator-target="resultTotal">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Low (−15%)</span>
              <span class="text-base font-bold text-rose-700 dark:text-rose-400" data-bathroom-remodel-calculator-target="resultLow">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">High (+15%)</span>
              <span class="text-base font-bold text-rose-700 dark:text-rose-400" data-bathroom-remodel-calculator-target="resultHigh">—</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-rose-200/50 dark:border-rose-800/50">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Base</span>
              <span class="text-sm font-bold text-rose-700 dark:text-rose-400" data-bathroom-remodel-calculator-target="resultBase">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Add-ons</span>
              <span class="text-sm font-bold text-rose-700 dark:text-rose-400" data-bathroom-remodel-calculator-target="resultAddOns">—</span>
            </div>
            <div class="pt-3 border-t border-rose-200/50 dark:border-rose-800/50">
              <p class="text-xs uppercase font-semibold text-gray-500 dark:text-gray-400 mb-2">Breakdown</p>
              <ul class="space-y-1 text-sm text-gray-700 dark:text-gray-300" data-bathroom-remodel-calculator-target="breakdownList"></ul>
            </div>
          </div>
          <button data-action="click->bathroom-remodel-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-pink-600 to-rose-600 hover:from-pink-700 hover:to-rose-700 text-white rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-rose-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>

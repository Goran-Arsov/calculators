    ] %>

    <%= render "shared/calculator_disclaimer", category: "construction" %>

    <% blog_posts = related_blog_posts("bathroom-remodel-cost-calculator") %>
    <%= render "shared/recommended_reading", posts: blog_posts if blog_posts.any? %>
  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

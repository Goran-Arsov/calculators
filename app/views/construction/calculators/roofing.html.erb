    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Roofing Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate the shingle bundles, felt underlayment rolls, and nail boxes you need based on your roof dimensions and pitch.</p>

    <div data-controller="roofing-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="roofing-roof-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Roof Length (ft)</label>
            <input id="roofing-roof-length" type="number" data-roofing-calculator-target="length" data-action="input->roofing-calculator#calculate" class="w-full" placeholder="40" step="0.1" min="0">
          </div>
          <div>
            <label for="roofing-roof-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Roof Width (ft)</label>
            <input id="roofing-roof-width" type="number" data-roofing-calculator-target="width" data-action="input->roofing-calculator#calculate" class="w-full" placeholder="30" step="0.1" min="0">
          </div>
          <div>
            <label for="roofing-roof-pitch" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Roof Pitch (rise per 12 in run)</label>
            <select id="roofing-roof-pitch" data-roofing-calculator-target="pitch" data-action="change->roofing-calculator#calculate" class="w-full">
              <% (0..12).each do |p| %>
                <option value="<%= p %>" <%= "selected" if p == 6 %>><%= p %>/12</option>
              <% end %>
            </select>
          </div>
          <div>
            <label for="roofing-waste" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Waste (%)</label>
            <input id="roofing-waste" type="number" data-roofing-calculator-target="waste" data-action="input->roofing-calculator#calculate" class="w-full" value="10" step="1" min="0" max="50">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>

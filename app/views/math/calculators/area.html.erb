<%= faq_schema([
  { question: "How do you calculate the area of a rectangle?", answer: "Multiply the length by the width. The formula is A = l x w. For example, a rectangle that is 8 meters long and 5 meters wide has an area of 40 square meters." },
  { question: "How do you calculate the area of a circle?", answer: "Use the formula A = pi x r squared, where r is the radius. For example, a circle with a radius of 7 cm has an area of approximately 153.94 square centimeters." },
  { question: "How do you calculate the area of a triangle?", answer: "Use the formula A = 1/2 x base x height. The height must be perpendicular to the base. A triangle with a base of 10 and a height of 6 has an area of 30 square units." },
  { question: "What is the area of a trapezoid?", answer: "The area of a trapezoid is A = 1/2 x (base1 + base2) x height, where base1 and base2 are the two parallel sides and height is the perpendicular distance between them." },
  { question: "What units are used for area?", answer: "Area is measured in square units. Common units include square meters (m2), square centimeters (cm2), square feet (ft2), square inches (in2), and acres. Always square the linear unit when expressing area." }
]) %>


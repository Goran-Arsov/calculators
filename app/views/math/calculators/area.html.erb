    <%# Calculator UI %>
    <div data-controller="area-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="area-shape" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Shape</label>
            <select id="area-shape" data-area-calculator-target="shape" data-action="change->area-calculator#updateFields" class="w-full" aria-label="Shape">
              <option value="rectangle">Rectangle</option>
              <option value="triangle">Triangle</option>
              <option value="circle">Circle</option>
              <option value="trapezoid">Trapezoid</option>
              <option value="ellipse">Ellipse</option>
            </select>
          </div>

          <%# Rectangle fields %>
          <div data-area-calculator-target="rectangleFields">
            <div class="space-y-4">
              <div>
                <label for="area-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Length</label>
                <input id="area-length" type="number" data-area-calculator-target="length" data-action="input->area-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
              </div>
              <div>
                <label for="area-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Width</label>
                <input id="area-width" type="number" data-area-calculator-target="width" data-action="input->area-calculator#calculate" class="w-full" placeholder="5" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Triangle fields %>
          <div data-area-calculator-target="triangleFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-base" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base</label>
                <input id="area-base" type="number" data-area-calculator-target="base" data-action="input->area-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
              </div>
              <div>
                <label for="area-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Height</label>
                <input id="area-height" type="number" data-area-calculator-target="height" data-action="input->area-calculator#calculate" class="w-full" placeholder="6" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Circle fields %>
          <div data-area-calculator-target="circleFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-radius" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Radius</label>
                <input id="area-radius" type="number" data-area-calculator-target="radius" data-action="input->area-calculator#calculate" class="w-full" placeholder="7" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Trapezoid fields %>
          <div data-area-calculator-target="trapezoidFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-base-1" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base 1</label>
                <input id="area-base-1" type="number" data-area-calculator-target="base1" data-action="input->area-calculator#calculate" class="w-full" placeholder="8" step="any" min="0">
              </div>

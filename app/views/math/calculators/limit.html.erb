<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Limit Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Evaluate limits of any function as x approaches a value. Supports two-sided, left-sided, and right-sided limits with real-time numerical computation.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="limit-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-sm font-bold">lim</div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Evaluate lim<sub>x&rarr;a</sub> f(x)</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="limit-expression" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Function f(x)</label>
            <input id="limit-expression" type="text" autocomplete="off" spellcheck="false" data-limit-calculator-target="expression" data-action="input->limit-calculator#calculate" class="w-full font-mono" placeholder="e.g. sin(x)/x" value="sin(x)/x">
          </div>
          <div>
            <label for="limit-approach" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">x approaches</label>
            <input id="limit-approach" type="text" autocomplete="off" data-limit-calculator-target="approach" data-action="input->limit-calculator#calculate" class="w-full font-mono" placeholder="e.g. 0, pi, infinity" value="0">
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1.5">Enter a number, pi, e, infinity, or -infinity.</p>
          </div>
          <div>
            <label for="limit-direction" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Direction</label>
            <select id="limit-direction" data-limit-calculator-target="direction" data-action="change->limit-calculator#calculate" class="w-full">
              <option value="both">Two-sided (both)</option>
              <option value="left">Left-sided (x &rarr; a&minus;)</option>
              <option value="right">Right-sided (x &rarr; a&plus;)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Result</h2>
          <div class="space-y-3">
            <div>
              <span class="text-gray-600 dark:text-gray-400 block text-sm mb-1">Limit</span>
              <span class="text-2xl font-bold text-green-600 dark:text-green-400 break-all" data-limit-calculator-target="result">&mdash;</span>
            </div>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div>
                <span class="text-gray-500 dark:text-gray-400 block">Left limit</span>
                <span class="font-semibold text-gray-900 dark:text-white" data-limit-calculator-target="leftLimit">&mdash;</span>
              </div>
              <div>
                <span class="text-gray-500 dark:text-gray-400 block">Right limit</span>
                <span class="font-semibold text-gray-900 dark:text-white" data-limit-calculator-target="rightLimit">&mdash;</span>

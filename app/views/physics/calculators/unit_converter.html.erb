    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Convert between common units of length, weight, temperature, speed, volume, and area instantly.</p>

    <div data-controller="unit-converter" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Convert Units</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Conversion</label>
          <select data-unit-converter-target="conversion" data-action="change->unit-converter#updateLabels" class="w-full" aria-label="Conversion">
            <optgroup label="Length">
              <option value="m_ft">Meters &rarr; Feet</option>
              <option value="ft_m">Feet &rarr; Meters</option>
              <option value="km_mi">Kilometers &rarr; Miles</option>
              <option value="mi_km">Miles &rarr; Kilometers</option>
              <option value="in_cm">Inches &rarr; Centimeters</option>
              <option value="cm_in">Centimeters &rarr; Inches</option>
              <option value="m_yd">Meters &rarr; Yards</option>
              <option value="yd_m">Yards &rarr; Meters</option>
            </optgroup>
            <optgroup label="Weight">
              <option value="kg_lb">Kilograms &rarr; Pounds</option>
              <option value="lb_kg">Pounds &rarr; Kilograms</option>
              <option value="g_oz">Grams &rarr; Ounces</option>
              <option value="oz_g">Ounces &rarr; Grams</option>
            </optgroup>
            <optgroup label="Speed">
              <option value="kmh_mph">km/h &rarr; mph</option>
              <option value="mph_kmh">mph &rarr; km/h</option>

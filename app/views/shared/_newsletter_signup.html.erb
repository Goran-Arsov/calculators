<%# Newsletter signup CTA — drives return traffic %>
<section class="mt-14 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl border border-blue-100 dark:border-blue-800/30 p-8 md:p-10 text-center">
  <div class="max-w-lg mx-auto">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Get Smarter with Money</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">Free weekly tips on finance, saving, and making better decisions. No spam, unsubscribe anytime.</p>
    <%= form_with model: NewsletterSubscriber.new, url: newsletter_subscribe_path, method: :post, class: "flex flex-col sm:flex-row gap-3" do |f| %>
      <%= f.email_field :email, placeholder: "you@example.com", required: true, class: "flex-1 px-4 py-3 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/40", "aria-label": "Email address" %>
      <button type="submit"
              class="px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl text-sm font-semibold shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        Subscribe
      </button>
    <% end %>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-3">Join 1,000+ readers. We respect your privacy.</p>
  </div>
</section>

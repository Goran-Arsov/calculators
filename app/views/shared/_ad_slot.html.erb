<div class="ad-slot ad-slot--<%= slot %>" data-ad-slot="<%= slot %>">
  <%#
    Uncomment after AdSense approval:

    if slot == "anchor"
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXX"
           data-ad-slot="YYYYYYYY"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    elsif slot == "multiplex"
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXX"
           data-ad-slot="YYYYYYYY"
           data-ad-format="autorelaxed"></ins>
    else
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXX"
           data-ad-slot="YYYYYYYY"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
    end
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  %>
  <% unless slot == "anchor" %>
    <div class="bg-gray-100/50 dark:bg-gray-800/50 rounded-xl p-4 text-center text-xs text-gray-300 dark:text-gray-600 min-h-[90px] flex items-center justify-center border border-dashed border-gray-200 dark:border-gray-700">
      Ad Space
    </div>
  <% end %>
</div>

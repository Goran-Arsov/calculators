<%# Ad slot — renders AdSense unit when enabled, placeholder when not %>
<% above_fold = %w[leaderboard].include?(slot) %>
<% is_anchor = slot == "anchor" %>
<% is_multiplex = slot == "multiplex" %>
<% is_sidebar = slot == "sidebar" %>
<% is_in_results = slot == "in_results" %>
<% is_in_content = slot == "in_content" %>
<%# Hide in_content ads on mobile to prevent excessive ad density
    (leaderboard + in_results already visible in a short scroll) %>
<% mobile_hidden = is_in_content ? "hidden md:block" : "" %>

<%# CLS fix: reserve space for ads before they load %>
<%
  cls_style = if is_sidebar
    "min-height:600px"
  elsif is_multiplex
    "min-height:120px"
  elsif above_fold
    "min-height:90px"
  elsif is_in_results
    "min-height:250px"
  elsif is_in_content
    "min-height:100px"
  else
    "min-height:90px"
  end
%>

<% if adsense_enabled? %>
  <div class="ad-slot ad-slot--<%= slot %> <%= mobile_hidden %>" data-ad-slot="<%= slot %>" data-ad-provider="<%= ad_provider %>" style="<%= cls_style unless is_anchor %>" role="complementary" aria-label="Advertisement">
    <% unless is_anchor %>
      <span class="block text-[10px] text-gray-400 dark:text-gray-600 mb-0.5">Advertisement</span>
    <% end %>
    <ins class="adsbygoogle"
         style="display:block<%= ';min-height:250px' if is_sidebar %>"
         data-ad-client="<%= adsense_pub_id %>"
         data-ad-slot="<%= ad_slot_id(slot) %>"
         <% if is_multiplex %>
           data-ad-format="autorelaxed"
         <% elsif is_anchor %>
           data-ad-format="auto"
           data-full-width-responsive="true"
         <% elsif is_sidebar %>
           data-ad-format="vertical"
         <% elsif is_in_results %>
           data-ad-format="fluid"
           data-ad-layout-key="-gw-3+1f-3d+2z"
         <% else %>
           data-ad-format="auto"
           data-full-width-responsive="true"
         <% end %>
         <% unless above_fold %> loading="lazy"<% end %>></ins>
    <script nonce="<%= content_security_policy_nonce %>">
      <% if above_fold %>
        (adsbygoogle = window.adsbygoogle || []).push({});
      <% else %>
        if ("requestIdleCallback" in window) {
          requestIdleCallback(function() { (adsbygoogle = window.adsbygoogle || []).push({}); });
        } else {
          (adsbygoogle = window.adsbygoogle || []).push({});
        }
      <% end %>
    </script>
  </div>
<% else %>
  <%# Placeholder for development — mimics real ad sizes to test layout %>
  <% unless is_anchor %>
    <div class="ad-slot ad-slot--<%= slot %> <%= mobile_hidden %>" data-ad-slot="<%= slot %>" data-ad-provider="<%= ad_provider %>" style="<%= cls_style %>">
      <div class="bg-gray-100/50 dark:bg-gray-800/30 rounded-xl text-center text-xs text-gray-300 dark:text-gray-600 flex items-center justify-center border border-dashed border-gray-200/60 dark:border-gray-700/60 h-full
        <%= 'p-4 min-h-[90px]' unless is_sidebar || is_multiplex %>
        <%= 'p-4 min-h-[250px]' if is_sidebar %>
        <%= 'p-4 min-h-[120px]' if is_multiplex %>">
        Ad<%= " (#{slot})" %>
      </div>
    </div>
  <% end %>
<% end %>

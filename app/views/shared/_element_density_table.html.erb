<section class="mt-12 pt-8 border-t border-gray-200/80 dark:border-gray-800">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-1.5 h-8 bg-gradient-to-b from-blue-600 to-violet-600 rounded-full"></div>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Element Density Reference Table</h2>
  </div>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Densities at standard conditions (20°C, 1 atm). Gases listed at STP density. Elements 100-118 have no measured density.</p>
  <div class="overflow-x-auto rounded-2xl border border-gray-200/80 dark:border-gray-800">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 dark:bg-gray-800/50">
          <th class="px-3 py-2.5 text-left font-semibold text-gray-600 dark:text-gray-400">Z</th>
          <th class="px-3 py-2.5 text-left font-semibold text-gray-600 dark:text-gray-400">Symbol</th>
          <th class="px-3 py-2.5 text-left font-semibold text-gray-600 dark:text-gray-400">Element</th>
          <th class="px-3 py-2.5 text-right font-semibold text-gray-600 dark:text-gray-400">Density (g/cm³)</th>
          <th class="px-3 py-2.5 text-center font-semibold text-gray-600 dark:text-gray-400">State</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        <% Physics::ElementData::ELEMENTS.each do |el| %>
          <tr class="hover:bg-blue-50/50 dark:hover:bg-blue-900/10 transition-colors">
            <td class="px-3 py-2 text-gray-500 dark:text-gray-400"><%= el[:z] %></td>
            <td class="px-3 py-2 font-semibold text-gray-900 dark:text-white"><%= el[:symbol] %></td>
            <td class="px-3 py-2 text-gray-700 dark:text-gray-300"><%= el[:name] %></td>
            <td class="px-3 py-2 text-right font-mono text-gray-900 dark:text-white">
              <% if el[:density] %>
                <%= el[:density] %>
              <% else %>
                <span class="text-gray-300 dark:text-gray-600">—</span>
              <% end %>
            </td>
            <td class="px-3 py-2 text-center">
              <% case el[:state] %>
              <% when "gas" %>
                <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-sky-100 text-sky-700 dark:bg-sky-900/30 dark:text-sky-400">Gas</span>
              <% when "liquid" %>
                <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">Liquid</span>
              <% when "solid" %>
                <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">Solid</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<%# Calculation history — shows user's recent calculations from localStorage %>
<section class="mt-10" data-controller="calculation-history">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-6 bg-gradient-to-b from-gray-400 to-gray-500 rounded-full"></div>
      <h3 class="text-base font-bold text-gray-900 dark:text-white">Your Recent Calculations</h3>
    </div>
    <button data-action="calculation-history#clearHistory"
            class="text-xs text-gray-400 hover:text-red-500 transition-colors">
      Clear
    </button>
  </div>

  <div data-calculation-history-target="empty" class="hidden text-sm text-gray-500 dark:text-gray-400 text-center py-4">
    No calculations yet. Use any calculator and your results will appear here.
  </div>

  <div data-calculation-history-target="container">
    <div data-calculation-history-target="list" class="space-y-1"></div>
  </div>
</section>

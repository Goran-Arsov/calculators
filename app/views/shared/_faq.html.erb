<%# Renders a visible "Frequently Asked Questions" section from an array of
    { question:, answer: } hashes. Pair with the `faq_schema` helper to emit
    the equivalent JSON-LD — passing the same array to both keeps the visible
    copy and the schema in sync.

    Locals:
      faqs           — array of { question:, answer: } hashes (required)
      heading_level  — top-level heading tag number, default 2
      title          — section title, default "Frequently Asked Questions" %>
<%
  level = local_assigns.fetch(:heading_level, 2)
  heading_title = local_assigns.fetch(:title, "Frequently Asked Questions")
  h_top = "h#{level}"
  h_item = "h#{level + 1}"
%>

<<%= h_top %>><%= heading_title %></<%= h_top %>>

<% faqs.each do |item| %>
  <<%= h_item %>><%= item[:question] %></<%= h_item %>>
  <p><%= item[:answer] %></p>
<% end %>

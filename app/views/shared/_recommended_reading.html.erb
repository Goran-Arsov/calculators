<%# Shows related blog posts on calculator pages — drives pageviews %>
<% if posts.any? %>
  <section class="mt-10 pt-8 border-t border-gray-200/80 dark:border-gray-800">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-1.5 h-8 bg-gradient-to-b from-emerald-500 to-teal-600 rounded-full"></div>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Recommended Reading</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% posts.each do |post| %>
        <%= link_to blog_post_path(post.slug), class: "group bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" do %>
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300"><%= post.category&.capitalize %></span>
          </div>
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug mb-2"><%= post.title %></h3>
          <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2"><%= post.excerpt %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

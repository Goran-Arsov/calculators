<%# Optional "Adjust for inflation" element for time-value calculators.
    Usage: <%= render "shared/inflation_adjustment", controller: "compound-interest-calculator" %>
    Requires the Stimulus controller to declare targets: inflationEnabled, inflationField, inflationRate.
    Off by default — checkbox unchecked, rate field hidden. %>
<div class="border-t border-gray-200 dark:border-gray-800 pt-4">
  <label class="flex items-center gap-2 cursor-pointer select-none">
    <input type="checkbox"
           data-<%= controller %>-target="inflationEnabled"
           data-action="change-><%= controller %>#calculate"
           class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
    <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Adjust for inflation</span>
  </label>
  <div data-<%= controller %>-target="inflationField" hidden class="mt-3">
    <label for="<%= controller %>-inflation-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual inflation rate (%)</label>
    <input id="<%= controller %>-inflation-rate"
           type="number" inputmode="decimal"
           data-<%= controller %>-target="inflationRate"
           data-action="input-><%= controller %>#calculate"
           class="w-full"
           value="3" step="0.1" min="0" placeholder="3.0">
    <p class="text-xs text-gray-500 dark:text-gray-500 mt-1.5">Shows results in today's dollars (real purchasing power).</p>
  </div>
</div>

<%# Show after first calculation — gentle email capture %>
<div data-controller="email-capture" class="hidden mt-6 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-5 border border-blue-100 dark:border-blue-800/50" data-email-capture-target="banner">
  <div class="flex items-start gap-4">
    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center shrink-0">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
    </div>
    <div class="flex-1">
      <p class="font-semibold text-gray-900 dark:text-white text-sm">Save your results & get weekly tips</p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Get calculator tips, formula guides, and financial insights delivered weekly. Join 10,000+ readers.</p>
      <div class="flex gap-2 mt-3">
        <input type="email" placeholder="your@email.com" autocomplete="email" spellcheck="false" class="flex-1 px-3 py-2 text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none" data-email-capture-target="input">
        <button data-action="click->email-capture#subscribe" class="px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all shrink-0">Subscribe</button>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">No spam. Unsubscribe anytime.</p>
    </div>
    <button data-action="click->email-capture#dismiss" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
</div>

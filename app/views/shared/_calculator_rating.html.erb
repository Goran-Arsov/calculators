<%# Star rating widget (0-5) with localStorage persistence and API backend %>
<div class="mt-8 mb-4" data-controller="calculator-rating" data-calculator-rating-slug-value="<%= slug %>">
  <div class="flex flex-col items-center gap-2 bg-gray-50 dark:bg-gray-800/60 rounded-xl px-6 py-4">
    <div class="flex items-center gap-3">
      <span class="text-sm text-gray-600 dark:text-gray-400" data-calculator-rating-target="prompt">Rate this tool</span>
      <%= render "shared/favorite_button", slug: slug, name: slug.titleize + " Calculator", path: request.path %>
    </div>

    <div class="flex items-center gap-1">
      <% (1..5).each do |i| %>
        <button type="button"
                data-calculator-rating-target="star"
                data-score="<%= i %>"
                data-action="click->calculator-rating#rate mouseenter->calculator-rating#hover mouseleave->calculator-rating#unhover"
                class="text-gray-300 dark:text-gray-600 cursor-pointer hover:scale-110 transition-all duration-150"
                aria-label="Rate <%= i %> out of 5">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </button>
      <% end %>
    </div>

    <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
      <span data-calculator-rating-target="average">0.0</span>
      <span>/</span>
      <span>5</span>
      <span class="mx-1">&middot;</span>
      <span data-calculator-rating-target="count">0 ratings</span>
    </div>
  </div>

  <%# Share this calculator %>
  <% share_url = CGI.escape(request.original_url) %>
  <% share_title = CGI.escape(slug.titleize + " Calculator - CalcWise") %>
  <% share_text = CGI.escape("Check out this " + slug.titleize + " Calculator: " + request.original_url) %>
  <div class="mt-4">
    <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider text-center mb-2">Share</p>
    <div class="flex items-center justify-center gap-2 flex-wrap">
      <a href="https://www.facebook.com/sharer/sharer.php?u=<%= share_url %>" target="_blank" rel="noopener noreferrer" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-[#1877F2] bg-[#1877F2]/10 hover:bg-[#1877F2] hover:text-white transition-all duration-200" aria-label="Share on Facebook">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="https://twitter.com/intent/tweet?url=<%= share_url %>&text=<%= share_title %>" target="_blank" rel="noopener noreferrer" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-gray-800 dark:text-gray-200 bg-gray-800/10 dark:bg-white/10 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-200" aria-label="Share on X/Twitter">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://wa.me/?text=<%= share_text %>" target="_blank" rel="noopener noreferrer" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-[#25D366] bg-[#25D366]/10 hover:bg-[#25D366] hover:text-white transition-all duration-200" aria-label="Share on WhatsApp">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <a href="viber://forward?text=<%= share_text %>" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-[#7360F2] bg-[#7360F2]/10 hover:bg-[#7360F2] hover:text-white transition-all duration-200" aria-label="Share on Viber">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.398.002C9.473.028 5.331.344 3.014 2.467 1.294 4.177.518 6.77.382 9.978.246 13.187.01 19.247 5.61 20.79l.002.001v2.39s-.038.97.602 1.169c.777.24 1.23-.5 1.972-1.296.406-.437.965-1.076 1.386-1.566 3.819.322 6.758-.413 7.094-.525.776-.257 5.17-.816 5.886-6.66.74-6.03-.36-9.83-2.34-11.546 0 0-1.537-1.413-5.093-1.621 0 0-.968-.118-2.302-.118-.14 0-.28.001-.42.004z"/></svg>
      </a>
      <a href="https://t.me/share/url?url=<%= share_url %>&text=<%= share_title %>" target="_blank" rel="noopener noreferrer" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-[#26A5E4] bg-[#26A5E4]/10 hover:bg-[#26A5E4] hover:text-white transition-all duration-200" aria-label="Share on Telegram">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
      <a href="mailto:?subject=<%= share_title %>&body=<%= share_text %>" class="w-[60px] h-10 flex items-center justify-center rounded-xl text-red-500 bg-red-500/10 hover:bg-red-500 hover:text-white transition-all duration-200" aria-label="Share via Email">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
    </div>
  </div>

  <%# Embed this calculator on your site %>
  <% category_slug = controller.class.module_parent_name&.downcase rescue nil %>
  <% if category_slug && %w[finance math physics health construction everyday].include?(category_slug) %>
    <% embed_slug = request.path.split("/").last %>
    <%= render "shared/embed_code",
      title: slug.titleize + " Calculator",
      url: calculator_embed_url(category: category_slug, slug: embed_slug) %>
  <% end %>
</div>

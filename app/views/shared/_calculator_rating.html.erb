<%# Calculator rating widget — thumbs up/down with localStorage persistence %>
<div class="mt-6 mb-4" data-controller="calculator-rating" data-calculator-rating-slug-value="<%= slug %>">
  <div class="inline-flex items-center gap-3 bg-gray-100 dark:bg-gray-800/60 rounded-xl px-4 py-2.5">
    <span class="text-sm text-gray-600 dark:text-gray-400" data-calculator-rating-target="prompt">Was this calculator helpful?</span>

    <button type="button"
            data-calculator-rating-target="upButton"
            data-action="calculator-rating#thumbsUp"
            class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-gray-500 dark:text-gray-400 hover:text-green-500 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors disabled:opacity-60 disabled:cursor-default disabled:hover:bg-transparent dark:disabled:hover:bg-transparent"
            aria-label="Thumbs up">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/>
      </svg>
      <span class="text-xs font-medium" data-calculator-rating-target="upCount">0</span>
    </button>

    <button type="button"
            data-calculator-rating-target="downButton"
            data-action="calculator-rating#thumbsDown"
            class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-gray-500 dark:text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors disabled:opacity-60 disabled:cursor-default disabled:hover:bg-transparent dark:disabled:hover:bg-transparent"
            aria-label="Thumbs down">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10zM17 2h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/>
      </svg>
      <span class="text-xs font-medium" data-calculator-rating-target="downCount">0</span>
    </button>
  </div>
</div>

<% cache [CACHE_VERSION, "footer", Date.current.year] do %>
<footer class="bg-white dark:bg-gray-900 border-t border-gray-200/80 dark:border-gray-800 mt-20">
  <!-- Gradient accent line -->
  <div class="h-px bg-gradient-to-r from-transparent via-blue-500 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div>
        <div class="flex items-center space-x-2.5 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-violet-600 rounded-xl flex items-center justify-center shadow-sm">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          </div>
          <span class="text-lg font-bold gradient-text dark:gradient-text-dark">Calc Hammer</span>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Free online calculators for finance, math, health, and more. Fast, accurate, and easy to use.</p>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4">Finance</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Mortgage Calculator", finance_mortgage_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Tax Bracket Calculator", finance_tax_bracket_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Auto Loan Calculator", finance_auto_loan_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Home Affordability", finance_home_affordability_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Credit Card Payoff", finance_credit_card_payoff_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("finance"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4">Math</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Percentage Calculator", math_percentage_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Fraction Calculator", math_fraction_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Area Calculator", math_area_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("math"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>

        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4 mt-8">Physics</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Velocity Calculator", physics_velocity_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Force Calculator", physics_force_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("physics"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>

        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4 mt-8">Health</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "BMI Calculator", health_bmi_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Calorie Calculator", health_calorie_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "TDEE Calculator", health_tdee_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("health"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>

        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4 mt-8">Construction</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Paint Calculator", construction_paint_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Concrete Calculator", construction_concrete_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("construction"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>

        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4 mt-8">Everyday</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Tip Calculator", everyday_tip_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Discount Calculator", everyday_discount_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to category_path("everyday"), class: "inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors group" do %>
            View All
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <% end %></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4">Suites</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Home Buying Suite", suite_home_buying_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Fitness Suite", suite_fitness_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Business Startup Suite", suite_business_startup_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
        </ul>

        <h4 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-widest mb-4 mt-8">Company</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "About", about_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Blog", blog_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Contact", contact_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Privacy Policy", privacy_policy_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Terms of Service", terms_of_service_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
          <li><%= link_to "Disclaimer", disclaimer_path, class: "text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800 text-center text-sm text-gray-400 dark:text-gray-500">
      <p>&copy; <%= Date.current.year %> Calc Hammer. All rights reserved. All calculators are for informational purposes only.</p>
    </div>
  </div>
</footer>
<% end %>

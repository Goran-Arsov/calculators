<footer class="bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">CalcWise</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Free online calculators for finance, math, health, and more. Fast, accurate, and easy to use.</p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Finance</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "Mortgage Calculator", finance_mortgage_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Compound Interest", finance_compound_interest_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Loan Calculator", finance_loan_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Investment Calculator", finance_investment_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "View All Finance →", category_path("finance"), class: "text-blue-600 dark:text-blue-400 font-medium" %></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Math</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "Percentage Calculator", math_percentage_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Fraction Calculator", math_fraction_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Area Calculator", math_area_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "View All Math →", category_path("math"), class: "text-blue-600 dark:text-blue-400 font-medium" %></li>
        </ul>

        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4 mt-6">Health</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "BMI Calculator", health_bmi_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Calorie Calculator", health_calorie_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "View All Health →", category_path("health"), class: "text-blue-600 dark:text-blue-400 font-medium" %></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><%= link_to "About", about_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Blog", blog_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Privacy Policy", privacy_policy_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
          <li><%= link_to "Terms of Service", terms_of_service_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 text-center text-sm text-gray-500 dark:text-gray-400">
      <p>&copy; <%= Date.current.year %> CalcWise. All rights reserved. All calculators are for informational purposes only.</p>
    </div>
  </div>
</footer>

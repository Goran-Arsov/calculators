<%# Social sharing buttons — drives organic traffic %>
<% share_url = CGI.escape(url) %>
<% share_title = CGI.escape(title) %>
<% share_text = CGI.escape("#{title} — #{url}") %>

<div class="flex flex-col items-center gap-2 mt-6">
  <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Share</span>
  <div class="flex gap-2 flex-wrap justify-center">
    <%# Facebook %>
    <a href="https://www.facebook.com/sharer/sharer.php?u=<%= share_url %>"
       target="_blank" rel="noopener noreferrer"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-[#1877F2]/10 text-[#1877F2]/70 hover:bg-[#1877F2]/20 hover:text-[#1877F2] transition-colors"
       aria-label="Share on Facebook">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
    </a>
    <%# Twitter/X %>
    <a href="https://twitter.com/intent/tweet?url=<%= share_url %>&text=<%= share_title %>"
       target="_blank" rel="noopener noreferrer"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-gray-200/60 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-black/10 dark:hover:bg-white/10 hover:text-black dark:hover:text-white transition-colors"
       aria-label="Share on Twitter">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
    </a>
    <%# WhatsApp %>
    <a href="https://wa.me/?text=<%= share_text %>"
       target="_blank" rel="noopener noreferrer"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-[#25D366]/10 text-[#25D366]/70 hover:bg-[#25D366]/20 hover:text-[#25D366] transition-colors"
       aria-label="Share on WhatsApp">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
    </a>
    <%# Viber %>
    <a href="viber://forward?text=<%= share_text %>"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-[#7360F2]/10 text-[#7360F2]/70 hover:bg-[#7360F2]/20 hover:text-[#7360F2] transition-colors"
       aria-label="Share on Viber">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.398.002C9.473.028 5.331.344 3.014 2.467 1.294 4.177.518 6.77.382 9.978.246 13.187.01 19.247 5.61 20.79l.002.001v2.39s-.038.97.602 1.169c.777.24 1.23-.5 1.972-1.296.406-.437.965-1.076 1.386-1.566 3.819.322 6.758-.413 7.094-.525.776-.257 5.17-.816 5.886-6.66.74-6.03-.36-9.83-2.34-11.546 0 0-1.537-1.413-5.093-1.621 0 0-.968-.118-2.302-.118-.14 0-.28.001-.42.004zm.137 1.71c.127-.002.26 0 .396.003 1.15.006 2.005.103 2.005.103 3.05.178 4.228 1.263 4.228 1.263 1.655 1.435 2.632 4.752 1.99 9.967-.6 4.88-4.232 5.272-4.883 5.488-.28.094-2.89.743-6.225.524 0 0-2.464 2.97-3.233 3.744-.12.122-.262.17-.357.146-.132-.035-.168-.19-.166-.42.002-.322.02-4.012.02-4.012C3.122 17.342 3.323 11.85 3.437 9.143c.114-2.707.74-4.89 2.148-6.276C7.393 1.098 10.383.894 11.535.712z" /><path d="M12.196 5.238c-.247-.003-.494.202-.49.535.003.336.248.529.497.532a5.763 5.763 0 014.104 1.725 5.52 5.52 0 011.504 3.156c.038.263.262.447.497.447h.028c.275-.03.479-.272.45-.543a6.583 6.583 0 00-1.792-3.763 6.82 6.82 0 00-4.859-2.088l-.004-.001h.065zm.14 2.097c-.252 0-.498.193-.498.515 0 .28.224.505.478.524a3.15 3.15 0 012.025.862c.498.503.76 1.105.81 1.836.017.275.24.486.512.486h.015c.28-.017.497-.252.48-.53a4.272 4.272 0 00-1.123-2.544 4.233 4.233 0 00-2.7-1.149zm-3.703.88c-.252 0-.515.058-.756.176l-.03.016c-.285.158-.54.36-.712.608-.3.405-.41.884-.34 1.345.224 1.537 1.065 3.246 2.415 4.6 1.788 1.79 3.772 2.84 5.403 3.056h.015c.09.012.18.017.266.017.394 0 .762-.133 1.073-.397.255-.178.463-.444.62-.737l.014-.03c.27-.543.07-1.149-.396-1.42l-1.635-.96c-.36-.213-.818-.13-1.093.162l-.47.451a.46.46 0 01-.414.116s-1.202-.303-2.365-1.463c-1.163-1.16-1.467-2.362-1.467-2.362a.458.458 0 01.115-.412l.453-.47c.292-.273.375-.73.163-1.09l-.96-1.637a1.086 1.086 0 00-.68-.507 1.135 1.135 0 00-.42-.053z" /></svg>
    </a>
    <%# Telegram %>
    <a href="https://t.me/share/url?url=<%= share_url %>&text=<%= share_title %>"
       target="_blank" rel="noopener noreferrer"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-[#26A5E4]/10 text-[#26A5E4]/70 hover:bg-[#26A5E4]/20 hover:text-[#26A5E4] transition-colors"
       aria-label="Share on Telegram">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" /></svg>
    </a>
    <%# LinkedIn %>
    <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= share_url %>"
       target="_blank" rel="noopener noreferrer"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-[#0A66C2]/10 text-[#0A66C2]/70 hover:bg-[#0A66C2]/20 hover:text-[#0A66C2] transition-colors"
       aria-label="Share on LinkedIn">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
    </a>
    <%# Email %>
    <a href="mailto:?subject=<%= share_title %>&body=<%= share_text %>"
       class="w-11 h-11 flex items-center justify-center rounded-lg bg-red-500/10 text-red-500/70 hover:bg-red-500/20 hover:text-red-500 transition-colors"
       aria-label="Share via Email">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
    </a>
    <%# Copy link %>
    <button onclick="navigator.clipboard.writeText('<%= url %>');this.querySelector('svg').classList.add('text-green-500');setTimeout(()=>this.querySelector('svg').classList.remove('text-green-500'),1500)"
            class="w-11 h-11 flex items-center justify-center rounded-lg bg-gray-200/60 dark:bg-gray-700 text-gray-500 dark:text-gray-400 hover:bg-gray-300/60 dark:hover:bg-gray-600 hover:text-gray-700 dark:hover:text-gray-200 transition-colors"
            aria-label="Copy link">
      <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
    </button>
    <%# Share with results — builds URL with current calculator input values %>
    <button onclick="(function(btn){var c=document.querySelector('[data-controller*=calculator]');if(!c)return;var p=new URLSearchParams();c.querySelectorAll('input,select').forEach(function(i){for(var a of i.attributes){if(a.name.endsWith('-target')&&i.value){p.set(a.value,i.value)}}});var u=window.location.origin+window.location.pathname+'?'+p.toString();navigator.clipboard.writeText(u);btn.querySelector('svg').classList.add('text-green-500');setTimeout(function(){btn.querySelector('svg').classList.remove('text-green-500')},1500)})(this)"
            class="w-11 h-11 flex items-center justify-center rounded-lg bg-blue-500/10 text-blue-500/70 hover:bg-blue-500/20 hover:text-blue-500 transition-colors"
            aria-label="Share results link"
            title="Copy link with your inputs">
      <svg class="w-4 h-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
    </button>
  </div>
</div>

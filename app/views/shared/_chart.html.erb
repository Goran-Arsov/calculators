<%# Reusable chart container for calculator visualizations %>
<%# Usage: render "shared/chart", type: "donut", id: "mortgage-breakdown" %>
<div class="mt-6" data-controller="chart" data-chart-type-value="<%= type %>" data-chart-width-value="<%= local_assigns[:width] || 280 %>" data-chart-height-value="<%= local_assigns[:height] || 280 %>">
  <div data-chart-target="canvas" id="<%= local_assigns[:id] || 'chart' %>" class="flex flex-col items-center">
    <div class="w-full max-w-[280px] h-[200px] bg-gray-50 dark:bg-gray-800/50 rounded-xl animate-pulse"></div>
  </div>
</div>

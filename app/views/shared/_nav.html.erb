<% cache [CACHE_VERSION, "nav", request.path] do %>
<nav class="glass dark:glass-dark border-b border-gray-200/50 dark:border-gray-700/50 sticky top-0 z-50 transition-all duration-300" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-16 gap-4">

      <%# Logo (left) %>
      <%= link_to root_path, class: "flex items-center space-x-2 group shrink-0" do %>
        <div class="w-9 h-9 bg-gradient-to-br from-blue-600 to-violet-600 rounded-xl flex items-center justify-center shadow-md shadow-blue-500/20 group-hover:shadow-lg group-hover:shadow-blue-500/30 transition-all duration-300">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <span class="text-xl font-bold gradient-text dark:gradient-text-dark hidden sm:inline">Calc Hammer</span>
      <% end %>

      <%# Search bar (center, grows to fill) %>
      <div class="flex-1 max-w-2xl" data-controller="calculator-search" data-calculator-search-calculators-value="<%= all_calculators_json %>">
        <div class="relative">
          <div class="flex items-center bg-gray-100/80 dark:bg-gray-800/80 rounded-xl border border-gray-200/60 dark:border-gray-700/60 focus-within:ring-2 focus-within:ring-blue-500/40 focus-within:border-blue-400 dark:focus-within:border-blue-500 focus-within:bg-white dark:focus-within:bg-gray-900 transition-all">
            <div class="px-3 flex items-center shrink-0">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <input type="text"
              data-calculator-search-target="input"
              data-action="input->calculator-search#search keydown->calculator-search#keydown"
              class="w-full py-2.5 bg-transparent text-gray-900 dark:text-white text-sm focus:outline-none placeholder-gray-400 dark:placeholder-gray-500"
              placeholder="Search all calculators and tools..."
              autocomplete="off"
              aria-label="Search all calculators and tools"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false">
            <button data-action="click->calculator-search#submitSearch" class="px-3 flex items-center shrink-0 text-gray-400 dark:text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors cursor-pointer" aria-label="Search">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
          </div>
          <%# Dropdown %>
          <div data-calculator-search-target="dropdown" class="hidden absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-900 rounded-2xl border border-gray-200/80 dark:border-gray-800 shadow-xl shadow-black/10 overflow-hidden z-50">
            <div data-calculator-search-target="list" class="max-h-80 overflow-y-auto divide-y divide-gray-100 dark:divide-gray-800"></div>
          </div>
        </div>
      </div>

      <%# Right side: Categories dropdown + Everything button + dark mode %>
      <div class="flex items-center gap-2 shrink-0">

        <%# Categories dropdown (desktop) %>
        <div class="hidden md:block relative" data-navbar-target="categoryDropdown">
          <button data-action="click->navbar#toggleCategories" data-navbar-target="categoriesButton" aria-expanded="false" aria-haspopup="true" class="flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-200">
            Categories
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div data-navbar-target="categoryMenu" role="menu" class="hidden absolute right-0 top-full mt-2 w-56 bg-white dark:bg-gray-900 rounded-xl border border-gray-200/80 dark:border-gray-800 shadow-xl shadow-black/10 overflow-hidden z-50 py-1">
            <%= link_to "Finance", category_path("finance"), role: "menuitem", "aria-current": (request.path.start_with?("/finance") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Math", category_path("math"), role: "menuitem", "aria-current": (request.path.start_with?("/math") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Physics", category_path("physics"), role: "menuitem", "aria-current": (request.path.start_with?("/physics") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Health", category_path("health"), role: "menuitem", "aria-current": (request.path.start_with?("/health") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Construction", category_path("construction"), role: "menuitem", "aria-current": (request.path.start_with?("/construction") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Textile", category_path("textile"), role: "menuitem", "aria-current": (request.path.start_with?("/textile") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Alcohol & Brewing", category_path("alcohol"), role: "menuitem", "aria-current": (request.path.start_with?("/alcohol") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Geography", category_path("geography"), role: "menuitem", "aria-current": (request.path.start_with?("/geography") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "Everyday", category_path("everyday"), role: "menuitem", "aria-current": (request.path.start_with?("/everyday") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <%= link_to "IT Tools", it_tools_path, role: "menuitem", "aria-current": (request.path.start_with?("/it-tools") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
            <div class="border-t border-gray-100 dark:border-gray-800 my-1"></div>
            <%= link_to "Blog", blog_path, role: "menuitem", "aria-current": (request.path.start_with?("/blog") ? "page" : nil), class: "block px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
          </div>
        </div>

        <%# Everything button (desktop) %>
        <%= link_to browse_path, class: "hidden md:inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-sm font-medium bg-gradient-to-r from-blue-600 to-violet-600 text-white hover:from-blue-700 hover:to-violet-700 shadow-sm shadow-blue-500/20 hover:shadow-md transition-all duration-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Everything
        <% end %>

        <%# Locale switcher (desktop, only on translatable pages) %>
        <% if (locale_links = language_switcher).present? %>
          <div class="hidden md:block relative" data-navbar-target="localeDropdown">
            <button data-action="click->navbar#toggleLocale" data-navbar-target="localeButton" aria-expanded="false" aria-haspopup="true" class="flex items-center gap-1 px-2.5 py-2 rounded-lg text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-200">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="uppercase text-xs"><%= (params[:locale] || "en")[0..1] %></span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div data-navbar-target="localeMenu" role="menu" class="hidden absolute right-0 top-full mt-2 w-40 bg-white dark:bg-gray-900 rounded-xl border border-gray-200/80 dark:border-gray-800 shadow-xl shadow-black/10 overflow-hidden z-50 py-1">
              <% locale_links.each do |link| %>
                <a href="<%= link[:path] %>" role="menuitem" class="block px-4 py-2 text-sm <%= link[:current] ? 'text-blue-600 dark:text-blue-400 font-semibold bg-blue-50 dark:bg-blue-900/20' : 'text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400' %> transition-colors"><%= link[:name] %></a>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Dark mode toggle %>
        <button data-controller="dark-mode" data-action="click->dark-mode#toggle" class="p-2.5 rounded-xl text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-700 dark:hover:text-gray-200 transition-all duration-200" aria-label="Toggle dark mode">
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg>
          <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
        </button>

        <%# Mobile menu button %>
        <button data-action="click->navbar#toggleMenu" data-navbar-target="menuButton" aria-expanded="false" aria-controls="mobile-menu" class="md:hidden p-2.5 rounded-xl text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-200" aria-label="Open menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden" data-navbar-target="menu" id="mobile-menu" role="navigation" aria-label="Mobile navigation">
    <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-200/50 dark:border-gray-700/50">
      <%= link_to "Finance", category_path("finance"), "aria-current": (request.path.start_with?("/finance") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Math", category_path("math"), "aria-current": (request.path.start_with?("/math") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Physics", category_path("physics"), "aria-current": (request.path.start_with?("/physics") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Health", category_path("health"), "aria-current": (request.path.start_with?("/health") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Construction", category_path("construction"), "aria-current": (request.path.start_with?("/construction") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Textile", category_path("textile"), "aria-current": (request.path.start_with?("/textile") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Alcohol & Brewing", category_path("alcohol"), "aria-current": (request.path.start_with?("/alcohol") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Geography", category_path("geography"), "aria-current": (request.path.start_with?("/geography") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Everyday", category_path("everyday"), "aria-current": (request.path.start_with?("/everyday") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "IT Tools", it_tools_path, "aria-current": (request.path.start_with?("/it-tools") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <%= link_to "Blog", blog_path, "aria-current": (request.path.start_with?("/blog") ? "page" : nil), class: "block px-4 py-2.5 rounded-xl text-gray-600 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 dark:hover:text-blue-400 font-medium transition-all duration-200" %>
      <div class="border-t border-gray-200/50 dark:border-gray-700/50 pt-2 mt-2">
        <%= link_to browse_path, class: "block px-4 py-2.5 rounded-xl font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 transition-all duration-200" do %>
          Everything
        <% end %>
      </div>
      <% if (mobile_locale_links = language_switcher).present? %>
        <div class="border-t border-gray-200/50 dark:border-gray-700/50 pt-2 mt-2">
          <div class="flex items-center gap-2 px-4 py-1 flex-wrap">
            <svg class="w-4 h-4 text-gray-400 dark:text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <% mobile_locale_links.each do |link| %>
              <% if link[:current] %>
                <span class="text-xs font-bold text-blue-600 dark:text-blue-400 px-2 py-1 bg-blue-50 dark:bg-blue-900/30 rounded-lg"><%= link[:name] %></span>
              <% else %>
                <a href="<%= link[:path] %>" class="text-xs text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 px-2 py-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"><%= link[:name] %></a>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</nav>
<% end %>

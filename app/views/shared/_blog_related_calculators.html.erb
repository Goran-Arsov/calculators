<%# Shows related calculators on blog posts — drives pageviews %>
<% if calculators.any? %>
  <section class="mt-10 pt-8 border-t border-gray-200/80 dark:border-gray-800">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-1.5 h-8 bg-gradient-to-b from-blue-600 to-violet-600 rounded-full"></div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Try These Calculators</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% calculators.each do |calc| %>
        <%= render "shared/calculator_card", calculator: calc %>
      <% end %>
    </div>
  </section>
<% end %>

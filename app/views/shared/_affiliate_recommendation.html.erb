<%# Contextual affiliate recommendations — clearly marked as advertising %>
<% if defined?(recommendations) && recommendations.present? %>
  <aside class="mt-8 bg-amber-50/50 dark:bg-amber-900/10 rounded-2xl p-5 border border-amber-200/50 dark:border-amber-800/30">
    <p class="text-xs font-medium text-amber-700 dark:text-amber-400 uppercase tracking-wider mb-3">Sponsored recommendations</p>
    <div class="space-y-3">
      <% recommendations.each do |rec| %>
        <a href="<%= rec[:url] %>" rel="sponsored nofollow noopener" target="_blank" class="flex items-center gap-3 p-3 bg-white dark:bg-gray-800 rounded-xl hover:shadow-md transition-all group">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-400 to-orange-500 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><%= rec[:title] %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= rec[:description] %></p>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      <% end %>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-3 italic">Calc Hammer may earn a commission from qualifying purchases. This does not affect our calculator results.</p>
  </aside>
<% end %>

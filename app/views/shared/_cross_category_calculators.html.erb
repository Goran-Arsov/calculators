<% calculators = cross_category_calculators(calculator_slug) %>
<% if calculators.any? %>
  <section class="mt-10">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-1 h-6 bg-gradient-to-b from-green-500 to-emerald-600 rounded-full"></div>
      <h2 class="text-lg font-bold text-gray-900 dark:text-white">You Might Also Need</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% calculators.each do |calc| %>
        <%= render "shared/calculator_card", calculator: calc %>
      <% end %>
    </div>
  </section>
<% end %>

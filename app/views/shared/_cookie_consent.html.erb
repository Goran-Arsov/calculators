<%# GDPR Cookie Consent Banner — required for AdSense in EU %>
<div id="cookie-consent"
     class="fixed bottom-0 inset-x-0 z-50 p-4 hidden"
     data-controller="cookie-consent">
  <div class="max-w-4xl mx-auto bg-white dark:bg-gray-900 rounded-2xl shadow-2xl shadow-black/10 border border-gray-200/80 dark:border-gray-800 p-5 md:p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
      We use cookies and similar technologies to serve ads, analyze traffic, and improve your experience.
      By clicking "Accept," you consent to our use of cookies.
      <%= link_to "Privacy Policy", privacy_policy_path, class: "text-blue-600 dark:text-blue-400 underline hover:text-blue-700 dark:hover:text-blue-300" %>.
    </div>
    <div class="flex gap-3 shrink-0">
      <button data-action="click->cookie-consent#reject"
              class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
        Reject
      </button>
      <button data-action="click->cookie-consent#accept"
              class="px-5 py-2 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 rounded-xl shadow-sm transition-all">
        Accept
      </button>
    </div>
  </div>
</div>

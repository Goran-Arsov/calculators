<% cache [CACHE_VERSION, "related", related.map { |c| c[:path] }] do %>
<section class="mt-14 pt-10 border-t border-gray-200/80 dark:border-gray-800">
  <div class="flex items-center gap-3 mb-8">
    <div class="w-1.5 h-8 bg-gradient-to-b from-blue-600 to-violet-600 rounded-full"></div>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Related Calculators</h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <% related.first(6).each do |calc| %>
      <%= render "shared/calculator_card", calculator: calc %>
    <% end %>
  </div>
</section>
<% end %>

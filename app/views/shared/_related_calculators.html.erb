<section class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Related Calculators</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% related.each do |calc| %>
      <%= render "shared/calculator_card", calculator: calc %>
    <% end %>
  </div>
</section>

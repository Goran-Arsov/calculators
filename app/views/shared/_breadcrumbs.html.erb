<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
    <% items.each_with_index do |item, index| %>
      <% if index > 0 %>
        <li class="flex items-center">
          <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
        </li>
      <% end %>
      <li>
        <% if item[:url] && index < items.length - 1 %>
          <%= link_to item[:name], item[:url], class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
        <% else %>
          <span class="text-gray-900 dark:text-white font-medium"><%= item[:name] %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>

      <button data-action="click->pwa-install#install" class="flex-1 px-3 py-2 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl hover:from-blue-700 hover:to-indigo-700 transition-all">
        Install
      </button>
    </div>
  </div>

<%# Comparison table partial — renders a side-by-side feature matrix %>
<%# Usage: render "shared/calculator_comparison",
#     title: "15-Year vs 30-Year Mortgage",
#     options: ["15-Year Fixed", "30-Year Fixed"],
#     features: [
#       { name: "Monthly Payment", values: ["Higher", "Lower"] },
#       { name: "Total Interest", values: ["Much Less", "Much More"] },
#       ...
#     ] %>
<div class="overflow-x-auto mb-8">
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr>
        <th class="text-left p-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 font-semibold text-gray-900 dark:text-white">Feature</th>
        <% options.each do |option| %>
          <th class="text-center p-3 bg-blue-50 dark:bg-blue-900/30 border border-gray-200 dark:border-gray-700 font-semibold text-blue-700 dark:text-blue-300"><%= option %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% features.each_with_index do |feature, i| %>
        <tr class="<%= i.even? ? '' : 'bg-gray-50/50 dark:bg-gray-800/30' %>">
          <td class="p-3 border border-gray-200 dark:border-gray-700 font-medium text-gray-700 dark:text-gray-300"><%= feature[:name] %></td>
          <% feature[:values].each do |value| %>
            <td class="p-3 border border-gray-200 dark:border-gray-700 text-center text-gray-600 dark:text-gray-400"><%= value %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

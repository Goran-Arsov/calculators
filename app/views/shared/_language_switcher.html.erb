<% links = language_switcher %>
<% if links.present? %>
  <div class="flex items-center gap-2 mb-4">
    <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wide"><svg class="inline w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></span>
    <% links.each do |link| %>
      <% if link[:current] %>
        <span class="text-xs font-bold text-blue-600 dark:text-blue-400 px-2 py-1 bg-blue-50 dark:bg-blue-900/30 rounded-lg"><%= link[:name] %></span>
      <% else %>
        <a href="<%= link[:path] %>" class="text-xs text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 px-2 py-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"><%= link[:name] %></a>
      <% end %>
    <% end %>
  </div>
<% end %>

            <label for="ccc-b-name" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">College Name</label>
            <input id="ccc-b-name" type="text" data-college-cost-comparison-calculator-target="collegeBName" data-action="input->college-cost-comparison-calculator#calculate" class="w-full" placeholder="Private University">

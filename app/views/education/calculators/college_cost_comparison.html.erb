            <input id="ccc-b-room" type="number" inputmode="decimal" data-college-cost-comparison-calculator-target="collegeBRoomBoard" data-action="input->college-cost-comparison-calculator#calculate" class="w-full" placeholder="14000" step="500" min="0">
          </div>

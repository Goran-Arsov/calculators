          </div>
          <div>
            <label for="ccc-a-aid" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Financial Aid ($)</label>
            <input id="ccc-a-aid" type="number" inputmode="decimal" data-college-cost-comparison-calculator-target="collegeAAid" data-action="input->college-cost-comparison-calculator#calculate" class="w-full" placeholder="5000" step="500" min="0">

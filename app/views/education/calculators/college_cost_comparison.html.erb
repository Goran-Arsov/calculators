          </div>
          <div>
            <label for="ccc-a-room" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room & Board ($)</label>
            <input id="ccc-a-room" type="number" inputmode="decimal" data-college-cost-comparison-calculator-target="collegeARoomBoard" data-action="input->college-cost-comparison-calculator#calculate" class="w-full" placeholder="10000" step="500" min="0">
          </div>

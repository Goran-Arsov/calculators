<%# SEO meta tags %>
<% set_meta_tags(
  title: "College Cost Comparison Calculator - Compare 4-Year Costs",
  description: "Compare the total 4-year cost of two colleges side by side. Factor in tuition, room and board, fees, financial aid, and annual inflation to find the more affordable option.",
  canonical: education_college_cost_comparison_url,
  og: {
    title: "College Cost Comparison Calculator - Compare 4-Year Costs | Calc Hammer",
    description: "Compare the total 4-year cost of two colleges side by side. Factor in tuition, room and board, fees, financial aid, and annual inflation to find the more affordable option.",
    url: education_college_cost_comparison_url,
    type: "website",
    site_name: "Calc Hammer"
  }
) %>

<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Education", url: category_url("education") },
  { name: "College Cost Comparison Calculator", url: education_college_cost_comparison_url }
]) %>

<%= faq_schema([
  { question: "What costs should I include when comparing colleges?", answer: "Include tuition, mandatory fees, room and board (or estimated living expenses for commuters), books and supplies, transportation, and personal expenses. Subtract any grants, scholarships, and tuition waivers to get the net cost. The federal net price calculator on each college's website provides a personalized estimate." },
  { question: "How does financial aid affect total college cost?", answer: "Financial aid from grants and scholarships directly reduces your out-of-pocket cost each year. Renewable scholarships provide consistent savings across all four years, while one-time awards only reduce costs in the year received. Always check whether aid is guaranteed for all four years or subject to renewal requirements like maintaining a specific GPA." },
  { question: "Why does college cost inflation matter?", answer: "College costs have historically risen 3-5% annually, faster than general inflation. A school charging $30,000 today could cost over $33,000 by your senior year. This calculator adjusts tuition and fees upward each year while keeping financial aid constant, giving you a more realistic total cost estimate." },
  { question: "Should I choose the cheapest college?", answer: "Not necessarily. Consider the return on investment including average starting salaries for graduates, employment rates, program quality, networking opportunities, and quality of life. A slightly more expensive school with better career outcomes may have a higher ROI over a 10-year horizon despite the higher upfront cost." },
  { question: "What is the difference between sticker price and net price?", answer: "Sticker price is the published tuition and fees before any financial aid. Net price is what you actually pay after subtracting grants, scholarships, and education tax benefits. The average student pays significantly less than sticker price, which is why comparing net prices is essential for an accurate cost comparison." }
]) %>

<%= calculator_schema_with_ratings(
  name: "College Cost Comparison Calculator",
  description: "Compare the total 4-year cost of two colleges including tuition, room and board, fees, and financial aid with inflation adjustments.",
  url: education_college_cost_comparison_url,
  category: "FinanceApplication",
  calculator_slug: "college-cost-comparison"
) %>


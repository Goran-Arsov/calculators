            <input id="ct-cost-new" type="number" inputmode="decimal" data-credit-transfer-calculator-target="costPerCreditNew" data-action="input->credit-transfer-calculator#calculate" class="w-full" placeholder="350" step="10" min="0">
          </div>
          <div>
            <label for="ct-per-semester" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Credits per Semester</label>

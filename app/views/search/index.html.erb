<div class="max-w-4xl mx-auto">
  <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">
    <% if @query.present? %>
      Search results for "<%= @query %>"
    <% else %>
      Search calculators
    <% end %>
  </h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8">
    <% if @query.present? %>
      <%= pluralize(@results.size, "calculator") %> matching the name "<%= @query %>".
    <% else %>
      Type a query in the search bar above to find calculators and tools by name.
    <% end %>
  </p>

  <% if @query.present? && @results.any? %>
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200/80 dark:border-gray-800 overflow-hidden">
      <ul class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @results.each do |calc| %>
          <li>
            <%= link_to calc[:path], class: "flex items-center gap-4 px-5 py-4 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors" do %>
              <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-violet-600 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-base font-semibold text-gray-900 dark:text-white truncate"><%= calc[:name] %></div>
                <div class="text-sm text-gray-500 dark:text-gray-400 truncate"><%= calc[:category_title] %></div>
                <% if calc[:description].present? %>
                  <div class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-2"><%= calc[:description] %></div>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% elsif @query.present? %>
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200/80 dark:border-gray-800 p-12 text-center">
      <p class="text-gray-500 dark:text-gray-400 mb-3">No calculators found with "<%= @query %>" in the name.</p>
      <%= link_to "Browse all calculators", browse_path, class: "text-blue-600 dark:text-blue-400 font-medium hover:underline" %>
    </div>
  <% end %>
</div>

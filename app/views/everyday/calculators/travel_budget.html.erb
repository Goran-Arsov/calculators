            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Daily Total (all travelers)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-travel-budget-calculator-target="resultDailyTotal">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 font-semibold">Trip Total</span>
              <span class="text-2xl font-bold text-green-600 dark:text-green-400" data-travel-budget-calculator-target="resultTripTotal">$0.00</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Accommodation (40%)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-travel-budget-calculator-target="resultAccommodation">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Food (25%)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-travel-budget-calculator-target="resultFood">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Transport (15%)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-travel-budget-calculator-target="resultTransport">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Activities (20%)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-travel-budget-calculator-target="resultActivities">$0.00</span>
            </div>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Travel Budget Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate your total trip cost with daily budgets, traveler count, and a category breakdown for smarter travel planning.</p>

    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="travel-budget-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="travel-daily-budget" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Daily Budget Per Person ($)</label>
            <input id="travel-daily-budget" type="number" inputmode="decimal" data-travel-budget-calculator-target="dailyBudget" data-action="input->travel-budget-calculator#calculate" class="w-full" placeholder="150" step="1" min="0">
          </div>
          <div>
            <label for="travel-num-days" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Days</label>
            <input id="travel-num-days" type="number" inputmode="numeric" data-travel-budget-calculator-target="numDays" data-action="input->travel-budget-calculator#calculate" class="w-full" placeholder="7" step="1" min="1">
          </div>
          <div>
            <label for="travel-num-travelers" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Travelers</label>
            <input id="travel-num-travelers" type="number" inputmode="numeric" data-travel-budget-calculator-target="numTravelers" data-action="input->travel-budget-calculator#calculate" class="w-full" placeholder="2" step="1" min="1">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Trip Budget</h2>

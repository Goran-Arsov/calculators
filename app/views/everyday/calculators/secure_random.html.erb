              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="checkbox" checked
                       data-secure-random-calculator-target="includeUppercase"
                       data-action="change->secure-random-calculator#generate"
                       class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500">
                <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Uppercase letters <span class="text-gray-400 dark:text-gray-500">(A-Z)</span></span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="checkbox" checked
                       data-secure-random-calculator-target="includeDigits"
                       data-action="change->secure-random-calculator#generate"
                       class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500">

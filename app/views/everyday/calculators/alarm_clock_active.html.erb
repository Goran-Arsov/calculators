<%# This is a state page (the user lands here when the alarm fires). It has no
    original content and canonicalizes to the main alarm clock page, so tell
    search engines not to index it — otherwise Google reports it as a duplicate
    without a user-selected canonical. %>
<% set_meta_tags(
  title: "Alarm Clock Active",
  canonical: everyday_alarm_clock_url,
  robots: "noindex, follow"
) %>

<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Everyday", url: category_path("everyday") },
  { name: "Alarm Clock", url: everyday_alarm_clock_path },
  { name: "Active Alarm" }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">

    <div data-controller="alarm-clock-active-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">

      <%# Mute button (hidden until alarm is started) %>
      <div class="flex justify-end mb-2">
        <button data-alarm-clock-active-calculator-target="muteBtn" data-action="click->alarm-clock-active-calculator#toggleMute"
          class="hidden text-xs px-3 py-1.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors font-medium">Mute</button>
      </div>

      <%# Reason display (top) — same font as clock %>
      <div class="text-center mb-2">
        <p data-alarm-clock-active-calculator-target="reasonLabel" class="hidden text-[40px] font-mono font-bold text-gray-900 dark:text-white tracking-wider bg-gray-50 dark:bg-gray-800 rounded-xl px-6 py-3 w-full"></p>
        <hr data-alarm-clock-active-calculator-target="reasonHr" class="hidden mt-3 border-gray-200 dark:border-gray-700">
      </div>

      <%# Current time + Alarm time stacked for easy comparison %>
      <div class="flex flex-col items-start mx-auto mb-4 w-fit">
        <div class="text-[32px] font-mono font-bold tracking-wider select-none whitespace-nowrap text-gray-900 dark:text-white flex">
          <span data-alarm-clock-active-calculator-target="clockTime" class="inline-block w-[5.5ch] text-right">00:00</span><span data-alarm-clock-active-calculator-target="clockSeconds" class="inline-block w-[3ch]">:00</span>
          <span data-alarm-clock-active-calculator-target="clockDay" class="ml-8"></span>
        </div>
        <div class="text-[32px] font-mono font-bold tracking-wider whitespace-nowrap text-red-600 dark:text-red-400 flex">
          <span data-alarm-clock-active-calculator-target="alarmTime" class="inline-block w-[5.5ch] text-right"></span><span class="inline-block w-[3ch]"></span>
          <span data-alarm-clock-active-calculator-target="alarmDay" class="ml-8"></span>
        </div>
      </div>

      <%# Progress bar %>
      <div class="mb-4">
        <div data-alarm-clock-active-calculator-target="progressWrap" class="flex flex-col-reverse gap-px w-full rounded-xl overflow-hidden"></div>
        <p data-alarm-clock-active-calculator-target="progressLabel" class="text-base text-gray-900 dark:text-gray-100 mt-1.5 text-center font-semibold"></p>
      </div>

      <%# Set Alarm Time section %>
      <div class="border-t border-gray-200 dark:border-gray-700 pt-6 mb-4">
        <div class="flex items-center justify-center gap-2 mb-5">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white">Set Alarm Time</h2>
        </div>
      </div>

      <%# Time inputs %>
      <div class="grid grid-cols-2 gap-4 max-w-md mx-auto mb-4">
        <div class="text-center">
          <label for="active-alarm-hour" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Hour (0-23)</label>
          <input id="active-alarm-hour" type="number" inputmode="decimal" min="0" max="23" data-alarm-clock-active-calculator-target="hour" class="w-full text-center text-2xl font-mono">
        </div>
        <div class="text-center">
          <label for="active-alarm-minute" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Minute (0-59)</label>
          <input id="active-alarm-minute" type="number" inputmode="decimal" min="0" max="59" data-alarm-clock-active-calculator-target="minute" class="w-full text-center text-2xl font-mono">
        </div>
      </div>

      <%# Day selector %>
      <div class="max-w-md mx-auto mb-4">
        <label for="active-alarm-day" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Day</label>
        <select id="active-alarm-day" data-alarm-clock-active-calculator-target="day" class="w-full text-sm">
          <option value="today">Today</option>
          <option value="tomorrow">Tomorrow</option>
          <option value="monday">Monday</option>
          <option value="tuesday">Tuesday</option>
          <option value="wednesday">Wednesday</option>
          <option value="thursday">Thursday</option>
          <option value="friday">Friday</option>
          <option value="saturday">Saturday</option>
          <option value="sunday">Sunday</option>
        </select>
      </div>

      <%# Reason input %>
      <div class="max-w-md mx-auto mb-6">
        <label for="active-alarm-reason" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Alarm Reason (optional)</label>
        <input id="active-alarm-reason" type="text" data-alarm-clock-active-calculator-target="reason" placeholder="e.g., Wake up, Meeting starts, Lunch break" class="w-full text-sm">
      </div>

      <%# Buttons %>
      <div class="flex items-center justify-center gap-3 max-w-md mx-auto">
        <button data-alarm-clock-active-calculator-target="startBtn" data-action="click->alarm-clock-active-calculator#startAlarm" class="flex-1 px-6 py-3 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-semibold">Start Alarm</button>
        <button data-alarm-clock-active-calculator-target="cancelBtn" data-action="click->alarm-clock-active-calculator#cancel" class="hidden flex-1 px-6 py-3 bg-gradient-to-r from-yellow-500 to-amber-500 hover:from-yellow-600 hover:to-amber-600 text-white rounded-xl shadow-sm shadow-yellow-500/20 hover:shadow-md hover:shadow-yellow-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 text-sm font-semibold">Cancel Alarm</button>
      </div>

      <%# Alarm overlay (hidden until alarm fires) %>
      <div data-alarm-clock-active-calculator-target="alarmOverlay" class="hidden fixed inset-0 z-50 flex flex-col items-center justify-center">
        <p data-alarm-clock-active-calculator-target="alarmText" class="text-6xl md:text-8xl font-extrabold text-white mb-4 drop-shadow-lg">ALARM!</p>
        <p data-alarm-clock-active-calculator-target="reasonDisplay" class="hidden text-2xl md:text-3xl text-white mb-8 drop-shadow-md"></p>
        <button data-alarm-clock-active-calculator-target="stopBtn" data-action="click->alarm-clock-active-calculator#stopAlarm" class="px-8 py-4 bg-white text-red-600 rounded-2xl text-xl font-bold shadow-2xl hover:bg-gray-100 transition-colors duration-200">Stop Alarm</button>
      </div>
    </div>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Color Palette Picker</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Click anywhere on the palette to pick a color. The side panel shows a swatch with HEX, RGB, and HSL codes ready to copy.</p>

    <div data-controller="color-palette-picker-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="flex flex-col md:flex-row gap-6">

        <%# Palette canvas %>
        <div class="flex-1 relative">
          <canvas data-color-palette-picker-calculator-target="canvas"
                  data-action="click->color-palette-picker-calculator#pick"
                  width="600" height="300"
                  class="w-full rounded-xl cursor-crosshair border border-gray-200 dark:border-gray-700"
                  style="image-rendering: auto;"></canvas>
          <%# Crosshair indicator %>
          <div data-color-palette-picker-calculator-target="crosshair"
               class="hidden absolute w-6 h-6 -ml-3 -mt-3 pointer-events-none rounded-full border-2 border-white shadow-lg"
               style="box-shadow: 0 0 0 1px rgba(0,0,0,0.3), 0 2px 8px rgba(0,0,0,0.3);"></div>
        </div>

        <%# Side panel %>
        <div data-color-palette-picker-calculator-target="sidebar"
             class="hidden w-full md:w-56 shrink-0 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-5 transition-all duration-200">

          <%# Color swatch %>

               class="w-full h-28 rounded-xl border border-gray-200 dark:border-gray-700 mb-5 shadow-inner"
               style="background-color: #ffffff;"></div>

          <%# HEX %>
          <div class="mb-3">
            <div class="flex justify-between items-center mb-1">
              <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">HEX</span>
              <button data-action="click->color-palette-picker-calculator#copyHex"
                      class="text-xs px-2 py-0.5 bg-white dark:bg-gray-700 text-blue-600 dark:text-blue-400 rounded-md hover:bg-blue-50 dark:hover:bg-gray-600 transition-colors font-medium border border-gray-200 dark:border-gray-600">
                Copy
              </button>
            </div>
            <p class="font-mono text-lg font-bold text-gray-900 dark:text-white" data-color-palette-picker-calculator-target="hexValue">--</p>
          </div>

          <%# RGB %>
          <div class="mb-3">
            <div class="flex justify-between items-center mb-1">
              <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">RGB</span>
              <button data-action="click->color-palette-picker-calculator#copyRgb"
                      class="text-xs px-2 py-0.5 bg-white dark:bg-gray-700 text-blue-600 dark:text-blue-400 rounded-md hover:bg-blue-50 dark:hover:bg-gray-600 transition-colors font-medium border border-gray-200 dark:border-gray-600">
                Copy

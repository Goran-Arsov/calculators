<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">API Rate Limit Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate requests per second, daily quotas, usage percentage, and safe request rates from your API rate limit.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="api-rate-limit-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Rate Limit (requests)</label>
            <input type="number" inputmode="numeric" data-api-rate-limit-calculator-target="rateLimit" data-action="input->api-rate-limit-calculator#calculate" class="w-full" placeholder="1000" min="1">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Window (seconds)</label>
            <input type="number" inputmode="numeric" data-api-rate-limit-calculator-target="windowSeconds" data-action="input->api-rate-limit-calculator#calculate" class="w-full" placeholder="3600" min="1">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current Usage (requests used)</label>
            <input type="number" inputmode="numeric" data-api-rate-limit-calculator-target="currentUsage" data-action="input->api-rate-limit-calculator#calculate" class="w-full" placeholder="0" min="0" value="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Burst Limit <span class="text-gray-400 font-normal">(optional)</span></label>
            <input type="number" inputmode="numeric" data-api-rate-limit-calculator-target="burstLimit" data-action="input->api-rate-limit-calculator#calculate" class="w-full" placeholder="50" min="0">
          </div>
        </div>

        <div aria-live="polite" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Requests/sec</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultRps">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Requests/min</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultRpm">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Requests/hour</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultRph">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Requests/day</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultRpd">-</span></div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Remaining</span><span class="font-bold text-green-600 dark:text-green-400" data-api-rate-limit-calculator-target="resultRemaining">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Usage</span><span class="font-bold text-amber-600 dark:text-amber-400" data-api-rate-limit-calculator-target="resultUsage">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Min interval</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultTimePerReq">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Time until reset</span><span class="font-bold text-blue-600 dark:text-blue-400" data-api-rate-limit-calculator-target="resultReset">-</span></div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Safe rate (80%)</span><span class="font-bold text-green-600 dark:text-green-400" data-api-rate-limit-calculator-target="resultSafeRps">-</span></div>
            <div class="flex justify-between hidden" data-burst-row><span class="text-gray-600 dark:text-gray-400">Burst</span><span class="font-bold text-purple-600 dark:text-purple-400" data-api-rate-limit-calculator-target="resultBurst">-</span></div>
          </div>
          <button data-action="click->api-rate-limit-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm text-sm font-medium transition-all duration-200">Copy Results</button>
        </div>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Image Resizer</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Resize images directly in your browser. Upload an image, set new dimensions, choose a format and quality level, then download the resized result. No server upload needed.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="image-resizer-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="space-y-6">
        <%# File upload %>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Upload Image</label>
          <input type="file" accept="image/*" data-image-resizer-calculator-target="fileInput"
                 data-action="change->image-resizer-calculator#loadImage"
                 class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 dark:file:bg-blue-900/30 dark:file:text-blue-400 hover:file:bg-blue-100">
        </div>

        <%# Original preview %>
        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Original Image</h3>
          <div data-image-resizer-calculator-target="originalPreview"
               class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 min-h-[8rem] flex items-center justify-center text-gray-400 dark:text-gray-500">
            <span>Upload an image to see preview</span>
          </div>
          <div data-image-resizer-calculator-target="originalInfo" class="mt-2"></div>
        </div>

        <%# Dimension inputs %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="img-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Width (px)</label>
            <input id="img-width" type="number" min="1" max="10000" data-image-resizer-calculator-target="widthInput"
                   data-action="input->image-resizer-calculator#updateWidth"
                   class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                   placeholder="800" autocomplete="off">
          </div>
          <div>
            <label for="img-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Height (px)</label>
            <input id="img-height" type="number" min="1" max="10000" data-image-resizer-calculator-target="heightInput"
                   data-action="input->image-resizer-calculator#updateHeight"
                   class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                   placeholder="600" autocomplete="off">
          </div>
        </div>

        <%# Aspect ratio checkbox %>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="img-aspect" data-image-resizer-calculator-target="aspectRatioCheckbox" checked
                 class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500 w-4 h-4">
          <label for="img-aspect" class="text-sm font-semibold text-gray-600 dark:text-gray-400 cursor-pointer">Maintain aspect ratio</label>
        </div>

        <%# Quality slider and format %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="img-quality" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Quality: <span data-image-resizer-calculator-target="qualityValue">85</span>%</label>
            <input id="img-quality" type="range" min="1" max="100" value="85" data-image-resizer-calculator-target="qualitySlider"
                   data-action="input->image-resizer-calculator#updateQualityDisplay"
                   class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-lg appearance-none cursor-pointer accent-blue-600">
          </div>
          <div>
            <label for="img-format" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Output Format</label>
            <select id="img-format" data-image-resizer-calculator-target="formatSelect"
                    class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <option value="png">PNG</option>
              <option value="jpeg">JPEG</option>
              <option value="webp">WebP</option>
            </select>
          </div>
        </div>

        <%# Resize button %>
        <button data-action="click->image-resizer-calculator#resize"
                class="w-full px-4 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-semibold">
          Resize Image
        </button>

        <%# Resized preview %>
        <div>
          <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Resized Image</h3>
          <div data-image-resizer-calculator-target="resizedPreview"
               class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 min-h-[8rem] flex items-center justify-center text-gray-400 dark:text-gray-500">
            <span>Resized image will appear here</span>
          </div>
          <div data-image-resizer-calculator-target="resizedInfo" class="mt-2"></div>
        </div>

        <%# Download button %>
        <button data-action="click->image-resizer-calculator#download" data-image-resizer-calculator-target="downloadBtn"
                class="hidden w-full px-4 py-3 bg-green-600 hover:bg-green-700 text-white rounded-xl shadow-sm transition-colors text-sm font-semibold">
          Download Resized Image
        </button>
      </div>
    </div>


            <label for="cost-per-km-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (km)</label>
            <input id="cost-per-km-distance" type="number" inputmode="decimal" data-cost-per-km-calculator-target="distance" data-action="input->cost-per-km-calculator#calculate" class="w-full" placeholder="500" step="0.1" min="0">
          </div>
          <div>
            <label for="cost-per-km-fuel-used" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Used (liters)</label>
            <input id="cost-per-km-fuel-used" type="number" inputmode="decimal" data-cost-per-km-calculator-target="fuelUsed" data-action="input->cost-per-km-calculator#calculate" class="w-full" placeholder="40" step="0.1" min="0">
          </div>
          <div>
            <label for="cost-per-km-fuel-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Price ($/liter)</label>

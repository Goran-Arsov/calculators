              <span class="text-sm text-gray-600 dark:text-gray-400">Cost per km</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-cost-per-km-calculator-target="costPerKm">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost per mile</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-per-km-calculator-target="costPerMile">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Total fuel cost</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-per-km-calculator-target="totalFuelCost">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Distance (miles)</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-per-km-calculator-target="distanceMiles">&mdash;</span>

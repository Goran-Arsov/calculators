<%# SEO meta tags %>
<% set_meta_tags(
  title: "Lorem Ipsum Generator - Free Online Tool",
  description: "Generate lorem ipsum placeholder text by paragraphs, sentences, or words. Copy generated text instantly. Free online lorem ipsum generator.",
  canonical: everyday_lorem_ipsum_url,
  og: {
    title: "Lorem Ipsum Generator - Free Online Tool | CalcWise",
    description: "Generate lorem ipsum placeholder text by paragraphs, sentences, or words. Customize the amount and copy with one click.",
    url: everyday_lorem_ipsum_url,
    type: "website",
    site_name: "CalcWise"
  }
) %>

<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Everyday", url: category_url("everyday") },
  { name: "Lorem Ipsum Generator", url: everyday_lorem_ipsum_url }
]) %>

<%= faq_schema([
  { question: "What is Lorem Ipsum?", answer: "Lorem Ipsum is placeholder text used in the printing and typesetting industry since the 1500s. It is derived from a Latin text by Cicero written in 45 BC called 'de Finibus Bonorum et Malorum'. It has been the industry standard for placeholder text because it has a roughly normal distribution of letters and words, making it look like readable English." },
  { question: "Why use Lorem Ipsum instead of real text?", answer: "Lorem Ipsum is used because it allows designers and developers to focus on visual design and layout without being distracted by readable content. If real text were used, reviewers would focus on the content rather than the design. Lorem Ipsum provides a natural-looking text distribution that mimics real content without conveying meaning." },
  { question: "How many words are in a paragraph of Lorem Ipsum?", answer: "A standard Lorem Ipsum paragraph contains approximately 40 to 80 words, depending on the generator. Our tool generates paragraphs with 4 to 8 sentences, with each sentence containing 8 to 16 words. This produces paragraphs that closely resemble natural English writing patterns." },
  { question: "Can I use Lorem Ipsum in production?", answer: "Lorem Ipsum is intended for design mockups and prototypes only. You should never ship Lorem Ipsum text in a production website or application. Always replace placeholder text with real content before publishing. Having a process to check for remaining placeholder text before launch is a good practice." },
  { question: "Are there alternatives to Lorem Ipsum?", answer: "Yes, there are many alternatives including Hipster Ipsum, Bacon Ipsum, Cupcake Ipsum, and other themed generators. Some designers prefer using real content from the start to design for actual text lengths and reading flow. However, Lorem Ipsum remains the most widely used and recognized placeholder text in the industry." }
]) %>

<%= calculator_schema(
  name: "Lorem Ipsum Generator",
  description: "Generate lorem ipsum placeholder text by paragraphs, sentences, or words with word count and copy functionality.",
  url: everyday_lorem_ipsum_url,
  category: "UtilityApplication"
) %>

<%# Breadcrumbs %>
<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Everyday", url: category_path("everyday") },
  { name: "Lorem Ipsum Generator" }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Lorem Ipsum Generator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Generate lorem ipsum placeholder text by paragraphs, sentences, or words. Perfect for mockups and prototypes.</p>

    <div data-controller="lorem-ipsum-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Count</label>
            <input type="number" data-lorem-ipsum-calculator-target="count" data-action="input->lorem-ipsum-calculator#calculate"
              class="w-full" value="3" min="1" max="100" step="1">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit</label>
            <select data-lorem-ipsum-calculator-target="unit" data-action="change->lorem-ipsum-calculator#calculate"
              class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-2.5 text-sm">
              <option value="paragraphs">Paragraphs</option>
              <option value="sentences">Sentences</option>
              <option value="words">Words</option>
            </select>
          </div>
          <div class="flex items-end">
            <div class="w-full bg-gray-50 dark:bg-gray-800 rounded-xl p-3 text-center">
              <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Word Count</span>
              <div class="text-lg font-bold text-blue-600 dark:text-blue-400" data-lorem-ipsum-calculator-target="resultWordCount">&mdash;</div>
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Generated Text</label>
          <textarea data-lorem-ipsum-calculator-target="output" readonly
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white p-3 text-sm"
            rows="10" placeholder="Click Generate or adjust settings to create lorem ipsum text..."></textarea>
        </div>

        <button data-action="click->lorem-ipsum-calculator#copy" class="w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Text</button>
      </div>
    </div>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>

    <article class="prose dark:prose-invert max-w-none">
      <h2>How to Use the Lorem Ipsum Generator</h2>
      <p>
        Select how many paragraphs, sentences, or words you need and the generator creates lorem ipsum placeholder text instantly. The word count is displayed automatically so you know exactly how much text you have generated. Click the copy button to copy the text to your clipboard and paste it directly into your design tool, CMS, or code editor.
      </p>
      <p>
        The generator uses a vocabulary derived from the classical Lorem Ipsum text with additional Latin words for variety. Each paragraph contains 4 to 8 sentences, and each sentence contains 8 to 16 words with proper capitalization and punctuation. The text is shuffled each time to provide unique output for every generation.
      </p>

      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <h2>The History of Lorem Ipsum</h2>
      <p>
        Lorem Ipsum has been the industry standard placeholder text since the 1500s when an unknown printer took a galley of type and scrambled it to make a type specimen book. The text is derived from sections 1.10.32 and 1.10.33 of "de Finibus Bonorum et Malorum" (The Extremes of Good and Evil) by Cicero, written in 45 BC. Richard McClintock, a Latin professor at Hampden-Sydney College in Virginia, discovered the source in 1982.
      </p>

      <h3>When to Use Placeholder Text</h3>
      <p>
        Use Lorem Ipsum during the wireframing and mockup phase of design when final content is not yet available. It helps designers and stakeholders evaluate layout, typography, spacing, and visual hierarchy without the distraction of reading actual content. Replace all placeholder text with real content before any design is finalized or published.
      </p>

      <h3>How Much Text to Generate</h3>
      <p>
        For a typical blog post layout, generate 3 to 5 paragraphs. For a product description, 1 to 2 paragraphs work well. For testing responsive typography, generate a variety of lengths. For filling a complete page layout, 5 to 10 paragraphs provide enough content to evaluate scroll behavior and content flow. Match your generated text length to the expected length of real content for the most accurate design preview.
      </p>

      <h2>Frequently Asked Questions</h2>

      <h3>What is Lorem Ipsum?</h3>
      <p>Placeholder text derived from a 45 BC Latin work by Cicero. It has been the industry standard since the 1500s.</p>

      <h3>Why use Lorem Ipsum instead of real text?</h3>
      <p>It lets designers focus on layout and visual design without readers being distracted by content meaning.</p>

      <h3>How many words are in a paragraph?</h3>
      <p>Our generator produces paragraphs with 4-8 sentences of 8-16 words each, averaging 40-80 words per paragraph.</p>

      <h3>Can I use Lorem Ipsum in production?</h3>
      <p>No. Always replace placeholder text with real content before publishing. Lorem Ipsum is for design and development only.</p>

      <h3>Is the generated text random?</h3>
      <p>The words are shuffled from a Latin vocabulary for each generation, so every output is unique while maintaining a natural appearance.</p>

    <%# Social sharing %>
    <%= render "shared/social_share", title: "Lorem Ipsum Generator", url: everyday_lorem_ipsum_url %>
    </article>

    <%= render "shared/related_calculators", related: [
      { name: "Word Counter", description: "Count words, sentences, paragraphs with reading and speaking time estimates.", path: everyday_word_counter_path, icon_path: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
      { name: "Character Counter", description: "Detailed character analysis with letter, digit, and special character counts.", path: everyday_character_counter_path, icon_path: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
      { name: "Markdown Preview", description: "Write markdown and see a live HTML preview with formatting applied.", path: everyday_markdown_preview_path, icon_path: "M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" }
    ] %>

    <%= render "shared/calculator_disclaimer", category: "everyday" %>

    <% blog_posts = related_blog_posts("lorem-ipsum-generator") %>
    <%= render "shared/recommended_reading", posts: blog_posts if blog_posts.any? %>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

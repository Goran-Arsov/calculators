              <span class="text-lg font-bold text-rose-600 dark:text-rose-400" data-price-per-weight-calculator-target="pricePerKg">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Per lb</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-price-per-weight-calculator-target="pricePerLb">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Per 100g</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-price-per-weight-calculator-target="pricePer100g">&mdash;</span>
            </div>

              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-weight-converter-calculator-target="resultG">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Kilograms (kg)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-weight-converter-calculator-target="resultKg">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Tonnes (t)</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-weight-converter-calculator-target="resultTonne">--</span>
            </div>
            <div class="flex justify-between items-center">

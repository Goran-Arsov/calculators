<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Weight Converter</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Enter a weight value and select the unit to see instant conversions across all 7 weight units -- metric and imperial.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>

        </div>

        <p data-regex-tester-calculator-target="resultError" class="hidden text-sm text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded-xl p-3"></p>

        <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4">

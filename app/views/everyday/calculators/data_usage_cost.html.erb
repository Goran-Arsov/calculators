            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Unused Value</span>
              <span class="text-lg font-bold text-amber-600 dark:text-amber-400" data-data-usage-cost-calculator-target="unusedDataValue">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Total Cost</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-data-usage-cost-calculator-target="totalCost">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Effective $/GB</span>
              <span class="text-lg font-bold text-green-600 dark:text-green-400" data-data-usage-cost-calculator-target="effectiveCostPerGb">&mdash;</span>
            </div>
          </div>
          <button data-action="click->data-usage-cost-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-cyan-600 to-teal-600 hover:from-cyan-700 hover:to-teal-700 text-white rounded-xl shadow-sm shadow-cyan-500/20 hover:shadow-md hover:shadow-cyan-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Data Usage Cost Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Analyze your data plan's true cost per GB, overage charges, and unused data value to optimize your mobile spending.</p>

    <div data-controller="data-usage-cost-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Plan Size (GB)</label>
            <input type="number" data-data-usage-cost-calculator-target="planSize" data-action="input->data-usage-cost-calculator#calculate" class="w-full" placeholder="20" step="0.1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Plan Cost ($)</label>
            <input type="number" data-data-usage-cost-calculator-target="planCost" data-action="input->data-usage-cost-calculator#calculate" class="w-full" placeholder="50" step="0.01" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Actual Usage (GB)</label>
            <input type="number" data-data-usage-cost-calculator-target="actualUsage" data-action="input->data-usage-cost-calculator#calculate" class="w-full" placeholder="15" step="0.1" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Overage Rate ($/GB)</label>
            <input type="number" data-data-usage-cost-calculator-target="overageRate" data-action="input->data-usage-cost-calculator#calculate" class="w-full" placeholder="10" step="0.01" min="0" value="0">
          </div>
        </div>
        <div class="bg-gradient-to-br from-cyan-50 to-teal-50 dark:from-cyan-900/20 dark:to-teal-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Data Cost Analysis</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost per GB</span>
              <span class="text-lg font-bold text-cyan-600 dark:text-cyan-400" data-data-usage-cost-calculator-target="costPerGb">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Usage</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-data-usage-cost-calculator-target="usagePercentage">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Overage</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-data-usage-cost-calculator-target="overageGb">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Overage Cost</span>
              <span class="text-lg font-bold text-red-600 dark:text-red-400" data-data-usage-cost-calculator-target="overageCost">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">

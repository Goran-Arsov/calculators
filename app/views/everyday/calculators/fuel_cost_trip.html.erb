              <option value="mpg">MPG (US)</option>
              <option value="km_per_l">km/L</option>
            </select>
          </div>
          <div>
            <label for="fuel-cost-trip-fuel-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Price</label>
            <input id="fuel-cost-trip-fuel-price" type="number" data-fuel-cost-trip-calculator-target="fuelPrice" data-action="input->fuel-cost-trip-calculator#calculate" class="w-full" placeholder="1.50" step="0.01" min="0">
          </div>
          <div>
            <label for="fuel-cost-trip-price-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price Unit</label>
            <select id="fuel-cost-trip-price-unit" data-fuel-cost-trip-calculator-target="priceUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Price unit">

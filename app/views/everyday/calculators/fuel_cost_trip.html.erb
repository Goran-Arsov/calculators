          </div>
          <div>
            <label for="fuel-cost-trip-distance-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance Unit</label>
            <select id="fuel-cost-trip-distance-unit" data-fuel-cost-trip-calculator-target="distanceUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Distance unit">
              <option value="km" selected>Kilometers</option>
              <option value="miles">Miles</option>
            </select>
          </div>
          <div>
            <label for="fuel-cost-trip-fuel-efficiency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Efficiency</label>
            <input id="fuel-cost-trip-fuel-efficiency" type="number" data-fuel-cost-trip-calculator-target="fuelEfficiency" data-action="input->fuel-cost-trip-calculator#calculate" class="w-full" placeholder="8" step="0.1" min="0">
          </div>
          <div>
            <label for="fuel-cost-trip-efficiency-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Efficiency Unit</label>
            <select id="fuel-cost-trip-efficiency-unit" data-fuel-cost-trip-calculator-target="efficiencyUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Efficiency unit">

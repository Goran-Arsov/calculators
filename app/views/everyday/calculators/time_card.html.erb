<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Everyday", url: category_url("everyday") },
  { name: "Time Card Calculator", url: everyday_time_card_url }
]) %>

<%= faq_schema([
  { question: "How do I calculate hours worked from a time card?", answer: "Enter your clock-in time and clock-out time. The calculator subtracts the start from the end to get your total time on-site. If you had an unpaid break, enter the break duration in minutes and it will be deducted to give you your actual hours worked. Multiply by your hourly rate to get your gross pay." },
  { question: "Does the calculator work for overnight shifts?", answer: "Yes. If your clock-out time is earlier than your clock-in time (for example, clocking in at 11 PM and out at 7 AM), the calculator detects the overnight shift and correctly calculates 8 hours instead of a negative number." },
  { question: "How is the weekly projection calculated?", answer: "The weekly projection multiplies your daily hours worked and daily gross pay by 5 (a standard 5-day work week). This gives you an estimate of your weekly earnings if you work the same schedule every weekday. Adjust mentally for weeks where you work more or fewer days." },
  { question: "Should I include paid breaks in the break minutes?", answer: "No, only enter unpaid break time. Paid breaks (like 10- or 15-minute rest breaks) are compensated time and should not be deducted from your hours worked. Typically, only meal breaks of 30 minutes or longer are unpaid, but this varies by employer and state law." },
  { question: "How do I verify my paycheck with this calculator?", answer: "Enter your exact clock-in and clock-out times for each day, deduct your unpaid breaks, and note the hours worked. Sum the hours across all days in the pay period and multiply by your hourly rate. Compare this gross pay figure with your paycheck stub gross pay to identify any discrepancies." }
]) %>

<%= calculator_schema(
  name: "Time Card Calculator",
  description: "Calculate hours worked and gross pay from clock-in and clock-out times with break deductions and weekly projections.",
  url: everyday_time_card_url,
  category: "UtilitiesApplication"
) %>

<%# Breadcrumbs %>
<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Everyday", url: category_path("everyday") },
  { name: "Time Card Calculator" }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Time Card Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your hours worked, gross pay, and weekly projection from clock-in/out times, break duration, and hourly rate.</p>

    <div data-controller="time-card-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="time-card-clock-in" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Clock In</label>
            <input id="time-card-clock-in" type="time" data-time-card-calculator-target="clockIn" data-action="input->time-card-calculator#calculate" class="w-full">
          </div>
          <div>
            <label for="time-card-clock-out" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Clock Out</label>
            <input id="time-card-clock-out" type="time" data-time-card-calculator-target="clockOut" data-action="input->time-card-calculator#calculate" class="w-full">
          </div>
          <div>
            <label for="time-card-break" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Break (minutes)</label>
            <input id="time-card-break" type="number" data-time-card-calculator-target="breakMinutes" data-action="input->time-card-calculator#calculate" class="w-full" value="30" min="0" step="5">
          </div>
          <div>
            <label for="time-card-hourly-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Hourly Rate ($)</label>
            <input id="time-card-hourly-rate" type="number" data-time-card-calculator-target="hourlyRate" data-action="input->time-card-calculator#calculate" class="w-full" placeholder="15.00" step="0.01" min="0">
          </div>
        </div>
        <div class="bg-gradient-to-br from-indigo-50 to-violet-50 dark:from-indigo-900/20 dark:to-violet-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Time Card Summary</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Hours Worked</span>
              <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400" data-time-card-calculator-target="resultHoursWorked">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Minutes</span>
              <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400" data-time-card-calculator-target="resultTotalMinutes">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Gross Pay</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-time-card-calculator-target="resultGrossPay">&mdash;</span>
            </div>
            <div class="flex justify-between items-center border-t border-gray-200 dark:border-gray-700 pt-3">
              <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Weekly Hours</span>
              <span class="text-lg font-bold text-indigo-600 dark:text-indigo-400" data-time-card-calculator-target="resultWeeklyHours">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Weekly Pay</span>
              <span class="text-lg font-bold text-green-600 dark:text-green-400" data-time-card-calculator-target="resultWeeklyPay">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Overnight?</span>
              <span class="text-lg font-bold text-indigo-600 dark:text-indigo-400" data-time-card-calculator-target="resultOvernight">&mdash;</span>
            </div>
          </div>
          <button data-action="click->time-card-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white rounded-xl shadow-sm shadow-indigo-500/20 hover:shadow-md hover:shadow-indigo-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>

    <article class="prose dark:prose-invert max-w-none">
      <h2>How to Use the Time Card Calculator</h2>
      <p>
        Enter your clock-in and clock-out times using the time pickers, then specify your break duration in minutes and your hourly rate. The calculator instantly computes your hours worked (after break deduction), gross pay for the day, and projects your weekly hours and pay assuming a 5-day schedule. If your shift spans midnight, the calculator automatically detects the overnight crossing and calculates correctly.
      </p>
      <p>
        This tool replaces manual time card calculations that are prone to arithmetic errors, especially when dealing with odd shift lengths or overnight hours. By entering your exact times and break, you get a precise calculation that you can compare against your paycheck to ensure accuracy.
      </p>

      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <h2>Understanding Time Card Calculations</h2>
      <p>
        A time card records when you start and stop working. The basic calculation is simple: subtract clock-in from clock-out, then subtract unpaid breaks. The result is your hours worked for the day. Multiply by your hourly rate to get gross pay before taxes and deductions. The complexity arises with overnight shifts, varying break rules, and rounding policies that differ between employers.
      </p>

      <h3>Common Time Card Rounding</h3>
      <p>
        Some employers round clock times to the nearest quarter hour (15 minutes), tenth of an hour (6 minutes), or even half hour. For example, clocking in at 8:07 AM might be rounded to 8:00 AM or 8:15 AM depending on the policy. This calculator uses exact times without rounding, giving you a precise baseline that you can then adjust based on your employer's rounding rules.
      </p>

      <h3>Verifying Your Paycheck</h3>
      <p>
        To verify your paycheck, use this calculator for each day in the pay period, note the daily hours worked, and sum them. Compare the total hours and gross pay against your pay stub. Common discrepancies arise from rounding differences, incorrect break deductions, or missed clock punches. Keeping your own time card records helps resolve disputes quickly and ensures you are paid for all time worked.
      </p>

      <h2>Frequently Asked Questions</h2>

      <h3>How do I calculate hours worked from a time card?</h3>
      <p>
        Enter your clock-in time and clock-out time. The calculator subtracts the start from the end to get your total time. If you had an unpaid break, enter the duration and it will be deducted to give you actual hours worked.
      </p>

      <h3>Does the calculator work for overnight shifts?</h3>
      <p>
        Yes. If your clock-out time is earlier than your clock-in time, the calculator detects the overnight shift and correctly calculates the duration across midnight.
      </p>

      <h3>How is the weekly projection calculated?</h3>
      <p>
        The weekly projection multiplies your daily hours and gross pay by 5 (a standard work week). Adjust for weeks where you work more or fewer days.
      </p>

      <h3>Should I include paid breaks in the break minutes?</h3>
      <p>
        No, only enter unpaid break time. Paid breaks are compensated time and should not be deducted from your hours worked.
      </p>

      <h3>How do I verify my paycheck with this calculator?</h3>
      <p>
        Enter your exact times for each day, deduct unpaid breaks, and sum the hours across the pay period. Compare the total gross pay with your pay stub to identify discrepancies.
      </p>

    <%= render "shared/print_button" %>


      { name: "Date Difference Calculator", description: "Calculate the exact difference between any two dates.", path: everyday_date_difference_path, icon_path: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
      { name: "Tip Calculator", description: "Calculate tip amounts and split the bill among friends.", path: everyday_tip_path, icon_path: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" }
    ] %>

    <%# Calculator disclaimer %>
    <%= render "shared/calculator_disclaimer", category: "everyday" %>

    <%# Recommended reading %>
    <% blog_posts = related_blog_posts("time-card-calculator") %>
    <%= render "shared/recommended_reading", posts: blog_posts if blog_posts.any? %>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

<%= faq_schema([
  { question: "How is the required final exam grade calculated?", answer: "The formula is: Required Final = (Desired Grade - Current Grade x (1 - Final Weight / 100)) / (Final Weight / 100). For example, if your current grade is 85%, the final is worth 30%, and you want a 90%, you need: (90 - 85 x 0.7) / 0.3 = (90 - 59.5) / 0.3 = 101.67%. This means you would need over 100% on the final, which is not achievable without extra credit." },
  { question: "What if the required grade is over 100%?", answer: "If the calculator shows a required grade above 100%, it means your desired grade is not achievable through the final exam alone under normal scoring. You would need extra credit opportunities, grade curve adjustments, or to revise your target grade to a more realistic level." },
  { question: "How much does the final exam usually count?", answer: "Final exam weights vary by course and institution. Common weights are 20-40% of the total grade. Some courses have finals worth as little as 10% or as much as 50%. Check your course syllabus for the exact weight, as this significantly affects the required grade calculation." },
  { question: "What letter grade corresponds to each percentage?", answer: "In the standard scale: A is 90-100%, B is 80-89%, C is 70-79%, D is 60-69%, and F is below 60%. Some institutions use plus/minus grades (A-, B+, etc.) with different cutoffs. Check your school's grading policy for the exact scale used." },
  { question: "Can I use this calculator for midterms too?", answer: "Yes. The formula works for any exam that has a known weight in your final grade. Enter your current grade (from all work completed so far), the exam weight percentage, and your target grade. The calculator will show what you need on that particular exam." }
]) %>

<%= calculator_schema_with_ratings(
  name: "Final Grade Calculator",
  description: "Calculate the grade needed on your final exam to achieve your desired course grade.",
  url: everyday_final_grade_url,
  category: "EducationalApplication",
  calculator_slug: "final-grade"
) %>


            <label for="work-break-shift-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Shift Length (hours)</label>
            <input id="work-break-shift-length" type="number" data-work-break-calculator-target="shiftHours" data-action="input->work-break-calculator#calculate" class="w-full" placeholder="8" value="8" min="0.5" max="24" step="0.5">
          </div>
          <div>
            <label for="work-break-meal-break-after" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Meal Break After (hours)</label>
            <input id="work-break-meal-break-after" type="number" data-work-break-calculator-target="breakThreshold" data-action="input->work-break-calculator#calculate" class="w-full" value="6" min="1" max="12" step="0.5">
          </div>
          <div>
            <label for="work-break-meal-break-duration" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Meal Break Duration (min)</label>
            <input id="work-break-meal-break-duration" type="number" data-work-break-calculator-target="breakDuration" data-action="input->work-break-calculator#calculate" class="w-full" value="30" min="5" max="60" step="5">
          </div>

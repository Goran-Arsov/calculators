            <label for="work-break-second-meal-after" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Second Meal After (hours)</label>
            <input id="work-break-second-meal-after" type="number" data-work-break-calculator-target="mealThreshold" data-action="input->work-break-calculator#calculate" class="w-full" value="10" min="4" max="24" step="0.5">
          </div>
          <div>
            <label for="work-break-second-meal-duration" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Second Meal Duration (min)</label>
            <input id="work-break-second-meal-duration" type="number" data-work-break-calculator-target="mealDuration" data-action="input->work-break-calculator#calculate" class="w-full" value="30" min="5" max="60" step="5">

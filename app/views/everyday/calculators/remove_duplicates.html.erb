<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Everyday", url: category_url("everyday") },
  { name: "Remove Duplicates", url: everyday_remove_duplicates_url }
]) %>

<%= faq_schema([
  { question: "How does the duplicate remover work?", answer: "The tool processes your text line by line and keeps only the first occurrence of each unique line. If the same line appears multiple times, only the first instance is preserved and subsequent duplicates are removed. The order of first appearances is maintained in the output." },
  { question: "Is the comparison case-sensitive?", answer: "Yes, the comparison is case-sensitive by default. This means 'Hello' and 'hello' are treated as different lines and both will be kept. If you need case-insensitive deduplication, convert your text to lowercase first using our Case Converter tool, then remove duplicates." },
  { question: "Does it preserve the original order?", answer: "Yes, the tool preserves the order of first occurrences. If your input is 'banana, apple, banana, cherry', the output will be 'banana, apple, cherry'. The first time each unique line appears determines its position in the output." },
  { question: "Can it handle large amounts of text?", answer: "Yes, the tool runs entirely in your browser and can handle thousands of lines efficiently. For extremely large files with hundreds of thousands of lines, processing may take a moment but will complete without issues. No data is sent to any server." },
  { question: "Does whitespace matter?", answer: "Yes, trailing and leading spaces on a line make it distinct from the same text without those spaces. 'Hello ' with a trailing space is different from 'Hello' without one. If this causes issues, trim your lines before deduplication." }
]) %>

<%= calculator_schema(
  name: "Remove Duplicates",
  description: "Remove duplicate lines from text with statistics on duplicates found and unique lines remaining.",
  url: everyday_remove_duplicates_url,
  category: "UtilityApplication"
) %>

<%# Breadcrumbs %>
<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Everyday", url: category_path("everyday") },

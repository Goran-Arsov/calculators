    <div data-controller="color-converter-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="space-y-6">

        <%# Color Picker and Preview %>
        <div class="flex items-center gap-6">
          <div>
            <label for="color-picker" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Color Picker</label>
            <input type="color" id="color-picker" value="#3B82F6"
              data-color-converter-calculator-target="colorPicker"
              data-action="input->color-converter-calculator#fromPicker change->color-converter-calculator#fromPicker"
              class="w-16 h-16 rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 cursor-pointer">
          </div>
          <div class="flex-1">
            <span class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Preview</span>
            <div data-color-converter-calculator-target="preview" class="w-full h-16 rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600" style="background-color: #3B82F6;"></div>
          </div>
        </div>

        <%# HEX Input %>
        <div>
          <label for="color-hex" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">HEX</label>
          <input type="text" id="color-hex" data-color-converter-calculator-target="hexInput"
            data-action="input->color-converter-calculator#fromHex"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="#3B82F6" value="#3B82F6">
        </div>

        <%# RGB Inputs %>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">RGB</label>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label for="color-r" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">R (0-255)</label>
              <input type="number" inputmode="decimal" id="color-r" min="0" max="255" data-color-converter-calculator-target="rgbR"
                data-action="input->color-converter-calculator#fromRgb"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="59">
            </div>
            <div>
              <label for="color-g" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">G (0-255)</label>
              <input type="number" inputmode="decimal" id="color-g" min="0" max="255" data-color-converter-calculator-target="rgbG"
                data-action="input->color-converter-calculator#fromRgb"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="130">
            </div>
            <div>
              <label for="color-b" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">B (0-255)</label>
              <input type="number" inputmode="decimal" id="color-b" min="0" max="255" data-color-converter-calculator-target="rgbB"
                data-action="input->color-converter-calculator#fromRgb"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="246">
            </div>
          </div>
        </div>

        <%# HSL Inputs %>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">HSL</label>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label for="color-h" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">H (0-360)</label>
              <input type="number" inputmode="decimal" id="color-h" min="0" max="360" data-color-converter-calculator-target="hslH"
                data-action="input->color-converter-calculator#fromHsl"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="217">
            </div>
            <div>
              <label for="color-s" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">S (0-100%)</label>
              <input type="number" inputmode="decimal" id="color-s" min="0" max="100" data-color-converter-calculator-target="hslS"
                data-action="input->color-converter-calculator#fromHsl"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="91">
            </div>
            <div>
              <label for="color-l" class="block text-xs text-gray-400 dark:text-gray-500 mb-1">L (0-100%)</label>
              <input type="number" inputmode="decimal" id="color-l" min="0" max="100" data-color-converter-calculator-target="hslL"
                data-action="input->color-converter-calculator#fromHsl"
                class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="60">
            </div>
          </div>
        </div>

        <%# Results %>
        <div class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <% [
              ["HEX", "resultHex"],
              ["RGB", "resultRgb"],
              ["HSL", "resultHsl"],
              ["Color Name", "resultColorName"],
              ["Luminance", "resultLuminance"],
              ["Best Text Color", "resultBestText"]
            ].each do |label, target| %>
              <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-3">
                <div class="flex justify-between items-center mb-1">
                  <span class="text-xs font-semibold text-gray-500 dark:text-gray-400"><%= label %></span>
                  <button data-action="click->color-converter-calculator#copyResult" data-color-converter-calculator-target-param="<%= target %>"
                    class="text-xs px-2 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors">Copy</button>
                </div>
                <div data-color-converter-calculator-target="<%= target %>" class="text-sm font-mono text-gray-900 dark:text-white break-all">&mdash;</div>
              </div>
            <% end %>
          </div>

          <%# Contrast & Accessibility %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <%# White text contrast %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4">
              <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-3">Contrast vs White Text</h3>
              <div class="mb-2">
                <span class="text-xs text-gray-500 dark:text-gray-400">Ratio: </span>
                <span data-color-converter-calculator-target="resultContrastWhite" class="text-sm font-mono font-semibold text-gray-900 dark:text-white">&mdash;</span>
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AA Normal</span>
                  <span data-color-converter-calculator-target="resultWcagWhiteAaNormal" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AA Large</span>
                  <span data-color-converter-calculator-target="resultWcagWhiteAaLarge" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AAA Normal</span>
                  <span data-color-converter-calculator-target="resultWcagWhiteAaaNormal" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AAA Large</span>
                  <span data-color-converter-calculator-target="resultWcagWhiteAaaLarge" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
              </div>
            </div>

            <%# Black text contrast %>
            <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4">
              <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-3">Contrast vs Black Text</h3>
              <div class="mb-2">
                <span class="text-xs text-gray-500 dark:text-gray-400">Ratio: </span>
                <span data-color-converter-calculator-target="resultContrastBlack" class="text-sm font-mono font-semibold text-gray-900 dark:text-white">&mdash;</span>
              </div>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AA Normal</span>
                  <span data-color-converter-calculator-target="resultWcagBlackAaNormal" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AA Large</span>
                  <span data-color-converter-calculator-target="resultWcagBlackAaLarge" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AAA Normal</span>
                  <span data-color-converter-calculator-target="resultWcagBlackAaaNormal" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-500 dark:text-gray-400">AAA Large</span>
                  <span data-color-converter-calculator-target="resultWcagBlackAaaLarge" class="inline-block px-2 py-0.5 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-500">&mdash;</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <button data-action="click->color-converter-calculator#copy" class="w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy All Results</button>
      </div>
    </div>

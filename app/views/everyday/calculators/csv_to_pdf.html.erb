<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">CSV to PDF Converter</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Paste CSV data or upload a .csv file, preview the table, and download a formatted PDF with headers and clean table layout. Everything runs locally in your browser.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="csv-to-pdf-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="space-y-5">
        <%# File upload and delimiter %>
        <div class="flex flex-wrap gap-4 items-end">
          <div class="flex-1 min-w-[200px]">
            <label for="csv-pdf-file" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Upload CSV File</label>
            <input id="csv-pdf-file" type="file" accept=".csv,.tsv,.txt"
                   data-csv-to-pdf-calculator-target="fileInput"
                   data-action="change->csv-to-pdf-calculator#loadFile"
                   class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 dark:file:bg-blue-900/30 dark:file:text-blue-400">
          </div>
          <div>
            <label for="csv-pdf-delim" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Delimiter</label>
            <select id="csv-pdf-delim" data-csv-to-pdf-calculator-target="delimiter" data-action="change->csv-to-pdf-calculator#parse"
                    class="rounded-lg border-gray-300 dark:border-gray-600 dark:bg-gray-800 text-sm">
              <option value=",">Comma (,)</option>
              <option value="&#9;">Tab</option>
              <option value=";">Semicolon (;)</option>
              <option value="|">Pipe (|)</option>
            </select>
          </div>
        </div>

        <%# CSV text input %>
        <div>
          <label for="csv-pdf-input" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Or Paste CSV Data</label>
          <textarea id="csv-pdf-input" rows="8"
                    data-csv-to-pdf-calculator-target="csvInput"
                    data-action="input->csv-to-pdf-calculator#parse"
                    class="w-full font-mono text-sm border-gray-300 dark:border-gray-600 dark:bg-gray-800 rounded-xl"
                    placeholder="name,email,age&#10;Alice,alice@example.com,30&#10;Bob,bob@example.com,25"></textarea>
        </div>

        <%# Header checkbox %>
        <div class="flex items-center gap-2">
          <input id="csv-pdf-header" type="checkbox" checked
                 data-csv-to-pdf-calculator-target="headerCheckbox"
                 data-action="change->csv-to-pdf-calculator#parse"
                 class="rounded border-gray-300 dark:border-gray-600 text-blue-600 focus:ring-blue-500">
          <label for="csv-pdf-header" class="text-sm text-gray-600 dark:text-gray-400">First row is header</label>
        </div>

        <%# Preview %>
        <div data-csv-to-pdf-calculator-target="preview" class="hidden">
          <h3 class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-2">Preview</h3>
          <div class="overflow-x-auto max-h-80 border border-gray-200 dark:border-gray-700 rounded-xl" data-csv-to-pdf-calculator-target="previewTable"></div>
        </div>

        <%# Stats and download %>
        <div class="flex flex-wrap items-center gap-6">
          <div class="flex gap-6 text-sm">
            <div><span class="text-gray-500 dark:text-gray-400">Rows:</span> <span class="font-semibold text-gray-900 dark:text-white" data-csv-to-pdf-calculator-target="resultRows">--</span></div>
            <div><span class="text-gray-500 dark:text-gray-400">Columns:</span> <span class="font-semibold text-gray-900 dark:text-white" data-csv-to-pdf-calculator-target="resultCols">--</span></div>
          </div>
          <button data-csv-to-pdf-calculator-target="downloadBtn" data-action="click->csv-to-pdf-calculator#download" disabled
                  class="px-5 py-2.5 bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-700 hover:to-rose-700 disabled:from-gray-400 disabled:to-gray-400 text-white rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 text-sm font-medium">
            Download PDF
          </button>
        </div>
      </div>
    </div>


              <input type="text" data-color-contrast-checker-calculator-target="foreground" data-action="input->color-contrast-checker-calculator#calculate" class="flex-1 font-mono" placeholder="#000000" value="#000000">
            </div>
            <div data-color-contrast-checker-calculator-target="fgPreview" class="mt-2 w-full h-6 rounded" style="background-color: #000000;"></div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Background Color</label>

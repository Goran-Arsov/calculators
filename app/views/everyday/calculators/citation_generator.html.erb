        </div>

        <%# Journal fields %>
        <div data-citation-generator-calculator-target="journalFields" class="hidden space-y-4">
          <div>
            <label for="cg-journal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Journal Name</label>
            <input id="cg-journal" type="text" data-citation-generator-calculator-target="journalName" data-action="input->citation-generator-calculator#calculate" class="w-full" placeholder="Journal of Psychology">
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label for="cg-volume" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Volume</label>
              <input id="cg-volume" type="text" data-citation-generator-calculator-target="volume" data-action="input->citation-generator-calculator#calculate" class="w-full" placeholder="12">
            </div>
            <div>
              <label for="cg-issue" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Issue</label>

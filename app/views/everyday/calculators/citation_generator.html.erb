        </div>
        <div>
          <label for="cg-title" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Title</label>
          <input id="cg-title" type="text" data-citation-generator-calculator-target="title" data-action="input->citation-generator-calculator#calculate" class="w-full" placeholder="The Art of Research">
        </div>
        <div>

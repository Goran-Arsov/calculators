          ["objectSrc", "object-src", "Controls plugins like Flash and Java applets"],
          ["baseUri", "base-uri", "Restricts URLs that can appear in the base element"],
          ["formAction", "form-action", "Restricts URLs that forms can submit to"],
          ["frameAncestors", "frame-ancestors", "Controls which sites can embed this page in frames"],
          ["reportUri", "report-uri", "URL where the browser sends violation reports"]

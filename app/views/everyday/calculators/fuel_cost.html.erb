            <label for="fuel-cost-gas-price-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gas Price ($/gal)</label>
            <input id="fuel-cost-gas-price-2" type="number" data-fuel-cost-calculator-target="priceForDist" data-action="input->fuel-cost-calculator#calcDistance" class="w-full" placeholder="3.50" step="0.01" min="0">

    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Find the exact duration between any two dates expressed in days, weeks, months, and years.</p>

    <div data-controller="date-difference-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

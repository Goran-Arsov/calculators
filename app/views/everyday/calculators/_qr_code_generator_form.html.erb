<div data-controller="qr-code-generator-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
  <div class="space-y-6">

    <%# Format tabs %>
    <div role="tablist" aria-label="QR content format" class="flex flex-wrap gap-1.5 border-b border-gray-200 dark:border-gray-700 pb-3">
      <% [["text", "Text / URL"], ["wifi", "Wi-Fi"], ["vcard", "Contact"], ["sms", "SMS"], ["geo", "Location"]].each do |slug, label| %>
        <button type="button" role="tab" data-format="<%= slug %>"
          data-qr-code-generator-calculator-target="tabButton"
          data-action="click->qr-code-generator-calculator#selectTab"
          class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">
          <%= label %>
        </button>
      <% end %>
    </div>

    <%# Text / URL section (default) %>
    <div data-qr-code-generator-calculator-target="textSection">
      <label for="qr-text-input" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Text or URL</label>
      <textarea id="qr-text-input" data-qr-code-generator-calculator-target="textInput"
        class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
        rows="3" placeholder="Enter a URL, email, phone number, or any text..."></textarea>
    </div>

    <%# Wi-Fi section %>
    <div data-qr-code-generator-calculator-target="wifiSection" class="hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="qr-wifi-ssid" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Network Name (SSID)</label>
          <input type="text" id="qr-wifi-ssid" data-qr-code-generator-calculator-target="wifiSsid"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="MyWiFi">
        </div>
        <div>
          <label for="qr-wifi-password" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Password</label>
          <input type="text" id="qr-wifi-password" data-qr-code-generator-calculator-target="wifiPassword"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="password">
        </div>
        <div>
          <label for="qr-wifi-encryption" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Encryption</label>
          <select id="qr-wifi-encryption" data-qr-code-generator-calculator-target="wifiEncryption"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="WPA" selected>WPA / WPA2 / WPA3</option>
            <option value="WEP">WEP</option>
            <option value="nopass">None (open)</option>
          </select>
        </div>
        <label class="flex items-center gap-2 mt-7">
          <input type="checkbox" data-qr-code-generator-calculator-target="wifiHidden" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
          <span class="text-sm text-gray-700 dark:text-gray-300">Hidden network</span>
        </label>
      </div>
    </div>

    <%# vCard section %>
    <div data-qr-code-generator-calculator-target="vcardSection" class="hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="qr-vcard-first" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">First Name</label>
          <input type="text" id="qr-vcard-first" data-qr-code-generator-calculator-target="vcardFirstName"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label for="qr-vcard-last" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Last Name</label>
          <input type="text" id="qr-vcard-last" data-qr-code-generator-calculator-target="vcardLastName"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label for="qr-vcard-org" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Organization</label>
          <input type="text" id="qr-vcard-org" data-qr-code-generator-calculator-target="vcardOrg"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label for="qr-vcard-phone" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Phone</label>
          <input type="tel" id="qr-vcard-phone" data-qr-code-generator-calculator-target="vcardPhone"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label for="qr-vcard-email" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Email</label>
          <input type="email" id="qr-vcard-email" data-qr-code-generator-calculator-target="vcardEmail"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label for="qr-vcard-url" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Website</label>
          <input type="url" id="qr-vcard-url" data-qr-code-generator-calculator-target="vcardUrl"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
      </div>
    </div>

    <%# SMS section %>
    <div data-qr-code-generator-calculator-target="smsSection" class="hidden space-y-4">
      <div>
        <label for="qr-sms-number" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Phone Number</label>
        <input type="tel" id="qr-sms-number" data-qr-code-generator-calculator-target="smsNumber"
          class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          placeholder="+15551234567">
      </div>
      <div>
        <label for="qr-sms-body" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Message (optional)</label>
        <textarea id="qr-sms-body" data-qr-code-generator-calculator-target="smsBody" rows="2"
          class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          placeholder="Prefilled message"></textarea>
      </div>
    </div>

    <%# Geo section %>
    <div data-qr-code-generator-calculator-target="geoSection" class="hidden">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="qr-geo-lat" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Latitude</label>
          <input type="number" id="qr-geo-lat" step="any" data-qr-code-generator-calculator-target="geoLat"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="40.7128">
        </div>
        <div>
          <label for="qr-geo-lng" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Longitude</label>
          <input type="number" id="qr-geo-lng" step="any" data-qr-code-generator-calculator-target="geoLng"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="-74.0060">
        </div>
      </div>
    </div>

    <%# Options (collapsible) %>
    <details class="rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <summary class="cursor-pointer select-none px-4 py-3 bg-gray-50 dark:bg-gray-800 text-sm font-semibold text-gray-700 dark:text-gray-300">Appearance &amp; options</summary>
      <div class="p-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="qr-ec-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Error Correction</label>
          <select id="qr-ec-level" data-qr-code-generator-calculator-target="ecLevel"
            data-action="change->qr-code-generator-calculator#optionChanged"
            class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="L">Low (7% recovery)</option>
            <option value="M" selected>Medium (15% recovery)</option>
            <option value="Q">Quartile (25% recovery)</option>
            <option value="H">High (30% recovery)</option>
          </select>
        </div>
        <div>
          <label for="qr-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Size (px per module: <span data-qr-code-generator-calculator-target="sizeValue">8</span>)</label>
          <input type="range" id="qr-size" min="4" max="16" value="8" step="1"
            data-qr-code-generator-calculator-target="sizeInput"
            data-action="input->qr-code-generator-calculator#optionChanged"
            class="w-full">
        </div>
        <div>
          <label for="qr-fg" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Foreground</label>
          <input type="color" id="qr-fg" value="#000000"
            data-qr-code-generator-calculator-target="fgColor"
            data-action="input->qr-code-generator-calculator#optionChanged"
            class="h-11 w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 cursor-pointer">
        </div>
        <div>
          <label for="qr-bg" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Background</label>
          <input type="color" id="qr-bg" value="#ffffff"
            data-qr-code-generator-calculator-target="bgColor"
            data-action="input->qr-code-generator-calculator#optionChanged"
            class="h-11 w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 cursor-pointer">
        </div>
        <div>
          <label for="qr-margin" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Quiet Zone (<span data-qr-code-generator-calculator-target="marginValue">4</span> modules)</label>
          <input type="range" id="qr-margin" min="0" max="8" value="4" step="1"
            data-qr-code-generator-calculator-target="marginInput"
            data-action="input->qr-code-generator-calculator#optionChanged"
            class="w-full">
        </div>
        <div>
          <label for="qr-logo" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Center Logo (optional)</label>
          <input type="file" id="qr-logo" accept="image/*"
            data-qr-code-generator-calculator-target="logoInput"
            data-action="change->qr-code-generator-calculator#logoChanged"
            class="block w-full text-sm text-gray-600 dark:text-gray-400 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-blue-600 file:text-white file:font-semibold hover:file:bg-blue-700 cursor-pointer">
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">Forces High error correction.</p>
        </div>
      </div>
    </details>

    <div data-qr-code-generator-calculator-target="contrastWarning" class="hidden p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl text-xs text-amber-800 dark:text-amber-300">
      &#9888; Foreground and background colors have low contrast. The QR code may not scan reliably.
    </div>

    <button type="button" data-action="click->qr-code-generator-calculator#generate"
      class="px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-colors shadow-sm">
      Generate QR Code
    </button>

    <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 grid grid-cols-3 gap-4">
      <div class="text-center">
        <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Status</span>
        <span class="text-sm font-bold" data-qr-code-generator-calculator-target="resultStatus">&mdash;</span>
      </div>
      <div class="text-center">
        <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Characters</span>
        <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-qr-code-generator-calculator-target="resultCharCount">&mdash;</span>
      </div>
      <div class="text-center">
        <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Type</span>
        <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-qr-code-generator-calculator-target="resultType">&mdash;</span>
      </div>
    </div>

    <div data-qr-code-generator-calculator-target="qrOutput" class="text-center py-4">
      <p class="text-gray-400">Enter data and click Generate</p>
    </div>

    <div data-qr-code-generator-calculator-target="downloadArea"></div>
  </div>
</div>

        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">%</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Find Coupon %</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="coupon-original-price-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Original Price ($)</label>
            <input id="coupon-original-price-2" type="number" data-discount-calculator-target="originalB" data-action="input->discount-calculator#calcDiscountPercent" class="w-full" placeholder="120.00" step="0.01" min="0">
          </div>
          <div>
            <label for="coupon-price-after-coupon" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price After Coupon ($)</label>
            <input id="coupon-price-after-coupon" type="number" data-discount-calculator-target="salePriceB" data-action="input->discount-calculator#calcDiscountPercent" class="w-full" placeholder="90.00" step="0.01" min="0">
          </div>

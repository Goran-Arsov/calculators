<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Coupon Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your coupon savings instantly. Find the final price after a coupon discount or determine the coupon percentage between two prices.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="discount-calculator ad-engagement" class="space-y-5 mb-8">
      <%# Card 1: Find Price After Coupon %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">$</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Apply Coupon</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="coupon-original-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Original Price ($)</label>
            <input id="coupon-original-price" type="number" data-discount-calculator-target="priceA" data-action="input->discount-calculator#calcSalePrice" class="w-full" placeholder="100.00" step="0.01" min="0">
          </div>
          <div>
            <label for="coupon-coupon" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Coupon (%)</label>
            <input id="coupon-coupon" type="number" data-discount-calculator-target="discountPercent" data-action="input->discount-calculator#calcSalePrice" class="w-full" placeholder="15" step="0.1" min="0" max="100">
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Final Price</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-discount-calculator-target="resultSalePrice">&mdash;</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">You Save</span>
            <span class="text-lg font-bold text-green-600 dark:text-green-400" data-discount-calculator-target="resultSavingsA">&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Find Coupon Percentage %>

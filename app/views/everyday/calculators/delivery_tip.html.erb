      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="delivery-tip-order-total" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Order Total ($)</label>
            <input id="delivery-tip-order-total" type="number" inputmode="decimal" data-tip-calculator-target="bill" data-action="input->tip-calculator#calculate" class="w-full" placeholder="35.00" step="0.01" min="0">
          </div>
          <div>
            <label for="delivery-tip-tip" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tip (%)</label>
            <input id="delivery-tip-tip" type="number" inputmode="decimal" data-tip-calculator-target="tipPercent" data-action="input->tip-calculator#calculate" class="w-full" value="18" step="1" min="0" max="100">
          </div>
          <div>
            <label for="delivery-tip-split-between" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Split Between</label>

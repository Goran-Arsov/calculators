  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Moving Cost Estimator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Enter your move distance, home size, and any extras to get an estimated cost range for your upcoming move.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="moving-cost-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="moving-cost-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (miles)</label>
            <input id="moving-cost-distance" type="number" inputmode="decimal" data-moving-cost-calculator-target="distance" data-action="input->moving-cost-calculator#calculate" class="w-full" placeholder="50" step="1" min="1">
          </div>
          <div>
            <label for="moving-cost-home-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Home Size</label>
            <select id="moving-cost-home-size" data-moving-cost-calculator-target="homeSize" data-action="change->moving-cost-calculator#calculate" class="w-full">
              <option value="studio">Studio</option>
              <option value="1bed">1 Bedroom</option>
              <option value="2bed" selected>2 Bedrooms</option>
              <option value="3bed">3 Bedrooms</option>
              <option value="4bed">4 Bedrooms</option>
              <option value="5bed">5+ Bedrooms</option>
            </select>
          </div>
          <div>
            <label for="moving-cost-optional-extras" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-2">Optional Extras</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <input id="moving-cost-optional-extras" type="checkbox" data-moving-cost-calculator-target="packing" data-action="change->moving-cost-calculator#calculate"> Professional Packing
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <input type="checkbox" data-moving-cost-calculator-target="piano" data-action="change->moving-cost-calculator#calculate"> Piano/Specialty Items
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <input type="checkbox" data-moving-cost-calculator-target="storage" data-action="change->moving-cost-calculator#calculate"> Temporary Storage
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <input type="checkbox" data-moving-cost-calculator-target="insurance" data-action="change->moving-cost-calculator#calculate"> Moving Insurance
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <input type="checkbox" data-moving-cost-calculator-target="stairs" data-action="change->moving-cost-calculator#calculate"> Stairs/Elevator Fee
              </label>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Estimated Cost Range</h2>

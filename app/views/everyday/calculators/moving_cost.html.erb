              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-moving-cost-calculator-target="resultHigh">$0</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Base Move</span>
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400"><span data-moving-cost-calculator-target="resultBaseLow">$0</span> - <span data-moving-cost-calculator-target="resultBaseHigh">$0</span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Extras</span>
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400"><span data-moving-cost-calculator-target="resultExtrasLow">$0</span> - <span data-moving-cost-calculator-target="resultExtrasHigh">$0</span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Move Type</span>
              <span class="text-sm font-medium text-blue-600 dark:text-blue-400" data-moving-cost-calculator-target="resultMoveType">--</span>

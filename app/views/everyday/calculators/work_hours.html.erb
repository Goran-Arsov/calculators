    <%# Email capture — shows after 2nd calculator visit %>
    <%= render "shared/calculation_email_capture" %>

      <div class="my-6"><%= render "shared/ad_slot", slot: "after_intro" %></div>

    </article>

    <%= render "shared/related_calculators", related: [
      { name: "Date Difference Calculator", description: "Calculate the exact difference between any two dates.", path: everyday_date_difference_path, icon_path: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
      { name: "Cost Per Hour Calculator", description: "Determine the cost per hour for any service or activity.", path: everyday_cost_per_hour_path, icon_path: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
      { name: "Age Calculator", description: "Calculate your exact age in years, months, and days.", path: everyday_age_path, icon_path: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" }
    ] %>

    <%# Calculator disclaimer %>
    <%= render "shared/calculator_disclaimer", category: "everyday" %>

    <%# Recommended reading %>
    <% blog_posts = related_blog_posts("work-hours-calculator") %>
    <%= render "shared/recommended_reading", posts: blog_posts if blog_posts.any? %>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

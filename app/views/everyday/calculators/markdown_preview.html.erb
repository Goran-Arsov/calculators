<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Everyday", url: category_url("everyday") },
  { name: "Markdown Preview", url: everyday_markdown_preview_url }
]) %>

<%= faq_schema([
  { question: "What is Markdown?", answer: "Markdown is a lightweight markup language created by John Gruber in 2004. It uses simple text formatting syntax that converts to HTML. For example, # creates a heading, **text** creates bold, *text* creates italic, and [text](url) creates a link. It is widely used for README files, documentation, blog posts, forum comments, and note-taking applications." },
  { question: "What Markdown syntax does this preview support?", answer: "This preview supports headings (# through ######), bold (**text** or __text__), italic (*text* or _text_), links [text](url), unordered lists (- or * items), ordered lists (1. items), inline code (`code`), code blocks (``` fenced), blockquotes (> text), and horizontal rules (--- or ***). These cover the core Markdown specification." },
  { question: "Can I use this for GitHub README files?", answer: "Yes, the core Markdown syntax supported here is compatible with GitHub Flavored Markdown (GFM). Headings, bold, italic, links, lists, and code blocks all render the same way on GitHub. However, this preview does not support GFM-specific extensions like task lists, tables, strikethrough, or emoji shortcodes." },
  { question: "How is the preview rendered?", answer: "The preview is rendered entirely in your browser using a lightweight Markdown-to-HTML converter built into the tool. Your text is never sent to any server. The converter processes the Markdown syntax and generates corresponding HTML elements with Tailwind CSS styling for a clean, readable preview." },
  { question: "Can I copy the generated HTML?", answer: "Yes, you can copy the generated HTML using the Copy HTML button. This gives you the raw HTML output that you can paste into any HTML context. You can also copy the rendered text content (without HTML tags) using the Copy Text button. This is useful for previewing how your Markdown will look when rendered." }
]) %>

<%= calculator_schema(
  name: "Markdown Preview",
  description: "Live markdown to HTML preview with support for headings, formatting, links, lists, and code blocks.",
  url: everyday_markdown_preview_url,
  category: "UtilityApplication"
) %>

<%# Breadcrumbs %>
<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Everyday", url: category_path("everyday") },
  { name: "Markdown Preview" }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Markdown Preview</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Write markdown in the editor and see a live HTML preview. Supports headings, bold, italic, links, lists, code, and more.</p>

    <div data-controller="markdown-preview-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="markdown-preview-markdown-input" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Markdown Input</label>
            <textarea id="markdown-preview-markdown-input" data-markdown-preview-calculator-target="input" data-action="input->markdown-preview-calculator#calculate"
              class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white p-3 text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              rows="14" placeholder="# Hello World&#10;&#10;This is **bold** and *italic*.&#10;&#10;- List item 1&#10;- List item 2&#10;&#10;[Link text](https://example.com)&#10;&#10;```&#10;code block&#10;```"></textarea>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Preview</label>
            <div data-markdown-preview-calculator-target="output"
              class="w-full rounded-xl border-[1.5px] border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-800 p-3 overflow-y-auto"
              style="min-height: 21rem; max-height: 30rem;">
              <p class="text-gray-400 text-center py-8">Start typing markdown to see the preview</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 grid grid-cols-3 gap-4">
          <div class="text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Words</span>
            <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-markdown-preview-calculator-target="resultWordCount">&mdash;</span>
          </div>
          <div class="text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Lines</span>
            <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-markdown-preview-calculator-target="resultLineCount">&mdash;</span>
          </div>
          <div class="text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1">Headings</span>
            <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-markdown-preview-calculator-target="resultHeadingCount">&mdash;</span>
          </div>
        </div>

        <div class="flex gap-4">
          <button data-action="click->markdown-preview-calculator#copy"
            class="flex-1 px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy HTML</button>
          <button data-action="click->markdown-preview-calculator#copyText"
            class="flex-1 px-4 py-2.5 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl shadow-sm shadow-emerald-500/20 hover:shadow-md hover:shadow-emerald-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 text-sm font-medium">Copy Text</button>
        </div>
      </div>
    </div>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>

    <article class="prose dark:prose-invert max-w-none">
      <h2>How to Use the Markdown Preview</h2>
      <p>
        Type or paste markdown into the editor on the left and the preview updates in real time on the right. The tool supports all core markdown syntax: headings, bold, italic, links, unordered and ordered lists, inline code, fenced code blocks, blockquotes, and horizontal rules. Statistics below show word count, line count, and heading count.
      </p>
      <p>
        Use the Copy HTML button to get the raw HTML output for pasting into web pages or CMS editors. Use the Copy Text button to get the rendered text content without HTML tags. All processing happens in your browser with no data sent to any server, making it safe for private and sensitive content.
      </p>

      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <h2>Markdown Syntax Guide</h2>
      <p>
        Markdown was designed to be as readable as possible in its raw form. The syntax uses characters you would naturally use in plain text emails. Headings use hash symbols (#, ##, ###). Bold uses double asterisks (**bold**). Italic uses single asterisks (*italic*). Links use brackets and parentheses [text](url). Lists use dashes or numbers. Code uses backticks.
      </p>

      <h3>Headings</h3>
      <p>
        Use one to six hash symbols followed by a space to create headings. # for h1, ## for h2, ### for h3, and so on. Most documents use h1 for the title and h2/h3 for sections and subsections. Headings help both readers and search engines understand the structure of your content. A well-structured heading hierarchy improves readability and accessibility.
      </p>

      <h3>Text Formatting</h3>
      <p>
        Bold text is wrapped in double asterisks (**bold**) or double underscores (__bold__). Italic text uses single asterisks (*italic*) or single underscores (_italic_). Inline code uses backticks (`code`). Fenced code blocks use triple backticks on separate lines before and after the code. These formatting options cover the vast majority of text formatting needs for documentation, blog posts, and technical writing.
      </p>

      <h3>Lists and Links</h3>
      <p>
        Unordered lists use a dash, asterisk, or plus sign followed by a space. Ordered lists use numbers followed by a period and space. Links use the format [display text](URL). Lists and links are the backbone of structured content in markdown. Nested lists are created by indenting child items with spaces. Links can include titles using [text](url "title") format for accessibility.
      </p>

      <h2>Frequently Asked Questions</h2>

      <h3>What is Markdown?</h3>
      <p>A lightweight markup language that converts to HTML. Created in 2004, used for documentation, READMEs, blogs, and notes.</p>

      <h3>What syntax does this preview support?</h3>
      <p>Headings, bold, italic, links, unordered and ordered lists, inline code, code blocks, blockquotes, and horizontal rules.</p>

      <h3>Can I use this for GitHub READMEs?</h3>
      <p>Yes. Core syntax is compatible with GitHub Flavored Markdown. Tables, task lists, and strikethrough are not supported.</p>

      <h3>How is the preview rendered?</h3>
      <p>Entirely in your browser. A lightweight converter processes Markdown to HTML with styled output. No server processing.</p>

      <h3>Can I copy the generated HTML?</h3>
      <p>Yes. Copy HTML gives you raw HTML tags. Copy Text gives you the rendered text without tags.</p>

    <%= render "shared/print_button" %>

    <%# Social sharing %>
    <%= render "shared/social_share", title: "Markdown Preview", url: everyday_markdown_preview_url %>

    <%# Email capture — shows after 2nd calculator visit %>
    <%= render "shared/calculation_email_capture" %>

      <div class="my-6"><%= render "shared/ad_slot", slot: "after_intro" %></div>

    </article>

    <%= render "shared/related_calculators", related: [
      { name: "Markdown to HTML Converter", description: "Convert Markdown documents to clean, semantic HTML with full syntax support.", path: everyday_markdown_to_html_path, icon_path: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" },
      { name: "Markdown Table Generator", description: "Generate properly formatted Markdown tables with an interactive editor.", path: everyday_markdown_table_generator_path, icon_path: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
      { name: "HTML to Markdown Converter", description: "Convert HTML markup to clean Markdown syntax for documentation and content.", path: everyday_html_to_markdown_path, icon_path: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" }
    ] %>

    <%= render "shared/calculator_disclaimer", category: "everyday" %>

    <% blog_posts = related_blog_posts("markdown-preview") %>
    <%= render "shared/recommended_reading", posts: blog_posts if blog_posts.any? %>

  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

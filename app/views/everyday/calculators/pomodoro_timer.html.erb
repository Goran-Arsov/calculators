    <div data-controller="pomodoro-timer-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">

      <%# Progress bar (100 bars stacked vertically) %>
      <div class="mb-4">
        <div data-pomodoro-timer-calculator-target="progressContainer" class="flex flex-col-reverse gap-px w-full rounded-xl overflow-hidden"></div>
        <p data-pomodoro-timer-calculator-target="progressLabel" class="text-base text-gray-900 dark:text-gray-100 mt-1.5 text-center font-semibold"></p>
      </div>

      <%# Phase and session info %>
      <div class="text-center mb-2">
        <span data-pomodoro-timer-calculator-target="phaseLabel" class="text-lg font-bold text-red-600 dark:text-red-400">Work</span>
        <span class="text-gray-400 dark:text-gray-500 mx-2">|</span>
        <span class="text-sm text-gray-500 dark:text-gray-400">Session </span>
        <span data-pomodoro-timer-calculator-target="sessionLabel" class="text-sm font-semibold text-gray-700 dark:text-gray-300">1 / 4</span>
      </div>

      <%# Countdown display %>
      <div class="text-center mb-8">
        <div data-pomodoro-timer-calculator-target="display" class="text-7xl md:text-8xl font-mono font-bold text-gray-900 dark:text-white tracking-wider select-none">25:00</div>
      </div>

      <%# Settings %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto mb-6">
        <div class="text-center">
          <label for="pomo-work" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Work (min)</label>
          <input id="pomo-work" type="number" inputmode="decimal" min="1" max="120" value="25" data-pomodoro-timer-calculator-target="workInput" class="w-full text-center text-xl font-mono">
        </div>
        <div class="text-center">
          <label for="pomo-break" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Break (min)</label>
          <input id="pomo-break" type="number" inputmode="decimal" min="1" max="60" value="5" data-pomodoro-timer-calculator-target="breakInput" class="w-full text-center text-xl font-mono">
        </div>
        <div class="text-center">
          <label for="pomo-long-break" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Long Break (min)</label>
          <input id="pomo-long-break" type="number" inputmode="decimal" min="1" max="120" value="15" data-pomodoro-timer-calculator-target="longBreakInput" class="w-full text-center text-xl font-mono">
        </div>
        <div class="text-center">
          <label for="pomo-sessions" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Sessions</label>
          <input id="pomo-sessions" type="number" inputmode="decimal" min="1" max="10" value="4" data-pomodoro-timer-calculator-target="sessionsInput" class="w-full text-center text-xl font-mono">
        </div>
      </div>

      <%# Control buttons %>
      <div class="flex items-center justify-center gap-3 max-w-lg mx-auto">
        <button data-pomodoro-timer-calculator-target="startBtn" data-action="click->pomodoro-timer-calculator#start" class="flex-1 px-6 py-3 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-semibold">Start</button>
        <button data-pomodoro-timer-calculator-target="pauseBtn" data-action="click->pomodoro-timer-calculator#pause" class="hidden flex-1 px-6 py-3 bg-gradient-to-r from-yellow-500 to-amber-500 hover:from-yellow-600 hover:to-amber-600 text-white rounded-xl shadow-sm shadow-yellow-500/20 hover:shadow-md hover:shadow-yellow-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 text-sm font-semibold">Pause</button>
        <button data-pomodoro-timer-calculator-target="skipBtn" data-action="click->pomodoro-timer-calculator#skip" class="flex-1 px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-semibold">Skip</button>
        <button data-pomodoro-timer-calculator-target="resetBtn" data-action="click->pomodoro-timer-calculator#reset" class="flex-1 px-6 py-3 bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white rounded-xl shadow-sm shadow-gray-500/20 hover:shadow-md hover:shadow-gray-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 text-sm font-semibold">Reset</button>
      </div>

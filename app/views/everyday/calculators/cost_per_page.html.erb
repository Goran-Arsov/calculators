              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cost-per-page-calculator-target="resultCostPer100">--</span>
            </div>
            <div data-cost-per-page-calculator-target="monthlyPanel" class="hidden space-y-3">
              <hr class="border-gray-200 dark:border-gray-700">
              <div class="flex justify-between items-center">
                <span class="text-gray-600 dark:text-gray-400">Monthly Cost</span>
                <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cost-per-page-calculator-target="resultMonthlyCost">--</span>

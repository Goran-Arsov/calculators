<%# SEO meta tags %>
<% set_meta_tags(
  title: "Student Budget Calculator - Free College Budget Planner",
  description: "Plan your college budget by entering tuition, room and board, books, transportation, and financial aid. Calculate your annual funding gap and monthly expenses.",
  canonical: everyday_student_budget_url,
  og: {
    title: "Student Budget Calculator - Free College Budget Planner | CalcWise",
    description: "Plan your college budget by calculating total costs, financial aid, and monthly funding gaps for 12-month and 9-month academic years.",
    url: everyday_student_budget_url,
    type: "website",
    site_name: "CalcWise"
  }

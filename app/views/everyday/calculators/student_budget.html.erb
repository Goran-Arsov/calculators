<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Everyday", url: category_url("everyday") },
  { name: "Student Budget Calculator", url: everyday_student_budget_url }
]) %>

<%= faq_schema([
  { question: "What costs should I include in a student budget?", answer: "A comprehensive student budget should include tuition and fees, room and board (housing and meals), textbooks and supplies, transportation costs (car, gas, public transit, parking), and personal expenses (clothing, entertainment, phone, toiletries). Do not forget health insurance if not covered by parents, and technology costs like a laptop or software subscriptions." },
  { question: "What is the difference between a 12-month and 9-month budget?", answer: "A 12-month budget divides your annual funding gap by 12, giving the monthly amount you need to cover throughout the entire year. A 9-month budget divides by 9, representing the academic year (September through May). The 9-month figure is higher per month but only applies during the school year, assuming you earn or save during summer months." },
  { question: "How can I reduce my college costs?", answer: "Apply for scholarships and grants early and often. Consider community college for general education credits before transferring. Buy used or rental textbooks, or use library reserves. Use student discounts for software, transportation, and entertainment. Cook meals instead of eating out. Share housing with roommates. Apply for work-study programs that fit your class schedule." },
  { question: "What is a funding gap?", answer: "A funding gap is the difference between your total college costs and your total financial resources (financial aid, work income, and scholarships). A positive gap means you need additional funding through savings, loans, or additional income. A negative gap means your aid exceeds your costs, and the surplus may be refunded to you." },
  { question: "How much should a college student budget monthly?", answer: "Monthly budgets vary widely by location and lifestyle. National averages suggest $1,000-$2,500 per month beyond tuition for living expenses. Students in expensive cities may need more. The key is to track your actual spending for the first month, then adjust your budget based on real data rather than estimates." }
]) %>

<%= calculator_schema_with_ratings(
  name: "Student Budget Calculator",
  description: "Calculate total college costs, financial aid coverage, and monthly funding gaps for academic year planning.",
  url: everyday_student_budget_url,
  category: "FinanceApplication",
  calculator_slug: "student-budget"
) %>


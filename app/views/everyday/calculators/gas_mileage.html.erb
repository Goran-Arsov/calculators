    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Gas Mileage Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your vehicle's fuel efficiency in MPG or L/100km by entering the distance traveled and fuel consumed.</p>

    <div data-controller="gas-mileage-calculator ad-engagement" class="space-y-5 mb-8">
      <%# Card 1: MPG %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">MI</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Miles per Gallon (MPG)</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="gas-mileage-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (miles)</label>
            <input id="gas-mileage-distance" type="number" data-gas-mileage-calculator-target="distanceMiles" data-action="input->gas-mileage-calculator#calcMpg" class="w-full" placeholder="300" step="0.1" min="0">
          </div>
          <div>
            <label for="gas-mileage-fuel" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel (gallons)</label>
            <input id="gas-mileage-fuel" type="number" data-gas-mileage-calculator-target="fuelGallons" data-action="input->gas-mileage-calculator#calcMpg" class="w-full" placeholder="10" step="0.01" min="0">
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">MPG</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gas-mileage-calculator-target="resultMpg">&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: L/100km %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">KM</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Liters per 100 km (L/100km)</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="gas-mileage-distance-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (km)</label>
            <input id="gas-mileage-distance-2" type="number" data-gas-mileage-calculator-target="distanceKm" data-action="input->gas-mileage-calculator#calcLper100km" class="w-full" placeholder="500" step="0.1" min="0">
          </div>
          <div>
            <label for="gas-mileage-fuel-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel (liters)</label>
            <input id="gas-mileage-fuel-2" type="number" data-gas-mileage-calculator-target="fuelLiters" data-action="input->gas-mileage-calculator#calcLper100km" class="w-full" placeholder="40" step="0.01" min="0">
          </div>

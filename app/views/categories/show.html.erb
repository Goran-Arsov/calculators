<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: @category[:title] }
] %>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: @category[:title], url: category_url(@slug) }
]) %>

<section class="mb-12">
  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight"><%= @category[:title] %></h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl leading-relaxed"><%= @category[:description] %></p>
  </div>

  <%# Ad: leaderboard — placed below content heading per AdSense best practices %>
  <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

  <div class="lg:grid lg:grid-cols-3 lg:gap-8">
    <div class="lg:col-span-2">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% @calculators.each do |calc| %>
          <%= render "shared/calculator_card", calculator: calc %>
        <% end %>
      </div>

      <%# Programmatic SEO — specialized calculators for this category %>
      <% if @programmatic_calculators.any? %>
        <section class="mt-14 pt-10 border-t border-gray-200/80 dark:border-gray-800">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-1.5 h-8 bg-gradient-to-b from-violet-500 to-purple-600 rounded-full"></div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Specialized Calculators</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <% @programmatic_calculators.first(12).each do |calc| %>
              <%= render "shared/calculator_card", calculator: calc %>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# Ad: below grid %>
      <div class="mt-8"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <%# Related blog posts for this category %>
      <% if @blog_posts.any? %>
        <section class="mt-14 pt-10 border-t border-gray-200/80 dark:border-gray-800">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1.5 h-8 bg-gradient-to-b from-emerald-500 to-teal-600 rounded-full"></div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Related Articles</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <% @blog_posts.each do |post| %>
              <%= link_to blog_post_path(post.slug), class: "group bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" do %>
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug mb-2"><%= post.title %></h3>
                <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2"><%= post.excerpt %></p>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# Cross-category linking — explore other categories %>
      <%
        all_categories = [
          { slug: "finance", title: "Finance Calculators", from_color: "from-emerald-500", to_color: "to-teal-600" },
          { slug: "math", title: "Math Calculators", from_color: "from-amber-500", to_color: "to-orange-600" },
          { slug: "physics", title: "Physics Calculators", from_color: "from-cyan-500", to_color: "to-blue-600" },
          { slug: "health", title: "Health Calculators", from_color: "from-rose-500", to_color: "to-pink-600" },
          { slug: "construction", title: "Construction Calculators", from_color: "from-yellow-500", to_color: "to-amber-600" },
          { slug: "everyday", title: "Everyday Calculators", from_color: "from-violet-500", to_color: "to-purple-600" }
        ]
        other_categories = all_categories.reject { |cat| cat[:slug] == @slug }
      %>
      <section class="mt-14 pt-10 border-t border-gray-200/80 dark:border-gray-800">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-blue-500 to-indigo-600 rounded-full"></div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Explore Other Categories</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% other_categories.each do |cat| %>
            <%= link_to category_path(cat[:slug]), class: "group bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" do %>
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-8 bg-gradient-to-b <%= cat[:from_color] %> <%= cat[:to_color] %> rounded-full"></div>
                <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><%= cat[:title] %></h3>
              </div>
            <% end %>
          <% end %>
        </div>
      </section>

      <%# Multiplex ad — recommended content grid at bottom %>
      <div class="mt-8"><%= render "shared/ad_slot", slot: "multiplex" %></div>
    </div>

    <%# Sidebar — visible on desktop %>
    <div class="hidden lg:block">
      <div class="sticky top-24 space-y-6">
        <%= render "shared/ad_slot", slot: "sidebar" %>
      </div>
    </div>
  </div>
</section>

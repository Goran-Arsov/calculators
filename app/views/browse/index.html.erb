<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Browse All" }
] %>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Browse All", url: browse_url }
]) %>

<section class="mb-12">
  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight">All Calculators & Tools</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl leading-relaxed">Browse every calculator and tool on Calc Hammer, organized by category.</p>
  </div>

  <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

  <% @categories.each_with_index do |cat, idx| %>
    <div class="mb-14" id="<%= cat[:slug] %>">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <div class="w-1.5 h-8 bg-gradient-to-b from-blue-500 to-violet-600 rounded-full"></div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight"><%= cat[:title] %></h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 font-medium">(<%= cat[:calculators].size %>)</span>
        </div>
        <%= link_to category_path(cat[:slug]), class: "text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors" do %>
          View category
        <% end %>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% cat[:calculators].each do |calc| %>
          <%= render "shared/calculator_card", calculator: calc %>
        <% end %>
      </div>
    </div>

    <% if idx == 2 %>
      <div class="mb-10"><%= render "shared/ad_slot", slot: "in_content" %></div>
    <% end %>
  <% end %>

  <div class="mt-8"><%= render "shared/ad_slot", slot: "multiplex" %></div>
</section>

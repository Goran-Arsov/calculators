<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Priming Sugar Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate the exact amount of priming sugar to bottle condition your beer to a target carbonation level. Accounts for residual CO2 dissolved at your fermentation temperature.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="priming-sugar-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="ps-volume" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Batch Volume (gal)</label>
            <input id="ps-volume" type="number" inputmode="decimal" data-priming-sugar-calculator-target="volume" data-action="input->priming-sugar-calculator#calculate" class="w-full" value="5" step="0.1" min="0">
          </div>
          <div>
            <label for="ps-temp" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fermentation Temp (°F)</label>
            <input id="ps-temp" type="number" inputmode="decimal" data-priming-sugar-calculator-target="tempF" data-action="input->priming-sugar-calculator#calculate" class="w-full" value="68" step="1" min="32" max="100">
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">The highest temperature during active fermentation, not the current temp.</p>
          </div>
          <div>
            <label for="ps-co2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Target CO2 Volumes</label>
            <input id="ps-co2" type="number" inputmode="decimal" data-priming-sugar-calculator-target="targetCo2" data-action="input->priming-sugar-calculator#calculate" class="w-full" value="2.4" step="0.1" min="0.5" max="5">
          </div>
          <div>
            <label for="ps-sugar" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sugar Type</label>
            <select id="ps-sugar" data-priming-sugar-calculator-target="sugarType" data-action="change->priming-sugar-calculator#calculate" class="w-full">

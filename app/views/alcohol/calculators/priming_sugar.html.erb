              <span class="text-gray-700 dark:text-gray-300 font-semibold">Sugar to Add</span>
              <span class="text-3xl font-extrabold text-yellow-600 dark:text-yellow-400" data-priming-sugar-calculator-target="resultGrams">—</span>
            </div>
            <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">In Ounces</span><span class="font-semibold" data-priming-sugar-calculator-target="resultOz">—</span></div>

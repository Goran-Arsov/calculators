<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">IBU Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate International Bitterness Units (IBU) for your beer recipe using the Tinseth hop utilization formula. Enter your batch volume, original gravity, and up to four hop additions.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="ibu-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="ibu-volume" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Batch (gal)</label>
              <input id="ibu-volume" type="number" inputmode="decimal" data-ibu-calculator-target="batchVolume" data-action="input->ibu-calculator#calculate" class="w-full" value="5" step="0.1" min="0">
            </div>
            <div>
              <label for="ibu-og" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">OG</label>
              <input id="ibu-og" type="number" inputmode="decimal" data-ibu-calculator-target="og" data-action="input->ibu-calculator#calculate" class="w-full" value="1.055" step="0.001" min="1">
            </div>
          </div>

          <% [["1", "60", "Bittering"], ["2", "20", "Flavor"], ["3", "5", "Aroma"], ["4", "0", "Whirlpool"]].each_with_index do |(num, time, role), idx| %>
            <div class="border-t border-gray-200/60 dark:border-gray-700/60 pt-3">
              <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Hop <%= num %> — <%= role %></div>
              <div class="grid grid-cols-3 gap-2">
                <div>
                  <label for="ibu-hop<%= num %>-weight" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Weight (oz)</label>
                  <input id="ibu-hop<%= num %>-weight" type="number" inputmode="decimal" data-ibu-calculator-target="hop<%= num %>Weight" data-action="input->ibu-calculator#calculate" class="w-full" value="<%= idx == 0 ? '1.0' : (idx == 1 ? '0.5' : '0') %>" step="0.1" min="0">
                </div>
                <div>
                  <label for="ibu-hop<%= num %>-aa" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Alpha %</label>
                  <input id="ibu-hop<%= num %>-aa" type="number" inputmode="decimal" data-ibu-calculator-target="hop<%= num %>Aa" data-action="input->ibu-calculator#calculate" class="w-full" value="7.0" step="0.1" min="0">
                </div>
                <div>
                  <label for="ibu-hop<%= num %>-time" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Time (min)</label>
                  <input id="ibu-hop<%= num %>-time" type="number" inputmode="numeric" data-ibu-calculator-target="hop<%= num %>Time" data-action="input->ibu-calculator#calculate" class="w-full" value="<%= time %>" step="1" min="0">
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center pb-2 border-b border-amber-200/50 dark:border-amber-800/50">

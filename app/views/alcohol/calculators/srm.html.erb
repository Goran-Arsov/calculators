              <option value="imperial">Imperial (lb, gal)</option>
              <option value="metric">Metric (kg, L)</option>
            </select>
          </div>
          <div>
            <label for="srm-volume" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-srm-calculator-target="batchVolumeLabel">Batch Volume (gal)</span></label>

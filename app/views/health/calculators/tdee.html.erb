<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">TDEE Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your Total Daily Energy Expenditure and Basal Metabolic Rate to understand how many calories you burn each day.</p>

    <%# Ad: leaderboard — placed below content heading per AdSense best practices %>

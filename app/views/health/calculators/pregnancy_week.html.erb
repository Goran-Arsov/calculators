            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculate From</label>
            <select data-pregnancy-week-calculator-target="inputMode" data-action="change->pregnancy-week-calculator#toggleMode" class="w-full">

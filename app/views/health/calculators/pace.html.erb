    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Pace Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your running pace, finish time, or distance. Enter any two values and solve for the third.</p>

    <%# Calculator UI — 3 cards %>
    <div data-controller="pace-calculator" class="space-y-6 mb-8">

      <%# Card 1: Solve for Pace %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Solve for Pace</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label for="pace-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (km)</label>
            <input id="pace-distance" type="number" data-pace-calculator-target="distForPace" data-action="input->pace-calculator#calcPace" class="w-full" placeholder="5" step="0.01" min="0">
          </div>
          <div>
            <label for="pace-time" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time (mm:ss)</label>
            <input id="pace-time" type="text" data-pace-calculator-target="timeForPace" data-action="input->pace-calculator#calcPace" class="w-full" placeholder="25:00">
          </div>
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6 flex flex-col justify-center">
            <span class="text-sm text-gray-600 dark:text-gray-400 mb-1">Pace (min/km)</span>
            <span class="text-2xl font-bold text-green-600 dark:text-green-400" data-pace-calculator-target="resultPace">—</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Time %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Solve for Time</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label for="pace-distance-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (km)</label>
            <input id="pace-distance-2" type="number" data-pace-calculator-target="distForTime" data-action="input->pace-calculator#calcTime" class="w-full" placeholder="10" step="0.01" min="0">
          </div>
          <div>
            <label for="pace-pace" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Pace (min/km, e.g. 5:30)</label>
            <input id="pace-pace" type="text" data-pace-calculator-target="paceForTime" data-action="input->pace-calculator#calcTime" class="w-full" placeholder="5:30">
          </div>
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6 flex flex-col justify-center">

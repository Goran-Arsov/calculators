            <label for="pace-time-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time (mm:ss)</label>
            <input id="pace-time-2" type="text" data-pace-calculator-target="timeForDist" data-action="input->pace-calculator#calcDistance" class="w-full" placeholder="55:00">
          </div>

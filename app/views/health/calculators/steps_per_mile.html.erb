<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Steps Per Mile Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your personal steps per mile and steps per km from your walking or running data. See estimated calories burned and your stride length.</p>

    <%# Calculator UI %>
    <div data-controller="steps-per-mile-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="steps-per-mile-total-steps" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total Steps</label>
            <input id="steps-per-mile-total-steps" type="number" data-steps-per-mile-calculator-target="totalSteps" data-action="input->steps-per-mile-calculator#calculate" class="w-full" placeholder="4200" step="1" min="0">
          </div>
          <div>
            <label for="steps-per-mile-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance</label>
            <input id="steps-per-mile-distance" type="number" data-steps-per-mile-calculator-target="distance" data-action="input->steps-per-mile-calculator#calculate" class="w-full" placeholder="2" step="0.01" min="0">
          </div>
          <div>
            <label for="steps-per-mile-distance-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance Unit</label>
            <select id="steps-per-mile-distance-unit" data-steps-per-mile-calculator-target="unit" data-action="change->steps-per-mile-calculator#calculate" class="w-full">
              <option value="miles">Miles</option>
              <option value="km">Kilometers</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Steps per mile</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-steps-per-mile-calculator-target="stepsPerMile">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Steps per km</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-steps-per-mile-calculator-target="stepsPerKm">&mdash;</span>
            </div>
            <div class="flex justify-between items-center border-t border-gray-200 dark:border-gray-700 pt-3">
              <span class="text-sm text-gray-600 dark:text-gray-400">Estimated calories</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-steps-per-mile-calculator-target="estimatedCalories">&mdash;</span>
            </div>
            <div class="flex justify-between items-center border-t border-gray-200 dark:border-gray-700 pt-3">
              <span class="text-sm text-gray-600 dark:text-gray-400">Stride length (ft)</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-steps-per-mile-calculator-target="strideLengthFt">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Stride length (m)</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-steps-per-mile-calculator-target="strideLengthM">&mdash;</span>
            </div>
          </div>
          <button data-action="click->steps-per-mile-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>

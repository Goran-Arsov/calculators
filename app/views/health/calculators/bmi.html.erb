              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bmi-calculator-target="weightLabel">Weight (kg)</label>

                <option value="yards">yards</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time</label>
            <div class="flex gap-2 items-center">
              <input type="number" inputmode="numeric" data-swim-pace-calculator-target="timeMin" data-action="input->swim-pace-calculator#calculate" class="w-20" placeholder="6" min="0">
              <span class="text-gray-500">min</span>
              <input type="number" inputmode="numeric" data-swim-pace-calculator-target="timeSec" data-action="input->swim-pace-calculator#calculate" class="w-20" placeholder="30" min="0" max="59">
              <span class="text-gray-500">sec</span>
            </div>
          </div>
          <div class="pt-4 space-y-2">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pace /100m</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-swim-pace-calculator-target="pacePer100m">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pace /100yd</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-swim-pace-calculator-target="pacePer100y">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Speed</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-swim-pace-calculator-target="speedPerHour">—</span>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Estimated Times</h2>
          <div data-swim-pace-calculator-target="estimatedTimes" class="space-y-0.5"></div>
          <button data-action="click->swim-pace-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>

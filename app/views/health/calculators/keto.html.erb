    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your personalized daily keto macros for fat, protein, and net carbs based on your body stats and goals.</p>

    <%# Calculator UI %>
    <div data-controller="keto-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="keto-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="keto-unit-system" data-keto-calculator-target="unitSystem" data-action="change->keto-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg, cm)</option>
              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label for="keto-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-keto-calculator-target="weightLabel">Weight (kg)</label>
            <input id="keto-weight" type="number" data-keto-calculator-target="weight" data-action="input->keto-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="keto-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-keto-calculator-target="heightLabel">Height (cm)</label>
            <input id="keto-height" type="number" data-keto-calculator-target="height" data-action="input->keto-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
          </div>
          <div>
            <label for="keto-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age</label>
            <input id="keto-age" type="number" data-keto-calculator-target="age" data-action="input->keto-calculator#calculate" class="w-full" placeholder="30" min="1" max="120">
          </div>
          <div>
            <label for="keto-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
            <select id="keto-gender" data-keto-calculator-target="gender" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="keto-activity-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select id="keto-activity-level" data-keto-calculator-target="activityLevel" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Activity Level">
              <option value="sedentary">Sedentary (little or no exercise)</option>
              <option value="light">Lightly active (1-3 days/week)</option>
              <option value="moderate">Moderately active (3-5 days/week)</option>
              <option value="active">Very active (6-7 days/week)</option>
              <option value="very_active">Extra active (physical job + exercise)</option>
            </select>
          </div>
          <div>
            <label for="keto-goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Goal</label>
            <select id="keto-goal" data-keto-calculator-target="goal" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Goal">
              <option value="maintain">Maintain Weight</option>
              <option value="lose">Lose Weight</option>
              <option value="gain">Gain Weight</option>

              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-keto-calculator-target="dailyCalories">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fat</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400"><span data-keto-calculator-target="fatGrams">—</span> <span class="text-sm font-normal" data-keto-calculator-target="fatPercent"></span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Protein</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400"><span data-keto-calculator-target="proteinGrams">—</span> <span class="text-sm font-normal" data-keto-calculator-target="proteinPercent"></span></span>
            </div>
            <div class="flex justify-between items-center">

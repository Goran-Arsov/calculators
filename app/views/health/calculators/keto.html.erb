<%# JSON-LD schemas %>
<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Health", url: category_url("health") },
  { name: "Keto Calculator", url: health_keto_url }
]) %>

<%= faq_schema([
  { question: "What macros should I eat on keto?", answer: "A standard ketogenic diet typically targets 70% of calories from fat, 25% from protein, and 5% from carbohydrates. In practice, this means most people should aim for 20-25 grams of net carbs per day to maintain ketosis. Protein intake should be adequate to preserve muscle mass, and the remaining calories come from healthy fats. These ratios can be adjusted based on individual response and goals." },
  { question: "How many carbs can I eat and stay in ketosis?", answer: "Most people need to limit net carbs to 20-25 grams per day to enter and maintain ketosis. Some individuals with higher activity levels may tolerate up to 50 grams. Net carbs are calculated as total carbohydrates minus fiber and sugar alcohols. The threshold varies by person — some are more carb-sensitive than others. Testing blood ketone levels is the most reliable way to confirm ketosis." },
  { question: "How does the keto calculator determine my calories?", answer: "The calculator uses the Mifflin-St Jeor equation to estimate your Basal Metabolic Rate (BMR) based on your weight, height, age, and gender. It then multiplies BMR by an activity factor to calculate your Total Daily Energy Expenditure (TDEE). Finally, it adjusts calories based on your goal — maintaining weight, losing weight (500 calorie deficit), or gaining weight (500 calorie surplus)." },
  { question: "Should I eat more fat or protein on keto?", answer: "On keto, fat is your primary energy source and should make up about 70% of your calories. Protein should be moderate at about 25% of calories — enough to preserve muscle but not so much that excess protein converts to glucose through gluconeogenesis. Eating too little fat can leave you hungry and low on energy, while eating too much protein may interfere with ketosis in some individuals." },
  { question: "How long does it take to enter ketosis?", answer: "Most people enter ketosis within 2-4 days of restricting carbohydrates to 20-25 grams per day. The transition period, sometimes called 'keto flu,' can involve fatigue, headaches, and irritability as the body adapts to burning fat instead of carbohydrates. Staying well-hydrated and supplementing electrolytes (sodium, potassium, magnesium) can help ease this transition." }
]) %>

<%= calculator_schema(
  name: "Keto Calculator",
  description: "Calculate your personalized daily keto macros for fat, protein, and net carbs based on your body measurements and goals.",
  url: health_keto_url,
  category: "HealthApplication"
) %>


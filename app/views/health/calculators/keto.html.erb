  canonical: health_keto_url,
  og: {
    title: "Keto Calculator - Free Keto Macro Calculator Tool | CalcWise",
    description: "Calculate your personalized keto macros for fat, protein, and net carbs based on your body stats and goals.",
    url: health_keto_url,

            <select id="ba-stress" data-biological-age-calculator-target="stress" data-action="change->biological-age-calculator#calculate" class="w-full" aria-label="Stress Level">
              <option value="3">3 - Moderate</option>
              <option value="1">1 - Very Low</option>
              <option value="2">2 - Low</option>
              <option value="4">4 - High</option>
              <option value="5">5 - Very High</option>

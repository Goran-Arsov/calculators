<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Protein Intake Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your optimal daily protein intake based on your weight, activity level, and fitness goal.</p>

    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <%# Calculator UI %>
    <div data-controller="protein-intake-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="protein-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Weight (kg)</label>
            <input id="protein-weight" type="number" inputmode="decimal" data-protein-intake-calculator-target="weightKg" data-action="input->protein-intake-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="protein-activity" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select id="protein-activity" data-protein-intake-calculator-target="activityLevel" data-action="change->protein-intake-calculator#calculate" class="w-full" aria-label="Activity Level">
              <option value="sedentary">Sedentary (little or no exercise)</option>
              <option value="lightly_active">Lightly Active (1-3 days/week)</option>
              <option value="moderately_active">Moderately Active (3-5 days/week)</option>
              <option value="very_active">Very Active (6-7 days/week)</option>
              <option value="athlete">Athlete (2x daily training)</option>
            </select>
          </div>
          <div>
            <label for="protein-goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Goal</label>
            <select id="protein-goal" data-protein-intake-calculator-target="goal" data-action="change->protein-intake-calculator#calculate" class="w-full" aria-label="Fitness Goal">
              <option value="maintain">Maintain Weight</option>
              <option value="muscle_gain">Muscle Gain</option>
              <option value="fat_loss">Fat Loss</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Daily Protein</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400"><span data-protein-intake-calculator-target="dailyProteinGrams">—</span> g</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Protein per kg</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400"><span data-protein-intake-calculator-target="proteinPerKg">—</span> g/kg</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Per Meal (4 meals)</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400"><span data-protein-intake-calculator-target="perMealGrams">—</span> g</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Protein Calories</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400"><span data-protein-intake-calculator-target="proteinCalories">—</span> kcal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">% of 2000 cal</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400"><span data-protein-intake-calculator-target="proteinPctOf2000cal">—</span>%</span>
            </div>
          </div>
          <button data-action="click->protein-intake-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>

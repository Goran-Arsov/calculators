    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Find out your dog's age in human years, adjusted for breed size, because not all dogs age at the same rate.</p>

    <%# Calculator UI %>
    <div data-controller="dog-age-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Dog's Age (years)</label>
            <input type="number" data-dog-age-calculator-target="dogAge" data-action="input->dog-age-calculator#calculate" class="w-full" placeholder="5" step="0.5" min="0" max="30">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Size</label>
            <select data-dog-age-calculator-target="size" data-action="change->dog-age-calculator#calculate" class="w-full" aria-label="Size">
              <option value="small">Small (under 10 kg / 22 lbs)</option>
              <option value="medium">Medium (10-25 kg / 22-55 lbs)</option>
              <option value="large">Large (over 25 kg / 55 lbs)</option>
            </select>
          </div>
        </div>
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">

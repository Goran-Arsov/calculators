            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Resting Energy (RER)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dog-food-calculator-target="rer">&mdash;</span>
            </div>
          </div>

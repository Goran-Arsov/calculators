<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Dog Food Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Find out exactly how much to feed your dog each day based on their weight, age, activity level, and food calorie density.</p>

    <%# Calculator UI %>
    <div data-controller="dog-food-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Dog's Weight (lbs)</label>
            <input type="number" data-dog-food-calculator-target="weight" data-action="input->dog-food-calculator#calculate" class="w-full" placeholder="30" step="0.5" min="0" max="350">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select data-dog-food-calculator-target="activityLevel" data-action="change->dog-food-calculator#calculate" class="w-full">
              <option value="low">Low (mostly resting)</option>
              <option value="normal" selected>Normal (daily walks)</option>
              <option value="active">Active (regular exercise)</option>
              <option value="very_active">Very Active (working / sporting dog)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age Category</label>
            <select data-dog-food-calculator-target="ageCategory" data-action="change->dog-food-calculator#calculate" class="w-full">
              <option value="puppy">Puppy (under 1 year)</option>
              <option value="adult" selected>Adult (1-7 years)</option>
              <option value="senior">Senior (7+ years)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Food Calorie Density (kcal/cup)</label>
            <input type="number" data-dog-food-calculator-target="kcalPerCup" data-action="input->dog-food-calculator#calculate" class="w-full" placeholder="350" value="350" step="10" min="1">
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Daily Calories</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dog-food-calculator-target="dailyCalories">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Cups Per Day</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dog-food-calculator-target="cupsPerDay">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Per Meal (2x/day)</span>

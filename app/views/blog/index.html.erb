<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Blog" }
] %>

<section class="max-w-4xl mx-auto">
  <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">Blog</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">Expert articles about personal finance, math concepts, and health metrics to help you make better decisions.</p>

  <!-- Category filter -->
  <div class="flex flex-wrap gap-2 mb-8">
    <%= link_to "All", blog_path, class: "px-4 py-2 rounded-full text-sm font-medium #{params[:category].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700'}" %>
    <% %w[finance math health].each do |cat| %>
      <%= link_to cat.capitalize, blog_path(category: cat), class: "px-4 py-2 rounded-full text-sm font-medium #{params[:category] == cat ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700'}" %>
    <% end %>
  </div>

  <% if @posts.any? %>
    <div class="space-y-8">
      <% @posts.each do |post| %>
        <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-3">
            <% if post.category.present? %>
              <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"><%= post.category.capitalize %></span>
            <% end %>
            <time class="text-sm text-gray-500 dark:text-gray-400" datetime="<%= post.published_at.iso8601 %>"><%= post.published_at.strftime("%B %d, %Y") %></time>
          </div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
            <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
          </h2>
          <p class="text-gray-600 dark:text-gray-400"><%= post.excerpt %></p>
          <%= link_to "Read more →", blog_post_path(post.slug), class: "inline-block mt-3 text-blue-600 dark:text-blue-400 font-medium hover:underline" %>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 dark:text-gray-400 text-center py-12">No blog posts yet. Check back soon!</p>
  <% end %>
</section>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Blog", url: blog_url },
  { name: @post.title, url: blog_post_url(@post.slug) }
]) %>

<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Blog", url: blog_path },
  { name: @post.title }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 md:p-10 lg:p-12">
      <div class="flex items-center gap-3 mb-4">
        <% if @post.category.present? %>
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"><%= @post.category.capitalize %></span>
        <% end %>
        <time class="text-sm text-gray-500 dark:text-gray-400" datetime="<%= @post.published_at.iso8601 %>"><%= @post.published_at.strftime("%B %d, %Y") %></time>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-6"><%= @post.title %></h1>

      <div class="prose dark:prose-invert max-w-none">
        <%= raw @post.body %>
      </div>
    </article>

    <div class="mt-8">
      <%= render "shared/ad_slot", slot: "in_content" %>
    </div>
  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24">
      <%= render "shared/ad_slot", slot: "sidebar" %>
    </div>
  </div>
</div>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Blog", url: blog_url },
  { name: @post.title, url: blog_post_url(@post.slug) }
]) %>

<%= article_schema(
  title: @post.title,
  description: @post.meta_description.presence || @post.excerpt,
  url: blog_post_url(@post.slug),
  published_at: @post.published_at
) %>

<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Blog", url: blog_path },
  { name: @post.title }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <%# Leaderboard ad above article %>
    <div class="mb-6"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <article class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 md:p-10 lg:p-12">
      <div class="flex items-center gap-3 mb-4">
        <% if @post.category.present? %>
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"><%= @post.category.capitalize %></span>
        <% end %>
        <time class="text-sm text-gray-500 dark:text-gray-400" datetime="<%= @post.published_at.iso8601 %>"><%= @post.published_at.strftime("%B %d, %Y") %></time>
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-8 tracking-tight"><%= @post.title %></h1>

      <div class="prose dark:prose-invert max-w-none">
        <%= sanitize @post.body, tags: %w[p h2 h3 h4 ul ol li a strong em br hr blockquote code pre img sup sub span div table thead tbody tr th td], attributes: %w[href class id target rel src alt width height] %>
      </div>

      <%# Social sharing %>
      <%= render "shared/social_share", title: @post.title, url: blog_post_url(@post.slug) %>
    </article>

    <%# In-content ad below article %>
    <div class="mt-8"><%= render "shared/ad_slot", slot: "in_content" %></div>

    <%# Related calculators for this blog post's category %>
    <% if @post.category.present? %>
      <% blog_calcs = calculators_for_category(@post.category).sample(4).map { |c| c.merge(path: resolve_calculator_path(c)) } %>
      <%= render "shared/blog_related_calculators", calculators: blog_calcs %>
    <% end %>

    <%# Newsletter signup %>
    <%= render "shared/newsletter_signup" %>

    <%# Multiplex ad — recommended content style grid %>
    <div class="mt-8"><%= render "shared/ad_slot", slot: "multiplex" %></div>
  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24 space-y-6">
      <%# Popular calculators sidebar %>
      <%= render "shared/sidebar_popular" %>
      <%# Sidebar ad %>
      <%= render "shared/ad_slot", slot: "sidebar" %>
    </div>
  </div>
</div>

<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "IT Tools" }
] %>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "IT Tools", url: it_tools_url }
]) %>

<section class="mb-12">
  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight">IT Tools</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 max-w-3xl leading-relaxed">Free online tools for developers, sysadmins, and IT professionals. Generators, converters, formatters, decoders, and network utilities. Everything runs in your browser with no sign-up required.</p>
  </div>

  <%# Ad: leaderboard %>
  <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

  <div class="lg:grid lg:grid-cols-3 lg:gap-8">
    <div class="lg:col-span-2">

      <%# Security & Crypto %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-red-500 to-rose-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Security & Cryptography</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[password-generator password-strength-calculator secure-random-generator hash-generator hmac-generator ssl-certificate-decoder].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Encoding & Conversion %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-blue-500 to-indigo-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Encoding & Conversion</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[string-encoder-decoder base64-image-encoder html-entity-encoder-decoder escape-unescape-tool uuid-generator qr-code-generator base64-encoder-decoder url-encoder-decoder hex-ascii-converter].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Ad: mid-page %>
      <div class="mb-10"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <%# Data Format Tools %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-emerald-500 to-teal-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Data Format Tools</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[json-formatter yaml-to-json-converter csv-to-json-converter json-to-csv-converter json-to-yaml-converter json-to-typescript-generator xml-to-json-converter sql-formatter code-minifier-beautifier].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Code Formatters %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-orange-500 to-red-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Code Formatters</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[html-formatter-beautifier css-formatter-beautifier javascript-formatter-beautifier html-to-jsx-converter].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# File Converters %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-amber-500 to-orange-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">File Converters</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[csv-to-excel-converter excel-to-csv-converter markdown-to-html-converter html-to-markdown-converter txt-to-pdf-converter csv-to-pdf-converter markdown-to-pdf-converter excel-to-pdf-converter docx-to-pdf-converter odt-to-docx-converter odt-to-pdf-converter docx-to-odt-converter].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Networking %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-cyan-500 to-blue-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Networking</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[cidr-subnet-calculator ip-address-lookup dns-lookup mac-address-lookup port-number-reference url-parser].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Web & HTTP %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-violet-500 to-purple-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Web & HTTP</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[http-header-parser cors-header-checker csp-header-builder jwt-decoder color-converter color-palette-picker http-status-code-reference open-graph-preview curl-to-code-converter].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# DevOps & Config %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-sky-500 to-indigo-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">DevOps & Configuration</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[nginx-config-generator dockerfile-generator gitignore-generator env-variable-validator cron-expression-parser cron-job-generator chmod-calculator robots-txt-generator htaccess-generator].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Text & Code %>
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-8 bg-gradient-to-b from-pink-500 to-rose-600 rounded-full"></div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight">Text & Code</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <% %w[regex-builder regex-tester word-counter character-counter case-converter remove-duplicates text-diff-checker lorem-ipsum-generator markdown-preview markdown-table-generator unix-timestamp-converter regex-explainer svg-to-png-converter].each do |slug| %>
            <% tool = @tools.find { |t| t[:slug] == slug } %>
            <%= render "shared/calculator_card", calculator: tool if tool %>
          <% end %>
        </div>
      </div>

      <%# Multiplex ad %>
      <div class="mt-8"><%= render "shared/ad_slot", slot: "multiplex" %></div>
    </div>

    <%# Sidebar %>
    <div class="hidden lg:block">
      <div class="sticky top-24 space-y-6">
        <%= render "shared/ad_slot", slot: "sidebar" %>
      </div>
    </div>
  </div>
</section>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Time-Lapse Interval Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate the perfect shooting interval, total number of frames, and storage needs for your time-lapse project.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="timelapse-interval-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="tl-event" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Event Duration (minutes)</label>
            <input id="tl-event" type="number" inputmode="decimal" data-timelapse-interval-calculator-target="eventDuration" data-action="input->timelapse-interval-calculator#calculate" class="w-full" placeholder="120" step="1" min="1">
          </div>
          <div>
            <label for="tl-video" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Desired Video Length (seconds)</label>
            <input id="tl-video" type="number" inputmode="decimal" data-timelapse-interval-calculator-target="finalVideoSeconds" data-action="input->timelapse-interval-calculator#calculate" class="w-full" placeholder="30" step="1" min="1">
          </div>
          <div>
            <label for="tl-fps" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Playback Frame Rate (fps)</label>
            <input id="tl-fps" type="number" inputmode="decimal" data-timelapse-interval-calculator-target="playbackFps" data-action="input->timelapse-interval-calculator#calculate" class="w-full" placeholder="24" step="1" min="1" value="24">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Shooting Interval</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultInterval">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Frames</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultTotalFrames">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Video Duration</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultVideoDuration">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Event Duration</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultEventDuration">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Speed Factor</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultSpeedFactor">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">

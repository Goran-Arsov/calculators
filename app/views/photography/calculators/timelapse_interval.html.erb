              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultStorageJpeg">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Storage (RAW)</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-timelapse-interval-calculator-target="resultStorageRaw">&mdash;</span>
            </div>
          </div>
          <button data-action="click->timelapse-interval-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>

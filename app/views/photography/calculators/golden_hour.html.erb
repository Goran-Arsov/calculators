            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Day Length</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-golden-hour-calculator-target="resultDayLength">&mdash;</span>
            </div>
          </div>

          <h3 class="text-base font-semibold text-gray-900 dark:text-white mt-5 mb-3">Morning Golden Hour</h3>
          <div class="flex justify-between items-center text-sm">
            <span class="text-gray-600 dark:text-gray-400" data-golden-hour-calculator-target="resultMorningGoldenStart">&mdash;</span>
            <span class="text-gray-400">to</span>
            <span class="text-gray-600 dark:text-gray-400" data-golden-hour-calculator-target="resultMorningGoldenEnd">&mdash;</span>
          </div>

          <h3 class="text-base font-semibold text-gray-900 dark:text-white mt-4 mb-3">Evening Golden Hour</h3>
          <div class="flex justify-between items-center text-sm">
            <span class="text-gray-600 dark:text-gray-400" data-golden-hour-calculator-target="resultEveningGoldenStart">&mdash;</span>
            <span class="text-gray-400">to</span>
            <span class="text-gray-600 dark:text-gray-400" data-golden-hour-calculator-target="resultEveningGoldenEnd">&mdash;</span>
          </div>

          <h3 class="text-base font-semibold text-gray-900 dark:text-white mt-4 mb-3">Morning Blue Hour</h3>
          <div class="flex justify-between items-center text-sm">
            <span class="text-gray-600 dark:text-gray-400" data-golden-hour-calculator-target="resultMorningBlueStart">&mdash;</span>

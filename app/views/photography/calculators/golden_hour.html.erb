<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Sunset & Golden Hour Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Find the exact golden hour, blue hour, sunrise, and sunset times for your location to plan the perfect photography session.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="golden-hour-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="gh-lat" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Latitude</label>
            <input id="gh-lat" type="number" inputmode="decimal" data-golden-hour-calculator-target="latitude" data-action="input->golden-hour-calculator#calculate" class="w-full" placeholder="40.7128" step="0.0001" min="-90" max="90">
            <p class="text-xs text-gray-400 mt-1">Positive = North, Negative = South</p>
          </div>
          <div>
            <label for="gh-lon" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Longitude</label>
            <input id="gh-lon" type="number" inputmode="decimal" data-golden-hour-calculator-target="longitude" data-action="input->golden-hour-calculator#calculate" class="w-full" placeholder="-74.0060" step="0.0001" min="-180" max="180">
            <p class="text-xs text-gray-400 mt-1">Positive = East, Negative = West</p>
          </div>
          <div>
            <label for="gh-date" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Date</label>
            <input id="gh-date" type="date" data-golden-hour-calculator-target="date" data-action="input->golden-hour-calculator#calculate" class="w-full">
          </div>
          <div>
            <label for="gh-tz" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Timezone Offset (UTC)</label>
            <input id="gh-tz" type="number" inputmode="decimal" data-golden-hour-calculator-target="timezoneOffset" data-action="input->golden-hour-calculator#calculate" class="w-full" placeholder="0" step="0.5" min="-12" max="14" value="0">
            <p class="text-xs text-gray-400 mt-1">e.g. EST = -5, CET = 1, JST = 9</p>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Sun Times</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Sunrise</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-golden-hour-calculator-target="resultSunrise">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Sunset</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-golden-hour-calculator-target="resultSunset">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Solar Noon</span>

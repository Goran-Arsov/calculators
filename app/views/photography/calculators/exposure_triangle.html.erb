<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Exposure Triangle Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Change one exposure setting and instantly see the equivalent values for the others to maintain the same exposure.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="exposure-triangle-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Current Exposure</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div>
          <label for="et-cur-iso" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">ISO</label>
          <input id="et-cur-iso" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="currentIso" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="100" step="1" min="1">
        </div>
        <div>
          <label for="et-cur-aperture" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Aperture (f-number)</label>
          <input id="et-cur-aperture" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="currentAperture" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="5.6" step="0.1" min="0.7">
        </div>
        <div>
          <label for="et-cur-shutter" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Shutter Speed (seconds)</label>
          <input id="et-cur-shutter" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="currentShutter" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="0.008" step="any" min="0.000001">
          <p class="text-xs text-gray-400 mt-1">e.g. 1/125 = 0.008</p>
        </div>
      </div>

      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">New Exposure</h2>
      <div class="mb-4">
        <label for="et-solve" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Solve For</label>
        <select id="et-solve" data-exposure-triangle-calculator-target="solveFor" data-action="change->exposure-triangle-calculator#calculate" class="w-full">
          <option value="shutter">Shutter Speed</option>
          <option value="aperture">Aperture</option>
          <option value="iso">ISO</option>
        </select>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div>
          <label for="et-new-iso" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">New ISO</label>
          <input id="et-new-iso" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="newIso" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="200" step="1" min="1">
        </div>
        <div>
          <label for="et-new-aperture" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">New Aperture</label>
          <input id="et-new-aperture" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="newAperture" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="2.8" step="0.1" min="0.7">
        </div>
        <div>
          <label for="et-new-shutter" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">New Shutter Speed (s)</label>
          <input id="et-new-shutter" type="number" inputmode="decimal" data-exposure-triangle-calculator-target="newShutter" data-action="input->exposure-triangle-calculator#calculate" class="w-full" placeholder="0.004" step="any" min="0.000001">
        </div>
      </div>

      <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Equivalent Exposure</h2>
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Exposure Value (EV)</span>
            <span class="text-xl font-bold text-green-600 dark:text-green-400" data-exposure-triangle-calculator-target="resultEv">&mdash;</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">ISO</span>
            <span class="text-xl font-bold text-green-600 dark:text-green-400" data-exposure-triangle-calculator-target="resultIso">&mdash;</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Aperture</span>
            <span class="text-xl font-bold text-green-600 dark:text-green-400" data-exposure-triangle-calculator-target="resultAperture">&mdash;</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Shutter Speed</span>
            <span class="text-xl font-bold text-green-600 dark:text-green-400" data-exposure-triangle-calculator-target="resultShutter">&mdash;</span>
          </div>
        </div>
        <button data-action="click->exposure-triangle-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>

            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Size (GB)</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-video-file-size-calculator-target="resultFileSizeGb">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Video Data</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-video-file-size-calculator-target="resultVideoSize">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Audio Data</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-video-file-size-calculator-target="resultAudioSize">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Frames</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-video-file-size-calculator-target="resultTotalFrames">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">

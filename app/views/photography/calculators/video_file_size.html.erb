<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Video File Size Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate how much storage space your video will use based on bitrate, duration, and codec settings.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="video-file-size-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="vfs-bitrate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Video Bitrate (Mbps)</label>
            <input id="vfs-bitrate" type="number" inputmode="decimal" data-video-file-size-calculator-target="bitrate" data-action="input->video-file-size-calculator#calculate" class="w-full" placeholder="50" step="0.1" min="0.1">
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="vfs-duration" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Duration</label>
              <input id="vfs-duration" type="number" inputmode="decimal" data-video-file-size-calculator-target="duration" data-action="input->video-file-size-calculator#calculate" class="w-full" placeholder="60" step="1" min="1">
            </div>
            <div>
              <label for="vfs-duration-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit</label>
              <select id="vfs-duration-unit" data-video-file-size-calculator-target="durationUnit" data-action="change->video-file-size-calculator#calculate" class="w-full">
                <option value="seconds">Seconds</option>
                <option value="minutes" selected>Minutes</option>
                <option value="hours">Hours</option>
              </select>
            </div>
          </div>
          <div>
            <label for="vfs-codec" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Codec</label>
            <select id="vfs-codec" data-video-file-size-calculator-target="codec" data-action="change->video-file-size-calculator#calculate" class="w-full">
              <option value="h264">H.264 (AVC)</option>
              <option value="h265">H.265 (HEVC)</option>
              <option value="prores_422">ProRes 422</option>
              <option value="prores_4444">ProRes 4444</option>
              <option value="av1">AV1</option>
              <option value="vp9">VP9</option>
              <option value="raw">RAW</option>
            </select>
          </div>
          <div>
            <label for="vfs-fps" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Frame Rate (fps)</label>
            <input id="vfs-fps" type="number" inputmode="decimal" data-video-file-size-calculator-target="frameRate" data-action="input->video-file-size-calculator#calculate" class="w-full" placeholder="30" step="1" min="1" value="30">
          </div>
          <div>
            <label for="vfs-audio" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Audio Bitrate (kbps)</label>
            <input id="vfs-audio" type="number" inputmode="decimal" data-video-file-size-calculator-target="audioBitrate" data-action="input->video-file-size-calculator#calculate" class="w-full" placeholder="320" step="1" min="0" value="320">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">

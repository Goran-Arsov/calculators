          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity ($)</label>
            <input type="number" inputmode="decimal" data-date-night-budget-calculator-target="activity" data-action="input->date-night-budget-calculator#calculate" class="w-full" value="30" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Transport ($)</label>
            <input type="number" inputmode="decimal" data-date-night-budget-calculator-target="transport" data-action="input->date-night-budget-calculator#calculate" class="w-full" value="15" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Extras / babysitter ($)</label>
            <input type="number" inputmode="decimal" data-date-night-budget-calculator-target="extras" data-action="input->date-night-budget-calculator#calculate" class="w-full" value="20" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Dates per month</label>
            <input type="number" inputmode="numeric" data-date-night-budget-calculator-target="dates" data-action="input->date-night-budget-calculator#calculate" class="w-full" value="4" step="1" min="1">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-pink-50 to-orange-50 dark:from-pink-900/20 dark:to-orange-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Date Night Budget</h2>
          <div class="space-y-3">
            <div>
              <span class="text-gray-600 dark:text-gray-400 text-sm block">Per date</span>
              <span class="text-3xl font-extrabold text-pink-700 dark:text-pink-400" data-date-night-budget-calculator-target="resultPerDate">—</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-pink-200/50 dark:border-pink-800/50">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Monthly</span>
              <span class="text-xl font-bold text-pink-700 dark:text-pink-400" data-date-night-budget-calculator-target="resultMonthly">—</span>
            </div>
            <div class="flex justify-between items-center">

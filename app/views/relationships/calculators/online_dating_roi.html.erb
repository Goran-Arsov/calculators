<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Online Dating ROI Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">How long does online dating actually take? Enter your weekly message volume, response rate, date conversion, and relationship rate to see how many messages, dates, and hours it'll take to find a relationship.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="online-dating-roi-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Messages sent per week</label>
            <input type="number" inputmode="numeric" data-online-dating-roi-calculator-target="messages" data-action="input->online-dating-roi-calculator#calculate" class="w-full" value="20" step="1" min="1">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Response rate (%)</label>
            <input type="number" inputmode="decimal" data-online-dating-roi-calculator-target="responseRate" data-action="input->online-dating-roi-calculator#calculate" class="w-full" value="20" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Response → date conversion (%)</label>
            <input type="number" inputmode="decimal" data-online-dating-roi-calculator-target="dateRate" data-action="input->online-dating-roi-calculator#calculate" class="w-full" value="25" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Date → relationship rate (%)</label>
            <input type="number" inputmode="decimal" data-online-dating-roi-calculator-target="relRate" data-action="input->online-dating-roi-calculator#calculate" class="w-full" value="10" step="any" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-cyan-50 to-blue-50 dark:from-cyan-900/20 dark:to-blue-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Your ROI</h2>
          <div class="space-y-2">
            <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Responses/week</span><span class="font-bold text-cyan-700 dark:text-cyan-400" data-online-dating-roi-calculator-target="resultResponses">—</span></div>
            <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Dates/week</span><span class="font-bold text-cyan-700 dark:text-cyan-400" data-online-dating-roi-calculator-target="resultDates">—</span></div>
            <div class="flex justify-between items-center pt-3 border-t border-cyan-200/50 dark:border-cyan-800/50">
              <span class="text-gray-700 dark:text-gray-300 text-sm">Time to a relationship</span>
              <span class="text-base font-extrabold text-cyan-700 dark:text-cyan-400" data-online-dating-roi-calculator-target="resultWeeks">—</span>
            </div>
            <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Total messages</span><span class="font-bold text-cyan-700 dark:text-cyan-400" data-online-dating-roi-calculator-target="resultMessages">—</span></div>

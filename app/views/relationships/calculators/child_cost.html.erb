            <div class="text-xs text-gray-500 mt-1">total to age 18</div>
          </div>
          <div class="space-y-2 pt-3 border-t border-emerald-200/50 dark:border-emerald-800/50">
            <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Per child</span><span class="font-bold text-emerald-700 dark:text-emerald-400" data-child-cost-calculator-target="resultPerChild">—</span></div>
            <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Monthly per child</span><span class="font-bold text-emerald-700 dark:text-emerald-400" data-child-cost-calculator-target="resultMonthly">—</span></div>

              <option value="middle" selected>Middle ($60K–$130K)</option>
              <option value="high">Higher (over $130K)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cost of living</label>

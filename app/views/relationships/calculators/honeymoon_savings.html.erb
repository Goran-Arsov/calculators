<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Honeymoon Savings Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">How much do you need to save for your honeymoon? Enter your target cost, current savings, and how many months until your wedding to see exactly how much to put aside each month, week, and day.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="honeymoon-savings-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Target cost ($)</label>
            <input type="number" inputmode="decimal" data-honeymoon-savings-calculator-target="target" data-action="input->honeymoon-savings-calculator#calculate" class="w-full" value="5000" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current savings ($)</label>
            <input type="number" inputmode="decimal" data-honeymoon-savings-calculator-target="current" data-action="input->honeymoon-savings-calculator#calculate" class="w-full" value="500" step="any" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Months available</label>
            <input type="number" inputmode="numeric" data-honeymoon-savings-calculator-target="months" data-action="input->honeymoon-savings-calculator#calculate" class="w-full" value="12" step="1" min="1">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-teal-50 to-cyan-50 dark:from-teal-900/20 dark:to-cyan-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Savings Plan</h2>
          <div class="space-y-3">
            <div>
              <span class="text-gray-600 dark:text-gray-400 text-sm block">Save per month</span>
              <span class="text-3xl font-extrabold text-teal-700 dark:text-teal-400" data-honeymoon-savings-calculator-target="resultMonthly">—</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-teal-200/50 dark:border-teal-800/50 text-sm"><span class="text-gray-600 dark:text-gray-400">Per week</span><span class="font-bold text-teal-700 dark:text-teal-400" data-honeymoon-savings-calculator-target="resultWeekly">—</span></div>
            <div class="flex justify-between items-center text-sm"><span class="text-gray-600 dark:text-gray-400">Per day</span><span class="font-bold text-teal-700 dark:text-teal-400" data-honeymoon-savings-calculator-target="resultDaily">—</span></div>
            <div class="flex justify-between items-center text-sm"><span class="text-gray-600 dark:text-gray-400">Gap to goal</span><span class="font-bold text-teal-700 dark:text-teal-400" data-honeymoon-savings-calculator-target="resultGap">—</span></div>
            <div class="text-sm font-semibold text-teal-700 dark:text-teal-400 pt-2 border-t border-teal-200/50 dark:border-teal-800/50" data-honeymoon-savings-calculator-target="resultStatus">—</div>
          </div>
          <button data-action="click->honeymoon-savings-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-teal-600 to-cyan-600 hover:from-teal-700 hover:to-cyan-700 text-white rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2 text-sm font-medium">Copy Result</button>

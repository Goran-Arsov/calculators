<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Meat Cooking Time Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate cooking time for beef, pork, chicken, turkey, and lamb by cut, weight, doneness, and method.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="meat-cooking-time-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Units</label>
            <select data-meat-cooking-time-calculator-target="unitSystem" data-action="change->meat-cooking-time-calculator#switchUnits" class="w-full">
              <option value="imperial">Imperial (lbs, °F)</option>
              <option value="metric">Metric (kg, °C)</option>
            </select>
          </div>
          <div>
            <label for="mct-meat" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Meat Type</label>
            <select id="mct-meat" class="w-full" data-meat-cooking-time-calculator-target="meatType" data-action="change->meat-cooking-time-calculator#updateCutOptions">
              <option value="">Select meat...</option>
              <option value="beef">Beef</option>
              <option value="pork">Pork</option>
              <option value="chicken">Chicken</option>
              <option value="turkey">Turkey</option>
              <option value="lamb">Lamb</option>
            </select>
          </div>
          <div>
            <label for="mct-cut" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cut</label>
            <select id="mct-cut" class="w-full" data-meat-cooking-time-calculator-target="cutOptions" data-action="change->meat-cooking-time-calculator#updateDonenessOptions">
              <option value="">Select cut...</option>
            </select>
          </div>
          <div>
            <label for="mct-doneness" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Doneness</label>
            <select id="mct-doneness" class="w-full" data-meat-cooking-time-calculator-target="donenessOptions" data-action="change->meat-cooking-time-calculator#updateMethodOptions">
              <option value="">Select doneness...</option>
            </select>
          </div>
          <div>
            <label for="mct-method" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cooking Method</label>
            <select id="mct-method" class="w-full" data-meat-cooking-time-calculator-target="methodOptions" data-action="change->meat-cooking-time-calculator#calculate">
              <option value="">Select method...</option>
            </select>
          </div>
          <div>
            <label for="mct-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5"><span data-meat-cooking-time-calculator-target="weightLabel">Weight (lbs)</span></label>
            <input id="mct-weight" type="number" inputmode="decimal" min="0.1" step="0.1" placeholder="5" class="w-full" data-meat-cooking-time-calculator-target="weight" data-action="input->meat-cooking-time-calculator#calculate">
          </div>
        </div>

        <div data-meat-cooking-time-calculator-target="results" class="hidden" aria-live="polite" aria-atomic="true">
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Cooking Guide</h2>
            <div class="space-y-3">
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Estimated Time</span><span class="text-xl font-bold text-green-700 dark:text-green-400" data-meat-cooking-time-calculator-target="totalTime">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Target Internal Temp</span><span class="text-xl font-bold text-green-700 dark:text-green-400" data-meat-cooking-time-calculator-target="internalTemp">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Rest Time</span><span class="text-xl font-bold text-green-700 dark:text-green-400" data-meat-cooking-time-calculator-target="restTime">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Rate</span><span class="text-xl font-bold text-green-700 dark:text-green-400" data-meat-cooking-time-calculator-target="minutesPerLb">--</span></div>
            </div>
            <button data-action="click->meat-cooking-time-calculator#copy" class="mt-4 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm transition-all duration-200 text-sm font-medium">Copy Results</button>
          </div>
        </div>

              <option value="beef">Beef</option>
              <option value="pork">Pork</option>
              <option value="poultry">Poultry</option>
              <option value="seafood">Seafood</option>
              <option value="dairy">Dairy</option>
              <option value="bread_baked_goods">Bread & Baked Goods</option>
              <option value="fruits_vegetables">Fruits & Vegetables</option>
              <option value="prepared_foods">Prepared Foods</option>
            </select>
          </div>
          <div>
            <label for="fs-item" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Food Item</label>
            <select id="fs-item" class="w-full" data-freezer-storage-calculator-target="foodItemOptions" data-action="change->freezer-storage-calculator#calculate">
              <option value="">Select food item...</option>
            </select>
          </div>
        </div>

        <div data-freezer-storage-calculator-target="results" class="hidden" aria-live="polite" aria-atomic="true">

              <p class="text-sm text-gray-700 dark:text-gray-300" data-freezer-storage-calculator-target="note">--</p>
            </div>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">General Freezer Tips</h3>
            <ul data-freezer-storage-calculator-target="tips" class="space-y-1 list-disc list-inside"></ul>
            <button data-action="click->freezer-storage-calculator#copy" class="mt-4 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm transition-all duration-200 text-sm font-medium">Copy Results</button>

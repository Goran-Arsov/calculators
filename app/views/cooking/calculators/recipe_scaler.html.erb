          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Scaled Recipe</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Multiplier: <span class="font-bold text-green-700 dark:text-green-400" data-recipe-scaler-calculator-target="multiplier">--</span></p>

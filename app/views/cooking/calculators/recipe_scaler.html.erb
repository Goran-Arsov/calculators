        </div>
        <div>
          <label for="rs-desired" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Desired Servings</label>
          <input id="rs-desired" type="number" inputmode="numeric" min="1" step="1" placeholder="8" class="w-full" data-recipe-scaler-calculator-target="desiredServings" data-action="input->recipe-scaler-calculator#calculate">
        </div>
      </div>

      <div class="mb-4">
        <div class="flex justify-between items-center mb-2">
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400">Ingredients</label>
          <button type="button" data-action="click->recipe-scaler-calculator#addIngredient" class="text-sm text-green-600 hover:text-green-700 font-medium">+ Add Ingredient</button>
        </div>
        <div class="grid grid-cols-12 gap-2 mb-1 text-xs text-gray-400">
          <span class="col-span-5">Name</span>
          <span class="col-span-3">Amount</span>
          <span class="col-span-3">Unit</span>
          <span class="col-span-1"></span>
        </div>
        <div data-recipe-scaler-calculator-target="ingredientRows"></div>
      </div>

      <div data-recipe-scaler-calculator-target="results" class="hidden" aria-live="polite" aria-atomic="true">

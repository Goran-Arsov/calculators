            <option value="white_sugar">White Sugar</option>
            <option value="egg">Egg</option>
            <option value="buttermilk">Buttermilk</option>
          </select>
        </div>
        <div>
          <label for="bs-to" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Substitute With</label>
          <select id="bs-to" class="w-full" data-baking-substitution-calculator-target="toOptions" data-action="change->baking-substitution-calculator#calculate">

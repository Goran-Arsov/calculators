          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Substitute Amount</span>
              <span class="text-xl font-bold text-green-700 dark:text-green-400" data-baking-substitution-calculator-target="convertedAmount">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Conversion Ratio</span>
              <span class="text-xl font-bold text-green-700 dark:text-green-400" data-baking-substitution-calculator-target="ratio">--</span>
            </div>

              <p class="text-xs text-gray-500 dark:text-gray-400 font-semibold">What to actually measure:</p>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Added Flour</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="addedFlour">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Added Water</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="addedWater">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Salt</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="salt">--</span></div>
              <hr class="border-gray-200 dark:border-gray-700">
              <p class="text-xs text-gray-400">(Starter flour: <span data-sourdough-hydration-calculator-target="starterFlour">--</span>, Starter water: <span data-sourdough-hydration-calculator-target="starterWater">--</span>)</p>
            </div>
            <button data-action="click->sourdough-hydration-calculator#copy" class="mt-4 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm transition-all duration-200 text-sm font-medium">Copy Results</button>

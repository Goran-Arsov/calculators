<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Sourdough Hydration Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate precise flour, water, starter, and salt amounts using baker's percentages for perfect sourdough every time.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="sourdough-hydration-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <div>
            <label for="sh-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total Dough Weight (g)</label>
            <input id="sh-weight" type="number" inputmode="decimal" min="100" step="10" placeholder="900" class="w-full" data-sourdough-hydration-calculator-target="totalDoughWeight" data-action="input->sourdough-hydration-calculator#calculate">
          </div>
          <div>
            <label for="sh-hydration" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Target Hydration (%)</label>
            <input id="sh-hydration" type="number" inputmode="decimal" min="50" max="100" step="1" placeholder="72" class="w-full" data-sourdough-hydration-calculator-target="targetHydration" data-action="input->sourdough-hydration-calculator#calculate">
          </div>
          <div>
            <label for="sh-starter-pct" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Starter (% of flour)</label>
            <input id="sh-starter-pct" type="number" inputmode="decimal" min="5" max="50" step="1" placeholder="20" class="w-full" data-sourdough-hydration-calculator-target="starterPercentage" data-action="input->sourdough-hydration-calculator#calculate">
          </div>
          <div>
            <label for="sh-starter-hyd" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Starter Hydration (%)</label>
            <input id="sh-starter-hyd" type="number" inputmode="decimal" min="50" max="200" step="1" value="100" placeholder="100" class="w-full" data-sourdough-hydration-calculator-target="starterHydration" data-action="input->sourdough-hydration-calculator#calculate">
          </div>
          <div>
            <label for="sh-salt" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Salt (% of flour)</label>
            <input id="sh-salt" type="number" inputmode="decimal" min="0" max="5" step="0.1" value="2" placeholder="2" class="w-full" data-sourdough-hydration-calculator-target="saltPercentage" data-action="input->sourdough-hydration-calculator#calculate">
          </div>
        </div>

        <div data-sourdough-hydration-calculator-target="results" class="hidden" aria-live="polite" aria-atomic="true">
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Recipe</h2>
            <div class="space-y-3">
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Total Flour</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="totalFlour">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Total Water</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="totalWater">--</span></div>
              <div class="flex justify-between"><span class="text-gray-600 dark:text-gray-400">Starter</span><span class="font-bold text-green-700 dark:text-green-400" data-sourdough-hydration-calculator-target="starterAmount">--</span></div>

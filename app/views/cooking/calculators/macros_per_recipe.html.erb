<%# SEO meta tags %>
<% set_meta_tags(
  title: "Macros per Recipe Calculator - Nutrition per Serving",
  description: "Calculate total and per-serving macronutrients (calories, protein, carbs, fat) for any recipe. Get macro percentages and per-serving breakdowns instantly.",
  canonical: cooking_macros_per_recipe_url,
  og: {
    title: "Macros per Recipe Calculator - Free Online Tool | Calc Hammer",
    description: "Calculate total and per-serving macros for any recipe. Calories, protein, carbs, fat with macro percentages.",
    url: cooking_macros_per_recipe_url,
    type: "website",
    site_name: "Calc Hammer"
  }
) %>

<%= breadcrumb_schema([
  { name: "Home", url: root_url },
  { name: "Cooking", url: category_url("cooking") },
  { name: "Macros per Recipe Calculator", url: cooking_macros_per_recipe_url }
]) %>

<%= faq_schema([
  { question: "How do I calculate macros for a recipe?", answer: "Add up the calories, protein, carbs, and fat from each ingredient using nutrition labels or a food database. Divide each total by the number of servings to get per-serving macros. Multiply each ingredient's per-unit nutrition by the quantity used." },
  { question: "What is a good macro ratio?", answer: "It depends on your goals. A balanced diet typically splits calories as 30% protein, 40% carbs, 30% fat. For muscle building, try 35-40% protein, 30-40% carbs, 20-30% fat. For keto, aim for 70-75% fat, 20-25% protein, 5-10% carbs." },
  { question: "How many calories are in each macronutrient?", answer: "Protein has 4 calories per gram, carbohydrates have 4 calories per gram, and fat has 9 calories per gram. Alcohol has 7 calories per gram. These values are used to calculate the macro percentage split." },
  { question: "Do I need to weigh ingredients for accurate macros?", answer: "Yes, weighing ingredients with a kitchen scale is the most accurate method. Volume measurements (cups, tablespoons) can vary by 10-30% depending on how densely the ingredient is packed. A food scale costs $10-15 and dramatically improves accuracy." },
  { question: "Where can I find nutrition data for ingredients?", answer: "The USDA FoodData Central database (fdc.nal.usda.gov) is the most comprehensive free resource. Nutrition labels on packaged foods are also reliable. Popular apps like MyFitnessPal and Cronometer have extensive food databases." }
]) %>

<%= calculator_schema_with_ratings(
  name: "Macros per Recipe Calculator",
  description: "Calculate total and per-serving macronutrients for any recipe.",
  url: cooking_macros_per_recipe_url,
  category: "LifestyleApplication",
  calculator_slug: "macros-per-recipe"
) %>

<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Cooking", url: category_path("cooking") },
  { name: "Macros per Recipe Calculator" }
] %>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Macros per Recipe Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate total and per-serving calories, protein, carbs, and fat for any recipe with macro percentage breakdown.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="macros-per-recipe-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="mb-4">
        <label for="mpr-servings" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Servings</label>
        <input id="mpr-servings" type="number" inputmode="numeric" min="1" step="1" placeholder="4" class="w-full md:w-48" data-macros-per-recipe-calculator-target="servings" data-action="input->macros-per-recipe-calculator#calculate">
      </div>

      <div class="mb-4">
        <div class="flex justify-between items-center mb-2">
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400">Ingredients</label>
          <button type="button" data-action="click->macros-per-recipe-calculator#addIngredient" class="text-sm text-green-600 hover:text-green-700 font-medium">+ Add Ingredient</button>
        </div>
        <div class="grid grid-cols-12 gap-2 mb-1 text-xs text-gray-400">
          <span class="col-span-2">Name</span>
          <span class="col-span-2">Qty</span>
          <span class="col-span-2">Calories</span>
          <span class="col-span-2">Protein(g)</span>
          <span class="col-span-2">Carbs(g)</span>
          <span class="col-span-1">Fat(g)</span>
          <span class="col-span-1"></span>
        </div>
        <div data-macros-per-recipe-calculator-target="ingredientRows"></div>
      </div>

      <div data-macros-per-recipe-calculator-target="results" class="hidden" aria-live="polite" aria-atomic="true">
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6 mt-4">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Nutrition Summary</h2>

          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Total Recipe</h3>
              <div class="space-y-1.5">
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Calories</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="totalCalories">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Protein</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="totalProtein">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Carbs</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="totalCarbs">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Fat</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="totalFat">--</span></div>
              </div>
            </div>
            <div>
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Per Serving</h3>
              <div class="space-y-1.5">
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Calories</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="perCalories">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Protein</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="perProtein">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Carbs</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="perCarbs">--</span></div>
                <div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">Fat</span><span class="font-bold text-green-700 dark:text-green-400" data-macros-per-recipe-calculator-target="perFat">--</span></div>
              </div>
            </div>
          </div>

          <div class="border-t border-gray-200 dark:border-gray-700 pt-3">
            <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Macro Split (by calories)</h3>
            <div class="flex gap-4 text-sm">
              <span class="text-blue-600 dark:text-blue-400 font-bold">P: <span data-macros-per-recipe-calculator-target="proteinPct">--</span></span>
              <span class="text-amber-600 dark:text-amber-400 font-bold">C: <span data-macros-per-recipe-calculator-target="carbsPct">--</span></span>
              <span class="text-red-600 dark:text-red-400 font-bold">F: <span data-macros-per-recipe-calculator-target="fatPct">--</span></span>
            </div>
          </div>

          <button data-action="click->macros-per-recipe-calculator#copy" class="mt-4 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm transition-all duration-200 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <%= render "shared/calculator_rating", slug: "macros-per-recipe" %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "in_results" %></div>

    <article class="prose dark:prose-invert max-w-none">
      <h2>How to Use the Macros per Recipe Calculator</h2>
      <p>
        Enter the number of servings your recipe makes, then add each ingredient with its quantity, calories, protein, carbs, and fat per unit. Get this information from nutrition labels or the USDA FoodData Central database. The calculator sums all macronutrients across ingredients, divides by servings for per-serving values, and computes the macro percentage split based on calorie contribution.
      </p>
      <p>
        This calculator is invaluable for anyone tracking macros, following a specific diet plan, or simply wanting to understand the nutritional content of their home-cooked meals. By calculating macros before cooking, you can adjust ingredient quantities to hit your target ratios.
      </p>

      <div class="my-6"><%= render "shared/ad_slot", slot: "in_content" %></div>

      <h2>Understanding Macronutrients</h2>
      <p>
        The three macronutrients, protein, carbohydrates, and fat, provide all the energy (calories) in your food. Protein and carbs each provide 4 calories per gram, while fat provides 9 calories per gram. The macro percentage split shows what proportion of total calories comes from each macronutrient. This is the most useful metric for comparing your meals to dietary guidelines or personal macro targets.
      </p>

      <h3>Setting Macro Targets</h3>
      <p>
        Your ideal macro split depends on your goals. A balanced general diet might target 30% protein, 40% carbs, and 30% fat. Athletes and those building muscle often increase protein to 35-40%. Ketogenic diets flip the ratio to 70-75% fat, 20-25% protein, and only 5-10% carbs. Use this calculator to see how your actual recipes compare to your targets.
      </p>

      <h2>Frequently Asked Questions</h2>

      <h3>How do I calculate macros for a recipe?</h3>
      <p>Add up calories, protein, carbs, and fat from each ingredient, then divide by servings for per-serving macros.</p>

      <h3>What is a good macro ratio?</h3>
      <p>Balanced: 30/40/30 (P/C/F). Muscle building: 35-40/30-40/20-30. Keto: 20-25/5-10/70-75.</p>

      <h3>How many calories are in each macronutrient?</h3>
      <p>Protein: 4 cal/g. Carbs: 4 cal/g. Fat: 9 cal/g. Alcohol: 7 cal/g.</p>

      <h3>Do I need to weigh ingredients for accurate macros?</h3>
      <p>Yes, a kitchen scale is the most accurate method. Volume measurements can vary by 10-30%.</p>

      <h3>Where can I find nutrition data for ingredients?</h3>
      <p>USDA FoodData Central (fdc.nal.usda.gov), nutrition labels, or apps like MyFitnessPal and Cronometer.</p>
    </article>

    <%= render "shared/print_button" %>
    <%= render "shared/calculation_email_capture" %>

    <%= render "shared/related_calculators", related: [
      { name: "Meal Prep Cost Calculator", description: "Calculate cost per serving for your meal prep.", path: cooking_meal_prep_cost_path, icon_path: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
      { name: "Recipe Scaler", description: "Scale recipe ingredients up or down by servings.", path: cooking_recipe_scaler_path, icon_path: "M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" },
      { name: "Baking Substitution Calculator", description: "Find substitutions for common baking ingredients.", path: cooking_baking_substitution_path, icon_path: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" }
    ] %>

    <%= render "shared/calculator_disclaimer", category: "cooking" %>
  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

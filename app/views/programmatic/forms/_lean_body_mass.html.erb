    <div data-controller="lean-body-mass-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="lean-body-mass-calculation-method" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculation Method</label>
            <select id="lean-body-mass-calculation-method" data-lean-body-mass-calculator-target="method" data-action="change->lean-body-mass-calculator#updateMethod" class="w-full" aria-label="Calculation Method">
              <option value="body_fat">From Body Fat Percentage</option>
              <option value="formula">From Height & Weight (Formula)</option>
            </select>
          </div>
          <div>
            <label for="lean-body-mass-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="lean-body-mass-unit-system" data-lean-body-mass-calculator-target="unitSystem" data-action="change->lean-body-mass-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg, cm)</option>
              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label for="lean-body-mass-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-lean-body-mass-calculator-target="weightLabel">Weight (kg)</label>
            <input id="lean-body-mass-weight" type="number" data-lean-body-mass-calculator-target="weight" data-action="input->lean-body-mass-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div class="field-group">
            <label for="lean-body-mass-body-fat-percentage" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Body Fat Percentage (%)</label>
            <input id="lean-body-mass-body-fat-percentage" type="number" data-lean-body-mass-calculator-target="bodyFatPct" data-action="input->lean-body-mass-calculator#calculate" class="w-full" placeholder="20" step="0.1" min="1" max="70">
          </div>
          <div data-lean-body-mass-calculator-target="formulaFields" class="space-y-4 hidden">
            <div>
              <label for="lean-body-mass-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
              <select id="lean-body-mass-gender" data-lean-body-mass-calculator-target="gender" data-action="change->lean-body-mass-calculator#calculate" class="w-full" aria-label="Gender">
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </div>
            <div>
              <label for="lean-body-mass-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-lean-body-mass-calculator-target="heightLabel">Height (cm)</label>
              <input id="lean-body-mass-height" type="number" data-lean-body-mass-calculator-target="height" data-action="input->lean-body-mass-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
            </div>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Lean Body Mass</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="leanMass">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fat Mass</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="fatMass">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Body Fat %</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="bodyFatResult">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Lean %</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="leanPct">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="formula-row flex justify-between items-center hidden">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Boer Formula</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="boer">—</span>
            </div>
            <div class="formula-row flex justify-between items-center hidden">
              <span class="text-gray-600 dark:text-gray-400 text-sm">James Formula</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="james">—</span>
            </div>
            <div class="formula-row flex justify-between items-center hidden">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Hume Formula</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-lean-body-mass-calculator-target="hume">—</span>
            </div>
          </div>
          <button data-action="click->lean-body-mass-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

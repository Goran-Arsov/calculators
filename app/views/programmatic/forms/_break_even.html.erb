    <div data-controller="break-even-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="break-even-fixed-costs" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fixed Costs ($)</label>
            <input id="break-even-fixed-costs" type="number" inputmode="decimal" data-break-even-calculator-target="fixedCosts" data-action="input->break-even-calculator#calculate" class="w-full" placeholder="50000" step="any" min="0">
          </div>
          <div>
            <label for="break-even-price-per-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price per Unit ($)</label>
            <input id="break-even-price-per-unit" type="number" inputmode="decimal" data-break-even-calculator-target="pricePerUnit" data-action="input->break-even-calculator#calculate" class="w-full" placeholder="25" step="any" min="0">
          </div>
          <div>
            <label for="break-even-variable-cost-per-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Variable Cost per Unit ($)</label>
            <input id="break-even-variable-cost-per-unit" type="number" inputmode="decimal" data-break-even-calculator-target="variableCost" data-action="input->break-even-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Break-Even Units</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-break-even-calculator-target="resultUnits">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Break-Even Revenue</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-break-even-calculator-target="resultRevenue">$0.00</span>
            </div>
          </div>
          <button data-action="click->break-even-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

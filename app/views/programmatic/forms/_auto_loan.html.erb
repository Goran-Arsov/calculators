    <div data-controller="auto-loan-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="auto-loan-vehicle-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vehicle Price ($)</label>
            <input id="auto-loan-vehicle-price" type="number" inputmode="decimal" data-auto-loan-calculator-target="vehiclePrice" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="35000" step="500" min="0">
          </div>
          <div>
            <label for="auto-loan-down-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Down Payment ($)</label>
            <input id="auto-loan-down-payment" type="number" inputmode="decimal" data-auto-loan-calculator-target="downPayment" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="5000" step="500" min="0">
          </div>
          <div>
            <label for="auto-loan-trade-in-value" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Trade-in Value ($)</label>
            <input id="auto-loan-trade-in-value" type="number" inputmode="decimal" data-auto-loan-calculator-target="tradeInValue" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="3000" step="500" min="0">
          </div>
          <div>
            <label for="auto-loan-sales-tax-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sales Tax Rate (%)</label>
            <input id="auto-loan-sales-tax-rate" type="number" inputmode="decimal" data-auto-loan-calculator-target="salesTaxRate" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="6.25" step="0.01" min="0">
          </div>
          <div>
            <label for="auto-loan-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Interest Rate (%)</label>
            <input id="auto-loan-interest-rate" type="number" inputmode="decimal" data-auto-loan-calculator-target="rate" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="6.5" step="0.01" min="0">
          </div>
          <div>
            <label for="auto-loan-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Months)</label>
            <select id="auto-loan-loan-term" data-auto-loan-calculator-target="termMonths" data-action="change->auto-loan-calculator#calculate" class="w-full" aria-label="Loan Term (Months)">
              <option value="24">24 months (2 years)</option>
              <option value="36">36 months (3 years)</option>
              <option value="48">48 months (4 years)</option>
              <option value="60" selected>60 months (5 years)</option>
              <option value="72">72 months (6 years)</option>
              <option value="84">84 months (7 years)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Loan Amount</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-auto-loan-calculator-target="loanAmount">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Sales Tax</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-auto-loan-calculator-target="salesTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Monthly Payment</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-auto-loan-calculator-target="monthlyPayment">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Interest</span>
              <span class="text-xl font-bold text-red-600 dark:text-red-400" data-auto-loan-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Cost</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-auto-loan-calculator-target="totalCost">$0.00</span>
            </div>
          </div>
          <button data-action="click->auto-loan-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="bac-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="bac-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="bac-unit-system" data-bac-calculator-target="unitSystem" data-action="change->bac-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg)</option>
              <option value="imperial">Imperial (lbs)</option>
            </select>
          </div>
          <div>
            <label for="bac-number-of-standard-drinks" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Standard Drinks</label>
            <input id="bac-number-of-standard-drinks" type="number" data-bac-calculator-target="drinks" data-action="input->bac-calculator#calculate" class="w-full" placeholder="3" step="0.5" min="0">
          </div>
          <div>
            <label for="bac-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bac-calculator-target="weightLabel">Weight (kg)</label>
            <input id="bac-weight" type="number" data-bac-calculator-target="weight" data-action="input->bac-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="bac-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
            <select id="bac-gender" data-bac-calculator-target="gender" data-action="change->bac-calculator#calculate" class="w-full" aria-label="Gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="bac-hours-since-first-drink" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Hours Since First Drink</label>
            <input id="bac-hours-since-first-drink" type="number" data-bac-calculator-target="hours" data-action="input->bac-calculator#calculate" class="w-full" placeholder="1" step="0.5" min="0" value="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Estimated BAC</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-bac-calculator-target="bac">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Status</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-bac-calculator-target="status">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Time Until Sober</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-bac-calculator-target="hoursUntilSober">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div>
              <span class="text-gray-600 dark:text-gray-400 text-sm">Impairment Level</span>
              <p class="text-sm font-medium text-gray-900 dark:text-white mt-1" data-bac-calculator-target="impairment">—</p>
            </div>
          </div>
          <button data-action="click->bac-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

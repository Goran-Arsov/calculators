    <div data-controller="bmi-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="bmi-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="bmi-unit-system" data-bmi-calculator-target="unitSystem" data-action="change->bmi-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg, cm)</option>
              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label for="bmi-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bmi-calculator-target="weightLabel">Weight (kg)</label>
            <input id="bmi-weight" type="number" data-bmi-calculator-target="weight" data-action="input->bmi-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="bmi-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-bmi-calculator-target="heightLabel">Height (cm)</label>
            <input id="bmi-height" type="number" data-bmi-calculator-target="height" data-action="input->bmi-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Your BMI</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="bmi">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Category</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="category">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Healthy Weight Min</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="healthyMin">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Healthy Weight Max</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-bmi-calculator-target="healthyMax">&mdash;</span>
            </div>
          </div>
          <button data-action="click->bmi-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

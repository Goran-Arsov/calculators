    <div data-controller="dog-age-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="dog-age-dog-s-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Dog's Age (years)</label>
            <input id="dog-age-dog-s-age" type="number" data-dog-age-calculator-target="dogAge" data-action="input->dog-age-calculator#calculate" class="w-full" placeholder="5" step="0.5" min="0" max="30">
          </div>
          <div>
            <label for="dog-age-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Size</label>
            <select id="dog-age-size" data-dog-age-calculator-target="size" data-action="change->dog-age-calculator#calculate" class="w-full" aria-label="Size">
              <option value="small">Small (under 10 kg / 22 lbs)</option>
              <option value="medium">Medium (10-25 kg / 22-55 lbs)</option>
              <option value="large">Large (over 25 kg / 55 lbs)</option>
            </select>
          </div>
        </div>
        <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Result</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Human Age Equivalent</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-dog-age-calculator-target="humanAge">— years</span>
            </div>
          </div>
          <button data-action="click->dog-age-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Result</button>
        </div>
      </div>
    </div>

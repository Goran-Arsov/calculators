    <div data-controller="currency-converter-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="currency-converter-amount" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Amount</label>
            <input id="currency-converter-amount" type="number" inputmode="decimal" data-currency-converter-calculator-target="amount" data-action="input->currency-converter-calculator#calculate" class="w-full" placeholder="1000" step="0.01" min="0">
          </div>
          <div>
            <label for="currency-converter-from-currency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">From Currency</label>
            <select id="currency-converter-from-currency" data-currency-converter-calculator-target="fromCurrency" data-action="change->currency-converter-calculator#calculate" class="w-full" aria-label="From Currency">
              <option value="USD" selected>USD - US Dollar</option>
              <option value="EUR">EUR - Euro</option>
              <option value="GBP">GBP - British Pound</option>
              <option value="JPY">JPY - Japanese Yen</option>
              <option value="CAD">CAD - Canadian Dollar</option>
              <option value="AUD">AUD - Australian Dollar</option>
              <option value="CHF">CHF - Swiss Franc</option>
              <option value="CNY">CNY - Chinese Yuan</option>
              <option value="INR">INR - Indian Rupee</option>
              <option value="MXN">MXN - Mexican Peso</option>
              <option value="BRL">BRL - Brazilian Real</option>
              <option value="KRW">KRW - South Korean Won</option>
              <option value="SEK">SEK - Swedish Krona</option>
              <option value="NOK">NOK - Norwegian Krone</option>
              <option value="NZD">NZD - New Zealand Dollar</option>
              <option value="SGD">SGD - Singapore Dollar</option>
              <option value="HKD">HKD - Hong Kong Dollar</option>
              <option value="TRY">TRY - Turkish Lira</option>
              <option value="ZAR">ZAR - South African Rand</option>
              <option value="AED">AED - UAE Dirham</option>
            </select>
          </div>

          <%# Swap button %>
          <div class="flex justify-center">
            <button data-action="click->currency-converter-calculator#swap" class="p-2 rounded-full bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" title="Swap currencies" aria-label="Swap currencies">
              <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>
            </button>
          </div>

          <div>
            <label for="currency-converter-to-currency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">To Currency</label>
            <select id="currency-converter-to-currency" data-currency-converter-calculator-target="toCurrency" data-action="change->currency-converter-calculator#calculate" class="w-full" aria-label="To Currency">
              <option value="USD">USD - US Dollar</option>
              <option value="EUR" selected>EUR - Euro</option>
              <option value="GBP">GBP - British Pound</option>
              <option value="JPY">JPY - Japanese Yen</option>
              <option value="CAD">CAD - Canadian Dollar</option>
              <option value="AUD">AUD - Australian Dollar</option>
              <option value="CHF">CHF - Swiss Franc</option>
              <option value="CNY">CNY - Chinese Yuan</option>
              <option value="INR">INR - Indian Rupee</option>
              <option value="MXN">MXN - Mexican Peso</option>
              <option value="BRL">BRL - Brazilian Real</option>
              <option value="KRW">KRW - South Korean Won</option>
              <option value="SEK">SEK - Swedish Krona</option>
              <option value="NOK">NOK - Norwegian Krone</option>
              <option value="NZD">NZD - New Zealand Dollar</option>
              <option value="SGD">SGD - Singapore Dollar</option>
              <option value="HKD">HKD - Hong Kong Dollar</option>
              <option value="TRY">TRY - Turkish Lira</option>
              <option value="ZAR">ZAR - South African Rand</option>
              <option value="AED">AED - UAE Dirham</option>
            </select>
          </div>
        </div>

        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-4">
            <div>
              <span class="block text-sm text-gray-500 dark:text-gray-400 mb-1">Converted Amount</span>
              <span class="text-3xl font-bold text-blue-600 dark:text-blue-400" data-currency-converter-calculator-target="convertedAmount">0.00</span>
            </div>
            <div class="pt-4 border-t border-blue-200/50 dark:border-blue-800/50 space-y-2">
              <div>
                <span class="block text-sm text-gray-500 dark:text-gray-400 mb-1">Exchange Rate</span>
                <span class="text-lg font-semibold text-gray-900 dark:text-white" data-currency-converter-calculator-target="exchangeRate">&mdash;</span>
              </div>
              <div>
                <span class="block text-sm text-gray-500 dark:text-gray-400 mb-1">Inverse Rate</span>
                <span class="text-lg font-semibold text-gray-900 dark:text-white" data-currency-converter-calculator-target="inverseRate">&mdash;</span>
              </div>
            </div>
          </div>
          <div class="mt-4 p-3 bg-amber-50 dark:bg-amber-900/20 rounded-xl border border-amber-200/50 dark:border-amber-800/50">
            <p class="text-xs text-amber-700 dark:text-amber-400">Rates are approximate and may not reflect current market values. For actual transactions, consult your bank or a live rate provider.</p>
          </div>
          <button data-action="click->currency-converter-calculator#copy" class="mt-4 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

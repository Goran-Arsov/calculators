    <div data-controller="tdee-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="tdee-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Weight (kg)</label>
            <input id="tdee-weight" type="number" data-tdee-calculator-target="weight" data-action="input->tdee-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="tdee-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Height (cm)</label>
            <input id="tdee-height" type="number" data-tdee-calculator-target="height" data-action="input->tdee-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
          </div>
          <div>
            <label for="tdee-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age (years)</label>
            <input id="tdee-age" type="number" data-tdee-calculator-target="age" data-action="input->tdee-calculator#calculate" class="w-full" placeholder="30" step="1" min="1" max="120">
          </div>
          <div>
            <label for="tdee-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
            <select id="tdee-gender" data-tdee-calculator-target="gender" data-action="change->tdee-calculator#calculate" class="w-full" aria-label="Gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="tdee-activity-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select id="tdee-activity-level" data-tdee-calculator-target="activityLevel" data-action="change->tdee-calculator#calculate" class="w-full" aria-label="Activity Level">
              <option value="sedentary">Sedentary (little or no exercise)</option>
              <option value="light">Lightly Active (1-3 days/week)</option>
              <option value="moderate">Moderately Active (3-5 days/week)</option>
              <option value="active">Very Active (6-7 days/week)</option>
              <option value="extra">Extra Active (intense daily + physical job)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Basal Metabolic Rate</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-tdee-calculator-target="bmr">— cal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">TDEE</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-tdee-calculator-target="tdee">— cal</span>
            </div>
          </div>
          <button data-action="click->tdee-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="tax-bracket-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="tax-bracket-filing-status" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Filing Status</label>
            <select id="tax-bracket-filing-status" data-tax-bracket-calculator-target="filingStatus" data-action="change->tax-bracket-calculator#calculate" class="w-full" aria-label="Filing Status">
              <option value="">Select filing status</option>
              <option value="single">Single</option>
              <option value="married_filing_jointly">Married Filing Jointly</option>
              <option value="married_filing_separately">Married Filing Separately</option>
              <option value="head_of_household">Head of Household</option>
            </select>
          </div>
          <div>
            <label for="tax-bracket-taxable-income" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Taxable Income ($)</label>
            <input id="tax-bracket-taxable-income" type="number" data-tax-bracket-calculator-target="income" data-action="input->tax-bracket-calculator#calculate" class="w-full" placeholder="85000" step="100" min="0">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Federal Tax</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tax-bracket-calculator-target="totalTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Effective Tax Rate</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tax-bracket-calculator-target="effectiveRate">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Marginal Tax Rate</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tax-bracket-calculator-target="marginalRate">0%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">After-Tax Income</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-tax-bracket-calculator-target="afterTaxIncome">$0.00</span>
            </div>
          </div>
          <button data-action="click->tax-bracket-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>

      <%# Bracket breakdown table %>
      <div class="mt-8">
        <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-4">Bracket Breakdown</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-700">
                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Rate</th>
                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Income Range</th>
                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Taxable</th>
                <th class="py-2.5 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Tax</th>
              </tr>
            </thead>
            <tbody data-tax-bracket-calculator-target="breakdownBody">
            </tbody>
          </table>
        </div>
      </div>
    </div>

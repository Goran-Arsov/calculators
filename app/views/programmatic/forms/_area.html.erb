    <div data-controller="area-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="area-shape" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Shape</label>
            <select id="area-shape" data-area-calculator-target="shape" data-action="change->area-calculator#updateFields" class="w-full" aria-label="Shape">
              <option value="rectangle">Rectangle</option>
              <option value="triangle">Triangle</option>
              <option value="circle">Circle</option>
              <option value="trapezoid">Trapezoid</option>
              <option value="ellipse">Ellipse</option>
            </select>
          </div>

          <%# Rectangle fields %>
          <div data-area-calculator-target="rectangleFields">
            <div class="space-y-4">
              <div>
                <label for="area-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Length</label>
                <input id="area-length" type="number" inputmode="decimal" data-area-calculator-target="length" data-action="input->area-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
              </div>
              <div>
                <label for="area-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Width</label>
                <input id="area-width" type="number" inputmode="decimal" data-area-calculator-target="width" data-action="input->area-calculator#calculate" class="w-full" placeholder="5" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Triangle fields %>
          <div data-area-calculator-target="triangleFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-base" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base</label>
                <input id="area-base" type="number" inputmode="decimal" data-area-calculator-target="base" data-action="input->area-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
              </div>
              <div>
                <label for="area-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Height</label>
                <input id="area-height" type="number" inputmode="decimal" data-area-calculator-target="height" data-action="input->area-calculator#calculate" class="w-full" placeholder="6" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Circle fields %>
          <div data-area-calculator-target="circleFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-radius" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Radius</label>
                <input id="area-radius" type="number" inputmode="decimal" data-area-calculator-target="radius" data-action="input->area-calculator#calculate" class="w-full" placeholder="7" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Trapezoid fields %>
          <div data-area-calculator-target="trapezoidFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-base-1" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base 1</label>
                <input id="area-base-1" type="number" inputmode="decimal" data-area-calculator-target="base1" data-action="input->area-calculator#calculate" class="w-full" placeholder="8" step="any" min="0">
              </div>
              <div>
                <label for="area-base-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base 2</label>
                <input id="area-base-2" type="number" inputmode="decimal" data-area-calculator-target="base2" data-action="input->area-calculator#calculate" class="w-full" placeholder="5" step="any" min="0">
              </div>
              <div>
                <label for="area-height-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Height</label>
                <input id="area-height-2" type="number" inputmode="decimal" data-area-calculator-target="trapezoidHeight" data-action="input->area-calculator#calculate" class="w-full" placeholder="4" step="any" min="0">
              </div>
            </div>
          </div>

          <%# Ellipse fields %>
          <div data-area-calculator-target="ellipseFields" class="hidden">
            <div class="space-y-4">
              <div>
                <label for="area-semi-major-axis" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Semi-Major Axis (a)</label>
                <input id="area-semi-major-axis" type="number" inputmode="decimal" data-area-calculator-target="semiMajor" data-action="input->area-calculator#calculate" class="w-full" placeholder="10" step="any" min="0">
              </div>
              <div>
                <label for="area-semi-minor-axis" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Semi-Minor Axis (b)</label>
                <input id="area-semi-minor-axis" type="number" inputmode="decimal" data-area-calculator-target="semiMinor" data-action="input->area-calculator#calculate" class="w-full" placeholder="6" step="any" min="0">
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Result</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-area-calculator-target="result">0</span>
            </div>
          </div>
          <button data-action="click->area-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Result</button>
        </div>
      </div>
    </div>

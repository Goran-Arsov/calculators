    <div data-controller="gpa-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Grade</span>
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Credits</span>
          </div>
          <% 6.times do |i| %>
            <div class="grid grid-cols-2 gap-3">
              <select data-gpa-calculator-target="grade<%= i + 1 %>" data-action="change->gpa-calculator#calculate" class="w-full" aria-label="Grade for course <%= i + 1 %>">
                <option value="" selected>--</option>
                <option value="4.0">A</option>
                <option value="3.7">A-</option>
                <option value="3.3">B+</option>
                <option value="3.0">B</option>
                <option value="2.7">B-</option>
                <option value="2.3">C+</option>
                <option value="2.0">C</option>
                <option value="1.7">C-</option>
                <option value="1.3">D+</option>
                <option value="1.0">D</option>
                <option value="0.0">F</option>
              </select>
              <input type="number" data-gpa-calculator-target="credits<%= i + 1 %>" data-action="input->gpa-calculator#calculate" class="w-full" placeholder="3" step="1" min="0" max="12">
            </div>
          <% end %>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">GPA</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gpa-calculator-target="resultGpa">0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Credits</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gpa-calculator-target="resultTotalCredits">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Quality Points</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gpa-calculator-target="resultQualityPoints">0.00</span>
            </div>
          </div>
          <button data-action="click->gpa-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="fence-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="fence-total-fence-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total Fence Length (ft)</label>
            <input id="fence-total-fence-length" type="number" data-fence-calculator-target="length" data-action="input->fence-calculator#calculate" class="w-full" placeholder="100" step="1" min="0">
          </div>
          <div>
            <label for="fence-fence-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fence Height (ft)</label>
            <input id="fence-fence-height" type="number" data-fence-calculator-target="height" data-action="input->fence-calculator#calculate" class="w-full" value="6" step="0.5" min="1">
          </div>
          <div>
            <label for="fence-post-spacing" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Post Spacing (ft)</label>
            <input id="fence-post-spacing" type="number" data-fence-calculator-target="spacing" data-action="input->fence-calculator#calculate" class="w-full" value="8" step="0.5" min="1">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Posts</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fence-calculator-target="resultPosts">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Rails</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fence-calculator-target="resultRails">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pickets</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fence-calculator-target="resultPickets">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Sections</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fence-calculator-target="resultSections">0</span>
            </div>
          </div>
          <button data-action="click->fence-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="screen-size-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="screen-size-diagonal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Diagonal (inches)</label>
            <input id="screen-size-diagonal" type="number" inputmode="decimal" data-screen-size-calculator-target="diagonal" data-action="input->screen-size-calculator#calculate" class="w-full" placeholder="27" step="0.1" min="0">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="screen-size-aspect-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Aspect Width</label>
              <input id="screen-size-aspect-width" type="number" inputmode="decimal" data-screen-size-calculator-target="aspectWidth" data-action="input->screen-size-calculator#calculate" class="w-full" placeholder="16" step="1" min="1" value="16">
            </div>
            <div>
              <label for="screen-size-aspect-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Aspect Height</label>
              <input id="screen-size-aspect-height" type="number" inputmode="decimal" data-screen-size-calculator-target="aspectHeight" data-action="input->screen-size-calculator#calculate" class="w-full" placeholder="9" step="1" min="1" value="9">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="screen-size-horizontal-res" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Horizontal Res (px)</label>
              <input id="screen-size-horizontal-res" type="number" inputmode="decimal" data-screen-size-calculator-target="resH" data-action="input->screen-size-calculator#calculate" class="w-full" placeholder="1920" step="1" min="0">
            </div>
            <div>
              <label for="screen-size-vertical-res" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vertical Res (px)</label>
              <input id="screen-size-vertical-res" type="number" inputmode="decimal" data-screen-size-calculator-target="resV" data-action="input->screen-size-calculator#calculate" class="w-full" placeholder="1080" step="1" min="0">
            </div>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Width</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultWidth">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Height</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultHeight">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultArea">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Aspect Ratio</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultAspect">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Resolution</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultResolution">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pixel Density</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-screen-size-calculator-target="resultPpi">--</span>
            </div>
          </div>
          <button data-action="click->screen-size-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="estate-tax-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="estate-tax-total-estate-value" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total Estate Value ($)</label>
            <input id="estate-tax-total-estate-value" type="number" inputmode="decimal" data-estate-tax-calculator-target="estateValue" data-action="input->estate-tax-calculator#calculate" class="w-full" placeholder="15000000" step="100000" min="0">
          </div>
          <div>
            <label for="estate-tax-filing-status" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Filing Status</label>
            <select id="estate-tax-filing-status" data-estate-tax-calculator-target="filingStatus" data-action="change->estate-tax-calculator#calculate" class="w-full">
              <option value="single" selected>Single / Individual</option>
              <option value="married">Married (with portability)</option>
            </select>
          </div>
          <div>
            <label for="estate-tax-deductions" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Deductions ($)</label>
            <input id="estate-tax-deductions" type="number" inputmode="decimal" data-estate-tax-calculator-target="deductions" data-action="input->estate-tax-calculator#calculate" class="w-full" placeholder="0" step="10000" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Estate Tax</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-estate-tax-calculator-target="estateTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Effective Rate</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-estate-tax-calculator-target="effectiveRate">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net to Heirs</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-estate-tax-calculator-target="netToHeirs">$0.00</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Exemption</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-estate-tax-calculator-target="exemption">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Taxable Estate</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-estate-tax-calculator-target="taxableEstate">$0.00</span>
            </div>
          </div>
          <button data-action="click->estate-tax-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

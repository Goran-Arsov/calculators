    <div data-controller="calorie-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="bulking-calories-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="bulking-calories-unit-system" data-calorie-calculator-target="unitSystem" data-action="change->calorie-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg, cm)</option>
              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label for="bulking-calories-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age (years)</label>
            <input id="bulking-calories-age" type="number" inputmode="decimal" data-calorie-calculator-target="age" data-action="input->calorie-calculator#calculate" class="w-full" placeholder="25" step="1" min="1" max="120">
          </div>
          <div>
            <label for="bulking-calories-sex" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sex</label>
            <select id="bulking-calories-sex" data-calorie-calculator-target="sex" data-action="change->calorie-calculator#calculate" class="w-full" aria-label="Sex">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="bulking-calories-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-calorie-calculator-target="weightLabel">Weight (kg)</label>
            <input id="bulking-calories-weight" type="number" inputmode="decimal" data-calorie-calculator-target="weight" data-action="input->calorie-calculator#calculate" class="w-full" placeholder="75" step="0.1" min="0">
          </div>
          <div>
            <label for="bulking-calories-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-calorie-calculator-target="heightLabel">Height (cm)</label>
            <input id="bulking-calories-height" type="number" inputmode="decimal" data-calorie-calculator-target="height" data-action="input->calorie-calculator#calculate" class="w-full" placeholder="178" step="0.1" min="0">
          </div>
          <div>
            <label for="bulking-calories-activity-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select id="bulking-calories-activity-level" data-calorie-calculator-target="activityLevel" data-action="change->calorie-calculator#calculate" class="w-full" aria-label="Activity Level">
              <option value="sedentary">Sedentary (little or no exercise)</option>
              <option value="light">Light (exercise 1-3 days/week)</option>
              <option value="moderate">Moderate (exercise 3-5 days/week)</option>
              <option value="active" selected>Active (exercise 6-7 days/week)</option>
              <option value="very_active">Very Active (intense exercise daily)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Basal Metabolic Rate</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-calorie-calculator-target="bmr">— cal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Maintenance (TDEE)</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-calorie-calculator-target="tdee">— cal</span>
            </div>
            <hr class="border-green-200 dark:border-green-800">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Mild Weight Loss (-0.25 kg/wk)</span>
              <span class="text-lg font-semibold text-green-600 dark:text-green-400" data-calorie-calculator-target="mildLoss">— cal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Weight Loss (-0.5 kg/wk)</span>
              <span class="text-lg font-semibold text-green-600 dark:text-green-400" data-calorie-calculator-target="weightLoss">— cal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Mild Weight Gain (+0.25 kg/wk)</span>
              <span class="text-lg font-semibold text-green-600 dark:text-green-400" data-calorie-calculator-target="mildGain">— cal</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Weight Gain (+0.5 kg/wk)</span>
              <span class="text-lg font-semibold text-green-600 dark:text-green-400" data-calorie-calculator-target="weightGain">— cal</span>
            </div>
          </div>
          <button data-action="click->calorie-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

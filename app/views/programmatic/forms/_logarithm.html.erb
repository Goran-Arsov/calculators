    <div data-controller="logarithm-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">log</div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Compute Logarithm</h2>
        <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">log<sub>b</sub>(x)</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="logarithm-value" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Value (x)</label>
            <input id="logarithm-value" type="number" inputmode="decimal" data-logarithm-calculator-target="value" data-action="input->logarithm-calculator#calculate" class="w-full" placeholder="100" step="any" min="0.0001">
          </div>
          <div>
            <label for="logarithm-base-e-for-ln-10-2-or-any-positive-number" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Base (b) <span class="font-normal text-gray-400">e for ln, 10, 2, or any positive number &ne; 1</span></label>
            <input id="logarithm-base-e-for-ln-10-2-or-any-positive-number" type="text" data-logarithm-calculator-target="base" data-action="input->logarithm-calculator#calculate" class="w-full" placeholder="e" value="e">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">log<sub>b</sub>(x)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-logarithm-calculator-target="result">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">ln(x)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-logarithm-calculator-target="ln">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">log<sub>10</sub>(x)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-logarithm-calculator-target="log10">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">log<sub>2</sub>(x)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-logarithm-calculator-target="log2">&mdash;</span>
            </div>
          </div>
          <button data-action="click->logarithm-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

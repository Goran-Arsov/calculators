    <div data-controller="unit-price-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="unit-price-unit-label" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit Label (optional)</label>
            <input id="unit-price-unit-label" type="text" data-unit-price-calculator-target="unit" data-action="input->unit-price-calculator#calculate" class="w-full" placeholder="oz, lb, count, etc." value="oz">
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 space-y-3">
            <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300">Product A</h3>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="unit-price-price" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Price ($)</label>
                <input id="unit-price-price" type="number" inputmode="decimal" data-unit-price-calculator-target="priceA" data-action="input->unit-price-calculator#calculate" class="w-full" placeholder="3.99" step="0.01" min="0">
              </div>
              <div>
                <label for="unit-price-quantity" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Quantity</label>
                <input id="unit-price-quantity" type="number" inputmode="decimal" data-unit-price-calculator-target="quantityA" data-action="input->unit-price-calculator#calculate" class="w-full" placeholder="12" step="0.01" min="0">
              </div>
            </div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 space-y-3">
            <h3 class="text-sm font-bold text-gray-700 dark:text-gray-300">Product B</h3>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="unit-price-price-2" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Price ($)</label>
                <input id="unit-price-price-2" type="number" inputmode="decimal" data-unit-price-calculator-target="priceB" data-action="input->unit-price-calculator#calculate" class="w-full" placeholder="5.49" step="0.01" min="0">
              </div>
              <div>
                <label for="unit-price-quantity-2" class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Quantity</label>
                <input id="unit-price-quantity-2" type="number" inputmode="decimal" data-unit-price-calculator-target="quantityB" data-action="input->unit-price-calculator#calculate" class="w-full" placeholder="24" step="0.01" min="0">
              </div>
            </div>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Product A Unit Price</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-unit-price-calculator-target="resultUnitPriceA">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Product B Unit Price</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-unit-price-calculator-target="resultUnitPriceB">--</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Better Deal</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-unit-price-calculator-target="resultBetterDeal">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Savings/Unit</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-unit-price-calculator-target="resultSavingsPerUnit">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Savings</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-unit-price-calculator-target="resultSavingsPercent">--</span>
            </div>
          </div>
          <button data-action="click->unit-price-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

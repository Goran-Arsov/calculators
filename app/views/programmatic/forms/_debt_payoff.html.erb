    <div data-controller="debt-payoff-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="balance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current Balance ($)</label>
            <input type="number" id="balance" min="0" step="100" value="15000" placeholder="e.g. 15000"
              data-debt-payoff-calculator-target="balance"
              data-action="input->debt-payoff-calculator#calculate"
              class="w-full">
          </div>
          <div>
            <label for="rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Interest Rate (%)</label>
            <input type="number" id="rate" min="0" max="50" step="0.1" value="18.9" placeholder="e.g. 18.9"
              data-debt-payoff-calculator-target="rate"
              data-action="input->debt-payoff-calculator#calculate"
              class="w-full">
          </div>
          <div>
            <label for="monthly-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Payment ($)</label>
            <input type="number" id="monthly-payment" min="0" step="10" value="400" placeholder="e.g. 400"
              data-debt-payoff-calculator-target="monthlyPayment"
              data-action="input->debt-payoff-calculator#calculate"
              class="w-full">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Months to Pay Off</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-debt-payoff-calculator-target="monthsToPayoff">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Years to Pay Off</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-debt-payoff-calculator-target="yearsToPayoff">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Total Amount Paid</span>
              <span class="text-lg font-bold text-green-600 dark:text-green-400" data-debt-payoff-calculator-target="totalPaid">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Total Interest Paid</span>
              <span class="text-lg font-bold text-red-600 dark:text-red-400" data-debt-payoff-calculator-target="totalInterest">$0.00</span>
            </div>
          </div>
          <button data-action="click->debt-payoff-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

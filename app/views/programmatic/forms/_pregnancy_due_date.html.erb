    <div data-controller="pregnancy-due-date-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="pregnancy-due-date-first-day-of-last-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">First Day of Last Period</label>
            <input id="pregnancy-due-date-first-day-of-last-period" type="date" data-pregnancy-due-date-calculator-target="lastPeriod" data-action="input->pregnancy-due-date-calculator#calculate" class="w-full">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Due Date</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-pregnancy-due-date-calculator-target="dueDate">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Conception Date</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-pregnancy-due-date-calculator-target="conceptionDate">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Weeks Pregnant</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-pregnancy-due-date-calculator-target="weeksPregnant">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Trimester</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-pregnancy-due-date-calculator-target="trimester">—</span>
            </div>
          </div>
          <button data-action="click->pregnancy-due-date-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

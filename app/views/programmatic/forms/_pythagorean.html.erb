    <div data-controller="pythagorean-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for c (hypotenuse) %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">c</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for c (Hypotenuse)</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">c = &radic;(a&sup2; + b&sup2;)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="pythagorean-side-a" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Side a</label>
            <input id="pythagorean-side-a" type="number" data-pythagorean-calculator-target="aForC" data-action="input->pythagorean-calculator#calcC" class="w-full" placeholder="3" step="any" min="0">
          </div>
          <div>
            <label for="pythagorean-side-b" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Side b</label>
            <input id="pythagorean-side-b" type="number" data-pythagorean-calculator-target="bForC" data-action="input->pythagorean-calculator#calcC" class="w-full" placeholder="4" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Hypotenuse c</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pythagorean-calculator-target="resultC" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for a %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">a</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for a</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">a = &radic;(c&sup2; &minus; b&sup2;)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="pythagorean-side-b-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Side b</label>
            <input id="pythagorean-side-b-2" type="number" data-pythagorean-calculator-target="bForA" data-action="input->pythagorean-calculator#calcA" class="w-full" placeholder="4" step="any" min="0">
          </div>
          <div>
            <label for="pythagorean-hypotenuse-c" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Hypotenuse c</label>
            <input id="pythagorean-hypotenuse-c" type="number" data-pythagorean-calculator-target="cForA" data-action="input->pythagorean-calculator#calcA" class="w-full" placeholder="5" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Side a</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-pythagorean-calculator-target="resultA" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for b %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">b</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for b</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">b = &radic;(c&sup2; &minus; a&sup2;)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="pythagorean-side-a-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Side a</label>
            <input id="pythagorean-side-a-2" type="number" data-pythagorean-calculator-target="aForB" data-action="input->pythagorean-calculator#calcB" class="w-full" placeholder="3" step="any" min="0">
          </div>
          <div>
            <label for="pythagorean-hypotenuse-c-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Hypotenuse c</label>
            <input id="pythagorean-hypotenuse-c-2" type="number" data-pythagorean-calculator-target="cForB" data-action="input->pythagorean-calculator#calcB" class="w-full" placeholder="5" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Side b</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-pythagorean-calculator-target="resultB" data-result>&mdash;</span>
          </div>
        </div>
      </div>
    </div>

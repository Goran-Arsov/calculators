    <div data-controller="paycheck-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="freelance-tax-annual-freelance-income" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Freelance Income ($)</label>
            <input id="freelance-tax-annual-freelance-income" type="number" data-paycheck-calculator-target="annualSalary" data-action="input->paycheck-calculator#calculate" class="w-full" placeholder="85000" step="1000" min="0">
            <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">Enter your gross self-employment income before deductions</p>
          </div>
          <div>
            <label for="freelance-tax-state-tax-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">State Tax Level</label>
            <select id="freelance-tax-state-tax-level" data-paycheck-calculator-target="stateTaxLevel" data-action="change->paycheck-calculator#calculate" class="w-full">
              <option value="none">None (0%)</option>
              <option value="low">Low (3%)</option>
              <option value="medium" selected>Medium (5%)</option>
              <option value="high">High (7%)</option>
              <option value="very_high">Very High (10%)</option>
            </select>
          </div>
          <div>
            <label for="freelance-tax-estimated-payment-frequency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Estimated Payment Frequency</label>
            <select id="freelance-tax-estimated-payment-frequency" data-paycheck-calculator-target="payFrequency" data-action="change->paycheck-calculator#calculate" class="w-full">
              <option value="weekly">Weekly (52/year)</option>
              <option value="biweekly">Biweekly (26/year)</option>
              <option value="semimonthly">Semi-Monthly (24/year)</option>
              <option value="monthly" selected>Monthly (12/year)</option>
            </select>
          </div>
          <div>
            <label for="freelance-tax-annual-business-deductions" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Business Deductions ($)</label>
            <input id="freelance-tax-annual-business-deductions" type="number" data-paycheck-calculator-target="preTaxDeductions" data-action="input->paycheck-calculator#calculate" class="w-full" placeholder="10000" step="500" min="0">
            <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">Home office, equipment, software, insurance, etc.</p>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Monthly Net Income</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="paycheckNet">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Monthly Gross Income</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="paycheckGross">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Net Income</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-paycheck-calculator-target="annualNet">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Gross Income</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="annualGross">$0.00</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Federal Tax</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="federalTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">State Tax</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="stateTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Social Security</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="socialSecurity">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Medicare</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="medicare">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total FICA / SE Tax</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="fica">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Deductions</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="totalDeductions">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Effective Tax Rate</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="effectiveTaxRate">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pay Periods/Year</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="payPeriods">0</span>
            </div>
          </div>
          <button data-action="click->paycheck-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

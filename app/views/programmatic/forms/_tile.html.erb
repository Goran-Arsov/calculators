    <div data-controller="tile-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="tile-area" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Area (sq ft)</label>
            <input id="tile-area" type="number" data-tile-calculator-target="area" data-action="input->tile-calculator#calculate" class="w-full" placeholder="100" step="0.1" min="0">
          </div>
          <div>
            <label for="tile-tile-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tile Length (inches)</label>
            <input id="tile-tile-length" type="number" data-tile-calculator-target="tileLength" data-action="input->tile-calculator#calculate" class="w-full" placeholder="12" step="0.25" min="0">
          </div>
          <div>
            <label for="tile-tile-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Tile Width (inches)</label>
            <input id="tile-tile-width" type="number" data-tile-calculator-target="tileWidth" data-action="input->tile-calculator#calculate" class="w-full" placeholder="12" step="0.25" min="0">
          </div>
          <div>
            <label for="tile-grout-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Grout Width (inches)</label>
            <input id="tile-grout-width" type="number" data-tile-calculator-target="groutWidth" data-action="input->tile-calculator#calculate" class="w-full" value="0.125" step="0.0625" min="0">
          </div>
          <div>
            <label for="tile-waste" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Waste (%)</label>
            <input id="tile-waste" type="number" data-tile-calculator-target="waste" data-action="input->tile-calculator#calculate" class="w-full" value="10" step="1" min="0" max="50">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Area + Waste</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tile-calculator-target="resultAreaWaste">0 sq ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Tiles Needed</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tile-calculator-target="resultTiles">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Grout</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tile-calculator-target="resultGrout">0 lbs</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Adhesive (50-lb bags)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-tile-calculator-target="resultAdhesive">0 bags</span>
            </div>
          </div>
          <button data-action="click->tile-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

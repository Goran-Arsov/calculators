    <div data-controller="keto-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="keto-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="keto-unit-system" data-keto-calculator-target="unitSystem" data-action="change->keto-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (kg, cm)</option>
              <option value="imperial">Imperial (lbs, in)</option>
            </select>
          </div>
          <div>
            <label for="keto-weight" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-keto-calculator-target="weightLabel">Weight (kg)</label>
            <input id="keto-weight" type="number" inputmode="decimal" data-keto-calculator-target="weight" data-action="input->keto-calculator#calculate" class="w-full" placeholder="70" step="0.1" min="0">
          </div>
          <div>
            <label for="keto-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-keto-calculator-target="heightLabel">Height (cm)</label>
            <input id="keto-height" type="number" inputmode="decimal" data-keto-calculator-target="height" data-action="input->keto-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
          </div>
          <div>
            <label for="keto-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age</label>
            <input id="keto-age" type="number" inputmode="decimal" data-keto-calculator-target="age" data-action="input->keto-calculator#calculate" class="w-full" placeholder="30" min="1" max="120">
          </div>
          <div>
            <label for="keto-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
            <select id="keto-gender" data-keto-calculator-target="gender" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="keto-activity-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Activity Level</label>
            <select id="keto-activity-level" data-keto-calculator-target="activityLevel" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Activity Level">
              <option value="sedentary">Sedentary (little or no exercise)</option>
              <option value="light">Lightly active (1-3 days/week)</option>
              <option value="moderate">Moderately active (3-5 days/week)</option>
              <option value="active">Very active (6-7 days/week)</option>
              <option value="very_active">Extra active (physical job + exercise)</option>
            </select>
          </div>
          <div>
            <label for="keto-goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Goal</label>
            <select id="keto-goal" data-keto-calculator-target="goal" data-action="change->keto-calculator#calculate" class="w-full" aria-label="Goal">
              <option value="maintain">Maintain Weight</option>
              <option value="lose">Lose Weight</option>
              <option value="gain">Gain Weight</option>
            </select>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Your Keto Macros</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Daily Calories</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-keto-calculator-target="dailyCalories">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fat</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400"><span data-keto-calculator-target="fatGrams">—</span> <span class="text-sm font-normal" data-keto-calculator-target="fatPercent"></span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Protein</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400"><span data-keto-calculator-target="proteinGrams">—</span> <span class="text-sm font-normal" data-keto-calculator-target="proteinPercent"></span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net Carbs</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400"><span data-keto-calculator-target="carbGrams">—</span> <span class="text-sm font-normal" data-keto-calculator-target="carbPercent"></span></span>
            </div>
          </div>
          <button data-action="click->keto-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="cd-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="cd-deposit-amount" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Deposit Amount ($)</label>
            <input id="cd-deposit-amount" type="number" data-cd-calculator-target="principal" data-action="input->cd-calculator#calculate" class="w-full" placeholder="10000" step="100" min="0">
          </div>
          <div>
            <label for="cd-apy" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">APY (%)</label>
            <input id="cd-apy" type="number" data-cd-calculator-target="apy" data-action="input->cd-calculator#calculate" class="w-full" placeholder="5.00" step="0.01" min="0">
          </div>
          <div>
            <label for="cd-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Term (Months)</label>
            <input id="cd-term" type="number" data-cd-calculator-target="termMonths" data-action="input->cd-calculator#calculate" class="w-full" placeholder="12" step="1" min="1" max="120">
          </div>
          <div>
            <label for="cd-compounding-frequency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Compounding Frequency</label>
            <select id="cd-compounding-frequency" data-cd-calculator-target="compounding" data-action="change->cd-calculator#calculate" class="w-full">
              <option value="daily" selected>Daily</option>
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="annually">Annually</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Maturity Value</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cd-calculator-target="maturityValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Interest Earned</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-cd-calculator-target="interestEarned">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">APY</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cd-calculator-target="effectiveApy">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Term Length</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cd-calculator-target="termDisplay">0</span>
            </div>
          </div>
          <button data-action="click->cd-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="home-affordability-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="home-affordability-annual-gross-income" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Gross Income ($)</label>
            <input id="home-affordability-annual-gross-income" type="number" data-home-affordability-calculator-target="annualIncome" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="85000" step="1000" min="0">
          </div>
          <div>
            <label for="home-affordability-monthly-debts" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Debts ($)</label>
            <input id="home-affordability-monthly-debts" type="number" data-home-affordability-calculator-target="monthlyDebts" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="500" step="50" min="0">
            <p class="text-xs text-gray-400 mt-1">Car payments, student loans, credit card minimums, etc.</p>
          </div>
          <div>
            <label for="home-affordability-down-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Down Payment ($)</label>
            <input id="home-affordability-down-payment" type="number" data-home-affordability-calculator-target="downPayment" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="60000" step="1000" min="0">
          </div>
          <div>
            <label for="home-affordability-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Interest Rate (%)</label>
            <input id="home-affordability-interest-rate" type="number" data-home-affordability-calculator-target="interestRate" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="6.75" step="0.01" min="0">
          </div>
          <div>
            <label for="home-affordability-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Years)</label>
            <input id="home-affordability-loan-term" type="number" data-home-affordability-calculator-target="loanTerm" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="30" step="1" min="1" max="50">
          </div>
          <div>
            <label for="home-affordability-property-tax-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Property Tax Rate (%)</label>
            <input id="home-affordability-property-tax-rate" type="number" data-home-affordability-calculator-target="propertyTaxRate" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="1.25" step="0.01" min="0">
          </div>
          <div>
            <label for="home-affordability-annual-homeowners-insurance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Homeowners Insurance ($)</label>
            <input id="home-affordability-annual-homeowners-insurance" type="number" data-home-affordability-calculator-target="annualInsurance" data-action="input->home-affordability-calculator#calculate" class="w-full" placeholder="1800" step="100" min="0">
          </div>
        </div>

        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center pb-3 border-b border-blue-200/50 dark:border-blue-800/50">
              <span class="text-gray-600 dark:text-gray-400">Max Home Price</span>
              <span class="text-2xl font-bold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="maxHomePrice">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Max Loan Amount</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="maxLoanAmount">$0.00</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-blue-200/50 dark:border-blue-800/50">
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Monthly Breakdown</span>
              <span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Principal & Interest</span>
              <span class="font-semibold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="monthlyPI">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Property Tax</span>
              <span class="font-semibold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="monthlyTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Insurance</span>
              <span class="font-semibold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="monthlyInsurance">$0.00</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-blue-200/50 dark:border-blue-800/50">
              <span class="text-gray-600 dark:text-gray-400">Total Monthly Payment</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="totalMonthlyPayment">$0.00</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-blue-200/50 dark:border-blue-800/50">
              <span class="text-gray-600 dark:text-gray-400">Front-End DTI</span>
              <span class="font-semibold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="frontEndDTI">0.0%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Back-End DTI</span>
              <span class="font-semibold text-blue-600 dark:text-blue-400" data-home-affordability-calculator-target="backEndDTI">0.0%</span>
            </div>
          </div>
          <button data-action="click->home-affordability-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

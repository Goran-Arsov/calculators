    <div data-controller="standard-deviation-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">&sigma;</div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Descriptive Statistics</h2>
        <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">&sigma; = &radic;(&Sigma;(x&minus;&mu;)&sup2; / N)</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="standard-deviation-data-values" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Data Values (comma-separated)</label>
            <input id="standard-deviation-data-values" type="text" data-standard-deviation-calculator-target="values" data-action="input->standard-deviation-calculator#calculate" class="w-full" placeholder="10, 20, 30, 40, 50">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Count</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="count">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Mean</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="mean">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Std Dev (Population)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="stdDev">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Variance</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="variance">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Min</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="min">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Max</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="max">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Range</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-standard-deviation-calculator-target="range">&mdash;</span>
            </div>
          </div>
          <button data-action="click->standard-deviation-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="blood-pressure-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="blood-pressure-systolic" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Systolic (top number, mmHg)</label>
            <input id="blood-pressure-systolic" type="number" inputmode="decimal" data-blood-pressure-calculator-target="systolic" data-action="input->blood-pressure-calculator#calculate" class="w-full" placeholder="120" min="60" max="300">
          </div>
          <div>
            <label for="blood-pressure-diastolic" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Diastolic (bottom number, mmHg)</label>
            <input id="blood-pressure-diastolic" type="number" inputmode="decimal" data-blood-pressure-calculator-target="diastolic" data-action="input->blood-pressure-calculator#calculate" class="w-full" placeholder="80" min="30" max="200">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Category</span>
              <span class="text-xl font-bold text-gray-400" data-blood-pressure-calculator-target="category">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Risk Level</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-blood-pressure-calculator-target="riskLevel">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pulse Pressure</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-blood-pressure-calculator-target="pulsePressure">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Mean Arterial Pressure</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-blood-pressure-calculator-target="map">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div>
              <span class="text-gray-600 dark:text-gray-400 text-sm">Recommendation</span>
              <p class="text-sm font-medium text-gray-900 dark:text-white mt-1" data-blood-pressure-calculator-target="recommendation">Enter your blood pressure reading to see your results.</p>
            </div>
          </div>
          <button data-action="click->blood-pressure-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

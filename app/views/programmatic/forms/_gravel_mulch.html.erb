    <div data-controller="gravel-mulch-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="gravel-mulch-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Length (ft)</label>
            <input id="gravel-mulch-length" type="number" data-gravel-mulch-calculator-target="length" data-action="input->gravel-mulch-calculator#calculate" class="w-full" placeholder="20" step="0.1" min="0">
          </div>
          <div>
            <label for="gravel-mulch-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Width (ft)</label>
            <input id="gravel-mulch-width" type="number" data-gravel-mulch-calculator-target="width" data-action="input->gravel-mulch-calculator#calculate" class="w-full" placeholder="10" step="0.1" min="0">
          </div>
          <div>
            <label for="gravel-mulch-depth" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Depth (in)</label>
            <input id="gravel-mulch-depth" type="number" data-gravel-mulch-calculator-target="depth" data-action="input->gravel-mulch-calculator#calculate" class="w-full" placeholder="3" step="0.5" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gravel-mulch-calculator-target="resultArea">0 sq ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Cubic Yards</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gravel-mulch-calculator-target="resultCubicYards">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Tons (Gravel)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-gravel-mulch-calculator-target="resultTons">0</span>
            </div>
          </div>
          <button data-action="click->gravel-mulch-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

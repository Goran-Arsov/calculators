    <div data-controller="fuel-cost-trip-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="fuel-cost-trip-trip-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Trip Distance</label>
            <input id="fuel-cost-trip-trip-distance" type="number" data-fuel-cost-trip-calculator-target="distance" data-action="input->fuel-cost-trip-calculator#calculate" class="w-full" placeholder="400" step="0.1" min="0">
          </div>
          <div>
            <label for="fuel-cost-trip-distance-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance Unit</label>
            <select id="fuel-cost-trip-distance-unit" data-fuel-cost-trip-calculator-target="distanceUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Distance unit">
              <option value="km" selected>Kilometers</option>
              <option value="miles">Miles</option>
            </select>
          </div>
          <div>
            <label for="fuel-cost-trip-fuel-efficiency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Efficiency</label>
            <input id="fuel-cost-trip-fuel-efficiency" type="number" data-fuel-cost-trip-calculator-target="fuelEfficiency" data-action="input->fuel-cost-trip-calculator#calculate" class="w-full" placeholder="8" step="0.1" min="0">
          </div>
          <div>
            <label for="fuel-cost-trip-efficiency-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Efficiency Unit</label>
            <select id="fuel-cost-trip-efficiency-unit" data-fuel-cost-trip-calculator-target="efficiencyUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Efficiency unit">
              <option value="l_per_100km" selected>L/100km</option>
              <option value="mpg">MPG (US)</option>
              <option value="km_per_l">km/L</option>
            </select>
          </div>
          <div>
            <label for="fuel-cost-trip-fuel-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fuel Price</label>
            <input id="fuel-cost-trip-fuel-price" type="number" data-fuel-cost-trip-calculator-target="fuelPrice" data-action="input->fuel-cost-trip-calculator#calculate" class="w-full" placeholder="1.50" step="0.01" min="0">
          </div>
          <div>
            <label for="fuel-cost-trip-price-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price Unit</label>
            <select id="fuel-cost-trip-price-unit" data-fuel-cost-trip-calculator-target="priceUnit" data-action="change->fuel-cost-trip-calculator#calculate" class="w-full" aria-label="Price unit">
              <option value="per_liter" selected>Per Liter</option>
              <option value="per_gallon">Per Gallon (US)</option>
            </select>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-cyan-50 dark:from-blue-900/20 dark:to-cyan-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Trip Fuel Cost</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Trip Cost</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fuel-cost-trip-calculator-target="tripCost">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Fuel Needed</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-fuel-cost-trip-calculator-target="fuelNeededLiters">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Fuel (gallons)</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-fuel-cost-trip-calculator-target="fuelNeededGallons">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost per km</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-fuel-cost-trip-calculator-target="costPerKm">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost per mile</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-fuel-cost-trip-calculator-target="costPerMile">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">L/100km</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-fuel-cost-trip-calculator-target="lPer100km">&mdash;</span>
            </div>
          </div>
          <button data-action="click->fuel-cost-trip-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-700 hover:to-cyan-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

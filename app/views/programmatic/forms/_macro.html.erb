    <div data-controller="macro-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="macro-daily-calories" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Daily Calories</label>
            <input id="macro-daily-calories" type="number" data-macro-calculator-target="calories" data-action="input->macro-calculator#calculate" class="w-full" placeholder="2000" step="1" min="0">
          </div>
          <div>
            <label for="macro-goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Goal</label>
            <select id="macro-goal" data-macro-calculator-target="goal" data-action="change->macro-calculator#calculate" class="w-full" aria-label="Goal">
              <option value="maintain">Maintain Weight</option>
              <option value="cut">Cut (Fat Loss)</option>
              <option value="bulk">Bulk (Muscle Gain)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Protein</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="protein">— g</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Carbs</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="carbs">— g</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fat</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-macro-calculator-target="fat">— g</span>
            </div>
          </div>
          <button data-action="click->macro-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

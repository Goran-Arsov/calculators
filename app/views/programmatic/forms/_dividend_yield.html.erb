    <div data-controller="dividend-yield-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Yield %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">Y</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Yield</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Yield = (Dividend / Price) &times; 100</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="dividend-yield-annual-dividend" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Dividend ($)</label>
            <input id="dividend-yield-annual-dividend" type="number" data-dividend-yield-calculator-target="dividendForYield" data-action="input->dividend-yield-calculator#calcYield" class="w-full" placeholder="2.50" step="any" min="0">
          </div>
          <div>
            <label for="dividend-yield-stock-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Stock Price ($)</label>
            <input id="dividend-yield-stock-price" type="number" data-dividend-yield-calculator-target="priceForYield" data-action="input->dividend-yield-calculator#calcYield" class="w-full" placeholder="50" step="any" min="0">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Yield</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dividend-yield-calculator-target="resultYield" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Dividend %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">D</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Dividend</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Dividend = Price &times; Yield / 100</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="dividend-yield-stock-price-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Stock Price ($)</label>
            <input id="dividend-yield-stock-price-2" type="number" data-dividend-yield-calculator-target="priceForDividend" data-action="input->dividend-yield-calculator#calcDividend" class="w-full" placeholder="50" step="any" min="0">
          </div>
          <div>
            <label for="dividend-yield-yield" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Yield (%)</label>
            <input id="dividend-yield-yield" type="number" data-dividend-yield-calculator-target="yieldForDividend" data-action="input->dividend-yield-calculator#calcDividend" class="w-full" placeholder="5" step="any" min="0">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Annual Dividend</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-dividend-yield-calculator-target="resultDividend" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Price %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">P</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Price</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Price = Dividend / (Yield / 100)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="dividend-yield-annual-dividend-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Dividend ($)</label>
            <input id="dividend-yield-annual-dividend-2" type="number" data-dividend-yield-calculator-target="dividendForPrice" data-action="input->dividend-yield-calculator#calcPrice" class="w-full" placeholder="2.50" step="any" min="0">
          </div>
          <div>
            <label for="dividend-yield-yield-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Yield (%)</label>
            <input id="dividend-yield-yield-2" type="number" data-dividend-yield-calculator-target="yieldForPrice" data-action="input->dividend-yield-calculator#calcPrice" class="w-full" placeholder="5" step="any" min="0">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Stock Price</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-dividend-yield-calculator-target="resultPrice" data-result>&mdash;</span>
          </div>
        </div>
      </div>
    </div>

    <div data-controller="pregnancy-week-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="pregnancy-week-calculate-from" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculate From</label>
            <select id="pregnancy-week-calculate-from" data-pregnancy-week-calculator-target="inputMode" data-action="change->pregnancy-week-calculator#toggleMode" class="w-full" aria-label="Calculate From">
              <option value="lmp">Last Menstrual Period (LMP)</option>
              <option value="due_date">Due Date</option>
            </select>
          </div>
          <div class="input-group">
            <label for="pregnancy-week-first-day-of-last-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">First Day of Last Period</label>
            <input id="pregnancy-week-first-day-of-last-period" type="date" data-pregnancy-week-calculator-target="lmpDate" data-action="input->pregnancy-week-calculator#calculate" class="w-full">
          </div>
          <div class="input-group hidden">
            <label for="pregnancy-week-due-date" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Due Date</label>
            <input id="pregnancy-week-due-date" type="date" data-pregnancy-week-calculator-target="dueDate" data-action="input->pregnancy-week-calculator#calculate" class="w-full">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Current Week</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pregnancy-week-calculator-target="currentWeek">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Trimester</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pregnancy-week-calculator-target="trimester">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Due Date</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pregnancy-week-calculator-target="dueDateResult">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Days Remaining</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pregnancy-week-calculator-target="daysRemaining">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Complete</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-pregnancy-week-calculator-target="percentComplete">&mdash;</span>
            </div>
            <div class="mt-3">
              <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
                <div data-pregnancy-week-calculator-target="progressBar" class="bg-gradient-to-r from-blue-500 to-indigo-500 h-3 rounded-full transition-all duration-500" style="width: 0%"></div>
              </div>
            </div>
            <div class="baby-size-display hidden mt-4 p-4 bg-white/60 dark:bg-gray-800/60 rounded-xl text-center">
              <p class="text-sm font-semibold text-blue-700 dark:text-blue-300" data-pregnancy-week-calculator-target="babySize"></p>
            </div>
          </div>
          <button data-action="click->pregnancy-week-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

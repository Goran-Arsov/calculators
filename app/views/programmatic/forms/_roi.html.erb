    <div data-controller="roi-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for ROI %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">%</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for ROI</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">ROI = ((Gain - Cost) / Cost) &times; 100</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="roi-gain" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gain ($)</label>
            <input id="roi-gain" type="number" inputmode="decimal" data-roi-calculator-target="gainForRoi" data-action="input->roi-calculator#calcRoi" class="w-full" placeholder="15000" step="any" min="0">
          </div>
          <div>
            <label for="roi-cost" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cost ($)</label>
            <input id="roi-cost" type="number" inputmode="decimal" data-roi-calculator-target="costForRoi" data-action="input->roi-calculator#calcRoi" class="w-full" placeholder="10000" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">ROI</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-roi-calculator-target="resultRoi" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Gain %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">G</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Gain</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Gain = Cost &times; (1 + ROI / 100)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="roi-roi" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">ROI (%)</label>
            <input id="roi-roi" type="number" inputmode="decimal" data-roi-calculator-target="roiForGain" data-action="input->roi-calculator#calcGain" class="w-full" placeholder="50" step="any">
          </div>
          <div>
            <label for="roi-cost-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cost ($)</label>
            <input id="roi-cost-2" type="number" inputmode="decimal" data-roi-calculator-target="costForGain" data-action="input->roi-calculator#calcGain" class="w-full" placeholder="10000" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Gain</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-roi-calculator-target="resultGain" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Cost %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">C</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Cost</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Cost = Gain / (1 + ROI / 100)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="roi-roi-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">ROI (%)</label>
            <input id="roi-roi-2" type="number" inputmode="decimal" data-roi-calculator-target="roiForCost" data-action="input->roi-calculator#calcCost" class="w-full" placeholder="50" step="any">
          </div>
          <div>
            <label for="roi-gain-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gain ($)</label>
            <input id="roi-gain-2" type="number" inputmode="decimal" data-roi-calculator-target="gainForCost" data-action="input->roi-calculator#calcCost" class="w-full" placeholder="15000" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Cost</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-roi-calculator-target="resultCost" data-result>&mdash;</span>
          </div>
        </div>
      </div>
    </div>

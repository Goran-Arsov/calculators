    <div data-controller="deck-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="deck-deck-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Deck Length (ft)</label>
            <input id="deck-deck-length" type="number" data-deck-calculator-target="length" data-action="input->deck-calculator#calculate" class="w-full" placeholder="16" step="0.5" min="0">
          </div>
          <div>
            <label for="deck-deck-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Deck Width (ft)</label>
            <input id="deck-deck-width" type="number" data-deck-calculator-target="width" data-action="input->deck-calculator#calculate" class="w-full" placeholder="12" step="0.5" min="0">
          </div>
          <div>
            <label for="deck-board-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Board Length (ft)</label>
            <input id="deck-board-length" type="number" data-deck-calculator-target="boardLength" data-action="input->deck-calculator#calculate" class="w-full" value="12" step="2" min="1">
          </div>
          <div>
            <label for="deck-board-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Board Width (inches)</label>
            <input id="deck-board-width" type="number" data-deck-calculator-target="boardWidth" data-action="input->deck-calculator#calculate" class="w-full" value="5.5" step="0.5" min="1">
          </div>
          <div>
            <label for="deck-price-per-board" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price per Board ($)</label>
            <input id="deck-price-per-board" type="number" data-deck-calculator-target="pricePerBoard" data-action="input->deck-calculator#calculate" class="w-full" placeholder="8.50" step="0.01" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Deck Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultArea">0 sq ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Deck Boards</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultBoards">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Joists</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultJoists">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Posts</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultPosts">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Screw Boxes</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultScrewBoxes">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Est. Board Cost</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-deck-calculator-target="resultCost">$0.00</span>
            </div>
          </div>
          <button data-action="click->deck-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

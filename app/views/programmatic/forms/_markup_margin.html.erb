    <div data-controller="markup-margin-calculator" class="space-y-5 mb-8">
      <%# Card 1: Markup to Margin %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">M%</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Markup to Margin</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Margin = Markup / (100 + Markup) &times; 100</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="markup-margin-markup" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Markup (%)</label>
            <input id="markup-margin-markup" type="number" data-markup-margin-calculator-target="markupIn" data-action="input->markup-margin-calculator#calcMarginFromMarkup" class="w-full" placeholder="50" step="any" min="0">
          </div>
          <div></div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Margin</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-markup-margin-calculator-target="resultMarginFromMarkup" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Margin to Markup %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">%M</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Margin to Markup</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Markup = Margin / (100 - Margin) &times; 100</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="markup-margin-margin" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Margin (%)</label>
            <input id="markup-margin-margin" type="number" data-markup-margin-calculator-target="marginIn" data-action="input->markup-margin-calculator#calcMarkupFromMargin" class="w-full" placeholder="33.33" step="any" min="0" max="99.99">
          </div>
          <div></div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Markup</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-markup-margin-calculator-target="resultMarkupFromMargin" data-result>&mdash;</span>
          </div>
        </div>
      </div>
    </div>

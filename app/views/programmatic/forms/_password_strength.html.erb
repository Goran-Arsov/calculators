    <div data-controller="password-strength-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="password-strength-password" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Password</label>
            <input id="password-strength-password" type="text" data-password-strength-calculator-target="password" data-action="input->password-strength-calculator#calculate" class="w-full font-mono" placeholder="Enter a password" autocomplete="off">
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4">
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mb-3">
              <div data-password-strength-calculator-target="strengthBar" class="h-2 rounded-full transition-all duration-300 bg-gray-300" style="width: 0%"></div>
            </div>
            <h3 class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-2">Character Analysis</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <span class="text-gray-500 dark:text-gray-400">Lowercase (a-z)</span>
              <span class="font-medium text-gray-700 dark:text-gray-300" data-password-strength-calculator-target="resultLower">--</span>
              <span class="text-gray-500 dark:text-gray-400">Uppercase (A-Z)</span>
              <span class="font-medium text-gray-700 dark:text-gray-300" data-password-strength-calculator-target="resultUpper">--</span>
              <span class="text-gray-500 dark:text-gray-400">Digits (0-9)</span>
              <span class="font-medium text-gray-700 dark:text-gray-300" data-password-strength-calculator-target="resultDigits">--</span>
              <span class="text-gray-500 dark:text-gray-400">Symbols (!@#...)</span>
              <span class="font-medium text-gray-700 dark:text-gray-300" data-password-strength-calculator-target="resultSymbols">--</span>
            </div>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Strength</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultStrength">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Score</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultScore">-- / 7</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Entropy</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultEntropy">-- bits</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Length</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultLength">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Pool Size</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultPool">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Crack Time</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-password-strength-calculator-target="resultCrackTime">--</span>
            </div>
          </div>
          <button data-action="click->password-strength-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

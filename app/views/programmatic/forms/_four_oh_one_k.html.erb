    <div data-controller="four-oh-one-k-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="four-oh-one-k-current-401-balance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current 401(k) Balance ($)</label>
            <input id="four-oh-one-k-current-401-balance" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="currentBalance" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="50000" step="1000" min="0">
          </div>
          <div>
            <label for="four-oh-one-k-annual-contribution" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Contribution ($)</label>
            <input id="four-oh-one-k-annual-contribution" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="annualContribution" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="19500" step="500" min="0">
          </div>
          <div>
            <label for="four-oh-one-k-employer-match" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Employer Match (%)</label>
            <input id="four-oh-one-k-employer-match" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="employerMatchPercent" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="50" step="1" min="0" max="100">
          </div>
          <div>
            <label for="four-oh-one-k-employer-match-limit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Employer Match Limit (% of contribution)</label>
            <input id="four-oh-one-k-employer-match-limit" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="employerMatchLimit" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="100" step="1" min="0" max="100">
          </div>
          <div>
            <label for="four-oh-one-k-expected-annual-return" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Expected Annual Return (%)</label>
            <input id="four-oh-one-k-expected-annual-return" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="annualReturn" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="7" step="0.1" min="0">
          </div>
          <div>
            <label for="four-oh-one-k-years-to-retirement" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Years to Retirement</label>
            <input id="four-oh-one-k-years-to-retirement" type="number" inputmode="decimal" data-four-oh-one-k-calculator-target="yearsToRetirement" data-action="input->four-oh-one-k-calculator#calculate" class="w-full" placeholder="25" step="1" min="1" max="50">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Future Value</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-four-oh-one-k-calculator-target="futureValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Your Contributions</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-four-oh-one-k-calculator-target="totalContributions">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Employer Match Total</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-four-oh-one-k-calculator-target="totalEmployerMatch">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Investment Growth</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-four-oh-one-k-calculator-target="totalGrowth">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Employer Annual Match</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-four-oh-one-k-calculator-target="employerAnnualMatch">$0.00</span>
            </div>
          </div>
          <button data-action="click->four-oh-one-k-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="solar-savings-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="solar-savings-system-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">System Size (kW)</label>
            <input id="solar-savings-system-size" type="number" data-solar-savings-calculator-target="systemSize" data-action="input->solar-savings-calculator#calculate" class="w-full" placeholder="8" step="0.5" min="0">
          </div>
          <div>
            <label for="solar-savings-electricity-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Electricity Rate ($/kWh)</label>
            <input id="solar-savings-electricity-rate" type="number" data-solar-savings-calculator-target="electricityRate" data-action="input->solar-savings-calculator#calculate" class="w-full" placeholder="0.15" step="0.01" min="0">
          </div>
          <div>
            <label for="solar-savings-peak-sun-hours-per-day" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Peak Sun Hours per Day</label>
            <input id="solar-savings-peak-sun-hours-per-day" type="number" data-solar-savings-calculator-target="sunHours" data-action="input->solar-savings-calculator#calculate" class="w-full" placeholder="5" step="0.1" min="0" max="24">
          </div>
          <div>
            <label for="solar-savings-total-system-cost" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total System Cost ($)</label>
            <input id="solar-savings-total-system-cost" type="number" data-solar-savings-calculator-target="systemCost" data-action="input->solar-savings-calculator#calculate" class="w-full" placeholder="20000" step="500" min="0">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Production</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-solar-savings-calculator-target="resultProduction">0 kWh</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Savings</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-solar-savings-calculator-target="resultAnnualSavings">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Payback Period</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-solar-savings-calculator-target="resultPayback">0 years</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">25-Year Savings</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-solar-savings-calculator-target="resultLifetimeSavings">$0.00</span>
            </div>
          </div>
          <button data-action="click->solar-savings-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="hvac-btu-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="hvac-btu-room-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room Size (sq ft)</label>
            <input id="hvac-btu-room-size" type="number" data-hvac-btu-calculator-target="roomSqft" data-action="input->hvac-btu-calculator#calculate" class="w-full" placeholder="500" step="1" min="0">
          </div>
          <div>
            <label for="hvac-btu-ceiling-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Ceiling Height (ft)</label>
            <input id="hvac-btu-ceiling-height" type="number" data-hvac-btu-calculator-target="ceilingHeight" data-action="input->hvac-btu-calculator#calculate" class="w-full" value="8" step="0.5" min="1">
          </div>
          <div>
            <label for="hvac-btu-insulation-quality" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Insulation Quality</label>
            <select id="hvac-btu-insulation-quality" data-hvac-btu-calculator-target="insulation" data-action="change->hvac-btu-calculator#calculate" class="w-full">
              <option value="poor">Poor</option>
              <option value="average" selected>Average</option>
              <option value="good">Good</option>
            </select>
          </div>
          <div>
            <label for="hvac-btu-climate-zone" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Climate Zone</label>
            <select id="hvac-btu-climate-zone" data-hvac-btu-calculator-target="climateZone" data-action="change->hvac-btu-calculator#calculate" class="w-full">
              <option value="hot">Hot</option>
              <option value="warm">Warm</option>
              <option value="moderate" selected>Moderate</option>
              <option value="cool">Cool</option>
              <option value="cold">Cold</option>
            </select>
          </div>
          <div>
            <label for="hvac-btu-number-of-windows" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Windows</label>
            <input id="hvac-btu-number-of-windows" type="number" data-hvac-btu-calculator-target="windows" data-action="input->hvac-btu-calculator#calculate" class="w-full" value="2" step="1" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Base BTU</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-hvac-btu-calculator-target="resultBaseBtu">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Adjusted BTU</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-hvac-btu-calculator-target="resultTotalBtu">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Recommended</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-hvac-btu-calculator-target="resultRecommended">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Tonnage</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-hvac-btu-calculator-target="resultTonnage">0</span>
            </div>
          </div>
          <button data-action="click->hvac-btu-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="credit-card-payoff-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="credit-card-payoff-current-balance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current Balance ($)</label>
            <input id="credit-card-payoff-current-balance" type="number" data-credit-card-payoff-calculator-target="balance" data-action="input->credit-card-payoff-calculator#calculate" class="w-full" placeholder="5000" step="100" min="0">
          </div>
          <div>
            <label for="credit-card-payoff-apr" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">APR (%)</label>
            <input id="credit-card-payoff-apr" type="number" data-credit-card-payoff-calculator-target="apr" data-action="input->credit-card-payoff-calculator#calculate" class="w-full" placeholder="20.99" step="0.01" min="0">
          </div>
          <div>
            <label for="credit-card-payoff-monthly-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Payment ($)</label>
            <input id="credit-card-payoff-monthly-payment" type="number" data-credit-card-payoff-calculator-target="monthlyPayment" data-action="input->credit-card-payoff-calculator#calculate" class="w-full" placeholder="200" step="10" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Months to Payoff</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-credit-card-payoff-calculator-target="monthsToPayoff">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Years to Payoff</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-credit-card-payoff-calculator-target="yearsToPayoff">0.0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Interest</span>
              <span class="text-xl font-bold text-red-600 dark:text-red-400" data-credit-card-payoff-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Amount Paid</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-credit-card-payoff-calculator-target="totalPaid">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Payoff Date</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-credit-card-payoff-calculator-target="payoffDate">--</span>
            </div>
          </div>
          <button data-action="click->credit-card-payoff-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>

      <%# Amortization schedule %>
      <div class="mt-8">
        <button data-action="click->credit-card-payoff-calculator#toggleSchedule" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          Show Amortization Schedule
        </button>
        <div data-credit-card-payoff-calculator-target="scheduleSection" class="hidden mt-4">
          <div class="overflow-x-auto max-h-96 overflow-y-auto">
            <table class="w-full text-left">
              <thead class="sticky top-0 bg-white dark:bg-gray-900">
                <tr class="border-b border-gray-200 dark:border-gray-700">
                  <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Month</th>
                  <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Payment</th>
                  <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Principal</th>
                  <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Interest</th>
                  <th class="py-2.5 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Balance</th>
                </tr>
              </thead>
              <tbody data-credit-card-payoff-calculator-target="scheduleBody">
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

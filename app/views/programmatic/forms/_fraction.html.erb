    <div data-controller="fraction-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div class="grid grid-cols-5 gap-2 items-end">
            <div class="col-span-2">
              <label for="fraction-numerator-1" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Numerator 1</label>
              <input id="fraction-numerator-1" type="number" inputmode="decimal" data-fraction-calculator-target="num1" data-action="input->fraction-calculator#calculate" class="w-full" placeholder="1" step="1">
            </div>
            <div class="flex items-center justify-center pb-2">
              <span class="text-2xl font-bold text-gray-400 dark:text-gray-500">/</span>
            </div>
            <div class="col-span-2">
              <label for="fraction-denominator-1" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Denominator 1</label>
              <input id="fraction-denominator-1" type="number" inputmode="decimal" data-fraction-calculator-target="den1" data-action="input->fraction-calculator#calculate" class="w-full" placeholder="2" step="1">
            </div>
          </div>
          <div>
            <label for="fraction-operation" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Operation</label>
            <select id="fraction-operation" data-fraction-calculator-target="operation" data-action="change->fraction-calculator#calculate" class="w-full" aria-label="Operation">
              <option value="add">Add (+)</option>
              <option value="subtract">Subtract (-)</option>
              <option value="multiply">Multiply (x)</option>
              <option value="divide">Divide (/)</option>
            </select>
          </div>
          <div class="grid grid-cols-5 gap-2 items-end">
            <div class="col-span-2">
              <label for="fraction-numerator-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Numerator 2</label>
              <input id="fraction-numerator-2" type="number" inputmode="decimal" data-fraction-calculator-target="num2" data-action="input->fraction-calculator#calculate" class="w-full" placeholder="1" step="1">
            </div>
            <div class="flex items-center justify-center pb-2">
              <span class="text-2xl font-bold text-gray-400 dark:text-gray-500">/</span>
            </div>
            <div class="col-span-2">
              <label for="fraction-denominator-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Denominator 2</label>
              <input id="fraction-denominator-2" type="number" inputmode="decimal" data-fraction-calculator-target="den2" data-action="input->fraction-calculator#calculate" class="w-full" placeholder="3" step="1">
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Result</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fraction</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fraction-calculator-target="resultFraction">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Decimal</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fraction-calculator-target="resultDecimal">--</span>
            </div>
          </div>
          <button data-action="click->fraction-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

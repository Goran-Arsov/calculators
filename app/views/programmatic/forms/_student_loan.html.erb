    <div data-controller="student-loan-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="student-loan-loan-balance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Balance ($)</label>
            <input id="student-loan-loan-balance" type="number" data-student-loan-calculator-target="balance" data-action="input->student-loan-calculator#calculate" class="w-full" placeholder="35000" step="1000" min="0">
          </div>
          <div>
            <label for="student-loan-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Interest Rate (%)</label>
            <input id="student-loan-annual-interest-rate" type="number" data-student-loan-calculator-target="annualRate" data-action="input->student-loan-calculator#calculate" class="w-full" placeholder="5.5" step="0.1" min="0">
          </div>
          <div>
            <label for="student-loan-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Years)</label>
            <input id="student-loan-loan-term" type="number" data-student-loan-calculator-target="loanTermYears" data-action="input->student-loan-calculator#calculate" class="w-full" placeholder="10" step="1" min="1" max="30">
          </div>
          <div>
            <label for="student-loan-repayment-plan" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Repayment Plan</label>
            <select id="student-loan-repayment-plan" data-student-loan-calculator-target="planType" data-action="change->student-loan-calculator#calculate" class="w-full">
              <option value="standard" selected>Standard (10-year fixed)</option>
              <option value="graduated">Graduated (increasing payments)</option>
              <option value="extended">Extended (25-year term)</option>
              <option value="income_driven">Income-Driven (10% discretionary)</option>
            </select>
          </div>
          <div class="hidden" data-student-loan-calculator-target="incomeField">
            <label for="student-loan-monthly-gross-income" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Gross Income ($)</label>
            <input id="student-loan-monthly-gross-income" type="number" data-student-loan-calculator-target="monthlyIncome" data-action="input->student-loan-calculator#calculate" class="w-full" placeholder="4000" step="100" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Monthly Payment</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-student-loan-calculator-target="monthlyPayment">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Paid</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-student-loan-calculator-target="totalPaid">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Interest</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-student-loan-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Payoff Time</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-student-loan-calculator-target="payoffMonths">0 months</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Payoff Date</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-student-loan-calculator-target="payoffDate">N/A</span>
            </div>
            <div class="flex justify-between items-center hidden" data-student-loan-calculator-target="forgivenRow">
              <span class="text-gray-600 dark:text-gray-400">Forgiven Amount</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-student-loan-calculator-target="forgivenAmount">$0.00</span>
            </div>
          </div>
          <button data-action="click->student-loan-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

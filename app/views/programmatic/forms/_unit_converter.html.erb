    <div data-controller="unit-converter" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Convert Units</h2>
      <div class="space-y-4">
        <div>
          <label for="unit-converter-conversion" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Conversion</label>
          <select id="unit-converter-conversion" data-unit-converter-target="conversion" data-action="change->unit-converter#updateLabels" class="w-full" aria-label="Conversion">
            <optgroup label="Length">
              <option value="m_ft">Meters &rarr; Feet</option>
              <option value="ft_m">Feet &rarr; Meters</option>
              <option value="km_mi">Kilometers &rarr; Miles</option>
              <option value="mi_km">Miles &rarr; Kilometers</option>
              <option value="in_cm">Inches &rarr; Centimeters</option>
              <option value="cm_in">Centimeters &rarr; Inches</option>
              <option value="m_yd">Meters &rarr; Yards</option>
              <option value="yd_m">Yards &rarr; Meters</option>
            </optgroup>
            <optgroup label="Weight">
              <option value="kg_lb">Kilograms &rarr; Pounds</option>
              <option value="lb_kg">Pounds &rarr; Kilograms</option>
              <option value="g_oz">Grams &rarr; Ounces</option>
              <option value="oz_g">Ounces &rarr; Grams</option>
            </optgroup>
            <optgroup label="Speed">
              <option value="kmh_mph">km/h &rarr; mph</option>
              <option value="mph_kmh">mph &rarr; km/h</option>
              <option value="ms_kmh">m/s &rarr; km/h</option>
              <option value="kmh_ms">km/h &rarr; m/s</option>
            </optgroup>
            <optgroup label="Volume">
              <option value="l_gal">Liters &rarr; Gallons (US)</option>
              <option value="gal_l">Gallons (US) &rarr; Liters</option>
            </optgroup>
            <optgroup label="Area">
              <option value="sqm_sqft">m&sup2; &rarr; ft&sup2;</option>
              <option value="sqft_sqm">ft&sup2; &rarr; m&sup2;</option>
              <option value="ha_acre">Hectares &rarr; Acres</option>
              <option value="acre_ha">Acres &rarr; Hectares</option>
            </optgroup>
            <optgroup label="Temperature">
              <option value="c_f">&deg;C &rarr; &deg;F</option>
              <option value="f_c">&deg;F &rarr; &deg;C</option>
              <option value="c_k">&deg;C &rarr; K</option>
              <option value="k_c">K &rarr; &deg;C</option>
            </optgroup>
          </select>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="unit-converter-value" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Value (<span data-unit-converter-target="fromUnit">m</span>)</label>
            <input id="unit-converter-value" type="number" inputmode="decimal" data-unit-converter-target="input" data-action="input->unit-converter#convert" class="w-full" placeholder="1" step="any">
          </div>
          <div class="flex items-center justify-center text-gray-400 dark:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Result (<span data-unit-converter-target="toUnit">ft</span>)</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-unit-converter-target="result">&mdash;</span>
          </div>
        </div>
      </div>
    </div>

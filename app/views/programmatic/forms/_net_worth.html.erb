    <div data-controller="net-worth-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <%# Assets Column %>
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Assets
          </h2>
          <div class="space-y-4">
            <div>
              <label for="net-worth-cash-savings" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cash & Savings ($)</label>
              <input id="net-worth-cash-savings" type="number" data-net-worth-calculator-target="cash" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="50000" step="100" min="0">
            </div>
            <div>
              <label for="net-worth-investments" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Investments ($)</label>
              <input id="net-worth-investments" type="number" data-net-worth-calculator-target="investments" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="100000" step="100" min="0">
            </div>
            <div>
              <label for="net-worth-real-estate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Real Estate ($)</label>
              <input id="net-worth-real-estate" type="number" data-net-worth-calculator-target="realEstate" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="300000" step="1000" min="0">
            </div>
            <div>
              <label for="net-worth-vehicles" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vehicles ($)</label>
              <input id="net-worth-vehicles" type="number" data-net-worth-calculator-target="vehicles" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="25000" step="500" min="0">
            </div>
            <div>
              <label for="net-worth-other-assets" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Other Assets ($)</label>
              <input id="net-worth-other-assets" type="number" data-net-worth-calculator-target="otherAssets" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="10000" step="100" min="0">
            </div>
          </div>
        </div>

        <%# Liabilities Column %>
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
            Liabilities
          </h2>
          <div class="space-y-4">
            <div>
              <label for="net-worth-mortgage" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mortgage ($)</label>
              <input id="net-worth-mortgage" type="number" data-net-worth-calculator-target="mortgage" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="200000" step="1000" min="0">
            </div>
            <div>
              <label for="net-worth-student-loans" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Student Loans ($)</label>
              <input id="net-worth-student-loans" type="number" data-net-worth-calculator-target="studentLoans" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="35000" step="500" min="0">
            </div>
            <div>
              <label for="net-worth-auto-loans" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Auto Loans ($)</label>
              <input id="net-worth-auto-loans" type="number" data-net-worth-calculator-target="autoLoans" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="15000" step="500" min="0">
            </div>
            <div>
              <label for="net-worth-credit-cards" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Credit Cards ($)</label>
              <input id="net-worth-credit-cards" type="number" data-net-worth-calculator-target="creditCards" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="5000" step="100" min="0">
            </div>
            <div>
              <label for="net-worth-other-liabilities" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Other Liabilities ($)</label>
              <input id="net-worth-other-liabilities" type="number" data-net-worth-calculator-target="otherLiabilities" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="2000" step="100" min="0">
            </div>
          </div>
        </div>
      </div>

      <%# Results %>
      <div aria-live="polite" aria-atomic="true" class="mt-8 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Total Assets</span>
            <span class="text-xl font-bold text-green-600 dark:text-green-400" data-net-worth-calculator-target="totalAssets">$0.00</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Total Liabilities</span>
            <span class="text-xl font-bold text-red-600 dark:text-red-400" data-net-worth-calculator-target="totalLiabilities">$0.00</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Net Worth</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-net-worth-calculator-target="netWorth">$0.00</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-600 dark:text-gray-400">Asset-to-Debt Ratio</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-net-worth-calculator-target="assetToDebtRatio">0.00</span>
          </div>
        </div>
        <button data-action="click->net-worth-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
      </div>
    </div>

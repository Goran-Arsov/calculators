    <div data-controller="cooking-converter" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Convert Measurements</h2>
      <div class="space-y-4">
        <div>
          <label for="cooking-converter-conversion" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Conversion</label>
          <select id="cooking-converter-conversion" data-cooking-converter-target="conversion" data-action="change->cooking-converter#convert" class="w-full" aria-label="Conversion">
            <optgroup label="Volume">
              <option value="cups_ml">Cups &rarr; mL</option>
              <option value="ml_cups">mL &rarr; Cups</option>
              <option value="tbsp_ml">Tbsp &rarr; mL</option>
              <option value="ml_tbsp">mL &rarr; Tbsp</option>
              <option value="tsp_ml">Tsp &rarr; mL</option>
              <option value="ml_tsp">mL &rarr; Tsp</option>
              <option value="cups_tbsp">Cups &rarr; Tbsp</option>
              <option value="tbsp_tsp">Tbsp &rarr; Tsp</option>
            </optgroup>
            <optgroup label="Weight">
              <option value="oz_g">oz &rarr; g</option>
              <option value="g_oz">g &rarr; oz</option>
              <option value="lb_kg">lb &rarr; kg</option>
              <option value="kg_lb">kg &rarr; lb</option>
            </optgroup>
          </select>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="cooking-converter-value" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Value (<span data-cooking-converter-target="fromUnit">cups</span>)</label>
            <input id="cooking-converter-value" type="number" inputmode="decimal" data-cooking-converter-target="input" data-action="input->cooking-converter#convert" class="w-full" placeholder="1" step="any" min="0">
          </div>
          <div class="flex items-center justify-center text-gray-400 dark:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Result (<span data-cooking-converter-target="toUnit">mL</span>)</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-cooking-converter-target="result">&mdash;</span>
          </div>
        </div>
      </div>
    </div>

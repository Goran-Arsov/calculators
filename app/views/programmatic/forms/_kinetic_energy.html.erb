    <div data-controller="kinetic-energy-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Energy %>
      <div data-card="Kinetic Energy" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">KE</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Energy</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">KE = &frac12;mv&sup2;</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="kinetic-energy-mass" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mass (kg)</label>
            <input id="kinetic-energy-mass" type="number" data-kinetic-energy-calculator-target="massForKE" data-action="input->kinetic-energy-calculator#calcEnergy" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div>
            <label for="kinetic-energy-velocity" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Velocity (m/s)</label>
            <input id="kinetic-energy-velocity" type="number" data-kinetic-energy-calculator-target="velForKE" data-action="input->kinetic-energy-calculator#calcEnergy" class="w-full" placeholder="10" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Energy</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-kinetic-energy-calculator-target="resultEnergy" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Mass %>
      <div data-card="Mass" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">m</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Mass</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">m = 2KE / v&sup2;</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="kinetic-energy-energy" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Energy (J)</label>
            <input id="kinetic-energy-energy" type="number" data-kinetic-energy-calculator-target="keForM" data-action="input->kinetic-energy-calculator#calcMass" class="w-full" placeholder="500" step="any" min="0">
          </div>
          <div>
            <label for="kinetic-energy-velocity-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Velocity (m/s)</label>
            <input id="kinetic-energy-velocity-2" type="number" data-kinetic-energy-calculator-target="velForM" data-action="input->kinetic-energy-calculator#calcMass" class="w-full" placeholder="10" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Mass</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-kinetic-energy-calculator-target="resultMass" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Velocity %>
      <div data-card="Velocity" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">v</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Velocity</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">v = &radic;(2KE / m)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="kinetic-energy-energy-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Energy (J)</label>
            <input id="kinetic-energy-energy-2" type="number" data-kinetic-energy-calculator-target="keForV" data-action="input->kinetic-energy-calculator#calcVelocity" class="w-full" placeholder="500" step="any" min="0">
          </div>
          <div>
            <label for="kinetic-energy-mass-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mass (kg)</label>
            <input id="kinetic-energy-mass-2" type="number" data-kinetic-energy-calculator-target="massForV" data-action="input->kinetic-energy-calculator#calcVelocity" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Velocity</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-kinetic-energy-calculator-target="resultVelocity" data-result>—</span>
          </div>
        </div>
      </div>
    </div>

    <div data-controller="ideal-weight-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="ideal-weight-unit-system" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit System</label>
            <select id="ideal-weight-unit-system" data-ideal-weight-calculator-target="unitSystem" data-action="change->ideal-weight-calculator#updateLabels" class="w-full" aria-label="Unit System">
              <option value="metric">Metric (cm)</option>
              <option value="imperial">Imperial (inches)</option>
            </select>
          </div>
          <div>
            <label for="ideal-weight-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" data-ideal-weight-calculator-target="heightLabel">Height (cm)</label>
            <input id="ideal-weight-height" type="number" inputmode="decimal" data-ideal-weight-calculator-target="height" data-action="input->ideal-weight-calculator#calculate" class="w-full" placeholder="175" step="0.1" min="0">
          </div>
          <div>
            <label for="ideal-weight-gender" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gender</label>
            <select id="ideal-weight-gender" data-ideal-weight-calculator-target="gender" data-action="change->ideal-weight-calculator#calculate" class="w-full" aria-label="Gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div>
            <label for="ideal-weight-frame-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Frame Size</label>
            <select id="ideal-weight-frame-size" data-ideal-weight-calculator-target="frameSize" data-action="change->ideal-weight-calculator#calculate" class="w-full" aria-label="Frame Size">
              <option value="small">Small</option>
              <option value="medium" selected>Medium</option>
              <option value="large">Large</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Devine Formula</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="devine">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Robinson Formula</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="robinson">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Miller Formula</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="miller">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Hamwi Formula</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="hamwi">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Average</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="average">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Frame Adjusted</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-ideal-weight-calculator-target="frameAdjusted">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Ideal Range</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400"><span data-ideal-weight-calculator-target="idealMin">—</span> – <span data-ideal-weight-calculator-target="idealMax">—</span></span>
            </div>
          </div>
          <button data-action="click->ideal-weight-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="discount-calculator" class="space-y-5 mb-8">
      <%# Card 1: Find Clearance Price %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">$</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Find Clearance Price</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="clearance-original-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Original Price ($)</label>
            <input id="clearance-original-price" type="number" inputmode="decimal" data-discount-calculator-target="priceA" data-action="input->discount-calculator#calcSalePrice" class="w-full" placeholder="100.00" step="0.01" min="0">
          </div>
          <div>
            <label for="clearance-clearance-discount" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Clearance Discount (%)</label>
            <input id="clearance-clearance-discount" type="number" inputmode="decimal" data-discount-calculator-target="discountPercent" data-action="input->discount-calculator#calcSalePrice" class="w-full" placeholder="60" step="0.1" min="0" max="100">
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Clearance Price</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-discount-calculator-target="resultSalePrice">&mdash;</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">You Save</span>
            <span class="text-lg font-bold text-green-600 dark:text-green-400" data-discount-calculator-target="resultSavingsA">&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Find Clearance Discount Percentage %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">%</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Find Markdown %</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="clearance-original-price-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Original Price ($)</label>
            <input id="clearance-original-price-2" type="number" inputmode="decimal" data-discount-calculator-target="originalB" data-action="input->discount-calculator#calcDiscountPercent" class="w-full" placeholder="120.00" step="0.01" min="0">
          </div>
          <div>
            <label for="clearance-clearance-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Clearance Price ($)</label>
            <input id="clearance-clearance-price" type="number" inputmode="decimal" data-discount-calculator-target="salePriceB" data-action="input->discount-calculator#calcDiscountPercent" class="w-full" placeholder="36.00" step="0.01" min="0">
          </div>
          <div class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Markdown</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-discount-calculator-target="resultDiscountPercent">&mdash;</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">You Save</span>
            <span class="text-lg font-bold text-green-600 dark:text-green-400" data-discount-calculator-target="resultSavingsB">&mdash;</span>
          </div>
        </div>
      </div>
    </div>

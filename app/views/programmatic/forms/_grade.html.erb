    <div data-controller="grade-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Score (%)</span>
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400">Weight (%)</span>
          </div>
          <% 6.times do |i| %>
            <div class="grid grid-cols-2 gap-3">
              <input type="number" data-grade-calculator-target="score<%= i + 1 %>" data-action="input->grade-calculator#calculate" class="w-full" placeholder="Score" step="0.1" min="0" max="100">
              <input type="number" data-grade-calculator-target="weight<%= i + 1 %>" data-action="input->grade-calculator#calculate" class="w-full" placeholder="Weight" step="0.1" min="0">
            </div>
          <% end %>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Weighted Average</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-grade-calculator-target="resultAverage">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Letter Grade</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-grade-calculator-target="resultLetter">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Weight</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-grade-calculator-target="resultTotalWeight">0.0%</span>
            </div>
          </div>
          <button data-action="click->grade-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="bandwidth-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div class="grid grid-cols-3 gap-3">
            <div class="col-span-2">
              <label for="bandwidth-file-size" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">File Size</label>
              <input id="bandwidth-file-size" type="number" inputmode="decimal" data-bandwidth-calculator-target="fileSize" data-action="input->bandwidth-calculator#calculate" class="w-full" placeholder="100" step="0.1" min="0">
            </div>
            <div>
              <label for="bandwidth-unit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit</label>
              <select id="bandwidth-unit" data-bandwidth-calculator-target="fileUnit" data-action="change->bandwidth-calculator#calculate" class="w-full">
                <option value="B">Bytes</option>
                <option value="KB">KB</option>
                <option value="MB" selected>MB</option>
                <option value="GB">GB</option>
                <option value="TB">TB</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="col-span-2">
              <label for="bandwidth-connection-speed" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Connection Speed</label>
              <input id="bandwidth-connection-speed" type="number" inputmode="decimal" data-bandwidth-calculator-target="speed" data-action="input->bandwidth-calculator#calculate" class="w-full" placeholder="100" step="0.1" min="0">
            </div>
            <div>
              <label for="bandwidth-unit-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Unit</label>
              <select id="bandwidth-unit-2" data-bandwidth-calculator-target="speedUnit" data-action="change->bandwidth-calculator#calculate" class="w-full">
                <option value="bps">bps</option>
                <option value="Kbps">Kbps</option>
                <option value="Mbps" selected>Mbps</option>
                <option value="Gbps">Gbps</option>
              </select>
            </div>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Download Time</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-bandwidth-calculator-target="resultTime">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Exact Seconds</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-bandwidth-calculator-target="resultSeconds">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">File Size</span>
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400" data-bandwidth-calculator-target="resultFileMb">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Speed</span>
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400" data-bandwidth-calculator-target="resultSpeedMbps">--</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <p class="text-xs text-gray-500 dark:text-gray-400 font-semibold">Speed needed to download in:</p>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">1 minute</span>
              <span class="text-sm font-medium text-blue-600 dark:text-blue-400" data-bandwidth-calculator-target="resultSpeed1min">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">10 minutes</span>
              <span class="text-sm font-medium text-blue-600 dark:text-blue-400" data-bandwidth-calculator-target="resultSpeed10min">--</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">1 hour</span>
              <span class="text-sm font-medium text-blue-600 dark:text-blue-400" data-bandwidth-calculator-target="resultSpeed1hour">--</span>
            </div>
          </div>
          <button data-action="click->bandwidth-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="lumber-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="lumber-thickness" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Thickness (inches)</label>
            <input id="lumber-thickness" type="number" data-lumber-calculator-target="thickness" data-action="input->lumber-calculator#calculate" class="w-full" placeholder="2" step="0.25" min="0">
          </div>
          <div>
            <label for="lumber-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Width (inches)</label>
            <input id="lumber-width" type="number" data-lumber-calculator-target="width" data-action="input->lumber-calculator#calculate" class="w-full" placeholder="6" step="0.25" min="0">
          </div>
          <div>
            <label for="lumber-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Length (feet)</label>
            <input id="lumber-length" type="number" data-lumber-calculator-target="length" data-action="input->lumber-calculator#calculate" class="w-full" placeholder="8" step="0.5" min="0">
          </div>
          <div>
            <label for="lumber-quantity" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Quantity</label>
            <input id="lumber-quantity" type="number" data-lumber-calculator-target="quantity" data-action="input->lumber-calculator#calculate" class="w-full" value="1" step="1" min="1">
          </div>
          <div>
            <label for="lumber-price-per-board-foot" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Price per Board Foot ($)</label>
            <input id="lumber-price-per-board-foot" type="number" data-lumber-calculator-target="pricePerBf" data-action="input->lumber-calculator#calculate" class="w-full" placeholder="5.00" step="0.01" min="0">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Board Feet (each)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lumber-calculator-target="resultBfEach">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Board Feet</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lumber-calculator-target="resultTotalBf">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Linear Feet</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lumber-calculator-target="resultLinearFt">0 ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Cost per Piece</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lumber-calculator-target="resultCostEach">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Cost</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-lumber-calculator-target="resultTotalCost">$0.00</span>
            </div>
          </div>
          <button data-action="click->lumber-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="probability-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">P</div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Calculate Probability</h2>
        <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">P(A) = n(A) / n(S)</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="probability-favorable-outcomes" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Favorable Outcomes</label>
            <input id="probability-favorable-outcomes" type="number" inputmode="decimal" data-probability-calculator-target="favorable" data-action="input->probability-calculator#calculate" class="w-full" placeholder="1" step="any" min="0">
          </div>
          <div>
            <label for="probability-total-outcomes" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Total Outcomes</label>
            <input id="probability-total-outcomes" type="number" inputmode="decimal" data-probability-calculator-target="total" data-action="input->probability-calculator#calculate" class="w-full" placeholder="6" step="any" min="1">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Probability</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="probability">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Percentage</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="percentage">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Complementary</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="complementary">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Comp. %</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="complementaryPct">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Odds For</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="oddsFor">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Odds Against</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="oddsAgainst">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Odds Ratio</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-probability-calculator-target="oddsRatio">&mdash;</span>
            </div>
          </div>
          <button data-action="click->probability-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

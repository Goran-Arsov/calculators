    <div data-controller="percentage-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="percentage-calculation-mode" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculation Mode</label>
            <select id="percentage-calculation-mode" data-percentage-calculator-target="mode" data-action="change->percentage-calculator#calculate" class="w-full" aria-label="Calculation Mode">
              <option value="of">What is X% of Y?</option>
              <option value="is_what_percent">X is what % of Y?</option>
              <option value="change">% change from X to Y</option>
            </select>
          </div>
          <div>
            <label for="percentage-value-x" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Value X</label>
            <input id="percentage-value-x" type="number" data-percentage-calculator-target="value" data-action="input->percentage-calculator#calculate" class="w-full" placeholder="Enter a number" step="any">
          </div>
          <div>
            <label for="percentage-value-y" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Value Y</label>
            <input id="percentage-value-y" type="number" data-percentage-calculator-target="percentage" data-action="input->percentage-calculator#calculate" class="w-full" placeholder="Enter a number" step="any">
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Result</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Answer</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-percentage-calculator-target="result">--</span>
            </div>
          </div>
          <button data-action="click->percentage-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Result</button>
        </div>
      </div>
    </div>

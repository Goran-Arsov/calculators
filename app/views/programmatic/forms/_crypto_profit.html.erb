    <div data-controller="crypto-profit-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="crypto-profit-buy-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Price (per coin/token) ($)</label>
            <input id="crypto-profit-buy-price" type="number" data-crypto-profit-calculator-target="buyPrice" data-action="input->crypto-profit-calculator#calculate" class="w-full" placeholder="30000" step="0.01" min="0">
          </div>
          <div>
            <label for="crypto-profit-sell-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Price (per coin/token) ($)</label>
            <input id="crypto-profit-sell-price" type="number" data-crypto-profit-calculator-target="sellPrice" data-action="input->crypto-profit-calculator#calculate" class="w-full" placeholder="45000" step="0.01" min="0">
          </div>
          <div>
            <label for="crypto-profit-quantity" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Quantity</label>
            <input id="crypto-profit-quantity" type="number" data-crypto-profit-calculator-target="quantity" data-action="input->crypto-profit-calculator#calculate" class="w-full" placeholder="0.5" step="0.001" min="0">
          </div>
          <div>
            <label for="crypto-profit-buy-fee" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Fee (%)</label>
            <input id="crypto-profit-buy-fee" type="number" data-crypto-profit-calculator-target="buyFeePercent" data-action="input->crypto-profit-calculator#calculate" class="w-full" placeholder="0.5" step="0.01" min="0" value="0.5">
          </div>
          <div>
            <label for="crypto-profit-sell-fee" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Fee (%)</label>
            <input id="crypto-profit-sell-fee" type="number" data-crypto-profit-calculator-target="sellFeePercent" data-action="input->crypto-profit-calculator#calculate" class="w-full" placeholder="0.5" step="0.01" min="0" value="0.5">
          </div>
          <div>
            <label for="crypto-profit-holding-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Holding Period</label>
            <select id="crypto-profit-holding-period" data-crypto-profit-calculator-target="holdingPeriod" data-action="change->crypto-profit-calculator#calculate" class="w-full">
              <option value="long">Long-term (over 1 year)</option>
              <option value="short">Short-term (1 year or less)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Profit / Loss</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-crypto-profit-calculator-target="profit">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">ROI</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-crypto-profit-calculator-target="roi">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Price Change</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-crypto-profit-calculator-target="percentChange">0.00%</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Cost Basis</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="costBasis">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Cost (incl. fees)</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="totalCost">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Gross Revenue</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="grossRevenue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net Revenue</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="netRevenue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Fees</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="totalFees">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Capital Gains Tax (est.)</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="capitalGainsTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">After-Tax Profit</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="afterTaxProfit">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Break-Even Price</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-crypto-profit-calculator-target="breakEvenPrice">$0.00</span>
            </div>
          </div>
          <button data-action="click->crypto-profit-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

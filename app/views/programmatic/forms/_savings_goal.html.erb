    <div data-controller="savings-goal-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="goal" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Savings Goal ($)</label>
            <input type="number" id="goal" min="0" step="1000" value="50000" placeholder="e.g. 50000"
              data-savings-goal-calculator-target="goal"
              data-action="input->savings-goal-calculator#calculate"
              class="w-full">
          </div>
          <div>
            <label for="years" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time Frame (Years)</label>
            <input type="number" id="years" min="1" max="50" step="1" value="5" placeholder="e.g. 5"
              data-savings-goal-calculator-target="years"
              data-action="input->savings-goal-calculator#calculate"
              class="w-full">
          </div>
          <div>
            <label for="rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Expected Annual Return (%)</label>
            <input type="number" id="rate" min="0" max="30" step="0.1" value="4.5" placeholder="e.g. 4.5"
              data-savings-goal-calculator-target="rate"
              data-action="input->savings-goal-calculator#calculate"
              class="w-full">
          </div>
          <div>
            <label for="current-savings" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current Savings ($)</label>
            <input type="number" id="current-savings" min="0" step="500" value="5000" placeholder="e.g. 5000"
              data-savings-goal-calculator-target="currentSavings"
              data-action="input->savings-goal-calculator#calculate"
              class="w-full">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Monthly Savings Needed</span>
              <span class="text-lg font-bold text-green-600 dark:text-green-400" data-savings-goal-calculator-target="monthlySavings">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Total Contributions</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-savings-goal-calculator-target="totalContributions">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Interest Earned</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-savings-goal-calculator-target="totalInterest">$0.00</span>
            </div>
          </div>
          <button data-action="click->savings-goal-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="fuel-cost-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Cost %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">$</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Cost</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Cost = (Dist / MPG) &times; Price</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="fuel-cost-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (miles)</label>
            <input id="fuel-cost-distance" type="number" data-fuel-cost-calculator-target="distanceForCost" data-action="input->fuel-cost-calculator#calcCost" class="w-full" placeholder="300" step="1" min="0">
          </div>
          <div>
            <label for="fuel-cost-mpg" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">MPG</label>
            <input id="fuel-cost-mpg" type="number" data-fuel-cost-calculator-target="mpgForCost" data-action="input->fuel-cost-calculator#calcCost" class="w-full" placeholder="25" step="0.1" min="0">
          </div>
          <div>
            <label for="fuel-cost-gas-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gas Price ($/gal)</label>
            <input id="fuel-cost-gas-price" type="number" data-fuel-cost-calculator-target="priceForCost" data-action="input->fuel-cost-calculator#calcCost" class="w-full" placeholder="3.50" step="0.01" min="0">
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Fuel Cost</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-fuel-cost-calculator-target="resultCost">&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Distance %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">D</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Distance</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">Dist = (Budget / Price) &times; MPG</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="fuel-cost-budget" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Budget ($)</label>
            <input id="fuel-cost-budget" type="number" data-fuel-cost-calculator-target="budgetForDist" data-action="input->fuel-cost-calculator#calcDistance" class="w-full" placeholder="50" step="0.01" min="0">
          </div>
          <div>
            <label for="fuel-cost-mpg-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">MPG</label>
            <input id="fuel-cost-mpg-2" type="number" data-fuel-cost-calculator-target="mpgForDist" data-action="input->fuel-cost-calculator#calcDistance" class="w-full" placeholder="25" step="0.1" min="0">
          </div>
          <div>
            <label for="fuel-cost-gas-price-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gas Price ($/gal)</label>
            <input id="fuel-cost-gas-price-2" type="number" data-fuel-cost-calculator-target="priceForDist" data-action="input->fuel-cost-calculator#calcDistance" class="w-full" placeholder="3.50" step="0.01" min="0">
          </div>
          <div class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Max Distance</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-fuel-cost-calculator-target="resultDistance">&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for MPG Needed %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">M</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for MPG Needed</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">MPG = Dist / (Budget / Price)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="fuel-cost-distance-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (miles)</label>
            <input id="fuel-cost-distance-2" type="number" data-fuel-cost-calculator-target="distanceForMpg" data-action="input->fuel-cost-calculator#calcMpg" class="w-full" placeholder="400" step="1" min="0">
          </div>
          <div>
            <label for="fuel-cost-budget-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Budget ($)</label>
            <input id="fuel-cost-budget-2" type="number" data-fuel-cost-calculator-target="budgetForMpg" data-action="input->fuel-cost-calculator#calcMpg" class="w-full" placeholder="40" step="0.01" min="0">
          </div>
          <div>
            <label for="fuel-cost-gas-price-3" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Gas Price ($/gal)</label>
            <input id="fuel-cost-gas-price-3" type="number" data-fuel-cost-calculator-target="priceForMpg" data-action="input->fuel-cost-calculator#calcMpg" class="w-full" placeholder="3.50" step="0.01" min="0">
          </div>
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">MPG Needed</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-fuel-cost-calculator-target="resultMpg">&mdash;</span>
          </div>
        </div>
      </div>
    </div>

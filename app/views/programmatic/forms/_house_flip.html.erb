    <div data-controller="house-flip-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="house-flip-purchase-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Purchase Price ($)</label>
            <input id="house-flip-purchase-price" type="number" data-house-flip-calculator-target="purchasePrice" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="150000" step="1000" min="0">
          </div>
          <div>
            <label for="house-flip-renovation-cost" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Renovation Cost ($)</label>
            <input id="house-flip-renovation-cost" type="number" data-house-flip-calculator-target="renovationCost" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="40000" step="1000" min="0">
          </div>
          <div>
            <label for="house-flip-after-repair-value-arv" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">After Repair Value / ARV ($)</label>
            <input id="house-flip-after-repair-value-arv" type="number" data-house-flip-calculator-target="afterRepairValue" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="280000" step="1000" min="0">
          </div>
          <div>
            <label for="house-flip-holding-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Holding Period (Months)</label>
            <input id="house-flip-holding-period" type="number" data-house-flip-calculator-target="holdingMonths" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="6" step="1" min="1" max="36" value="6">
          </div>
          <div>
            <label for="house-flip-monthly-holding-cost" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Holding Cost ($)</label>
            <input id="house-flip-monthly-holding-cost" type="number" data-house-flip-calculator-target="holdingCostMonthly" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="1500" step="100" min="0">
          </div>
          <div>
            <label for="house-flip-buy-closing-costs" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Closing Costs (%)</label>
            <input id="house-flip-buy-closing-costs" type="number" data-house-flip-calculator-target="closingCostBuyPercent" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="2" step="0.1" min="0" value="2">
          </div>
          <div>
            <label for="house-flip-sell-closing-costs" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Closing Costs (%)</label>
            <input id="house-flip-sell-closing-costs" type="number" data-house-flip-calculator-target="closingCostSellPercent" data-action="input->house-flip-calculator#calculate" class="w-full" placeholder="6" step="0.1" min="0" value="6">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net Profit</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-house-flip-calculator-target="netProfit">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">ROI</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-house-flip-calculator-target="roi">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annualized ROI</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-house-flip-calculator-target="annualizedRoi">0.00%</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Investment</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-house-flip-calculator-target="totalInvestment">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Costs (incl. sell)</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-house-flip-calculator-target="totalCosts">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Buy Closing Costs</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-house-flip-calculator-target="closingCostsBuy">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Sell Closing Costs</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-house-flip-calculator-target="closingCostsSell">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Holding Costs</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-house-flip-calculator-target="totalHoldingCosts">$0.00</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">70% Rule Max Purchase</span>
              <span class="text-sm font-semibold text-orange-600 dark:text-orange-400" data-house-flip-calculator-target="maxPurchase70Rule">$0.00</span>
            </div>
          </div>
          <button data-action="click->house-flip-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="business-loan-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="business-loan-loan-amount" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Amount ($)</label>
            <input id="business-loan-loan-amount" type="number" inputmode="decimal" data-business-loan-calculator-target="amount" data-action="input->business-loan-calculator#calculate" class="w-full" placeholder="100000" step="1000" min="0">
          </div>
          <div>
            <label for="business-loan-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Interest Rate (%)</label>
            <input id="business-loan-annual-interest-rate" type="number" inputmode="decimal" data-business-loan-calculator-target="rate" data-action="input->business-loan-calculator#calculate" class="w-full" placeholder="8.5" step="0.01" min="0">
          </div>
          <div>
            <label for="business-loan-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Years)</label>
            <input id="business-loan-loan-term" type="number" inputmode="decimal" data-business-loan-calculator-target="years" data-action="input->business-loan-calculator#calculate" class="w-full" placeholder="5" step="1" min="1" max="30">
          </div>
          <div>
            <label for="business-loan-origination-fee" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Origination Fee (%)</label>
            <input id="business-loan-origination-fee" type="number" inputmode="decimal" data-business-loan-calculator-target="originationFee" data-action="input->business-loan-calculator#calculate" class="w-full" placeholder="2.0" step="0.1" min="0">
            <p class="text-xs text-gray-400 mt-1">One-time upfront fee charged by the lender (typically 1-6%)</p>
          </div>
        </div>

        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Monthly Payment</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="monthlyPayment">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Interest</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Repaid</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="totalPaid">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Origination Fee</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="originationFeeAmount">$0.00</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-blue-200/50 dark:border-blue-800/50">
              <span class="text-gray-600 dark:text-gray-400">Total Cost (incl. fees)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="totalCost">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Effective APR</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="effectiveAPR">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Number of Payments</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-business-loan-calculator-target="numPayments">0</span>
            </div>
          </div>
          <button data-action="click->business-loan-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="investment-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="investment-initial-investment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Initial Investment ($)</label>
            <input id="investment-initial-investment" type="number" data-investment-calculator-target="initial" data-action="input->investment-calculator#calculate" class="w-full" placeholder="10000" step="500" min="0">
          </div>
          <div>
            <label for="investment-monthly-contribution" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Contribution ($)</label>
            <input id="investment-monthly-contribution" type="number" data-investment-calculator-target="monthly" data-action="input->investment-calculator#calculate" class="w-full" placeholder="500" step="50" min="0">
          </div>
          <div>
            <label for="investment-expected-annual-return" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Expected Annual Return (%)</label>
            <input id="investment-expected-annual-return" type="number" data-investment-calculator-target="rate" data-action="input->investment-calculator#calculate" class="w-full" placeholder="7" step="0.1" min="0">
          </div>
          <div>
            <label for="investment-investment-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Investment Period (Years)</label>
            <input id="investment-investment-period" type="number" data-investment-calculator-target="years" data-action="input->investment-calculator#calculate" class="w-full" placeholder="20" step="1" min="1" max="100">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Future Value</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="futureValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Contributions</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="totalContributions">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Investment Growth</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-investment-calculator-target="totalGrowth">$0.00</span>
            </div>
          </div>
          <button data-action="click->investment-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

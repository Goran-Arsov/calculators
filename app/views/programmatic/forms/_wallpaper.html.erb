    <div data-controller="wallpaper-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="wallpaper-room-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room Length (ft)</label>
            <input id="wallpaper-room-length" type="number" data-wallpaper-calculator-target="length" data-action="input->wallpaper-calculator#calculate" class="w-full" placeholder="14" step="0.1" min="0">
          </div>
          <div>
            <label for="wallpaper-room-width" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Room Width (ft)</label>
            <input id="wallpaper-room-width" type="number" data-wallpaper-calculator-target="width" data-action="input->wallpaper-calculator#calculate" class="w-full" placeholder="12" step="0.1" min="0">
          </div>
          <div>
            <label for="wallpaper-wall-height" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Wall Height (ft)</label>
            <input id="wallpaper-wall-height" type="number" data-wallpaper-calculator-target="height" data-action="input->wallpaper-calculator#calculate" class="w-full" placeholder="8" step="0.1" min="0">
          </div>
          <div>
            <label for="wallpaper-doors" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Doors</label>
            <input id="wallpaper-doors" type="number" data-wallpaper-calculator-target="doors" data-action="input->wallpaper-calculator#calculate" class="w-full" value="1" step="1" min="0">
          </div>
          <div>
            <label for="wallpaper-windows" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Windows</label>
            <input id="wallpaper-windows" type="number" data-wallpaper-calculator-target="windows" data-action="input->wallpaper-calculator#calculate" class="w-full" value="2" step="1" min="0">
          </div>
          <div>
            <label for="wallpaper-pattern-repeat" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Pattern Repeat (inches, 0 for none)</label>
            <input id="wallpaper-pattern-repeat" type="number" data-wallpaper-calculator-target="patternRepeat" data-action="input->wallpaper-calculator#calculate" class="w-full" value="0" step="0.5" min="0">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Wall Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-wallpaper-calculator-target="resultWallArea">0 sq ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Coverable Area</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-wallpaper-calculator-target="resultCoverable">0 sq ft</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Strips</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-wallpaper-calculator-target="resultStrips">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Strips per Roll</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-wallpaper-calculator-target="resultStripsPerRoll">0</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Rolls Needed</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-wallpaper-calculator-target="resultRolls">0</span>
            </div>
          </div>
          <button data-action="click->wallpaper-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

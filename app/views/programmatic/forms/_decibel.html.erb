    <div data-controller="decibel-calculator" class="space-y-5 mb-8">
      <%# Card 1: Power Ratio to dB %>
      <div data-card="Power to dB" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">P</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Power Ratio &rarr; dB</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">dB = 10 log<sub>10</sub>(P<sub>2</sub>/P<sub>1</sub>)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
          <div>
            <label for="decibel-power-ratio" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Power Ratio (P<sub>2</sub>/P<sub>1</sub>)</label>
            <input id="decibel-power-ratio" type="number" inputmode="decimal" data-decibel-calculator-target="powerRatio" data-action="input->decibel-calculator#calcPowerDb" class="w-full" placeholder="2" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Decibels</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-decibel-calculator-target="resultPowerDb" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 2: dB to Power Ratio %>
      <div data-card="dB to Power Ratio" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">P</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">dB &rarr; Power Ratio</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">P<sub>2</sub>/P<sub>1</sub> = 10<sup>(dB/10)</sup></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
          <div>
            <label for="decibel-decibels" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Decibels (dB)</label>
            <input id="decibel-decibels" type="number" inputmode="decimal" data-decibel-calculator-target="powerDb" data-action="input->decibel-calculator#calcPowerRatio" class="w-full" placeholder="3" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Power Ratio</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-decibel-calculator-target="resultPowerRatio" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 3: Voltage Ratio to dB %>
      <div data-card="Voltage to dB" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">V</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Voltage Ratio &rarr; dB</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">dB = 20 log<sub>10</sub>(V<sub>2</sub>/V<sub>1</sub>)</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
          <div>
            <label for="decibel-voltage-ratio" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Voltage Ratio (V<sub>2</sub>/V<sub>1</sub>)</label>
            <input id="decibel-voltage-ratio" type="number" inputmode="decimal" data-decibel-calculator-target="voltageRatio" data-action="input->decibel-calculator#calcVoltageDb" class="w-full" placeholder="2" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Decibels</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-decibel-calculator-target="resultVoltageDb" data-result>&mdash;</span>
          </div>
        </div>
      </div>

      <%# Card 4: dB to Voltage Ratio %>
      <div data-card="dB to Voltage Ratio" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-purple-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">V</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">dB &rarr; Voltage Ratio</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">V<sub>2</sub>/V<sub>1</sub> = 10<sup>(dB/20)</sup></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
          <div>
            <label for="decibel-decibels-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Decibels (dB)</label>
            <input id="decibel-decibels-2" type="number" inputmode="decimal" data-decibel-calculator-target="voltageDb" data-action="input->decibel-calculator#calcVoltageRatio" class="w-full" placeholder="6" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-violet-50 to-purple-50 dark:from-violet-900/20 dark:to-purple-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Voltage Ratio</span>
            <span class="text-xl font-bold text-violet-600 dark:text-violet-400" data-decibel-calculator-target="resultVoltageRatio" data-result>&mdash;</span>
          </div>
        </div>
      </div>
    </div>

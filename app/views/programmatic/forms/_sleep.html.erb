    <div data-controller="sleep-calculator" class="space-y-6 mb-8">

      <%# Card 1: From Wake Time %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">I need to wake up at...</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="sleep-wake-up-time" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Wake-Up Time</label>
            <input id="sleep-wake-up-time" type="time" data-sleep-calculator-target="wakeTime" data-action="input->sleep-calculator#calcBedtimes" class="w-full">
          </div>
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-3 block">Suggested Bedtimes</span>
            <div class="space-y-2" data-sleep-calculator-target="resultBedtimes">
              <p class="text-gray-500 dark:text-gray-400">Enter a wake-up time to see suggestions</p>
            </div>
          </div>
        </div>
      </div>

      <%# Card 2: From Bed Time %>
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">I plan to go to bed at...</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="sleep-bedtime" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Bedtime</label>
            <input id="sleep-bedtime" type="time" data-sleep-calculator-target="bedTime" data-action="input->sleep-calculator#calcWakeTimes" class="w-full">
          </div>
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
            <span class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-3 block">Suggested Wake Times</span>
            <div class="space-y-2" data-sleep-calculator-target="resultWakeTimes">
              <p class="text-gray-500 dark:text-gray-400">Enter a bedtime to see suggestions</p>
            </div>
          </div>
        </div>
      </div>

    </div>

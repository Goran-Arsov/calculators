    <div data-controller="ohms-law-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Voltage %>
      <div data-card="Voltage" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">V</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Voltage</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">V = I &times; R</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="ohms-law-current" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current (A)</label>
            <input id="ohms-law-current" type="number" inputmode="decimal" data-ohms-law-calculator-target="currentForV" data-action="input->ohms-law-calculator#calcVoltage" class="w-full" placeholder="2" step="any">
          </div>
          <div>
            <label for="ohms-law-resistance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Resistance (&Omega;)</label>
            <input id="ohms-law-resistance" type="number" inputmode="decimal" data-ohms-law-calculator-target="resistanceForV" data-action="input->ohms-law-calculator#calcVoltage" class="w-full" placeholder="6" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Voltage</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-ohms-law-calculator-target="resultVoltage" data-result>—</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Power</span>
            <span class="text-lg font-bold text-gray-600 dark:text-gray-300" data-ohms-law-calculator-target="powerForV">—</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Current %>
      <div data-card="Current" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">I</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Current</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">I = V / R</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="ohms-law-voltage" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Voltage (V)</label>
            <input id="ohms-law-voltage" type="number" inputmode="decimal" data-ohms-law-calculator-target="voltageForI" data-action="input->ohms-law-calculator#calcCurrent" class="w-full" placeholder="12" step="any">
          </div>
          <div>
            <label for="ohms-law-resistance-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Resistance (&Omega;)</label>
            <input id="ohms-law-resistance-2" type="number" inputmode="decimal" data-ohms-law-calculator-target="resistanceForI" data-action="input->ohms-law-calculator#calcCurrent" class="w-full" placeholder="6" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Current</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-ohms-law-calculator-target="resultCurrent" data-result>—</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Power</span>
            <span class="text-lg font-bold text-gray-600 dark:text-gray-300" data-ohms-law-calculator-target="powerForI">—</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Resistance %>
      <div data-card="Resistance" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">R</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Resistance</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">R = V / I</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 items-end">
          <div>
            <label for="ohms-law-voltage-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Voltage (V)</label>
            <input id="ohms-law-voltage-2" type="number" inputmode="decimal" data-ohms-law-calculator-target="voltageForR" data-action="input->ohms-law-calculator#calcResistance" class="w-full" placeholder="12" step="any">
          </div>
          <div>
            <label for="ohms-law-current-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Current (A)</label>
            <input id="ohms-law-current-2" type="number" inputmode="decimal" data-ohms-law-calculator-target="currentForR" data-action="input->ohms-law-calculator#calcResistance" class="w-full" placeholder="2" step="any">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Resistance</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-ohms-law-calculator-target="resultResistance" data-result>—</span>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Power</span>
            <span class="text-lg font-bold text-gray-600 dark:text-gray-300" data-ohms-law-calculator-target="powerForR">—</span>
          </div>
        </div>
      </div>
    </div>

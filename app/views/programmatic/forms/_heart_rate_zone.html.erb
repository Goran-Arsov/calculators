    <div data-controller="heart-rate-zone-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="heart-rate-zone-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Age (years)</label>
            <input id="heart-rate-zone-age" type="number" inputmode="decimal" data-heart-rate-zone-calculator-target="age" data-action="input->heart-rate-zone-calculator#calculate" class="w-full" placeholder="30" min="1" max="120">
          </div>
          <div>
            <label for="heart-rate-zone-resting-heart-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Resting Heart Rate (bpm)</label>
            <input id="heart-rate-zone-resting-heart-rate" type="number" inputmode="decimal" data-heart-rate-zone-calculator-target="restingHr" data-action="input->heart-rate-zone-calculator#calculate" class="w-full" placeholder="70" min="30" max="120">
          </div>
          <div class="pt-4 space-y-2">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Max Heart Rate</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-heart-rate-zone-calculator-target="maxHr">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Heart Rate Reserve</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-heart-rate-zone-calculator-target="hrr">—</span>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Training Zones</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Zone 1 – Recovery</span>
              <span class="text-lg font-bold text-green-500" data-heart-rate-zone-calculator-target="zone1">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Zone 2 – Fat Burn</span>
              <span class="text-lg font-bold text-lime-500" data-heart-rate-zone-calculator-target="zone2">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Zone 3 – Cardio</span>
              <span class="text-lg font-bold text-yellow-500" data-heart-rate-zone-calculator-target="zone3">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Zone 4 – Threshold</span>
              <span class="text-lg font-bold text-orange-500" data-heart-rate-zone-calculator-target="zone4">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400 text-sm">Zone 5 – Peak</span>
              <span class="text-lg font-bold text-red-500" data-heart-rate-zone-calculator-target="zone5">—</span>
            </div>
          </div>
          <button data-action="click->heart-rate-zone-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="velocity-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Velocity %>
      <div data-card="Velocity" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">v</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Velocity</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">v = d / t</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="velocity-distance" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (m)</label>
            <input id="velocity-distance" type="number" data-velocity-calculator-target="distanceForV" data-action="input->velocity-calculator#calcVelocity" class="w-full" placeholder="100" step="any" min="0">
          </div>
          <div>
            <label for="velocity-time" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time (s)</label>
            <input id="velocity-time" type="number" data-velocity-calculator-target="timeForV" data-action="input->velocity-calculator#calcVelocity" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Velocity</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-velocity-calculator-target="resultVelocity" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Distance %>
      <div data-card="Distance" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">d</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Distance</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">d = v x t</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="velocity-velocity" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Velocity (m/s)</label>
            <input id="velocity-velocity" type="number" data-velocity-calculator-target="velocityForD" data-action="input->velocity-calculator#calcDistance" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div>
            <label for="velocity-time-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time (s)</label>
            <input id="velocity-time-2" type="number" data-velocity-calculator-target="timeForD" data-action="input->velocity-calculator#calcDistance" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Distance</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-velocity-calculator-target="resultDistance" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Time %>
      <div data-card="Time" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">t</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Time</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">t = d / v</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="velocity-distance-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Distance (m)</label>
            <input id="velocity-distance-2" type="number" data-velocity-calculator-target="distanceForT" data-action="input->velocity-calculator#calcTime" class="w-full" placeholder="100" step="any" min="0">
          </div>
          <div>
            <label for="velocity-velocity-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Velocity (m/s)</label>
            <input id="velocity-velocity-2" type="number" data-velocity-calculator-target="velocityForT" data-action="input->velocity-calculator#calcTime" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Time</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-velocity-calculator-target="resultTime" data-result>—</span>
          </div>
        </div>
      </div>
    </div>

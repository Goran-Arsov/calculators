    <div data-controller="intermittent-fasting-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="intermittent-fasting-fasting-method" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fasting Method</label>
            <select id="intermittent-fasting-fasting-method" data-intermittent-fasting-calculator-target="method" data-action="change->intermittent-fasting-calculator#calculate" class="w-full" aria-label="Fasting Method">
              <option value="16_8">16:8 (Leangains)</option>
              <option value="18_6">18:6</option>
              <option value="20_4">20:4 (Warrior Diet)</option>
              <option value="14_10">14:10 (Beginner)</option>
              <option value="omad">OMAD (One Meal a Day)</option>
            </select>
          </div>
          <div>
            <label for="intermittent-fasting-fasting-start-time" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Fasting Start Time</label>
            <input id="intermittent-fasting-fasting-start-time" type="time" data-intermittent-fasting-calculator-target="startTime" data-action="input->intermittent-fasting-calculator#calculate" class="w-full" value="20:00">
          </div>
          <div class="pt-4 space-y-2">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Method</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-intermittent-fasting-calculator-target="methodName">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fasting Duration</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-intermittent-fasting-calculator-target="fastingHours">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Eating Duration</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-intermittent-fasting-calculator-target="eatingHours">—</span>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Your Schedule</h2>
          <div class="space-y-3 mb-4">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fasting Window</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400"><span data-intermittent-fasting-calculator-target="fastingStart">—</span> – <span data-intermittent-fasting-calculator-target="fastingEnd">—</span></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Eating Window</span>
              <span class="text-sm font-bold text-green-600 dark:text-green-400"><span data-intermittent-fasting-calculator-target="eatingStart">—</span> – <span data-intermittent-fasting-calculator-target="eatingEnd">—</span></span>
            </div>
          </div>
          <hr class="border-gray-200 dark:border-gray-700 mb-4">
          <div data-intermittent-fasting-calculator-target="schedule" class="text-sm">
            <p class="text-gray-400 dark:text-gray-500 text-sm">Enter your start time to see your schedule</p>
          </div>
          <button data-action="click->intermittent-fasting-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

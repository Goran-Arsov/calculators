    <div data-controller="stock-profit-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="stock-profit-buy-price-per-share" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Price per Share ($)</label>
            <input id="stock-profit-buy-price-per-share" type="number" inputmode="decimal" data-stock-profit-calculator-target="buyPrice" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="50.00" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-sell-price-per-share" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Price per Share ($)</label>
            <input id="stock-profit-sell-price-per-share" type="number" inputmode="decimal" data-stock-profit-calculator-target="sellPrice" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="75.00" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-number-of-shares" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Shares</label>
            <input id="stock-profit-number-of-shares" type="number" inputmode="decimal" data-stock-profit-calculator-target="shares" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="100" step="1" min="0">
          </div>
          <div>
            <label for="stock-profit-buy-commission" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Commission ($)</label>
            <input id="stock-profit-buy-commission" type="number" inputmode="decimal" data-stock-profit-calculator-target="buyCommission" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="0" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-sell-commission" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Commission ($)</label>
            <input id="stock-profit-sell-commission" type="number" inputmode="decimal" data-stock-profit-calculator-target="sellCommission" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="0" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-holding-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Holding Period</label>
            <select id="stock-profit-holding-period" data-stock-profit-calculator-target="holdingPeriod" data-action="change->stock-profit-calculator#calculate" class="w-full">
              <option value="long">Long-term (over 1 year)</option>
              <option value="short">Short-term (1 year or less)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Profit / Loss</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-stock-profit-calculator-target="profit">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">ROI</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-stock-profit-calculator-target="roi">0.00%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Price Change</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-stock-profit-calculator-target="percentChange">0.00%</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Cost</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="totalCost">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Revenue</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="totalRevenue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Fees</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="totalFees">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Capital Gains Tax (est.)</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="capitalGainsTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">After-Tax Profit</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="afterTaxProfit">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Break-Even Price</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-stock-profit-calculator-target="breakEvenPrice">$0.00</span>
            </div>
          </div>
          <button data-action="click->stock-profit-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="conception-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="conception-calculate-from" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculate From</label>
            <select id="conception-calculate-from" data-conception-calculator-target="method" data-action="change->conception-calculator#updateFields" class="w-full" aria-label="Calculation Method">
              <option value="due_date">Due Date</option>
              <option value="lmp">Last Menstrual Period (LMP)</option>
            </select>
          </div>
          <div class="field-group">
            <label for="conception-due-date" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Due Date</label>
            <input id="conception-due-date" type="date" data-conception-calculator-target="dueDate" data-action="input->conception-calculator#calculate" class="w-full">
          </div>
          <div class="field-group hidden">
            <label for="conception-last-menstrual-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Last Menstrual Period</label>
            <input id="conception-last-menstrual-period" type="date" data-conception-calculator-target="lastPeriod" data-action="input->conception-calculator#calculate" class="w-full">
          </div>
          <div>
            <label for="conception-average-cycle-length" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Average Cycle Length (days)</label>
            <input id="conception-average-cycle-length" type="number" data-conception-calculator-target="cycleLength" data-action="input->conception-calculator#calculate" class="w-full" placeholder="28" value="28" min="20" max="45">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Estimated Conception</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="conceptionDate">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fertile Window Start</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="fertileStart">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Fertile Window End</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="fertileEnd">—</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Estimated LMP</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="estimatedLmp">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Due Date</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="estimatedDueDate">—</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Conception Range</span>
              <span class="text-sm font-bold text-blue-600 dark:text-blue-400" data-conception-calculator-target="conceptionRange">—</span>
            </div>
          </div>
          <button data-action="click->conception-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <div data-controller="force-calculator" class="space-y-5 mb-8">
      <%# Card 1: Solve for Force %>
      <div data-card="Force" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">F</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Force</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">F = m &times; a</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="force-mass" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mass (kg)</label>
            <input id="force-mass" type="number" data-force-calculator-target="massForF" data-action="input->force-calculator#calcForce" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div>
            <label for="force-acceleration" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Acceleration (m/s&sup2;)</label>
            <input id="force-acceleration" type="number" data-force-calculator-target="accForF" data-action="input->force-calculator#calcForce" class="w-full" placeholder="9.81" step="any">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Force</span>
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-force-calculator-target="resultForce" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 2: Solve for Mass %>
      <div data-card="Mass" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">m</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Mass</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">m = F / a</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="force-force" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Force (N)</label>
            <input id="force-force" type="number" data-force-calculator-target="forceForM" data-action="input->force-calculator#calcMass" class="w-full" placeholder="100" step="any">
          </div>
          <div>
            <label for="force-acceleration-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Acceleration (m/s&sup2;)</label>
            <input id="force-acceleration-2" type="number" data-force-calculator-target="accForM" data-action="input->force-calculator#calcMass" class="w-full" placeholder="9.81" step="any">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/20 dark:to-teal-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Mass</span>
            <span class="text-xl font-bold text-emerald-600 dark:text-emerald-400" data-force-calculator-target="resultMass" data-result>—</span>
          </div>
        </div>
      </div>

      <%# Card 3: Solve for Acceleration %>
      <div data-card="Acceleration" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 bg-gradient-to-br from-amber-500 to-orange-600 rounded-lg flex items-center justify-center text-white text-xs font-bold">a</div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Solve for Acceleration</h2>
          <span class="text-sm text-gray-400 dark:text-gray-500 ml-auto font-mono">a = F / m</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
          <div>
            <label for="force-force-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Force (N)</label>
            <input id="force-force-2" type="number" data-force-calculator-target="forceForA" data-action="input->force-calculator#calcAcceleration" class="w-full" placeholder="100" step="any">
          </div>
          <div>
            <label for="force-mass-2" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mass (kg)</label>
            <input id="force-mass-2" type="number" data-force-calculator-target="massForA" data-action="input->force-calculator#calcAcceleration" class="w-full" placeholder="10" step="any" min="0">
          </div>
          <div aria-live="polite" class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 rounded-xl p-4 text-center">
            <span class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">Acceleration</span>
            <span class="text-xl font-bold text-amber-600 dark:text-amber-400" data-force-calculator-target="resultAcceleration" data-result>—</span>
          </div>
        </div>
      </div>
    </div>

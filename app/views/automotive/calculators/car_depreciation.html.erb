            <label for="car-dep-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Purchase Price ($)</label>
            <input id="car-dep-price" type="number" inputmode="decimal" data-car-depreciation-calculator-target="purchasePrice" data-action="input->car-depreciation-calculator#calculate" class="w-full" placeholder="35000" step="500" min="0">
          </div>
          <div>
            <label for="car-dep-age" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vehicle Age (Years)</label>
            <input id="car-dep-age" type="number" inputmode="numeric" data-car-depreciation-calculator-target="vehicleAge" data-action="input->car-depreciation-calculator#calculate" class="w-full" placeholder="0" step="1" min="0">
          </div>
          <div>
            <label for="car-dep-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Depreciation Rate (%)</label>
            <input id="car-dep-rate" type="number" inputmode="decimal" data-car-depreciation-calculator-target="depreciationRate" data-action="input->car-depreciation-calculator#calculate" class="w-full" placeholder="15" step="0.5" min="0" max="100" value="15">
          </div>
          <div>
            <label for="car-dep-holding" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Holding Period (Years)</label>
            <input id="car-dep-holding" type="number" inputmode="numeric" data-car-depreciation-calculator-target="holdingYears" data-action="input->car-depreciation-calculator#calculate" class="w-full" placeholder="5" step="1" min="1" value="5">

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Car Depreciation Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">See how your vehicle's value changes over time. Enter purchase price, vehicle age, and depreciation rate to get a year-by-year breakdown.</p>

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>


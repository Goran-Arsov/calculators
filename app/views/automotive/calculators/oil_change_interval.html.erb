      { name: "Car Depreciation Calculator", description: "See how your vehicle's value changes over time.", path: automotive_car_depreciation_path, icon_path: "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" }
    ] %>

    <%= render "shared/calculator_disclaimer", category: "automotive" %>
  </div>

  <div class="hidden lg:block">
    <div class="sticky top-24"><%= render "shared/ad_slot", slot: "sidebar" %></div>
  </div>
</div>

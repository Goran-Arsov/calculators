<%= render "shared/breadcrumbs", items: [
  { name: "Home", url: root_path },
  { name: "Contact" }
] %>

<div class="max-w-4xl mx-auto">
  <article class="prose dark:prose-invert max-w-none">
    <h1>Contact Us</h1>

    <p>We'd love to hear from you. Whether you have a question about one of our calculators, want to report a bug, or have a suggestion for a new tool, we're here to help.</p>
  </article>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-10">
    <%# Contact form %>
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-6">Send Us a Message</h2>
      <% if flash[:notice] %>
        <div class="mb-4 p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl text-sm text-green-700 dark:text-green-400"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-sm text-red-700 dark:text-red-400"><%= flash[:alert] %></div>
      <% end %>
      <%= form_with model: ContactMessage.new, url: contact_path, method: :post, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" for="contact_message_name">Name</label>
          <%= f.text_field :name, id: "contact_message_name", required: true, class: "w-full", placeholder: "Your name" %>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" for="contact_message_email">Email</label>
          <%= f.email_field :email, id: "contact_message_email", required: true, class: "w-full", placeholder: "you@example.com" %>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" for="contact_message_subject">Subject</label>
          <%= f.select :subject, [["General Inquiry", "general"], ["Bug Report", "bug"], ["Calculator Suggestion", "suggestion"], ["Feedback", "feedback"], ["Business Inquiry", "business"]], {}, { id: "contact_message_subject", class: "w-full" } %>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5" for="contact_message_message">Message</label>
          <%= f.text_area :message, id: "contact_message_message", rows: 5, required: true, class: "w-full rounded-xl border-1.5 border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-white p-3 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 outline-none transition-all resize-y", placeholder: "How can we help?" %>
        </div>
        <button type="submit" class="w-full px-5 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl text-sm font-semibold shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
          Send Message
        </button>
        <p class="text-xs text-gray-400 dark:text-gray-500 text-center">We typically respond within 1-2 business days.</p>
      <% end %>
    </div>

    <%# Contact info + FAQ %>
    <div class="space-y-6">
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Other Ways to Reach Us</h2>
        <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <div>
              <p class="font-medium text-gray-900 dark:text-white">Email</p>
              <p>contact@calchammer.com</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <p class="font-medium text-gray-900 dark:text-white">Response Time</p>
              <p>We aim to respond within 1-2 business days.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Frequently Asked</h2>
        <div class="space-y-4 text-sm">
          <div>
            <p class="font-medium text-gray-900 dark:text-white mb-1">Are the calculators free?</p>
            <p class="text-gray-500 dark:text-gray-400">Yes, all CalcWise calculators are 100% free with no sign-up required.</p>
          </div>
          <div>
            <p class="font-medium text-gray-900 dark:text-white mb-1">Can I suggest a new calculator?</p>
            <p class="text-gray-500 dark:text-gray-400">Absolutely! Use the form on the left or email us. We prioritize suggestions from users.</p>
          </div>
          <div>
            <p class="font-medium text-gray-900 dark:text-white mb-1">I found an error in a calculation.</p>
            <p class="text-gray-500 dark:text-gray-400">Please let us know using the bug report option. Include the calculator name and the values you entered so we can investigate.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

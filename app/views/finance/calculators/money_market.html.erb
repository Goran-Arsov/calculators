<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Money Market Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">See how your money market account balance grows over time with compound interest and competitive rates.</p>

    <%# Calculator UI — reuses compound-interest-calculator Stimulus controller %>
    <div data-controller="compound-interest-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="money-market-initial-deposit" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Initial Deposit ($)</label>
            <input id="money-market-initial-deposit" type="number" data-compound-interest-calculator-target="principal" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="10000" step="500" min="0">
          </div>
          <div>
            <label for="money-market-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Interest Rate (%)</label>
            <input id="money-market-annual-interest-rate" type="number" data-compound-interest-calculator-target="rate" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="4.25" step="0.01" min="0">
          </div>
          <div>
            <label for="money-market-time-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Time Period (Years)</label>
            <input id="money-market-time-period" type="number" data-compound-interest-calculator-target="years" data-action="input->compound-interest-calculator#calculate" class="w-full" placeholder="5" step="1" min="1" max="100">
          </div>
          <div>
            <label for="money-market-compounding-frequency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Compounding Frequency</label>
            <select id="money-market-compounding-frequency" data-compound-interest-calculator-target="frequency" data-action="change->compound-interest-calculator#calculate" class="w-full" aria-label="Compounding Frequency">
              <option value="1">Annually (1x/year)</option>
              <option value="2">Semi-Annually (2x/year)</option>
              <option value="4">Quarterly (4x/year)</option>
              <option value="12" selected>Monthly (12x/year)</option>
              <option value="365">Daily (365x/year)</option>
            </select>
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Future Value</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="futureValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Interest Earned</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="totalInterest">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Initial Deposit</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-compound-interest-calculator-target="principalDisplay">$0.00</span>
            </div>
          </div>
          <button data-action="click->compound-interest-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-xl shadow-sm shadow-blue-500/20 hover:shadow-md hover:shadow-blue-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>


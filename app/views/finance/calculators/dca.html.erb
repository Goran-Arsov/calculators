    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">See how regular monthly investments grow over time with dollar-cost averaging and compound returns.</p>

    <%# Calculator UI %>
    <div data-controller="dca-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

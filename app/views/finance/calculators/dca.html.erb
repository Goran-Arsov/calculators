          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Investment ($)</label>
            <input type="number" data-dca-calculator-target="monthlyInvestment" data-action="input->dca-calculator#calculate" class="w-full" placeholder="500" step="50" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Expected Annual Return (%)</label>

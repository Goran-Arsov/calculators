          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Investment Period (Years)</label>
            <input type="number" data-dca-calculator-target="years" data-action="input->dca-calculator#calculate" class="w-full" placeholder="20" step="1" min="1" max="100">

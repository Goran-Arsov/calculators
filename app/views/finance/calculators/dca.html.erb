              <span class="text-gray-600 dark:text-gray-400">Future Value</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dca-calculator-target="resultFutureValue">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total Invested</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-dca-calculator-target="resultTotalInvested">$0.00</span>

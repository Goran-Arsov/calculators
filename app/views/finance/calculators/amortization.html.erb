                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Payment</th>
                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Principal</th>
                <th class="py-2.5 pr-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Interest</th>
                <th class="py-2.5 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider text-right">Balance</th>
              </tr>
            </thead>
            <tbody data-amortization-calculator-target="scheduleBody">
            </tbody>
          </table>
        </div>
      </div>

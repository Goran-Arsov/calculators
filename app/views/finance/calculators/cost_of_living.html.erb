              <span class="text-xl font-bold text-indigo-600 dark:text-indigo-400" data-cost-of-living-calculator-target="equivalentSalary">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Salary Difference</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-of-living-calculator-target="salaryDifference">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost Difference</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-of-living-calculator-target="percentageDifference">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Purchasing Power</span>
              <span class="text-lg font-bold text-green-600 dark:text-green-400" data-cost-of-living-calculator-target="purchasingPower">&mdash;</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Cost Ratio</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-cost-of-living-calculator-target="costRatio">&mdash;</span>
            </div>
          </div>

          </div>
          <div>
            <label for="motorcycle-loan-annual-interest-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Interest Rate (%)</label>
            <input id="motorcycle-loan-annual-interest-rate" type="number" data-loan-calculator-target="rate" data-action="input->loan-calculator#calculate" class="w-full" placeholder="7.0" step="0.01" min="0">
          </div>
          <div>
            <label for="motorcycle-loan-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Years)</label>
            <input id="motorcycle-loan-loan-term" type="number" data-loan-calculator-target="years" data-action="input->loan-calculator#calculate" class="w-full" placeholder="4" step="1" min="1" max="50">
          </div>
        </div>

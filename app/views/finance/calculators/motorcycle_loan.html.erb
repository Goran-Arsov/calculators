    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate your monthly motorcycle payment, total interest, and overall financing cost before you ride off the lot.</p>

    <%# Calculator UI — reuses loan-calculator Stimulus controller %>
    <div data-controller="loan-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="motorcycle-loan-motorcycle-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Motorcycle Price ($)</label>

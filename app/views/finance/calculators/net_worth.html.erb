            Assets
          </h2>
          <div class="space-y-4">
            <div>
              <label for="net-worth-cash-savings" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Cash & Savings ($)</label>
              <input id="net-worth-cash-savings" type="number" data-net-worth-calculator-target="cash" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="50000" step="100" min="0">
            </div>
            <div>
              <label for="net-worth-investments" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Investments ($)</label>
              <input id="net-worth-investments" type="number" data-net-worth-calculator-target="investments" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="100000" step="100" min="0">
            </div>
            <div>
              <label for="net-worth-real-estate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Real Estate ($)</label>
              <input id="net-worth-real-estate" type="number" data-net-worth-calculator-target="realEstate" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="300000" step="1000" min="0">
            </div>
            <div>
              <label for="net-worth-vehicles" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vehicles ($)</label>
              <input id="net-worth-vehicles" type="number" data-net-worth-calculator-target="vehicles" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="25000" step="500" min="0">
            </div>
            <div>
              <label for="net-worth-other-assets" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Other Assets ($)</label>
              <input id="net-worth-other-assets" type="number" data-net-worth-calculator-target="otherAssets" data-action="input->net-worth-calculator#calculate" class="w-full" placeholder="10000" step="100" min="0">
            </div>
          </div>
        </div>

        <%# Liabilities Column %>

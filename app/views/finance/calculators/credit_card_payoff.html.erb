            <input id="credit-card-payoff-apr" type="number" inputmode="decimal" data-credit-card-payoff-calculator-target="apr" data-action="input->credit-card-payoff-calculator#calculate" class="w-full" placeholder="20.99" step="0.01" min="0">
          </div>
          <div>
            <label for="credit-card-payoff-monthly-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Payment ($)</label>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Paycheck Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Estimate your net take-home pay after federal tax, state tax, Social Security, and Medicare deductions.</p>

    <%# Calculator UI %>
    <div data-controller="paycheck-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="paycheck-annual-salary" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Salary ($)</label>
            <input id="paycheck-annual-salary" type="number" data-paycheck-calculator-target="annualSalary" data-action="input->paycheck-calculator#calculate" class="w-full" placeholder="75000" step="1000" min="0">
          </div>
          <div>
            <label for="paycheck-state-tax-level" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">State Tax Level</label>
            <select id="paycheck-state-tax-level" data-paycheck-calculator-target="stateTaxLevel" data-action="change->paycheck-calculator#calculate" class="w-full">
              <option value="none">None (0%)</option>
              <option value="low">Low (3%)</option>
              <option value="medium" selected>Medium (5%)</option>
              <option value="high">High (7%)</option>
              <option value="very_high">Very High (10%)</option>
            </select>
          </div>
          <div>
            <label for="paycheck-pay-frequency" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Pay Frequency</label>
            <select id="paycheck-pay-frequency" data-paycheck-calculator-target="payFrequency" data-action="change->paycheck-calculator#calculate" class="w-full">
              <option value="weekly">Weekly (52/year)</option>
              <option value="biweekly" selected>Biweekly (26/year)</option>
              <option value="semimonthly">Semi-Monthly (24/year)</option>
              <option value="monthly">Monthly (12/year)</option>
            </select>
          </div>
          <div>
            <label for="paycheck-annual-pre-tax-deductions" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Pre-Tax Deductions ($)</label>
            <input id="paycheck-annual-pre-tax-deductions" type="number" data-paycheck-calculator-target="preTaxDeductions" data-action="input->paycheck-calculator#calculate" class="w-full" placeholder="0" step="100" min="0">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Per Paycheck (Net)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="paycheckNet">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Per Paycheck (Gross)</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="paycheckGross">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Net Pay</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-paycheck-calculator-target="annualNet">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Annual Gross Pay</span>
              <span class="text-xl font-bold text-blue-600 dark:text-blue-400" data-paycheck-calculator-target="annualGross">$0.00</span>
            </div>
            <hr class="border-gray-200 dark:border-gray-700">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Federal Tax</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="federalTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">State Tax</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="stateTax">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Social Security</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="socialSecurity">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Medicare</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="medicare">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Total FICA</span>
              <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" data-paycheck-calculator-target="fica">$0.00</span>
            </div>
            <div class="flex justify-between items-center">

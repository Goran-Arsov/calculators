              <span class="text-lg font-bold text-gray-900 dark:text-white" data-hourly-to-salary-calculator-target="resultWeekly">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600 dark:text-gray-400">Biweekly</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white" data-hourly-to-salary-calculator-target="resultBiweekly">$0.00</span>
            </div>
            <div class="flex justify-between items-center">

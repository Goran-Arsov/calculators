    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Convert between hourly rate and annual salary. See every pay period breakdown with customizable hours per week and weeks per year.</p>

    <div data-controller="hourly-to-salary-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Direction</label>
            <select data-hourly-to-salary-calculator-target="direction" data-action="change->hourly-to-salary-calculator#calculate" class="w-full" aria-label="Conversion direction">
              <option value="hourly_to_salary" selected>Hourly Rate to Salary</option>
              <option value="salary_to_hourly">Annual Salary to Hourly Rate</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Amount ($)</label>
            <input type="number" data-hourly-to-salary-calculator-target="amount" data-action="input->hourly-to-salary-calculator#calculate" class="w-full" placeholder="25.00" step="0.01" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Hours per Week</label>

<div class="lg:grid lg:grid-cols-3 lg:gap-8">
  <div class="lg:col-span-2">
    <%# Ad: leaderboard %>
    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Auto Loan Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Calculate your monthly car payment, total interest, and total cost with down payment, trade-in, and sales tax included.</p>

    <%# Calculator UI %>
    <div data-controller="auto-loan-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Vehicle Price ($)</label>
            <input type="number" data-auto-loan-calculator-target="vehiclePrice" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="35000" step="500" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Down Payment ($)</label>
            <input type="number" data-auto-loan-calculator-target="downPayment" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="5000" step="500" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Trade-in Value ($)</label>
            <input type="number" data-auto-loan-calculator-target="tradeInValue" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="3000" step="500" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sales Tax Rate (%)</label>
            <input type="number" data-auto-loan-calculator-target="salesTaxRate" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="6.25" step="0.01" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Interest Rate (%)</label>
            <input type="number" data-auto-loan-calculator-target="rate" data-action="input->auto-loan-calculator#calculate" class="w-full" placeholder="6.5" step="0.01" min="0">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Months)</label>
            <select data-auto-loan-calculator-target="termMonths" data-action="change->auto-loan-calculator#calculate" class="w-full">
              <option value="24">24 months (2 years)</option>
              <option value="36">36 months (3 years)</option>
              <option value="48">48 months (4 years)</option>
              <option value="60" selected>60 months (5 years)</option>
              <option value="72">72 months (6 years)</option>
              <option value="84">84 months (7 years)</option>
            </select>
          </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">

    <div class="mb-8"><%= render "shared/ad_slot", slot: "leaderboard" %></div>

    <div data-controller="vat-calculator ad-engagement" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="vat-mode" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Calculation Mode</label>
            <select id="vat-mode" data-vat-calculator-target="mode" data-action="change->vat-calculator#calculate" class="w-full">
              <option value="add">Add VAT (Net to Gross)</option>
              <option value="remove">Remove VAT (Gross to Net)</option>
            </select>
          </div>
          <div>
            <label for="vat-amount" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Amount ($)</label>
            <input id="vat-amount" type="number" inputmode="decimal" data-vat-calculator-target="amount" data-action="input->vat-calculator#calculate" class="w-full" placeholder="100.00" step="0.01" min="0">
          </div>
          <div>
            <label for="vat-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">VAT Rate (%)</label>
            <input id="vat-rate" type="number" inputmode="decimal" data-vat-calculator-target="vatRate" data-action="input->vat-calculator#calculate" class="w-full" placeholder="20" step="0.5" min="0" value="20">
          </div>
        </div>
        <div aria-live="polite" aria-atomic="true" class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net Price (excl. VAT)</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-vat-calculator-target="netPrice">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">VAT Amount</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-vat-calculator-target="vatAmount">$0.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Gross Price (incl. VAT)</span>
              <span class="text-2xl font-bold text-green-600 dark:text-green-400" data-vat-calculator-target="grossPrice">$0.00</span>
            </div>
          </div>
          <button data-action="click->vat-calculator#copy" class="mt-6 w-full px-4 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white rounded-xl shadow-sm shadow-green-500/20 hover:shadow-md hover:shadow-green-500/25 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 text-sm font-medium">Copy Results</button>
        </div>
      </div>
    </div>

    <%= render "shared/calculator_rating", slug: "vat" %>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3 tracking-tight">Rent vs. Buy Calculator</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8 leading-relaxed">Compare the long-term cost of renting versus buying a home, factoring in rent increases, mortgage rates, and your down payment.</p>

    <%# Calculator UI %>
    <div data-controller="rent-vs-buy-calculator" class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200/80 dark:border-gray-800 p-6 md:p-8 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="space-y-4">
          <div>
            <label for="rent-vs-buy-monthly-rent" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Monthly Rent ($)</label>
            <input id="rent-vs-buy-monthly-rent" type="number" data-rent-vs-buy-calculator-target="monthlyRent" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="1500" step="50" min="0">
          </div>
          <div>
            <label for="rent-vs-buy-home-price" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Home Price ($)</label>
            <input id="rent-vs-buy-home-price" type="number" data-rent-vs-buy-calculator-target="homePrice" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="350000" step="1000" min="0">
          </div>
          <div>
            <label for="rent-vs-buy-down-payment" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Down Payment (%)</label>
            <input id="rent-vs-buy-down-payment" type="number" data-rent-vs-buy-calculator-target="downPercent" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="20" step="1" min="0" max="100">
          </div>
          <div>
            <label for="rent-vs-buy-mortgage-rate" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Mortgage Rate (%)</label>
            <input id="rent-vs-buy-mortgage-rate" type="number" data-rent-vs-buy-calculator-target="mortgageRate" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="6.5" step="0.01" min="0">
          </div>
          <div>
            <label for="rent-vs-buy-loan-term" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Loan Term (Years)</label>
            <input id="rent-vs-buy-loan-term" type="number" data-rent-vs-buy-calculator-target="years" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="30" step="1" min="1" max="50">
          </div>
          <div>
            <label for="rent-vs-buy-annual-rent-increase" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Annual Rent Increase (%)</label>
            <input id="rent-vs-buy-annual-rent-increase" type="number" data-rent-vs-buy-calculator-target="rentIncrease" data-action="input->rent-vs-buy-calculator#calculate" class="w-full" placeholder="3" step="0.1" min="0">
          </div>
        </div>
        <div aria-live="polite" class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Results</h2>

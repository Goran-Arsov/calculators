          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">Take-Home Pay</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-400">Net Annual Pay</span>
              <span class="text-xl font-bold text-green-600 dark:text-green-400" data-net-pay-calculator-target="netAnnual">$0.00</span>
            </div>
            <div class="flex justify-between items-center">

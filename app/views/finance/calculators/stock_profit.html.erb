          </div>
          <div>
            <label for="stock-profit-number-of-shares" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Number of Shares</label>
            <input id="stock-profit-number-of-shares" type="number" data-stock-profit-calculator-target="shares" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="100" step="1" min="0">
          </div>
          <div>
            <label for="stock-profit-buy-commission" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Buy Commission ($)</label>
            <input id="stock-profit-buy-commission" type="number" data-stock-profit-calculator-target="buyCommission" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="0" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-sell-commission" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Sell Commission ($)</label>
            <input id="stock-profit-sell-commission" type="number" data-stock-profit-calculator-target="sellCommission" data-action="input->stock-profit-calculator#calculate" class="w-full" placeholder="0" step="0.01" min="0">
          </div>
          <div>
            <label for="stock-profit-holding-period" class="block text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1.5">Holding Period</label>
            <select id="stock-profit-holding-period" data-stock-profit-calculator-target="holdingPeriod" data-action="change->stock-profit-calculator#calculate" class="w-full">
              <option value="long">Long-term (over 1 year)</option>
              <option value="short">Short-term (1 year or less)</option>
            </select>
          </div>
        </div>

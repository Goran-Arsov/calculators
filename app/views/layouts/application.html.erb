<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <%= display_meta_tags site: "CalcWise", separator: "|", reverse: true %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if ENV["GOOGLE_SITE_VERIFICATION"].present? %>
      <meta name="google-site-verification" content="<%= ENV["GOOGLE_SITE_VERIFICATION"] %>">
    <% end %>

    <link rel="icon" href="/favicon.ico" sizes="48x48">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2563eb">
    <link rel="alternate" hreflang="en" href="<%= request.original_url %>">
    <link rel="alternate" hreflang="x-default" href="<%= request.original_url %>">

    <%# DNS prefetch + preconnect for ad networks — reduces latency %>
    <link rel="dns-prefetch" href="//pagead2.googlesyndication.com">
    <link rel="dns-prefetch" href="//adservice.google.com">
    <link rel="dns-prefetch" href="//www.googletagmanager.com">
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin>
    <link rel="preconnect" href="https://adservice.google.com" crossorigin>

    <%# Resource hints for faster subsequent navigations %>
    <link rel="dns-prefetch" href="//fonts.googleapis.com">

    <%= preload_link_tag(path_to_stylesheet("application.css"), as: "style") rescue nil %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      if (localStorage.getItem("darkMode") === "true" ||
          (!localStorage.getItem("darkMode") && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <%# Google Consent Mode v2 — must load BEFORE AdSense and Analytics scripts %>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      gtag("consent", "default", {
        "ad_storage": "denied",
        "ad_user_data": "denied",
        "ad_personalization": "denied",
        "analytics_storage": "denied",
        "wait_for_update": 500
      });

      // Restore stored consent immediately so ads load with correct signals
      var storedConsent = localStorage.getItem("cookie_consent");
      if (storedConsent === "accepted") {
        gtag("consent", "update", {
          "ad_storage": "granted",
          "ad_user_data": "granted",
          "ad_personalization": "granted",
          "analytics_storage": "granted"
        });
      }
    </script>

    <% if adsense_enabled? %>
      <%# AdSense — respects Consent Mode signals automatically %>
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= adsense_pub_id %>"
              crossorigin="anonymous" fetchpriority="low"></script>
    <% end %>

    <% if ENV["GA_MEASUREMENT_ID"].present? %>
      <%# Google Analytics 4 — also respects Consent Mode %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV["GA_MEASUREMENT_ID"] %>"></script>
      <script>
        gtag('js', new Date());
        gtag('config', '<%= ENV["GA_MEASUREMENT_ID"] %>');
      </script>
    <% end %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:shadow-lg focus:outline-none">
      Skip to main content
    </a>
    <%= render "shared/nav" %>

    <main id="main-content" class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
    <%= render "shared/cookie_consent" %>

    <%# Anchor ad — sticky bottom on mobile, high RPM %>
    <%= render "shared/ad_slot", slot: "anchor" %>

    <%# Register service worker for offline calculator support %>
    <script>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker.js").catch(function() {});
      }
    </script>

    <%= render "shared/pwa_install" %>

    <% if adsense_enabled? %>
      <%# Enable Auto Ads (vignettes + anchor) on Turbo navigations %>
      <script>
        document.addEventListener("turbo:load", function() {
          try {
            (adsbygoogle = window.adsbygoogle || []).push({
              google_ad_client: "<%= adsense_pub_id %>",
              enable_page_level_ads: true
            });
          } catch(e) {}
        });
      </script>
    <% end %>
  </body>
</html>

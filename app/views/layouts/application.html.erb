<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <%= display_meta_tags site: "Calc Hammer", separator: "|", reverse: true %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if ENV["GOOGLE_SITE_VERIFICATION"].present? %>
      <meta name="google-site-verification" content="<%= ENV["GOOGLE_SITE_VERIFICATION"] %>">
    <% end %>

    <meta name="google-adsense-account" content="ca-pub-6683743386982052">

    <link rel="icon" href="/favicon.ico" sizes="48x48">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2563eb">
    <%# hreflang alternates — on localized pages this emits links to every language
        version of the current page, so Google can cluster them correctly and stops
        reporting them as "duplicate without user-selected canonical". On non-translated
        pages the helper returns an empty string. %>
    <%= hreflang_tags %>

    <%# DNS prefetch + preconnect for ad networks — reduces latency %>
    <link rel="dns-prefetch" href="//pagead2.googlesyndication.com">
    <link rel="dns-prefetch" href="//adservice.google.com">
    <link rel="dns-prefetch" href="//www.googletagmanager.com">
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin>
    <link rel="preconnect" href="https://adservice.google.com" crossorigin>

    <%# Resource hints for faster subsequent navigations %>
    <link rel="dns-prefetch" href="//fonts.googleapis.com">

    <%= preload_link_tag(path_to_stylesheet("application.css"), as: "style", fetchpriority: "high") rescue nil %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "print", media: "print" %>
    <%= javascript_importmap_tags %>

    <script nonce="<%= content_security_policy_nonce %>">
      if (localStorage.getItem("darkMode") === "true" ||
          (!localStorage.getItem("darkMode") && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      }
    </script>

    <%# Google Consent Mode v2 — must load BEFORE AdSense and Analytics scripts %>
    <script nonce="<%= content_security_policy_nonce %>">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      gtag("consent", "default", {
        "ad_storage": "denied",
        "ad_user_data": "denied",
        "ad_personalization": "denied",
        "analytics_storage": "denied",
        "wait_for_update": 500
      });

      // Restore stored consent immediately so ads load with correct signals
      var storedConsent = localStorage.getItem("cookie_consent");
      if (storedConsent === "accepted") {
        gtag("consent", "update", {
          "ad_storage": "granted",
          "ad_user_data": "granted",
          "ad_personalization": "granted",
          "analytics_storage": "granted"
        });
      }
    </script>

    <% if adsense_enabled? %>
      <%# AdSense — respects Consent Mode signals automatically.
          When AUTO_ADS_ENABLED=true (default), the ?client= param enables
          Google Auto Ads to place additional units. Set AUTO_ADS_ENABLED=false
          to serve only manually placed ad units. %>
      <script async src="<%= adsense_script_url %>"
              crossorigin="anonymous" fetchpriority="low"></script>
    <% end %>

    <% if ENV["GA_MEASUREMENT_ID"].present? %>
      <%# Google Analytics 4 — also respects Consent Mode %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV["GA_MEASUREMENT_ID"] %>"></script>
      <script nonce="<%= content_security_policy_nonce %>">
        gtag('js', new Date());
        gtag('config', '<%= ENV["GA_MEASUREMENT_ID"] %>');
      </script>
    <% end %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:shadow-lg focus:outline-none">
      Skip to main content
    </a>
    <%= render "shared/nav" %>

    <main id="main-content" class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <noscript>
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4 mb-8 text-center">
          <p class="text-amber-800 dark:text-amber-200 text-sm font-medium">Our calculators require JavaScript to work. Please enable JavaScript in your browser settings to use this tool.</p>
        </div>
      </noscript>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
    <%= render "shared/cookie_consent" %>

    <%# Anchor ads are managed via AdSense Auto Ads dashboard settings.
        Manual anchor units conflict with Auto Ads and risk policy violations
        for duplicate sticky ads. %>

    <%# Register service worker for offline calculator support %>
    <script nonce="<%= content_security_policy_nonce %>">
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/service-worker.js").catch(function() {});
      }
    </script>

    <%= render "shared/pwa_install" %>

    <%# Auto Ads are toggled by AUTO_ADS_ENABLED env var (defaults to true).
        When enabled, the ?client= param in the adsbygoogle.js script URL
        lets Google inject additional ads. Fine-tune which formats appear
        (anchor, vignette, in-article, etc.) from the AdSense dashboard.
        Do NOT use enable_page_level_ads — it is deprecated and conflicts
        with manually placed ad units. %>
  </body>
</html>

              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Simple Interest</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Compound Interest</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <td class="px-4 py-3 font-medium text-gray-700 dark:text-gray-300">Formula</td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-400">I = P x r x t</td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-400">A = P(1 + r/n)^(nt)</td>
            </tr>
